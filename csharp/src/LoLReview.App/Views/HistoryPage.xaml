<Page
    x:Class="LoLReview.App.Views.HistoryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:LoLReview.App.ViewModels"
    xmlns:converters="using:LoLReview.App.Converters"
    mc:Ignorable="d"
    Background="{StaticResource AppBackgroundBrush}">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <converters:WinLossColorConverter x:Key="WinLossColor"/>
        <converters:KdaColorConverter x:Key="KdaColor"/>
    </Page.Resources>

    <Grid Padding="24,24,24,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══ Header ═══ -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12" Margin="0,0,0,16">
            <TextBlock Text="History"
                       FontSize="22" FontWeight="Bold"
                       Foreground="{StaticResource PrimaryTextBrush}"
                       VerticalAlignment="Center"/>
            <TextBlock Text="All recorded games"
                       FontSize="13"
                       Foreground="{StaticResource SecondaryTextBrush}"
                       VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Loading overlay -->
        <ProgressRing Grid.Row="1"
                      IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                      HorizontalAlignment="Center" VerticalAlignment="Center"
                      Width="48" Height="48"
                      Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVis}}"/>

        <!-- ═══ Tab View ═══ -->
        <Pivot Grid.Row="1">
            <Pivot.Resources>
                <Style TargetType="PivotHeaderItem">
                    <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}"/>
                    <Setter Property="FontSize" Value="14"/>
                </Style>
            </Pivot.Resources>

            <!-- ═══════════════════════════════════════════════════════ -->
            <!-- Tab 1: Recent Games                                    -->
            <!-- ═══════════════════════════════════════════════════════ -->
            <PivotItem Header="Recent Games">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Filter bar -->
                    <Border Grid.Row="0" Margin="0,8,0,12">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <ComboBox ItemsSource="{x:Bind ViewModel.ChampionFilters, Mode=OneWay}"
                                      SelectedItem="{x:Bind ViewModel.SelectedChampionFilter, Mode=TwoWay}"
                                      Width="200"
                                      Background="{StaticResource InputBackgroundBrush}"
                                      BorderBrush="{StaticResource SubtleBorderBrush}"
                                      PlaceholderText="All Champions"
                                      SelectionChanged="OnChampionFilterChanged"/>

                            <ComboBox x:Name="WinLossFilterCombo"
                                      Width="120"
                                      Background="{StaticResource InputBackgroundBrush}"
                                      BorderBrush="{StaticResource SubtleBorderBrush}"
                                      SelectedIndex="{x:Bind ViewModel.SelectedWinLossFilter, Mode=TwoWay}"
                                      SelectionChanged="OnWinLossFilterChanged">
                                <ComboBoxItem Content="All"/>
                                <ComboBoxItem Content="Wins Only"/>
                                <ComboBoxItem Content="Losses Only"/>
                            </ComboBox>
                        </StackPanel>
                    </Border>

                    <!-- Games list -->
                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Spacing="4">
                            <!-- No games message -->
                            <TextBlock Visibility="{x:Bind ViewModel.HasNoGames, Mode=OneWay, Converter={StaticResource BoolToVis}}"
                                       Text="No games recorded yet."
                                       FontSize="14"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       HorizontalAlignment="Center"
                                       Margin="0,40,0,0"/>

                            <!-- Game cards -->
                            <ItemsRepeater ItemsSource="{x:Bind ViewModel.Games, Mode=OneWay}">
                                <ItemsRepeater.Layout>
                                    <StackLayout Spacing="4"/>
                                </ItemsRepeater.Layout>
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate x:DataType="vm:GameDisplayItem">
                                        <Border Background="{StaticResource CardBackgroundBrush}"
                                                CornerRadius="8"
                                                BorderThickness="2"
                                                Padding="12,10">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Left: Champion + meta info -->
                                                <StackPanel Grid.Column="0" Spacing="2">
                                                    <TextBlock FontSize="15" FontWeight="Bold">
                                                        <Run Text="{x:Bind WinLossText}"/>
                                                        <Run Text="  "/>
                                                        <Run Text="{x:Bind ChampionName}"/>
                                                    </TextBlock>
                                                    <TextBlock FontSize="11"
                                                               Foreground="{StaticResource SecondaryTextBrush}">
                                                        <Run Text="{x:Bind DatePlayed}"/>
                                                        <Run Text="  &#8226;  "/>
                                                        <Run Text="{x:Bind Duration}"/>
                                                        <Run Text="  &#8226;  "/>
                                                        <Run Text="{x:Bind GameMode}"/>
                                                    </TextBlock>
                                                </StackPanel>

                                                <!-- Right: KDA + stats + button -->
                                                <StackPanel Grid.Column="1" HorizontalAlignment="Right" Spacing="2">
                                                    <TextBlock FontSize="14" FontWeight="Bold"
                                                               Foreground="{StaticResource PrimaryTextBrush}"
                                                               HorizontalAlignment="Right">
                                                        <Run Text="{x:Bind KdaText}"/>
                                                        <Run Text="  "/>
                                                        <Run Text="{x:Bind KdaRatioText}"/>
                                                    </TextBlock>
                                                    <TextBlock Text="{x:Bind StatsLine}"
                                                               FontSize="11"
                                                               Foreground="{StaticResource SecondaryTextBrush}"
                                                               HorizontalAlignment="Right"/>
                                                    <StackPanel Orientation="Horizontal"
                                                                HorizontalAlignment="Right"
                                                                Spacing="6"
                                                                Margin="0,4,0,0">
                                                        <Button Content="Watch VOD"
                                                                FontSize="11" Height="26"
                                                                Padding="14,0" CornerRadius="6"
                                                                Background="{StaticResource AccentGoldBrush}"
                                                                Foreground="#0a0a0f"
                                                                Tag="{x:Bind GameId}"
                                                                Visibility="{x:Bind HasVod, Converter={StaticResource BoolToVis}}"
                                                                Click="WatchVodButton_Click"/>
                                                        <Button Content="Review"
                                                                FontSize="11" Height="26"
                                                                Padding="14,0" CornerRadius="6"
                                                                Background="{StaticResource AccentBlueBrush}"
                                                                Foreground="{StaticResource PrimaryTextBrush}"
                                                                Tag="{x:Bind GameId}"
                                                                Click="ReviewButton_Click"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>

                            <!-- Load More button -->
                            <Button Content="Load More"
                                    Visibility="{x:Bind ViewModel.HasMorePages, Mode=OneWay, Converter={StaticResource BoolToVis}}"
                                    Command="{x:Bind ViewModel.LoadMoreCommand}"
                                    HorizontalAlignment="Center"
                                    Margin="0,12,0,24"
                                    Height="32" Width="160"
                                    CornerRadius="8"
                                    FontSize="13"
                                    Background="{StaticResource AccentBlueBrush}"
                                    Foreground="{StaticResource PrimaryTextBrush}"/>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </PivotItem>

            <!-- ═══════════════════════════════════════════════════════ -->
            <!-- Tab 2: Stats Overview                                  -->
            <!-- ═══════════════════════════════════════════════════════ -->
            <PivotItem Header="Stats Overview">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="0,8,0,24">
                    <StackPanel Spacing="12" MaxWidth="700" HorizontalAlignment="Center">

                        <!-- No stats message -->
                        <TextBlock Text="No stats yet &#8212; play some games!"
                                   FontSize="14"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,40,0,0">
                            <TextBlock.Visibility>
                                <Binding Path="HasStats" Mode="OneWay" Converter="{StaticResource BoolToVis}"
                                         ConverterParameter="Inverse"/>
                            </TextBlock.Visibility>
                        </TextBlock>

                        <!-- Big win rate -->
                        <StackPanel Visibility="{x:Bind ViewModel.HasStats, Mode=OneWay, Converter={StaticResource BoolToVis}}"
                                    HorizontalAlignment="Center"
                                    Spacing="0"
                                    Margin="0,20,0,20">
                            <TextBlock Text="{x:Bind ViewModel.OverallWinRateText, Mode=OneWay}"
                                       FontSize="48" FontWeight="Bold"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="{x:Bind ViewModel.OverallRecordText, Mode=OneWay}"
                                       FontSize="14"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>

                        <!-- Stats grid -->
                        <Grid Visibility="{x:Bind ViewModel.HasStats, Mode=OneWay, Converter={StaticResource BoolToVis}}"
                              HorizontalAlignment="Stretch"
                              Margin="20,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Row 1 -->
                            <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource CardStyle}" Margin="4">
                                <StackPanel HorizontalAlignment="Center" Spacing="2">
                                    <TextBlock Text="{x:Bind ViewModel.AvgKillsText, Mode=OneWay}"
                                               FontSize="20" FontWeight="Bold"
                                               Foreground="{StaticResource PrimaryTextBrush}"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="Avg Kills"
                                               FontSize="10"
                                               Foreground="{StaticResource SecondaryTextBrush}"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource CardStyle}" Margin="4">
                                <StackPanel HorizontalAlignment="Center" Spacing="2">
                                    <TextBlock Text="{x:Bind ViewModel.AvgDeathsText, Mode=OneWay}"
                                               FontSize="20" FontWeight="Bold"
                                               Foreground="{StaticResource PrimaryTextBrush}"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="Avg Deaths"
                                               FontSize="10"
                                               Foreground="{StaticResource SecondaryTextBrush}"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Row="0" Grid.Column="2" Style="{StaticResource CardStyle}" Margin="4">
                                <StackPanel HorizontalAlignment="Center" Spacing="2">
                                    <TextBlock Text="{x:Bind ViewModel.AvgAssistsText, Mode=OneWay}"
                                               FontSize="20" FontWeight="Bold"
                                               Foreground="{StaticResource PrimaryTextBrush}"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="Avg Assists"
                                               FontSize="10"
                                               Foreground="{StaticResource SecondaryTextBrush}"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Row="0" Grid.Column="3" Style="{StaticResource CardStyle}" Margin="4">
                                <StackPanel HorizontalAlignment="Center" Spacing="2">
                                    <TextBlock Text="{x:Bind ViewModel.AvgKdaText, Mode=OneWay}"
                                               FontSize="20" FontWeight="Bold"
                                               Foreground="{StaticResource PrimaryTextBrush}"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="Avg KDA"
                                               FontSize="10"
                                               Foreground="{StaticResource SecondaryTextBrush}"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Row="0" Grid.Column="4" Style="{StaticResource CardStyle}" Margin="4">
                                <StackPanel HorizontalAlignment="Center" Spacing="2">
                                    <TextBlock Text="{x:Bind ViewModel.AvgCsMinText, Mode=OneWay}"
                                               FontSize="20" FontWeight="Bold"
                                               Foreground="{StaticResource PrimaryTextBrush}"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="Avg CS/min"
                                               FontSize="10"
                                               Foreground="{StaticResource SecondaryTextBrush}"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <!-- Row 2 -->
                            <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource CardStyle}" Margin="4">
                                <StackPanel HorizontalAlignment="Center" Spacing="2">
                                    <TextBlock Text="{x:Bind ViewModel.AvgVisionText, Mode=OneWay}"
                                               FontSize="20" FontWeight="Bold"
                                               Foreground="{StaticResource PrimaryTextBrush}"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="Avg Vision"
                                               FontSize="10"
                                               Foreground="{StaticResource SecondaryTextBrush}"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource CardStyle}" Margin="4">
                                <StackPanel HorizontalAlignment="Center" Spacing="2">
                                    <TextBlock Text="{x:Bind ViewModel.BestKdaText, Mode=OneWay}"
                                               FontSize="20" FontWeight="Bold"
                                               Foreground="{StaticResource PrimaryTextBrush}"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="Best KDA"
                                               FontSize="10"
                                               Foreground="{StaticResource SecondaryTextBrush}"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Row="1" Grid.Column="2" Style="{StaticResource CardStyle}" Margin="4">
                                <StackPanel HorizontalAlignment="Center" Spacing="2">
                                    <TextBlock Text="{x:Bind ViewModel.MaxKillsText, Mode=OneWay}"
                                               FontSize="20" FontWeight="Bold"
                                               Foreground="{StaticResource PrimaryTextBrush}"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="Max Kills"
                                               FontSize="10"
                                               Foreground="{StaticResource SecondaryTextBrush}"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Row="1" Grid.Column="3" Style="{StaticResource CardStyle}" Margin="4">
                                <StackPanel HorizontalAlignment="Center" Spacing="2">
                                    <TextBlock Text="{x:Bind ViewModel.PentasText, Mode=OneWay}"
                                               FontSize="20" FontWeight="Bold"
                                               Foreground="{StaticResource PrimaryTextBrush}"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="Pentas"
                                               FontSize="10"
                                               Foreground="{StaticResource SecondaryTextBrush}"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Row="1" Grid.Column="4" Style="{StaticResource CardStyle}" Margin="4">
                                <StackPanel HorizontalAlignment="Center" Spacing="2">
                                    <TextBlock Text="{x:Bind ViewModel.QuadrasText, Mode=OneWay}"
                                               FontSize="20" FontWeight="Bold"
                                               Foreground="{StaticResource PrimaryTextBrush}"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="Quadras"
                                               FontSize="10"
                                               Foreground="{StaticResource SecondaryTextBrush}"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </PivotItem>

            <!-- ═══════════════════════════════════════════════════════ -->
            <!-- Tab 3: By Champion                                     -->
            <!-- ═══════════════════════════════════════════════════════ -->
            <PivotItem Header="By Champion">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="0,8,0,24">
                    <StackPanel Spacing="0">
                        <!-- No data message -->
                        <TextBlock Text="No champion data yet."
                                   FontSize="14"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,40,0,0"
                                   Visibility="{x:Bind HasNoChampionStats, Mode=OneWay, Converter={StaticResource BoolToVis}}"/>

                        <!-- Table header -->
                        <Border Background="{StaticResource InputBackgroundBrush}"
                                Padding="6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="100"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Champion"
                                           FontSize="11" FontWeight="Bold"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           Padding="6,6"/>
                                <TextBlock Grid.Column="1" Text="Games"
                                           FontSize="11" FontWeight="Bold"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           Padding="6,6"/>
                                <TextBlock Grid.Column="2" Text="WR%"
                                           FontSize="11" FontWeight="Bold"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           Padding="6,6"/>
                                <TextBlock Grid.Column="3" Text="Avg KDA"
                                           FontSize="11" FontWeight="Bold"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           Padding="6,6"/>
                                <TextBlock Grid.Column="4" Text="Avg CS/m"
                                           FontSize="11" FontWeight="Bold"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           Padding="6,6"/>
                                <TextBlock Grid.Column="5" Text="Avg Dmg"
                                           FontSize="11" FontWeight="Bold"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           Padding="6,6"/>
                            </Grid>
                        </Border>

                        <!-- Champion rows -->
                        <ItemsRepeater ItemsSource="{x:Bind ViewModel.ChampionStats, Mode=OneWay}">
                            <ItemsRepeater.Layout>
                                <StackLayout Spacing="0"/>
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="vm:ChampionStatsDisplayItem">
                                    <Border Padding="6"
                                            BorderBrush="{StaticResource SubtleBorderBrush}"
                                            BorderThickness="0,0,0,1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="160"/>
                                                <ColumnDefinition Width="70"/>
                                                <ColumnDefinition Width="70"/>
                                                <ColumnDefinition Width="90"/>
                                                <ColumnDefinition Width="90"/>
                                                <ColumnDefinition Width="100"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="{x:Bind ChampionName}"
                                                       FontSize="12"
                                                       Foreground="{StaticResource AccentGoldBrush}"
                                                       Padding="6,4"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="{x:Bind GamesText}"
                                                       FontSize="12"
                                                       Foreground="{StaticResource PrimaryTextBrush}"
                                                       Padding="6,4"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="2"
                                                       Text="{x:Bind WinRateText}"
                                                       FontSize="12"
                                                       Padding="6,4"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="3"
                                                       Text="{x:Bind AvgKdaText}"
                                                       FontSize="12"
                                                       Foreground="{StaticResource PrimaryTextBrush}"
                                                       Padding="6,4"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="4"
                                                       Text="{x:Bind AvgCsMinText}"
                                                       FontSize="12"
                                                       Foreground="{StaticResource PrimaryTextBrush}"
                                                       Padding="6,4"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="5"
                                                       Text="{x:Bind AvgDamageText}"
                                                       FontSize="12"
                                                       Foreground="{StaticResource PrimaryTextBrush}"
                                                       Padding="6,4"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </StackPanel>
                </ScrollViewer>
            </PivotItem>
        </Pivot>
    </Grid>
</Page>
