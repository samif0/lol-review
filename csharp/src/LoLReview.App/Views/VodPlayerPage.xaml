<Page
    x:Class="LoLReview.App.Views.VodPlayerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:LoLReview.App.Controls"
    xmlns:converters="using:LoLReview.App.Converters"
    xmlns:vm="using:LoLReview.App.ViewModels"
    Background="#0a0a0f"
    NavigationCacheMode="Disabled"
    IsTabStop="True">
    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility" />
        <!-- Flat button style: no WinUI hover chrome that fights XamlControlsResources -->
        <Style x:Key="FlatButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                Padding="{TemplateBinding Padding}">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal" />
                                    <VisualState x:Name="PointerOver">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="Root" Storyboard.TargetProperty="Opacity">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="0.75" />
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="Root" Storyboard.TargetProperty="Opacity">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="0.5" />
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Disabled">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="Root" Storyboard.TargetProperty="Opacity">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="0.3" />
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Content="{TemplateBinding Content}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid RowDefinitions="Auto,*,Auto,Auto,Auto">

        <!-- ═══ Header bar ═══════════════════════════════════════════ -->
        <Grid Grid.Row="0" Padding="16,12" Background="#0d0d15"
              ColumnDefinitions="Auto,*">
            <Button Command="{x:Bind ViewModel.GoBackCommand}"
                    Background="Transparent" BorderThickness="0"
                    VerticalAlignment="Center" Padding="8,4"
                    IsTabStop="False">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE72B;" FontSize="14" Foreground="#7070a0" />
                    <TextBlock Text="Back" Foreground="#7070a0" FontSize="13" />
                </StackPanel>
            </Button>
            <TextBlock Grid.Column="1"
                       Text="{x:Bind ViewModel.HeaderText, Mode=OneWay}"
                       Foreground="#e8e8f0" FontSize="16" FontWeight="SemiBold"
                       VerticalAlignment="Center" Margin="12,0,0,0" />
        </Grid>

        <!-- ═══ Video area ═══════════════════════════════════════════ -->
        <Grid x:Name="VideoContainer" Grid.Row="1" Background="Black" MinHeight="300"
              IsTabStop="True" AllowFocusOnInteraction="True"
              Tapped="OnVideoTapped">
            <!-- Focus sink: 1x1, fully transparent, non-interactive, off-screen margin -->
            <Button x:Name="FocusSink" Width="1" Height="1" Opacity="0"
                    IsTabStop="False" IsHitTestVisible="False" Padding="0" BorderThickness="0"
                    Margin="-2,-2,0,0"
                    HorizontalAlignment="Left" VerticalAlignment="Top" />
            <!-- VideoView created in code-behind to avoid XAML type resolution crash in unpackaged mode -->

            <!-- Loading overlay -->
            <Grid x:Name="LoadingOverlay" Background="#80000000"
                  Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                <ProgressRing IsActive="True" Width="48" Height="48" />
            </Grid>

            <!-- No VOD message -->
            <TextBlock x:Name="NoVodText"
                       Text="No VOD linked to this game"
                       Foreground="#7070a0" FontSize="16"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Visibility="Collapsed" />
        </Grid>

        <!-- ═══ Timeline ═════════════════════════════════════════════ -->
        <controls:TimelineControl Grid.Row="2" x:Name="Timeline"
                                  Height="44" Margin="0"
                                  Duration="{x:Bind ViewModel.GameDurationS, Mode=OneWay}"
                                  Position="{x:Bind ViewModel.CurrentTimeS, Mode=OneWay}"
                                  Events="{x:Bind ViewModel.GameEvents, Mode=OneWay}"
                                  Bookmarks="{x:Bind ViewModel.Bookmarks, Mode=OneWay}"
                                  DerivedEvents="{x:Bind ViewModel.DerivedEvents, Mode=OneWay}"
                                  ClipStart="{x:Bind ViewModel.ClipStartS, Mode=OneWay}"
                                  ClipEnd="{x:Bind ViewModel.ClipEndS, Mode=OneWay}" />

        <!-- ═══ Transport controls ═══════════════════════════════════ -->
        <Border Grid.Row="3" Background="#0d0d15" Padding="16,8"
                BorderBrush="#1e1e2e" BorderThickness="0,1,0,0">
            <Grid ColumnDefinitions="Auto,Auto,Auto,*,Auto,Auto">
                <!-- Seek back -->
                <Button Grid.Column="0"
                        Command="{x:Bind ViewModel.SeekBackwardCommand}"
                        Click="OnClipButtonClick"
                        Background="Transparent" BorderThickness="0" Padding="8,4"
                        IsTabStop="False">
                    <FontIcon Glyph="&#xEB9E;" FontSize="18" Foreground="#e8e8f0" />
                </Button>

                <!-- Play/Pause -->
                <Button Grid.Column="1"
                        Command="{x:Bind ViewModel.PlayPauseCommand}"
                        Click="OnClipButtonClick"
                        Background="Transparent" BorderThickness="0" Padding="8,4"
                        IsTabStop="False">
                    <FontIcon x:Name="PlayPauseIcon" Glyph="&#xE768;" FontSize="22" Foreground="#e8e8f0" />
                </Button>

                <!-- Seek forward -->
                <Button Grid.Column="2"
                        Command="{x:Bind ViewModel.SeekForwardCommand}"
                        Click="OnClipButtonClick"
                        Background="Transparent" BorderThickness="0" Padding="8,4"
                        IsTabStop="False">
                    <FontIcon Glyph="&#xEB9D;" FontSize="18" Foreground="#e8e8f0" />
                </Button>

                <!-- Time display -->
                <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="4"
                            VerticalAlignment="Center" Margin="16,0,0,0">
                    <TextBlock Text="{x:Bind ViewModel.CurrentTimeText, Mode=OneWay}"
                               Foreground="#e8e8f0" FontSize="13" FontFamily="Consolas" />
                    <TextBlock Text="/" Foreground="#404060" FontSize="13" />
                    <TextBlock Text="{x:Bind ViewModel.TotalTimeText, Mode=OneWay}"
                               Foreground="#7070a0" FontSize="13" FontFamily="Consolas" />
                </StackPanel>

                <!-- Speed selector -->
                <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="8"
                            VerticalAlignment="Center">
                    <TextBlock Text="Speed:" Foreground="#7070a0" FontSize="12"
                               VerticalAlignment="Center" />
                    <ComboBox x:Name="SpeedCombo"
                              Width="80" FontSize="12"
                              SelectedIndex="2"
                              IsTabStop="False"
                              SelectionChanged="OnSpeedChanged">
                        <ComboBoxItem Content="0.25x" Tag="0.25" />
                        <ComboBoxItem Content="0.5x" Tag="0.5" />
                        <ComboBoxItem Content="1.0x" Tag="1.0" />
                        <ComboBoxItem Content="1.5x" Tag="1.5" />
                        <ComboBoxItem Content="2.0x" Tag="2.0" />
                    </ComboBox>
                </StackPanel>

                <!-- Volume -->
                <StackPanel Grid.Column="5" Orientation="Horizontal" Spacing="6"
                            VerticalAlignment="Center" Margin="16,0,0,0">
                    <Button x:Name="MuteButton"
                            Click="OnMuteClick"
                            Background="Transparent" BorderThickness="0" Padding="4,0"
                            IsTabStop="False">
                        <FontIcon x:Name="VolumeIcon" Glyph="&#xE767;" FontSize="14" Foreground="#7070a0" />
                    </Button>
                    <Slider x:Name="VolumeSlider"
                            Width="80" Minimum="0" Maximum="100" Value="100"
                            IsTabStop="False"
                            ValueChanged="OnVolumeChanged" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ Bottom panel: Bookmarks + Clips ══════════════════════ -->
        <Border Grid.Row="4" Background="#0a0a0f" Padding="16,12"
                BorderBrush="#1e1e2e" BorderThickness="0,1,0,0">
            <Grid RowDefinitions="Auto,Auto,Auto,Auto">

                <!-- ── Row 0: Section headers ──────────────────────── -->
                <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto,Auto,Auto,Auto">

                    <!-- Bookmarks label + Add -->
                    <TextBlock Grid.Column="0" Text="Bookmarks" Foreground="#e8e8f0"
                               FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Button Grid.Column="1"
                            Command="{x:Bind ViewModel.AddBookmarkCommand}"
                            Click="OnClipButtonClick"
                            Style="{StaticResource FlatButton}"
                            Background="#1a1a24" CornerRadius="4" Padding="10,4">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <FontIcon Glyph="&#xE8A4;" FontSize="11" Foreground="#0099ff" />
                            <TextBlock Text="Add" Foreground="#0099ff" FontSize="12" />
                        </StackPanel>
                    </Button>

                    <!-- Clip controls inline -->
                    <TextBlock Grid.Column="2" Text="Clip:" Foreground="#7070a0"
                               FontSize="12" VerticalAlignment="Center" Margin="24,0,8,0" />
                    <Button Grid.Column="3"
                            Command="{x:Bind ViewModel.SetClipInCommand}"
                            Click="OnClipButtonClick"
                            Style="{StaticResource FlatButton}"
                            Background="#1a1a24" CornerRadius="4" Padding="10,4" Margin="0,0,4,0">
                        <TextBlock Text="[ In" Foreground="#22c55e" FontSize="12" />
                    </Button>
                    <Button Grid.Column="4"
                            Command="{x:Bind ViewModel.SetClipOutCommand}"
                            Click="OnClipButtonClick"
                            Style="{StaticResource FlatButton}"
                            Background="#1a1a24" CornerRadius="4" Padding="10,4" Margin="0,0,4,0">
                        <TextBlock Text="Out ]" Foreground="#22c55e" FontSize="12" />
                    </Button>
                    <Button Grid.Column="5"
                            Command="{x:Bind ViewModel.ExtractClipCommand}"
                            Click="OnClipButtonClick"
                            IsEnabled="{x:Bind ViewModel.HasClipRange, Mode=OneWay}"
                            Style="{StaticResource FlatButton}"
                            Background="#14532d" CornerRadius="4" Padding="10,4">
                        <TextBlock Text="Save Clip" Foreground="#22c55e" FontSize="12" FontWeight="SemiBold" />
                    </Button>
                </Grid>

                <!-- ── Row 1: clip note input + clip range/status ── -->
                <Grid Grid.Row="1" ColumnDefinitions="*,Auto" Margin="0,6,0,0">
                    <!-- Note input (shown when clip range set) -->
                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center"
                                Visibility="{x:Bind ViewModel.HasClipRange, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="Note:" Foreground="#7070a0" FontSize="12" VerticalAlignment="Center" />
                        <TextBox x:Name="ClipNoteBox"
                                 Text="{x:Bind ViewModel.ClipNote, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 PlaceholderText="optional clip note"
                                 Width="200" FontSize="12"
                                 Background="#12121a" Foreground="#e8e8f0"
                                 BorderBrush="#2a2a3a" BorderThickness="1"
                                 Padding="6,3" CornerRadius="4" />
                    </StackPanel>
                    <!-- Range + status + clear -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <TextBlock Text="{x:Bind ViewModel.ClipStatusText, Mode=OneWay}"
                                   Foreground="#22c55e" FontSize="11" VerticalAlignment="Center" />
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center"
                                    Visibility="{x:Bind ViewModel.HasClipRange, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Foreground="#7070a0" FontSize="11" VerticalAlignment="Center">
                                <Run Text="Range: " />
                                <Run Text="{x:Bind ViewModel.ClipRangeText, Mode=OneWay}" Foreground="#22c55e" />
                                <Run Text="  " />
                                <Run Text="{x:Bind ViewModel.ClipDurationText, Mode=OneWay}" Foreground="#e8e8f0" />
                            </TextBlock>
                            <Button Command="{x:Bind ViewModel.ClearClipCommand}"
                                    Click="OnClipButtonClick"
                                    Style="{StaticResource FlatButton}"
                                    Padding="4,2" CornerRadius="3">
                                <FontIcon Glyph="&#xE711;" FontSize="10" Foreground="#7070a0" />
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <!-- ── Row 2: ffmpeg warning ── -->
                <TextBlock x:Name="FfmpegWarning" Grid.Row="2"
                           Text="ffmpeg not found — install ffmpeg and add to PATH to enable clip extraction"
                           Foreground="#ef4444" FontSize="11"
                           Visibility="Collapsed"
                           VerticalAlignment="Center" />

                <!-- ── Row 3: Bookmark list ─────────────────────────── -->
                <ScrollViewer Grid.Row="3" MaxHeight="100" VerticalScrollBarVisibility="Auto"
                              Margin="0,8,0,0">
                    <ItemsRepeater ItemsSource="{x:Bind ViewModel.Bookmarks, Mode=OneWay}">
                        <ItemsRepeater.Layout>
                            <StackLayout Spacing="2" />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="vm:BookmarkItem">
                                <Border Background="#12121a" CornerRadius="4"
                                        Padding="8,5" PointerPressed="OnBookmarkTapped">
                                    <Grid ColumnDefinitions="Auto,*,Auto">
                                        <TextBlock Text="{x:Bind TimeText}"
                                                   Foreground="#0099ff" FontSize="12"
                                                   FontFamily="Consolas"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{x:Bind Note}"
                                                   Foreground="#e8e8f0" FontSize="12"
                                                   Margin="8,0,0,0"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" />
                                        <StackPanel Grid.Column="2" Orientation="Horizontal"
                                                    Spacing="4" VerticalAlignment="Center">
                                            <Border Visibility="{x:Bind IsClip, Converter={StaticResource BoolToVisibility}}"
                                                    Background="#14532d" CornerRadius="3"
                                                    Padding="4,1">
                                                <TextBlock Text="CLIP" Foreground="#22c55e"
                                                           FontSize="10" FontWeight="SemiBold" />
                                            </Border>
                                            <Button Tag="{x:Bind Id}"
                                                    Click="OnDeleteBookmark"
                                                    Background="Transparent"
                                                    BorderThickness="0" Padding="4,2"
                                                    IsTabStop="False">
                                                <FontIcon Glyph="&#xE74D;" FontSize="11"
                                                          Foreground="#404060" />
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </ScrollViewer>

            </Grid>
        </Border>
    </Grid>
</Page>
