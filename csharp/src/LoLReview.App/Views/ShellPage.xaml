<Page
    x:Class="LoLReview.App.Views.ShellPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <SolidColorBrush x:Key="AppBackgroundBrush" Color="#0a0a0f"/>
        <SolidColorBrush x:Key="SidebarBg" Color="#0d0d15"/>
        <SolidColorBrush x:Key="AccentGoldBrush" Color="#c89b3c"/>
        <SolidColorBrush x:Key="LossRedBrush" Color="#ef4444"/>
        <SolidColorBrush x:Key="WinGreenBrush" Color="#22c55e"/>
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#7070a0"/>
        <SolidColorBrush x:Key="NavHoverBrush" Color="#14141e"/>
        <SolidColorBrush x:Key="NavActiveBrush" Color="#0099ff"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#1e1e2e"/>

        <!-- Nav item button style: no chrome, full-width, left-aligned content -->
        <Style x:Key="NavItemStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#c0c0d8"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="14,0,8,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Margin" Value="6,1"/>
        </Style>
    </Page.Resources>

    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Connection status bar -->
        <Grid Grid.Row="0" Height="2">
            <Rectangle x:Name="ConnectionIndicator"
                       Fill="{StaticResource LossRedBrush}"
                       HorizontalAlignment="Stretch"/>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ═══ Custom Sidebar ═══ -->
            <Border Grid.Column="0" Background="{StaticResource SidebarBg}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <StackPanel Grid.Row="0" Margin="14,14,0,12" Spacing="4">
                        <TextBlock Text="LoL Review"
                                   FontSize="16" FontWeight="SemiBold"
                                   Foreground="{StaticResource AccentGoldBrush}"/>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Ellipse x:Name="StatusDot"
                                     Width="8" Height="8"
                                     Fill="{StaticResource LossRedBrush}"
                                     VerticalAlignment="Center"/>
                            <TextBlock x:Name="ConnectionStatusText"
                                       Text="Waiting for League..."
                                       FontSize="11"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Nav Items -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="NavPanel" Spacing="0">
                            <Button x:Name="NavDashboard" Tag="dashboard" Style="{StaticResource NavItemStyle}" Click="OnNavClick" IsTabStop="False">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <FontIcon Glyph="&#xE80F;" FontSize="14" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"/>
                                    <TextBlock Text="Dashboard" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="NavSession" Tag="session" Style="{StaticResource NavItemStyle}" Click="OnNavClick" IsTabStop="False">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <FontIcon Glyph="&#xE768;" FontSize="14" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"/>
                                    <TextBlock Text="Session" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="NavObjectives" Tag="objectives" Style="{StaticResource NavItemStyle}" Click="OnNavClick" IsTabStop="False">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <FontIcon Glyph="&#xF16B;" FontSize="14" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"/>
                                    <TextBlock Text="Objectives" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="NavRules" Tag="rules" Style="{StaticResource NavItemStyle}" Click="OnNavClick" IsTabStop="False">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <FontIcon Glyph="&#xE8FD;" FontSize="14" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"/>
                                    <TextBlock Text="Rules" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="NavTiltCheck" Tag="tiltcheck" Style="{StaticResource NavItemStyle}" Click="OnNavClick" IsTabStop="False">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <FontIcon Glyph="&#xEB51;" FontSize="14" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"/>
                                    <TextBlock Text="Tilt Check" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Separator -->
                            <Border Height="1" Background="{StaticResource BorderBrush}" Margin="14,6"/>

                            <Button x:Name="NavHistory" Tag="history" Style="{StaticResource NavItemStyle}" Click="OnNavClick" IsTabStop="False">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <FontIcon Glyph="&#xE81C;" FontSize="14" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"/>
                                    <TextBlock Text="History" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="NavLosses" Tag="losses" Style="{StaticResource NavItemStyle}" Click="OnNavClick" IsTabStop="False">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <FontIcon Glyph="&#xE7BA;" FontSize="14" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"/>
                                    <TextBlock Text="Losses" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="NavAnalytics" Tag="analytics" Style="{StaticResource NavItemStyle}" Click="OnNavClick" IsTabStop="False">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <FontIcon Glyph="&#xE9D9;" FontSize="14" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"/>
                                    <TextBlock Text="Analytics" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Footer (Settings) -->
                    <StackPanel Grid.Row="2" Margin="0,0,0,4">
                        <Border Height="1" Background="{StaticResource BorderBrush}" Margin="14,4"/>
                        <Button x:Name="NavSettings" Tag="settings" Style="{StaticResource NavItemStyle}" Click="OnNavClick" IsTabStop="False">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xE713;" FontSize="14" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"/>
                                <TextBlock Text="Settings" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ═══ Content Area ═══ -->
            <Frame x:Name="ContentFrame" Grid.Column="1"/>
        </Grid>
    </Grid>
</Page>
