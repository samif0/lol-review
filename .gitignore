# Cloudflare Wrangler build cache (never commit — contains deploy metadata)
**/.wrangler/

# C# / .NET build artifacts
**/bin/
**/obj/
/publish/
/Releases/
/.tmp-build/
**/.tmp-build/
.vs/
*.user
*.suo
/packages/

# Local data (database, logs)
/data/
/FEATURE_NOTES.local.md
/experiments/sam3_vod/.venv/
/experiments/sam3_vod/__pycache__/
/experiments/sam3_vod/*.local.json

# Legacy Python venvs removed in coach phase -1 (kept ignored for safety
# in case local copies still exist on any machine)
/.venv-coach-qwen/
/.venv-coach-gemma/
/experiments/coach_lab/

# Coach rebuild (phase 0+) Python sidecar
/coach/__pycache__/
/coach/**/__pycache__/
/coach/.venv/
/coach/.venv-*/
/coach/**/.venv/
/coach/coach.egg-info/
/coach/build/
/coach/dist/
/coach/.pytest_cache/
/coach/.ruff_cache/
/coach/.mypy_cache/
/.pytest_cache/

# Personal scratchpad tools (SchemaCheck etc) — never built by CI, never
# shipped. Source files live on disk for the dev who needs them, but
# nothing under here goes into the public repo.
/tools/

# Claude Code runtime artifacts (lock + scheduled-tasks)
/.claude/scheduled_tasks.lock

# Build logs
/build.binlog
*.binlog

# Coach sidecar runtime logs (may contain sensitive info like URLs with API keys)
coach/sidecar.stdout.log
coach/sidecar.stderr.log
coach/smoke.log
coach/_smoke.py

# OS junk
.fuse_hidden*
Thumbs.db
Desktop.ini
.DS_Store
