# Cloudflare Wrangler build cache (never commit — contains deploy metadata)
**/.wrangler/

# Environment / local-secret files — never commit. .dev.vars is wrangler's
# local secrets convention (RIOT_API_KEY etc. during `wrangler dev`).
.env
.env.*
**/.env
**/.env.*
**/.dev.vars
**/.dev.vars.*

# C# / .NET build artifacts
**/bin/
**/obj/
/publish/
/Releases/
/.tmp-build/
**/.tmp-build/
.vs/
*.user
*.suo
/packages/

# Ruflo / claude-flow runtime state (vector DB, locks) — never commit
agentdb.rvf
agentdb.rvf.lock
/artifacts/

# Local data (database, logs)
/data/
/FEATURE_NOTES.local.md
/experiments/sam3_vod/.venv/
/experiments/sam3_vod/__pycache__/
/experiments/sam3_vod/*.local.json

# Legacy Python venvs removed in coach phase -1 (kept ignored for safety
# in case local copies still exist on any machine)
/.venv-coach-qwen/
/.venv-coach-gemma/
/experiments/coach_lab/

# Coach rebuild (phase 0+) Python sidecar
/coach/__pycache__/
/coach/**/__pycache__/
/coach/.venv/
/coach/.venv-*/
/coach/**/.venv/
/coach/coach.egg-info/
/coach/build/
/coach/dist/
/coach/.pytest_cache/
/coach/.ruff_cache/
/coach/.mypy_cache/
/.pytest_cache/

# Personal scratchpad tools (SchemaCheck etc) — never built by CI, never
# shipped. Source files live on disk for the dev who needs them, but
# nothing under here goes into the public repo.
/tools/

# Claude Code runtime artifacts (lock + scheduled-tasks + launch config)
/.claude/scheduled_tasks.lock
/.claude/launch.json

# Build logs
/build.binlog
*.binlog

# Coach sidecar runtime logs (may contain sensitive info like URLs with API keys)
coach/sidecar.stdout.log
coach/sidecar.stderr.log
coach/smoke.log
coach/_smoke.py

# OS junk
.fuse_hidden*
Thumbs.db
Desktop.ini
.DS_Store

# Ruflo / claude-flow swarm tooling runtime artifacts (not part of the app)
.claude-flow/
.swarm/
ruvector.db

# Research loop: local DB snapshots (user game data - never commit)
automation/research/snapshots/

# Internal working material — lives on disk, stays off the public repo
/docs/
/experiments/
/.claude/
/PERF_REPORT.md
/scripts/scrub-api-key.ps1
/scripts/scrub-api-key.py

# Research loop working files (personal usage data - local only, public repo)
automation/

# throwaway WebView2 glass demo (not part of app)
_glassdemo/

# Tauri desktop build artifacts
desktop/node_modules/
desktop/src-tauri/target/
desktop/src-tauri/gen/
.parity/
