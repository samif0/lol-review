<Page
    x:Name="RootPage"
    x:Class="LoLReview.App.Views.PreGamePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:LoLReview.App.ViewModels"
    xmlns:converters="using:LoLReview.App.Converters"
    xmlns:controls="using:LoLReview.App.Controls"
    mc:Ignorable="d"
    Background="Transparent">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </Page.Resources>

    <ScrollViewer x:Name="RootScroll"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Spacing="14" Padding="40,20,40,40"
                    MaxWidth="580" HorizontalAlignment="Center">

            <!-- ═══ Hero ═══ -->
            <controls:HeroHeader EyebrowText="CHAMP SELECT"
                                 Title="Lock In"/>

            <!-- ═══ Mood (Tilt Fix) ═══ -->
            <controls:CornerBracketedCard
                CardBorderBrush="{StaticResource AccentPurpleBrush}"
                Visibility="{x:Bind ViewModel.ShowMoodSelector, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                <StackPanel Spacing="8">
                    <controls:SectionTitle Text="HOW ARE YOU FEELING?"/>
                    <controls:MoodSelector SelectedMood="{x:Bind ViewModel.SelectedMood, Mode=TwoWay}"/>
                </StackPanel>
            </controls:CornerBracketedCard>

            <!-- ═══ Priority Objective ═══ -->
            <controls:CornerBracketedCard
                CardBorderBrush="{StaticResource AccentBlueBrush}"
                Visibility="{x:Bind ViewModel.HasActiveObjective, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                <StackPanel Spacing="4">
                    <controls:SectionTitle Text="PRIORITY OBJECTIVE"/>
                    <TextBlock Text="{x:Bind ViewModel.ActiveObjectiveTitle, Mode=OneWay}"
                               FontFamily="{StaticResource HeadingFont}"
                               FontSize="16" FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryTextBrush}"
                               TextWrapping="Wrap"/>
                    <TextBlock Text="{x:Bind ViewModel.ActiveObjectiveCriteria, Mode=OneWay}"
                               FontFamily="{StaticResource MonoFont}"
                               FontSize="10"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </controls:CornerBracketedCard>

            <!-- ═══ Pre-Game Objectives (with practiced toggle) ═══ -->
            <controls:CornerBracketedCard
                CardBorderBrush="{StaticResource AccentGoldBrush}"
                Visibility="{x:Bind ViewModel.HasPreGameObjectives, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                <StackPanel Spacing="8">
                    <controls:SectionTitle Text="PRE-GAME OBJECTIVES"/>
                    <ItemsRepeater ItemsSource="{x:Bind ViewModel.PreGameObjectives, Mode=OneWay}">
                        <ItemsRepeater.Layout>
                            <StackLayout Spacing="8"/>
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="vm:ObjectiveAssessment">
                                <Border Background="{StaticResource InputBackgroundBrush}"
                                        CornerRadius="2"
                                        BorderThickness="1,1,1,2"
                                        BorderBrush="{StaticResource AccentGoldBrush}"
                                        Padding="14">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="{x:Bind Title}"
                                                       FontFamily="{StaticResource HeadingFont}"
                                                       FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{StaticResource PrimaryTextBrush}"/>
                                            <TextBlock Text="{x:Bind Criteria}"
                                                       FontFamily="{StaticResource MonoFont}"
                                                       FontSize="10"
                                                       Foreground="{StaticResource SecondaryTextBrush}"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <ToggleButton Grid.Column="1"
                                                      IsChecked="{x:Bind Practiced, Mode=TwoWay}"
                                                      Style="{StaticResource HudPracticedToggleStyle}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </StackPanel>
            </controls:CornerBracketedCard>

            <!-- ═══ Pick Objective (when no priority set) ═══ -->
            <controls:CornerBracketedCard
                CardBorderBrush="{StaticResource AccentGoldBrush}"
                Visibility="{x:Bind ViewModel.HasObjectiveFocusOptions, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                <StackPanel Spacing="8">
                    <controls:SectionTitle Text="PICK AN OBJECTIVE"/>
                    <ItemsRepeater ItemsSource="{x:Bind ViewModel.ObjectiveFocusOptions, Mode=OneWay}">
                        <ItemsRepeater.Layout>
                            <StackLayout Spacing="6"/>
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="vm:FocusObjectiveItem">
                                <Button Command="{Binding ElementName=RootPage, Path=ViewModel.SetObjectiveFocusCommand}"
                                        CommandParameter="{x:Bind Title}"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Left"
                                        Style="{StaticResource SecondaryActionButtonStyle}"
                                        Height="Auto" Padding="12,10">
                                    <StackPanel Spacing="2">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <Border Background="{StaticResource AccentGoldBrush}"
                                                    CornerRadius="2" Padding="6,2"
                                                    Visibility="{x:Bind IsPriority, Converter={StaticResource BoolToVis}}">
                                                <TextBlock Text="PRIORITY"
                                                           FontFamily="{StaticResource MonoFont}"
                                                           FontSize="8" FontWeight="Bold"
                                                           Foreground="Black"/>
                                            </Border>
                                            <TextBlock Text="{x:Bind Title}"
                                                       FontFamily="{StaticResource HeadingFont}"
                                                       FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{StaticResource PrimaryTextBrush}"/>
                                        </StackPanel>
                                        <TextBlock Text="{x:Bind Subtitle}"
                                                   FontFamily="{StaticResource MonoFont}"
                                                   FontSize="9"
                                                   Foreground="{StaticResource MutedTextBrush}"
                                                   Visibility="{x:Bind HasSubtitle, Converter={StaticResource BoolToVis}}"/>
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </StackPanel>
            </controls:CornerBracketedCard>

            <!-- ═══ Intel from Last Game ═══ -->
            <controls:CornerBracketedCard
                Visibility="{x:Bind ViewModel.HasLastFocus, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                <StackPanel Spacing="8">
                    <controls:SectionTitle Text="LAST GAME INTEL"/>
                    <TextBlock Text="{x:Bind ViewModel.LastFocus, Mode=OneWay}"
                               FontFamily="{StaticResource BodyFont}"
                               FontSize="13"
                               Foreground="{StaticResource PrimaryTextBrush}"
                               TextWrapping="Wrap"/>
                    <TextBlock Text="{x:Bind ViewModel.LastMistakes, Mode=OneWay}"
                               FontFamily="{StaticResource MonoFont}"
                               FontSize="10"
                               Foreground="{StaticResource MutedTextBrush}"
                               TextWrapping="Wrap"
                               Visibility="{x:Bind ViewModel.HasLastMistakes, Mode=OneWay, Converter={StaticResource BoolToVis}}"/>
                </StackPanel>
            </controls:CornerBracketedCard>

            <!-- ═══ Matchup Notes ═══ -->
            <controls:CornerBracketedCard
                CardBorderBrush="{StaticResource AccentGoldBrush}"
                Visibility="{x:Bind ViewModel.HasMatchupHistory, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                <StackPanel Spacing="8">
                    <controls:SectionTitle Text="{x:Bind ViewModel.MatchupHeaderText, Mode=OneWay}"/>
                    <ItemsRepeater ItemsSource="{x:Bind ViewModel.MatchupHistory, Mode=OneWay}">
                        <ItemsRepeater.Layout>
                            <StackLayout Spacing="6"/>
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="vm:PreGameMatchupItem">
                                <Border Background="{StaticResource SurfaceInsetBrush}"
                                        BorderBrush="{StaticResource SubtleBorderBrush}"
                                        BorderThickness="1" Padding="10,8">
                                    <StackPanel Spacing="3">
                                        <TextBlock Text="{x:Bind Note}"
                                                   FontSize="12"
                                                   Foreground="{StaticResource PrimaryTextBrush}"
                                                   TextWrapping="Wrap"/>
                                        <TextBlock Text="{x:Bind DateText}"
                                                   FontFamily="{StaticResource MonoFont}"
                                                   FontSize="9"
                                                   Foreground="{StaticResource MutedTextBrush}"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </StackPanel>
            </controls:CornerBracketedCard>

            <!-- ═══ Set Focus ═══ -->
            <controls:CornerBracketedCard
                CardBackground="{StaticResource FocusPanelBrush}"
                CardBorderBrush="{StaticResource AccentGoldBrush}">
                <StackPanel Spacing="10">
                    <controls:SectionTitle Text="SET FOCUS"/>

                    <TextBox Text="{x:Bind ViewModel.FocusText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             PlaceholderText="What's your #1 focus this game?"
                             TextWrapping="Wrap" AcceptsReturn="True"
                             MinHeight="60" FontSize="13"
                             Background="{StaticResource InputBackgroundBrush}"
                             BorderBrush="{StaticResource SubtleBorderBrush}"
                             Foreground="{StaticResource PrimaryTextBrush}"
                             CornerRadius="2"/>

                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <Button Content="CS/min"
                                Command="{x:Bind ViewModel.SetQuickFocusCommand}"
                                CommandParameter="CS better early"
                                Style="{StaticResource SecondaryActionButtonStyle}"
                                Height="26" Padding="10,0" FontSize="10"/>
                        <Button Content="Map awareness"
                                Command="{x:Bind ViewModel.SetQuickFocusCommand}"
                                CommandParameter="Track enemy JG"
                                Style="{StaticResource SecondaryActionButtonStyle}"
                                Height="26" Padding="10,0" FontSize="10"/>
                        <Button Content="Trading"
                                Command="{x:Bind ViewModel.SetQuickFocusCommand}"
                                CommandParameter="Trade on power spikes"
                                Style="{StaticResource SecondaryActionButtonStyle}"
                                Height="26" Padding="10,0" FontSize="10"/>
                        <Button Content="Vision"
                                Command="{x:Bind ViewModel.SetQuickFocusCommand}"
                                CommandParameter="Ward more"
                                Style="{StaticResource SecondaryActionButtonStyle}"
                                Height="26" Padding="10,0" FontSize="10"/>
                    </StackPanel>
                </StackPanel>
            </controls:CornerBracketedCard>

            <!-- ═══ Session Intention (first game) ═══ -->
            <controls:CornerBracketedCard
                Visibility="{x:Bind ViewModel.ShowIntention, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                <StackPanel Spacing="8">
                    <controls:SectionTitle Text="SESSION MINDSET"/>
                    <TextBox Text="{x:Bind ViewModel.SessionIntention, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             PlaceholderText="When [trigger] happens, I will [response]"
                             TextWrapping="Wrap" AcceptsReturn="True"
                             MinHeight="50" FontSize="12"
                             Background="{StaticResource InputBackgroundBrush}"
                             BorderBrush="{StaticResource SubtleBorderBrush}"
                             Foreground="{StaticResource PrimaryTextBrush}"
                             CornerRadius="2"/>
                </StackPanel>
            </controls:CornerBracketedCard>

            <!-- Auto-close note -->
            <TextBlock Text="This page closes automatically when your game loads."
                       FontFamily="{StaticResource MonoFont}"
                       FontSize="9"
                       Foreground="{StaticResource MutedTextBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,4,0,0"/>

        </StackPanel>
    </ScrollViewer>
</Page>
