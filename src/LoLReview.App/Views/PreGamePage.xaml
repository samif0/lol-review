<Page
    x:Name="RootPage"
    x:Class="LoLReview.App.Views.PreGamePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:LoLReview.App.ViewModels"
    xmlns:converters="using:LoLReview.App.Converters"
    xmlns:controls="using:LoLReview.App.Controls"
    mc:Ignorable="d"
    Background="Transparent">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Spacing="14" Padding="24,20"
                    Width="520" HorizontalAlignment="Center">

            <!-- ═══ Header ═══ -->
            <TextBlock Text="BEFORE YOU QUEUE UP..."
                       FontSize="22" FontWeight="Bold"
                       Foreground="{StaticResource AccentGoldBrush}"/>

            <TextBlock Text="Take a moment to set your focus for this game."
                       FontSize="13"
                       Foreground="{StaticResource SecondaryTextBrush}"/>

            <!-- ═══ Mood Check-in (Tilt Fix) ═══ -->
            <Border Visibility="{x:Bind ViewModel.ShowMoodSelector, Mode=OneWay, Converter={StaticResource BoolToVis}}"
                    Background="{StaticResource CardBackgroundBrush}"
                    BorderBrush="{StaticResource AccentPurpleBrush}"
                    BorderThickness="1" CornerRadius="2" Padding="14,10">
                <StackPanel Spacing="6">
                    <TextBlock Text="HOW ARE YOU FEELING RIGHT NOW?"
                               FontSize="11" FontWeight="Bold"
                               Foreground="{StaticResource AccentPurpleBrush}"/>

                    <controls:MoodSelector SelectedMood="{x:Bind ViewModel.SelectedMood, Mode=TwoWay}"/>
                </StackPanel>
            </Border>

            <!-- ═══ Session Intention (first game only) ═══ -->
            <Border Visibility="{x:Bind ViewModel.ShowIntention, Mode=OneWay, Converter={StaticResource BoolToVis}}"
                    Background="{StaticResource CardBackgroundBrush}"
                    BorderBrush="{StaticResource AccentGoldBrush}"
                    BorderThickness="2" CornerRadius="2" Padding="14,10">
                <StackPanel Spacing="6">
                    <TextBlock Text="SESSION MINDSET GOAL"
                               FontSize="11" FontWeight="Bold"
                               Foreground="{StaticResource AccentGoldBrush}"/>

                    <TextBlock Text="Try: &quot;When [trigger] happens, I will [response]&quot;"
                               FontSize="11"
                               Foreground="{StaticResource SecondaryTextBrush}"/>

                    <TextBox Text="{x:Bind ViewModel.SessionIntention, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             PlaceholderText="Your session mindset goal..."
                             TextWrapping="Wrap" AcceptsReturn="True"
                             MinHeight="50" FontSize="13"
                             Background="{StaticResource InputBackgroundBrush}"
                             BorderBrush="{StaticResource SubtleBorderBrush}"
                             Foreground="{StaticResource PrimaryTextBrush}"
                             CornerRadius="2"/>

                    <!-- Quick intention buttons -->
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <Button Content="When I die, I'll review why"
                                Command="{x:Bind ViewModel.SetQuickIntentionCommand}"
                                CommandParameter="When I die, I'll review why"
                                FontSize="10" Height="24" CornerRadius="2"
                                Padding="8,0"
                                Background="{StaticResource TagBackgroundBrush}"
                                Foreground="{StaticResource SecondaryTextBrush}"
                                BorderBrush="{StaticResource SubtleBorderBrush}"
                                BorderThickness="1" IsTabStop="False"/>
                        <Button Content="When tilted, I'll take 3 breaths"
                                Command="{x:Bind ViewModel.SetQuickIntentionCommand}"
                                CommandParameter="When tilted, I'll take 3 breaths"
                                FontSize="10" Height="24" CornerRadius="2"
                                Padding="8,0"
                                Background="{StaticResource TagBackgroundBrush}"
                                Foreground="{StaticResource SecondaryTextBrush}"
                                BorderBrush="{StaticResource SubtleBorderBrush}"
                                BorderThickness="1" IsTabStop="False"/>
                        <Button Content="When behind, I'll focus on farm"
                                Command="{x:Bind ViewModel.SetQuickIntentionCommand}"
                                CommandParameter="When behind, I'll focus on farm"
                                FontSize="10" Height="24" CornerRadius="2"
                                Padding="8,0"
                                Background="{StaticResource TagBackgroundBrush}"
                                Foreground="{StaticResource SecondaryTextBrush}"
                                BorderBrush="{StaticResource SubtleBorderBrush}"
                                BorderThickness="1" IsTabStop="False"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ═══ Active Objective ═══ -->
            <Border Visibility="{x:Bind ViewModel.HasActiveObjective, Mode=OneWay, Converter={StaticResource BoolToVis}}"
                    Background="{StaticResource CardBackgroundBrush}"
                    BorderBrush="{StaticResource AccentBlueBrush}"
                    BorderThickness="2" CornerRadius="2" Padding="14,10">
                <StackPanel Spacing="4">
                    <TextBlock Text="PRIORITY OBJECTIVE"
                               FontSize="11" FontWeight="Bold"
                               Foreground="{StaticResource AccentBlueBrush}"/>
                    <TextBlock Text="{x:Bind ViewModel.ActiveObjectiveTitle, Mode=OneWay}"
                               FontSize="14" FontWeight="Bold"
                               Foreground="{StaticResource PrimaryTextBrush}"
                               TextWrapping="Wrap"/>
                    <TextBlock Text="{x:Bind ViewModel.ActiveObjectiveCriteria, Mode=OneWay}"
                               FontSize="12"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <Border Visibility="{x:Bind ViewModel.HasObjectiveFocusOptions, Mode=OneWay, Converter={StaticResource BoolToVis}}"
                    Background="{StaticResource CardBackgroundBrush}"
                    BorderBrush="{StaticResource AccentGoldBrush}"
                    BorderThickness="1" CornerRadius="2" Padding="14,10">
                <StackPanel Spacing="8">
                    <TextBlock Text="PICK AN OBJECTIVE TO FOCUS ON"
                               FontSize="11" FontWeight="Bold"
                               Foreground="{StaticResource AccentGoldBrush}"/>

                    <ItemsRepeater ItemsSource="{x:Bind ViewModel.ObjectiveFocusOptions, Mode=OneWay}">
                        <ItemsRepeater.Layout>
                            <StackLayout Spacing="6"/>
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="vm:FocusObjectiveItem">
                                <Button Command="{Binding ElementName=RootPage, Path=ViewModel.SetObjectiveFocusCommand}"
                                        CommandParameter="{x:Bind Title}"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Left"
                                        Padding="12,10"
                                        CornerRadius="2"
                                        Background="{StaticResource InputBackgroundBrush}"
                                        BorderBrush="{StaticResource SubtleBorderBrush}"
                                        BorderThickness="1">
                                    <StackPanel Spacing="2">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <Border Background="{StaticResource AccentGoldBrush}"
                                                    CornerRadius="2"
                                                    Padding="6,2"
                                                    Visibility="{x:Bind IsPriority, Converter={StaticResource BoolToVis}}">
                                                <TextBlock Text="PRIORITY"
                                                           FontSize="9"
                                                           FontWeight="Bold"
                                                           Foreground="Black"/>
                                            </Border>
                                            <TextBlock Text="{x:Bind Title}"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource PrimaryTextBrush}"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <TextBlock Text="{x:Bind Subtitle}"
                                                   FontSize="11"
                                                   Foreground="{StaticResource SecondaryTextBrush}"
                                                   TextWrapping="Wrap"
                                                   Visibility="{x:Bind HasSubtitle, Converter={StaticResource BoolToVis}}"/>
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </StackPanel>
            </Border>

            <!-- ═══ Last Game Focus ═══ -->
            <Border Visibility="{x:Bind ViewModel.HasLastFocus, Mode=OneWay, Converter={StaticResource BoolToVis}}"
                    Style="{StaticResource CardStyle}">
                <StackPanel Spacing="4">
                    <TextBlock Text="YOUR FOCUS FROM LAST GAME"
                               FontSize="11" FontWeight="Bold"
                               Foreground="{StaticResource AccentBlueBrush}"/>
                    <TextBlock Text="{x:Bind ViewModel.LastFocus, Mode=OneWay}"
                               FontSize="14"
                               Foreground="{StaticResource PrimaryTextBrush}"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- ═══ Last Game Mistakes ═══ -->
            <Border Visibility="{x:Bind ViewModel.HasLastMistakes, Mode=OneWay, Converter={StaticResource BoolToVis}}"
                    Style="{StaticResource CardStyle}">
                <StackPanel Spacing="4">
                    <TextBlock Text="WHAT YOU WANTED TO IMPROVE"
                               FontSize="11" FontWeight="Bold"
                               Foreground="{StaticResource StarActiveBrush}"/>
                    <TextBlock Text="{x:Bind ViewModel.LastMistakes, Mode=OneWay}"
                               FontSize="13"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- ═══ Matchup History ═══ -->
            <Border Visibility="{x:Bind ViewModel.HasMatchupHistory, Mode=OneWay, Converter={StaticResource BoolToVis}}"
                    Background="{StaticResource CardBackgroundBrush}"
                    BorderBrush="{StaticResource AccentGoldBrush}"
                    BorderThickness="1" CornerRadius="2" Padding="14,12">
                <StackPanel Spacing="8">
                    <TextBlock Text="{x:Bind ViewModel.MatchupHeaderText, Mode=OneWay}"
                               FontSize="11" FontWeight="Bold"
                               Foreground="{StaticResource AccentGoldBrush}"/>
                    <ItemsRepeater ItemsSource="{x:Bind ViewModel.MatchupHistory, Mode=OneWay}">
                        <ItemsRepeater.Layout>
                            <StackLayout Spacing="8"/>
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="vm:PreGameMatchupItem">
                                <Border Background="{StaticResource InputBackgroundBrush}"
                                        BorderBrush="{StaticResource SubtleBorderBrush}"
                                        BorderThickness="1" CornerRadius="2" Padding="10,8">
                                    <StackPanel Spacing="4">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="{x:Bind DateText}"
                                                       FontSize="10"
                                                       Foreground="{StaticResource SecondaryTextBrush}"/>
                                            <Border Background="{StaticResource AccentGoldBrush}"
                                                    CornerRadius="2" Padding="5,1"
                                                    Visibility="{x:Bind WasHelpful, Converter={StaticResource BoolToVis}}">
                                                <TextBlock Text="HELPFUL"
                                                           FontSize="9" FontWeight="Bold"
                                                           Foreground="Black"/>
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="{x:Bind Note}"
                                                   FontSize="12"
                                                   Foreground="{StaticResource PrimaryTextBrush}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </StackPanel>
            </Border>

            <!-- Separator -->
            <Border Height="1" Background="{StaticResource SubtleBorderBrush}"/>

            <!-- ═══ Set Focus ═══ -->
            <TextBlock Text="What's your focus this game?"
                       FontSize="14" FontWeight="Bold"
                       Foreground="{StaticResource PrimaryTextBrush}"/>

            <TextBox Text="{x:Bind ViewModel.FocusText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     PlaceholderText="What will you focus on?"
                     TextWrapping="Wrap" AcceptsReturn="True"
                     MinHeight="70" FontSize="13"
                     Background="{StaticResource InputBackgroundBrush}"
                     BorderBrush="{StaticResource SubtleBorderBrush}"
                     Foreground="{StaticResource PrimaryTextBrush}"
                     CornerRadius="2"/>

            <!-- Quick focus buttons -->
            <StackPanel Orientation="Horizontal" Spacing="4">
                <Button Content="CS better early"
                        Command="{x:Bind ViewModel.SetQuickFocusCommand}"
                        CommandParameter="CS better early"
                        FontSize="11" Height="26" CornerRadius="2"
                        Padding="10,0"
                        Background="{StaticResource TagBackgroundBrush}"
                        Foreground="{StaticResource SecondaryTextBrush}"
                        BorderBrush="{StaticResource SubtleBorderBrush}"
                        BorderThickness="1" IsTabStop="False"/>
                <Button Content="Track enemy JG"
                        Command="{x:Bind ViewModel.SetQuickFocusCommand}"
                        CommandParameter="Track enemy JG"
                        FontSize="11" Height="26" CornerRadius="2"
                        Padding="10,0"
                        Background="{StaticResource TagBackgroundBrush}"
                        Foreground="{StaticResource SecondaryTextBrush}"
                        BorderBrush="{StaticResource SubtleBorderBrush}"
                        BorderThickness="1" IsTabStop="False"/>
                <Button Content="Don't die before 6"
                        Command="{x:Bind ViewModel.SetQuickFocusCommand}"
                        CommandParameter="Don't die before 6"
                        FontSize="11" Height="26" CornerRadius="2"
                        Padding="10,0"
                        Background="{StaticResource TagBackgroundBrush}"
                        Foreground="{StaticResource SecondaryTextBrush}"
                        BorderBrush="{StaticResource SubtleBorderBrush}"
                        BorderThickness="1" IsTabStop="False"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="4">
                <Button Content="Play for teamfights"
                        Command="{x:Bind ViewModel.SetQuickFocusCommand}"
                        CommandParameter="Play for teamfights"
                        FontSize="11" Height="26" CornerRadius="2"
                        Padding="10,0"
                        Background="{StaticResource TagBackgroundBrush}"
                        Foreground="{StaticResource SecondaryTextBrush}"
                        BorderBrush="{StaticResource SubtleBorderBrush}"
                        BorderThickness="1" IsTabStop="False"/>
                <Button Content="Ward more"
                        Command="{x:Bind ViewModel.SetQuickFocusCommand}"
                        CommandParameter="Ward more"
                        FontSize="11" Height="26" CornerRadius="2"
                        Padding="10,0"
                        Background="{StaticResource TagBackgroundBrush}"
                        Foreground="{StaticResource SecondaryTextBrush}"
                        BorderBrush="{StaticResource SubtleBorderBrush}"
                        BorderThickness="1" IsTabStop="False"/>
                <Button Content="Roam after push"
                        Command="{x:Bind ViewModel.SetQuickFocusCommand}"
                        CommandParameter="Roam after push"
                        FontSize="11" Height="26" CornerRadius="2"
                        Padding="10,0"
                        Background="{StaticResource TagBackgroundBrush}"
                        Foreground="{StaticResource SecondaryTextBrush}"
                        BorderBrush="{StaticResource SubtleBorderBrush}"
                        BorderThickness="1" IsTabStop="False"/>
            </StackPanel>

            <!-- Auto-close note -->
            <TextBlock Text="This page will close automatically when your game loads."
                       FontSize="11"
                       Foreground="{StaticResource SecondaryTextBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,8,0,0"/>

        </StackPanel>
    </ScrollViewer>
</Page>
