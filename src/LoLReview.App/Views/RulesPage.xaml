<Page
    x:Class="LoLReview.App.Views.RulesPage"
    x:Name="RulesPageRoot"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:converters="using:LoLReview.App.Converters"
    xmlns:vm="using:LoLReview.App.ViewModels"
    mc:Ignorable="d"
    Loaded="Page_Loaded">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <converters:InverseBoolConverter x:Key="InverseBool"/>
    </Page.Resources>

    <Grid Background="{StaticResource AppBackgroundBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Padding="24,20" Spacing="12" MaxWidth="900">

                <!-- Header Row -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="Session Rules"
                               FontSize="22" FontWeight="Bold"
                               Foreground="{StaticResource PrimaryTextBrush}"
                               VerticalAlignment="Center"/>
                    <Button Grid.Column="1"
                            Content="+ New Rule"
                            Command="{x:Bind ViewModel.ToggleCreateFormCommand}"
                            Background="{StaticResource AccentBlueBrush}"
                            Foreground="{StaticResource ActionPrimaryForegroundBrush}"
                            CornerRadius="6" Height="34"
                            BorderThickness="0"/>
                </Grid>

                <!-- Active Violations Banner -->
                <Border Background="#3f1111"
                        CornerRadius="8"
                        Padding="16,12"
                        BorderThickness="2"
                        BorderBrush="{StaticResource LossRedBrush}"
                        Visibility="{x:Bind ViewModel.HasViolations, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                    <StackPanel Spacing="8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE7BA;" FontSize="16"
                                      Foreground="{StaticResource LossRedBrush}"/>
                            <TextBlock Text="RULES VIOLATED"
                                       FontSize="13" FontWeight="Bold"
                                       Foreground="{StaticResource LossRedBrush}"/>
                        </StackPanel>
                        <ItemsRepeater ItemsSource="{x:Bind ViewModel.Violations, Mode=OneWay}">
                            <ItemsRepeater.Layout>
                                <StackLayout Spacing="4"/>
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="vm:ViolationBannerItem">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Text="{x:Bind RuleName}"
                                                   FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{StaticResource PrimaryTextBrush}"/>
                                        <TextBlock Text="&#x2014;"
                                                   FontSize="12"
                                                   Foreground="{StaticResource SecondaryTextBrush}"/>
                                        <TextBlock Text="{x:Bind Reason}"
                                                   FontSize="12"
                                                   Foreground="{StaticResource LossRedBrush}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </StackPanel>
                </Border>

                <!-- Create Form (collapsible) -->
                <Border Style="{StaticResource CardStyle}"
                        BorderBrush="{StaticResource AccentBlueBrush}"
                        Visibility="{x:Bind ViewModel.IsCreating, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                    <StackPanel Spacing="12">
                        <TextBlock Text="New Rule"
                                   FontSize="16" FontWeight="SemiBold"
                                   Foreground="{StaticResource PrimaryTextBrush}"/>

                        <!-- Name -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="Name *" FontSize="12"
                                       Foreground="{StaticResource SecondaryTextBrush}"/>
                            <TextBox Text="{x:Bind ViewModel.NewRuleName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     PlaceholderText="e.g., Stop after 3 losses"
                                     Background="{StaticResource InputBackgroundBrush}"
                                     Foreground="{StaticResource PrimaryTextBrush}"
                                     BorderBrush="{StaticResource SubtleBorderBrush}"
                                     CornerRadius="6"/>
                        </StackPanel>

                        <!-- Type -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="Type" FontSize="12"
                                       Foreground="{StaticResource SecondaryTextBrush}"/>
                            <ComboBox ItemsSource="{x:Bind ViewModel.RuleTypeOptions}"
                                      SelectedIndex="{x:Bind ViewModel.NewRuleTypeIndex, Mode=TwoWay}"
                                      Background="{StaticResource InputBackgroundBrush}"
                                      Foreground="{StaticResource PrimaryTextBrush}"
                                      BorderBrush="{StaticResource SubtleBorderBrush}"
                                      CornerRadius="6" MinWidth="250"/>
                        </StackPanel>

                        <!-- Condition Value (context-dependent) -->
                        <StackPanel Spacing="4"
                                    Visibility="{x:Bind ViewModel.ShowConditionField, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{x:Bind ViewModel.ConditionLabel, Mode=OneWay}"
                                       FontSize="12"
                                       Foreground="{StaticResource SecondaryTextBrush}"/>
                            <TextBox Text="{x:Bind ViewModel.NewConditionValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     PlaceholderText="{x:Bind ViewModel.ConditionPlaceholder, Mode=OneWay}"
                                     Background="{StaticResource InputBackgroundBrush}"
                                     Foreground="{StaticResource PrimaryTextBrush}"
                                     BorderBrush="{StaticResource SubtleBorderBrush}"
                                     CornerRadius="6"/>
                        </StackPanel>

                        <!-- Description -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="Description" FontSize="12"
                                       Foreground="{StaticResource SecondaryTextBrush}"/>
                            <TextBox Text="{x:Bind ViewModel.NewDescription, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     PlaceholderText="Why is this rule important to you?"
                                     Background="{StaticResource InputBackgroundBrush}"
                                     Foreground="{StaticResource PrimaryTextBrush}"
                                     BorderBrush="{StaticResource SubtleBorderBrush}"
                                     CornerRadius="6"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     MinHeight="60"/>
                        </StackPanel>

                        <!-- Action Buttons -->
                        <StackPanel Orientation="Horizontal" Spacing="8"
                                    HorizontalAlignment="Right">
                            <Button Content="Cancel"
                                    Command="{x:Bind ViewModel.ToggleCreateFormCommand}"
                                    Background="{StaticResource TagBackgroundBrush}"
                                    Foreground="{StaticResource PrimaryTextBrush}"
                                    CornerRadius="6" Height="32"
                                    BorderThickness="0"/>
                            <Button Content="Create"
                                    Command="{x:Bind ViewModel.CreateRuleCommand}"
                                    IsEnabled="{x:Bind ViewModel.CanCreate, Mode=OneWay}"
                                    Background="{StaticResource AccentBlueBrush}"
                                    Foreground="{StaticResource ActionPrimaryForegroundBrush}"
                                    CornerRadius="6" Height="32"
                                    BorderThickness="0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Empty State: suggested starter rules -->
                <StackPanel Spacing="8"
                            Visibility="{x:Bind ViewModel.HasRules, Mode=OneWay, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}">

                    <TextBlock Text="NO RULES YET"
                               FontSize="11" FontWeight="Bold"
                               Foreground="{StaticResource SecondaryTextBrush}"/>
                    <TextBlock Text="Add a rule to start tracking your adherence streak. Here are some common starting points:"
                               FontSize="13"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               TextWrapping="Wrap"/>

                    <ItemsRepeater ItemsSource="{x:Bind ViewModel.SuggestedRules}">
                        <ItemsRepeater.Layout>
                            <StackLayout Spacing="8"/>
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="vm:SuggestedRule">
                                <Border Background="{StaticResource CardBackgroundBrush}"
                                        CornerRadius="10"
                                        Padding="16,12"
                                        BorderThickness="1"
                                        BorderBrush="{StaticResource SubtleBorderBrush}"
                                        Opacity="0.85">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Spacing="4">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <Border Background="#1e3a5f"
                                                        CornerRadius="4" Padding="6,2">
                                                    <TextBlock Text="{x:Bind BadgeText}"
                                                               FontSize="9" FontWeight="Bold"
                                                               Foreground="#60a0ff"/>
                                                </Border>
                                                <TextBlock Text="{x:Bind Name}"
                                                           FontSize="14" FontWeight="SemiBold"
                                                           Foreground="{StaticResource PrimaryTextBrush}"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <TextBlock Text="{x:Bind Description}"
                                                       FontSize="12"
                                                       Foreground="{StaticResource SecondaryTextBrush}"
                                                       TextWrapping="Wrap"/>
                                            <TextBlock Text="{x:Bind ConditionText}"
                                                       FontSize="11"
                                                       Foreground="{StaticResource MutedTextBrush}"/>
                                        </StackPanel>
                                        <Button Grid.Column="1"
                                                Content="+ Add"
                                                FontSize="12" Height="30"
                                                Padding="14,0" CornerRadius="6"
                                                Background="{StaticResource AccentBlueBrush}"
                                                Foreground="{StaticResource ActionPrimaryForegroundBrush}"
                                                BorderThickness="0"
                                                VerticalAlignment="Center"
                                                Command="{Binding ElementName=RulesPageRoot, Path=ViewModel.AddSuggestedRuleCommand}"
                                                CommandParameter="{x:Bind}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </StackPanel>

                <!-- Active Rules Section Header -->
                <TextBlock Text="ACTIVE"
                           FontSize="11" FontWeight="Bold"
                           Foreground="{StaticResource SecondaryTextBrush}"
                           Visibility="{x:Bind ViewModel.HasActiveRules, Mode=OneWay, Converter={StaticResource BoolToVis}}"/>

                <!-- Active Rules List -->
                <ItemsRepeater ItemsSource="{x:Bind ViewModel.ActiveRules, Mode=OneWay}"
                               Visibility="{x:Bind ViewModel.HasActiveRules, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                    <ItemsRepeater.Layout>
                        <StackLayout Spacing="8"/>
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="vm:RuleDisplayItem">
                            <Border Background="{StaticResource CardBackgroundBrush}"
                                    CornerRadius="10"
                                    Padding="16,12"
                                    BorderThickness="2"
                                    BorderBrush="{StaticResource SubtleBorderBrush}">
                                <StackPanel Spacing="4">
                                    <!-- Top Row: Type Badge + Name + Violation Status -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0"
                                                Background="#1e40af"
                                                CornerRadius="4" Padding="6,2"
                                                Margin="0,0,8,0">
                                            <TextBlock Text="{x:Bind TypeBadge}"
                                                       FontSize="9" FontWeight="Bold"
                                                       Foreground="White"/>
                                        </Border>
                                        <TextBlock Grid.Column="1"
                                                   Text="{x:Bind Name}"
                                                   FontSize="15" FontWeight="Bold"
                                                   Foreground="{StaticResource PrimaryTextBrush}"
                                                   VerticalAlignment="Center"/>

                                        <!-- Violation badge -->
                                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                                            <Border Background="{StaticResource LossRedBrush}"
                                                    CornerRadius="4" Padding="8,2"
                                                    Visibility="{x:Bind IsViolated, Converter={StaticResource BoolToVis}}">
                                                <TextBlock Text="VIOLATED"
                                                           FontSize="10" FontWeight="Bold"
                                                           Foreground="White"/>
                                            </Border>
                                            <Border Background="{StaticResource WinGreenBrush}"
                                                    CornerRadius="4" Padding="8,2"
                                                    Visibility="{x:Bind IsOk, Converter={StaticResource BoolToVis}}">
                                                <TextBlock Text="OK"
                                                           FontSize="10" FontWeight="Bold"
                                                           Foreground="White"/>
                                            </Border>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Violation Reason -->
                                    <TextBlock Text="{x:Bind ViolationReason}"
                                               FontSize="12"
                                               Foreground="{StaticResource LossRedBrush}"
                                               Visibility="{x:Bind HasViolationReason, Converter={StaticResource BoolToVis}}"/>

                                    <!-- Description -->
                                    <TextBlock Text="{x:Bind Description}"
                                               FontSize="12"
                                               Foreground="{StaticResource SecondaryTextBrush}"
                                               TextWrapping="Wrap"
                                               Visibility="{x:Bind HasDescription, Converter={StaticResource BoolToVis}}"/>

                                    <!-- Condition -->
                                    <TextBlock Text="{x:Bind ConditionText}"
                                               FontSize="11"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               Visibility="{x:Bind HasCondition, Converter={StaticResource BoolToVis}}"/>

                                    <!-- Action Buttons -->
                                    <StackPanel Orientation="Horizontal" Spacing="6"
                                                HorizontalAlignment="Right"
                                                Margin="0,4,0,0">
                                        <Button Content="Delete"
                                                Background="Transparent"
                                                Foreground="{StaticResource LossRedBrush}"
                                                BorderBrush="{StaticResource LossRedBrush}"
                                                BorderThickness="1"
                                                CornerRadius="6" Height="28"
                                                FontSize="12"
                                                Tag="{x:Bind Id}"
                                                Click="DeleteRule_Click"/>
                                        <Button Content="{x:Bind ToggleText}"
                                                Background="Transparent"
                                                Foreground="{StaticResource SecondaryTextBrush}"
                                                BorderBrush="{StaticResource SubtleBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="6" Height="28"
                                                FontSize="12"
                                                Tag="{x:Bind Id}"
                                                Click="ToggleRule_Click"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>

                <!-- Inactive Rules Section Header -->
                <TextBlock Text="DISABLED"
                           FontSize="11" FontWeight="Bold"
                           Foreground="{StaticResource SecondaryTextBrush}"
                           Margin="0,12,0,0"
                           Visibility="{x:Bind ViewModel.HasInactiveRules, Mode=OneWay, Converter={StaticResource BoolToVis}}"/>

                <!-- Inactive Rules List -->
                <ItemsRepeater ItemsSource="{x:Bind ViewModel.InactiveRules, Mode=OneWay}"
                               Visibility="{x:Bind ViewModel.HasInactiveRules, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                    <ItemsRepeater.Layout>
                        <StackLayout Spacing="8"/>
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="vm:RuleDisplayItem">
                            <Border Background="{StaticResource CardBackgroundBrush}"
                                    CornerRadius="10"
                                    Padding="16,12"
                                    BorderThickness="1"
                                    BorderBrush="{StaticResource SubtleBorderBrush}"
                                    Opacity="0.6">
                                <StackPanel Spacing="4">
                                    <!-- Top Row: Type Badge + Name -->
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Border Background="#1e40af"
                                                CornerRadius="4" Padding="6,2"
                                                Opacity="0.5">
                                            <TextBlock Text="{x:Bind TypeBadge}"
                                                       FontSize="9" FontWeight="Bold"
                                                       Foreground="White"/>
                                        </Border>
                                        <TextBlock Text="{x:Bind Name}"
                                                   FontSize="15" FontWeight="Bold"
                                                   Foreground="{StaticResource SecondaryTextBrush}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <!-- Description -->
                                    <TextBlock Text="{x:Bind Description}"
                                               FontSize="12"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               TextWrapping="Wrap"
                                               Visibility="{x:Bind HasDescription, Converter={StaticResource BoolToVis}}"/>

                                    <!-- Condition -->
                                    <TextBlock Text="{x:Bind ConditionText}"
                                               FontSize="11"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               Visibility="{x:Bind HasCondition, Converter={StaticResource BoolToVis}}"/>

                                    <!-- Action Buttons -->
                                    <StackPanel Orientation="Horizontal" Spacing="6"
                                                HorizontalAlignment="Right"
                                                Margin="0,4,0,0">
                                        <Button Content="Delete"
                                                Background="Transparent"
                                                Foreground="{StaticResource LossRedBrush}"
                                                BorderBrush="{StaticResource LossRedBrush}"
                                                BorderThickness="1"
                                                CornerRadius="6" Height="28"
                                                FontSize="12"
                                                Tag="{x:Bind Id}"
                                                Click="DeleteRule_Click"/>
                                        <Button Content="{x:Bind ToggleText}"
                                                Background="Transparent"
                                                Foreground="{StaticResource WinGreenBrush}"
                                                BorderBrush="{StaticResource SubtleBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="6" Height="28"
                                                FontSize="12"
                                                Tag="{x:Bind Id}"
                                                Click="ToggleRule_Click"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>

                <!-- Loading indicator -->
                <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                              Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVis}}"
                              HorizontalAlignment="Center"
                              Width="40" Height="40"
                              Margin="0,20"/>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
