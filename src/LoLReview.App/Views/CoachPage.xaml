<Page
    x:Class="LoLReview.App.Views.CoachPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:converters="using:LoLReview.App.Converters"
    xmlns:controls="using:LoLReview.App.Controls"
    xmlns:vm="using:LoLReview.App.ViewModels"
    mc:Ignorable="d"
    Background="Transparent">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <converters:InverseBoolConverter x:Key="InverseBool"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis"/>

        <DataTemplate x:Key="UserMessageTemplate" x:DataType="vm:CoachChatMessageViewModel">
            <Grid Margin="0,6,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="YOU"
                           FontSize="10" FontWeight="SemiBold"
                           Foreground="{StaticResource SecondaryTextBrush}"
                           VerticalAlignment="Top"
                           Margin="0,2,0,0"/>
                <Border Grid.Column="1"
                        Background="{StaticResource InputBackgroundBrush}"
                        BorderBrush="{StaticResource SubtleBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="2"
                        Padding="10,8">
                    <TextBlock Text="{x:Bind Content, Mode=OneWay}"
                               FontSize="13"
                               Foreground="{StaticResource PrimaryTextBrush}"
                               TextWrapping="Wrap"
                               IsTextSelectionEnabled="True"/>
                </Border>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="AssistantMessageTemplate" x:DataType="vm:CoachChatMessageViewModel">
            <Grid Margin="0,6,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Spacing="2" Margin="0,2,0,0">
                    <TextBlock Text="COACH"
                               FontSize="10" FontWeight="SemiBold"
                               Foreground="{StaticResource AccentPurpleBrush}"/>
                    <TextBlock Text="{x:Bind ProviderTag, Mode=OneWay}"
                               FontSize="9"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               FontFamily="Consolas"
                               TextWrapping="Wrap"/>
                </StackPanel>
                <Border Grid.Column="1"
                        Background="{StaticResource CardBackgroundBrush}"
                        BorderBrush="{StaticResource AccentPurpleBrush}"
                        BorderThickness="1"
                        CornerRadius="2"
                        Padding="10,8">
                    <Grid>
                        <!-- Thinking indicator: shimmer bar + pulsing dots -->
                        <Grid Visibility="{x:Bind IsThinking, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                            <Grid.Resources>
                                <Storyboard x:Name="ThinkingStoryboard" RepeatBehavior="Forever">
                                    <!-- Dot 1 pulse -->
                                    <DoubleAnimation Storyboard.TargetName="ThinkDot1"
                                                     Storyboard.TargetProperty="Opacity"
                                                     From="0.25" To="1" Duration="0:0:0.6"
                                                     AutoReverse="True" BeginTime="0:0:0"/>
                                    <!-- Dot 2 pulse -->
                                    <DoubleAnimation Storyboard.TargetName="ThinkDot2"
                                                     Storyboard.TargetProperty="Opacity"
                                                     From="0.25" To="1" Duration="0:0:0.6"
                                                     AutoReverse="True" BeginTime="0:0:0.2"/>
                                    <!-- Dot 3 pulse -->
                                    <DoubleAnimation Storyboard.TargetName="ThinkDot3"
                                                     Storyboard.TargetProperty="Opacity"
                                                     From="0.25" To="1" Duration="0:0:0.6"
                                                     AutoReverse="True" BeginTime="0:0:0.4"/>
                                    <!-- Shimmer bar sweep -->
                                    <DoubleAnimation Storyboard.TargetName="ShimmerTranslate"
                                                     Storyboard.TargetProperty="X"
                                                     From="-40" To="80" Duration="0:0:1.4"/>
                                </Storyboard>
                            </Grid.Resources>
                            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center"
                                        Loaded="OnThinkingRootLoaded"
                                        Unloaded="OnThinkingRootUnloaded">
                                <TextBlock Text="Thinking"
                                           FontSize="12"
                                           FontStyle="Italic"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           VerticalAlignment="Center"/>
                                <StackPanel Orientation="Horizontal" Spacing="3" VerticalAlignment="Center">
                                    <Ellipse x:Name="ThinkDot1" Width="5" Height="5" Fill="{StaticResource AccentPurpleBrush}" Opacity="0.25"/>
                                    <Ellipse x:Name="ThinkDot2" Width="5" Height="5" Fill="{StaticResource AccentPurpleBrush}" Opacity="0.25"/>
                                    <Ellipse x:Name="ThinkDot3" Width="5" Height="5" Fill="{StaticResource AccentPurpleBrush}" Opacity="0.25"/>
                                </StackPanel>
                                <!-- Shimmer bar -->
                                <Border Width="80" Height="2"
                                        Background="{StaticResource SubtleBorderBrush}"
                                        CornerRadius="1"
                                        VerticalAlignment="Center">
                                    <Border.Clip>
                                        <RectangleGeometry Rect="0,0,80,2"/>
                                    </Border.Clip>
                                    <Rectangle Width="40" Height="2" HorizontalAlignment="Left">
                                        <Rectangle.Fill>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="Transparent" Offset="0"/>
                                                <GradientStop Color="#A78BFA" Offset="0.5"/>
                                                <GradientStop Color="Transparent" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Rectangle.Fill>
                                        <Rectangle.RenderTransform>
                                            <TranslateTransform x:Name="ShimmerTranslate" X="-40"/>
                                        </Rectangle.RenderTransform>
                                    </Rectangle>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <!-- Streamed / final content (shown once any text arrives) -->
                        <TextBlock Text="{x:Bind Content, Mode=OneWay}"
                                   Visibility="{x:Bind IsThinking, Mode=OneWay, Converter={StaticResource InverseBoolToVis}}"
                                   FontSize="13"
                                   Foreground="{StaticResource PrimaryTextBrush}"
                                   TextWrapping="Wrap"
                                   IsTextSelectionEnabled="True"/>
                    </Grid>
                </Border>
            </Grid>
        </DataTemplate>

        <vm:CoachChatMessageTemplateSelector x:Key="MessageSelector"
                                             UserTemplate="{StaticResource UserMessageTemplate}"
                                             AssistantTemplate="{StaticResource AssistantMessageTemplate}"/>
    </Page.Resources>

    <Grid x:Name="RootGrid">
        <Grid RowDefinitions="Auto,*,Auto" Padding="40,28,40,20">

            <!-- Header -->
            <StackPanel Grid.Row="0" Spacing="8" Margin="0,0,0,12">
                <controls:HeroHeader EyebrowText="ANALYSIS"
                                     Title="Coach"
                                     Subtitle="ASK ABOUT YOUR GAMES // GROUNDED IN YOUR OWN DATA"/>

                <!-- Scope chip + totals + new conversation -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Visibility="{x:Bind ViewModel.HasScope, Mode=OneWay, Converter={StaticResource BoolToVis}}"
                            Background="{StaticResource AccentBlueDimBrush}"
                            BorderBrush="{StaticResource AccentPurpleBrush}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="10,4">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="{x:Bind ViewModel.ScopeChipText, Mode=OneWay}"
                                       FontSize="11"
                                       Foreground="{StaticResource AccentPurpleBrush}"
                                       VerticalAlignment="Center"/>
                            <Button Content="×"
                                    Click="OnClearScopeClick"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="4,0"
                                    MinHeight="0" Height="16"
                                    FontSize="11"
                                    Foreground="{StaticResource AccentPurpleBrush}"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Grid.Column="1"
                               Text="{x:Bind ViewModel.CoachTotalsText, Mode=OneWay}"
                               FontSize="11"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               VerticalAlignment="Center"
                               Margin="12,0,0,0"
                               TextTrimming="CharacterEllipsis"/>

                    <Button Grid.Column="2"
                            Content="New conversation"
                            Command="{x:Bind ViewModel.NewConversationCommand}"
                            Style="{StaticResource QuietActionButtonStyle}"
                            FontSize="11" Height="28"
                            Padding="12,0" CornerRadius="2"/>
                </Grid>
            </StackPanel>

            <!-- Chat thread -->
            <Border Grid.Row="1"
                    Background="{StaticResource CardBackgroundBrush}"
                    BorderBrush="{StaticResource SubtleBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="2"
                    Padding="10">
                <ScrollViewer x:Name="ChatScroll"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{x:Bind ViewModel.Messages, Mode=OneWay}"
                                  ItemTemplateSelector="{StaticResource MessageSelector}"/>
                </ScrollViewer>
            </Border>

            <!-- Input row -->
            <Grid Grid.Row="2" Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0"
                         x:Name="InputBox"
                         Text="{x:Bind ViewModel.InputText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         PlaceholderText="Ask anything about your games — e.g. 'why am I losing lane on Jinx recently?' (Shift+Enter for newline)"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         MinHeight="44"
                         MaxHeight="120"
                         FontSize="13"
                         Background="{StaticResource InputBackgroundBrush}"
                         BorderBrush="{StaticResource SubtleBorderBrush}"
                         Foreground="{StaticResource PrimaryTextBrush}"
                         CornerRadius="2"
                         Margin="0,0,8,0"/>

                <Button Grid.Column="1"
                        Content="Ask"
                        Command="{x:Bind ViewModel.SendCommand}"
                        IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBool}}"
                        Style="{StaticResource PrimaryActionButtonStyle}"
                        FontSize="13" FontWeight="SemiBold"
                        Height="44" Padding="24,0"
                        CornerRadius="2"/>
            </Grid>

            <!-- Status line (floats over input bottom-row when busy) -->
            <TextBlock Grid.Row="2"
                       Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                       FontSize="10"
                       Foreground="{StaticResource SecondaryTextBrush}"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Top"
                       Margin="0,-4,120,0"/>
        </Grid>
    </Grid>
</Page>
