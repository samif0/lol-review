<Page
    x:Class="LoLReview.App.Views.CoachPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:svc="using:LoLReview.App.Services"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:converters="using:LoLReview.App.Converters"
    xmlns:controls="using:LoLReview.App.Controls"
    xmlns:vm="using:LoLReview.App.ViewModels"
    mc:Ignorable="d"
    Background="Transparent">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <converters:InverseBoolConverter x:Key="InverseBool"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis"/>

        <DataTemplate x:Key="UserMessageTemplate" x:DataType="vm:CoachChatMessageViewModel">
            <Grid Margin="0,6,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="YOU"
                           FontSize="{Binding Meta, Source={StaticResource FontSizes}}" FontWeight="SemiBold"
                           Foreground="{StaticResource SecondaryTextBrush}"
                           VerticalAlignment="Top"
                           Margin="0,2,0,0"/>
                <Border Grid.Column="1"
                        Background="{StaticResource InputBackgroundBrush}"
                        BorderBrush="{StaticResource SubtleBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="2"
                        Padding="10,8">
                    <TextBlock Text="{x:Bind Content, Mode=OneWay}"
                               FontSize="{Binding BodyEmphasis, Source={StaticResource FontSizes}}"
                               Foreground="{StaticResource PrimaryTextBrush}"
                               TextWrapping="Wrap"
                               IsTextSelectionEnabled="True"/>
                </Border>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="AssistantMessageTemplate" x:DataType="vm:CoachChatMessageViewModel">
            <Grid Margin="0,6,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Spacing="2" Margin="0,2,0,0">
                    <TextBlock Text="COACH"
                               FontSize="{Binding Meta, Source={StaticResource FontSizes}}" FontWeight="SemiBold"
                               Foreground="{StaticResource AccentPurpleBrush}"/>
                    <TextBlock Text="{x:Bind ProviderTag, Mode=OneWay}"
                               FontSize="{Binding Caption, Source={StaticResource FontSizes}}"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               FontFamily="Consolas"
                               TextWrapping="Wrap"/>
                </StackPanel>
                <Border Grid.Column="1"
                        Background="{StaticResource CardBackgroundBrush}"
                        BorderBrush="{StaticResource AccentPurpleBrush}"
                        BorderThickness="1"
                        CornerRadius="2"
                        Padding="10,8">
                    <Grid>
                        <!-- Thinking indicator: breathing italic text. -->
                        <Grid Visibility="{x:Bind IsThinking, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                            <Grid.Resources>
                                <Storyboard x:Name="ThinkingStoryboard" RepeatBehavior="Forever">
                                    <DoubleAnimation Storyboard.TargetName="ThinkingText"
                                                     Storyboard.TargetProperty="Opacity"
                                                     From="0.35" To="1.0" Duration="0:0:0.9"
                                                     AutoReverse="True"/>
                                </Storyboard>
                            </Grid.Resources>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                                        Loaded="OnThinkingRootLoaded"
                                        Unloaded="OnThinkingRootUnloaded">
                                <TextBlock x:Name="ThinkingText"
                                           Text="Thinking..."
                                           FontSize="{Binding BodyEmphasis, Source={StaticResource FontSizes}}"
                                           FontStyle="Italic"
                                           Foreground="{StaticResource AccentPurpleBrush}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>

                        <!-- Streamed / final content (shown once any text arrives) -->
                        <TextBlock Text="{x:Bind Content, Mode=OneWay}"
                                   Visibility="{x:Bind IsThinking, Mode=OneWay, Converter={StaticResource InverseBoolToVis}}"
                                   FontSize="{Binding BodyEmphasis, Source={StaticResource FontSizes}}"
                                   Foreground="{StaticResource PrimaryTextBrush}"
                                   TextWrapping="Wrap"
                                   IsTextSelectionEnabled="True"/>
                    </Grid>
                </Border>
            </Grid>
        </DataTemplate>

        <vm:CoachChatMessageTemplateSelector x:Key="MessageSelector"
                                             UserTemplate="{StaticResource UserMessageTemplate}"
                                             AssistantTemplate="{StaticResource AssistantMessageTemplate}"/>
    </Page.Resources>

    <Grid x:Name="RootGrid">
        <Grid RowDefinitions="Auto,*,Auto" Padding="40,28,40,20">

            <!-- Header -->
            <StackPanel Grid.Row="0" Spacing="8" Margin="0,0,0,12">
                <Grid>
                    <controls:HeroHeader EyebrowText="ANALYSIS"
                                         Title="Coach"
                                         Subtitle="ASK ABOUT YOUR GAMES // GROUNDED IN YOUR OWN DATA"/>
                    <Border Background="{StaticResource AccentPurpleBrush}"
                            CornerRadius="3"
                            Padding="6,2"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Margin="90,0,0,0">
                        <TextBlock Text="ALPHA"
                                   FontSize="{Binding Caption, Source={StaticResource FontSizes}}"
                                   FontWeight="Bold"
                                   Foreground="#07060B"/>
                    </Border>
                </Grid>

                <!-- Scope chip + totals + new conversation -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Visibility="{x:Bind ViewModel.HasScope, Mode=OneWay, Converter={StaticResource BoolToVis}}"
                            Background="{StaticResource AccentBlueDimBrush}"
                            BorderBrush="{StaticResource AccentPurpleBrush}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="10,4">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="{x:Bind ViewModel.ScopeChipText, Mode=OneWay}"
                                       FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                       Foreground="{StaticResource AccentPurpleBrush}"
                                       VerticalAlignment="Center"/>
                            <Button Content="Ã—"
                                    Click="OnClearScopeClick"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="4,0"
                                    MinHeight="0" Height="16"
                                    FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                    Foreground="{StaticResource AccentPurpleBrush}"/>
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="12,0,0,0"
                                Spacing="10">
                        <TextBlock Text="{x:Bind ViewModel.CoachTotalsText, Mode=OneWay}"
                                   FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis">
                            <ToolTipService.ToolTip>
                                <TextBlock TextWrapping="Wrap" MaxWidth="360" FontSize="{Binding Body, Source={StaticResource FontSizes}}">
                                    <Run FontWeight="SemiBold" Text="Summaries"/><Run Text=" grow as you log games â€” the coach auto-builds them after each save."/><LineBreak/>
                                    <Run FontWeight="SemiBold" Text="Signals"/><Run Text=" are per-game stats (KDA, gold/XP diffs, objectives). Grow every time you log a game."/><LineBreak/>
                                    <Run FontWeight="SemiBold" Text="Concepts"/><Run Text=" are themes pulled from your review text (mistakes, went well, focus next, matchup notes). Grow when you write reviews â€” requires the ML extras pack from Settings â†’ AI Coach."/>
                                </TextBlock>
                            </ToolTipService.ToolTip>
                        </TextBlock>
                        <TextBlock Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                                   FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                   Foreground="{StaticResource AccentPurpleBrush}"
                                   FontStyle="Italic"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="{x:Bind ViewModel.BackfillStatus, Mode=OneWay}"
                                   FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   VerticalAlignment="Center"/>
                        <Button Content="Build coach context"
                                Command="{x:Bind ViewModel.BackfillCommand}"
                                IsEnabled="{x:Bind ViewModel.IsBackfilling, Mode=OneWay, Converter={StaticResource InverseBool}}"
                                Style="{StaticResource QuietActionButtonStyle}"
                                FontSize="{Binding Meta, Source={StaticResource FontSizes}}" Height="28"
                                Padding="12,0" CornerRadius="2"
                                ToolTipService.ToolTip="Build game summaries + compute predictive features from your history. Run this once (or after a batch of new games) to give the coach richer context."/>
                        <Button Content="New conversation"
                                Command="{x:Bind ViewModel.NewConversationCommand}"
                                Style="{StaticResource QuietActionButtonStyle}"
                                FontSize="{Binding Meta, Source={StaticResource FontSizes}}" Height="28"
                                Padding="12,0" CornerRadius="2"/>
                    </StackPanel>
                </Grid>
            </StackPanel>

            <!-- Chat thread -->
            <Border Grid.Row="1"
                    Background="{StaticResource CardBackgroundBrush}"
                    BorderBrush="{StaticResource SubtleBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="2"
                    Padding="10">
                <ScrollViewer x:Name="ChatScroll"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{x:Bind ViewModel.Messages, Mode=OneWay}"
                                  ItemTemplateSelector="{StaticResource MessageSelector}"/>
                </ScrollViewer>
            </Border>

            <!-- Input row -->
            <Grid Grid.Row="2" Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0"
                         x:Name="InputBox"
                         Text="{x:Bind ViewModel.InputText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         PlaceholderText="Ask anything about your games â€” e.g. 'why am I losing lane on Jinx recently?' (Shift+Enter for newline)"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         MinHeight="44"
                         MaxHeight="120"
                         FontSize="{Binding BodyEmphasis, Source={StaticResource FontSizes}}"
                         Background="{StaticResource InputBackgroundBrush}"
                         BorderBrush="{StaticResource SubtleBorderBrush}"
                         Foreground="{StaticResource PrimaryTextBrush}"
                         CornerRadius="2"
                         Margin="0,0,8,0"/>

                <Button Grid.Column="1"
                        Content="Ask"
                        Command="{x:Bind ViewModel.SendCommand}"
                        IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBool}}"
                        Style="{StaticResource PrimaryActionButtonStyle}"
                        FontSize="{Binding BodyEmphasis, Source={StaticResource FontSizes}}" FontWeight="SemiBold"
                        Height="44" Padding="24,0"
                        CornerRadius="2"/>
            </Grid>

        </Grid>
    </Grid>
</Page>
