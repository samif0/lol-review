п»ї<Page
    x:Class="LoLReview.App.Views.SessionLoggerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:svc="using:LoLReview.App.Services"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:converters="using:LoLReview.App.Converters"
    xmlns:controls="using:LoLReview.App.Controls"
    xmlns:vm="using:LoLReview.App.ViewModels"
    mc:Ignorable="d"
    Background="Transparent"
    Loaded="Page_Loaded">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <converters:InverseBoolConverter x:Key="InverseBool"/>
        <converters:MentalRatingColorConverter x:Key="MentalColor"/>
        <converters:WinLossColorConverter x:Key="WinLossColor"/>
    </Page.Resources>

    <Grid x:Name="RootGrid" Background="Transparent">
        <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                      Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVis}}"
                      HorizontalAlignment="Center" VerticalAlignment="Center"
                      Width="48" Height="48"/>

        <Grid RowDefinitions="Auto,*">

            <!-- ГўвЂўВђГўвЂўВђГўвЂўВђ HERO ГўвЂўВђГўвЂўВђГўвЂўВђ -->
            <Grid Grid.Row="0" Margin="40,30,40,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <controls:HeroHeader Grid.Column="0"
                                     EyebrowText="SESSION INTEL"
                                     Title="Session Log"/>
                <Button Grid.Column="1"
                        Content="+ Manual Entry"
                        Click="OnManualEntryClick"
                        Style="{StaticResource GoldActionButtonStyle}"
                        Height="34" Padding="14,0" FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                        VerticalAlignment="Top" Margin="0,16,0,0"
                        IsTabStop="False"/>
            </Grid>

            <!-- ГўвЂўВђГўвЂўВђГўвЂўВђ CONTENT ГўвЂўВђГўвЂўВђГўвЂўВђ -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="40,0,40,40">
                <StackPanel Spacing="14" HorizontalAlignment="Stretch">

                    <!-- Date Navigation -->
                    <Border Background="{StaticResource CardBackgroundBrush}"
                            BorderBrush="{StaticResource SubtleBorderBrush}"
                            BorderThickness="1" CornerRadius="0" Padding="14">
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center" Spacing="12">
                            <Button Content="&#x25C0;  Prev"
                                    Command="{x:Bind ViewModel.PreviousDayCommand}"
                                    Style="{StaticResource SecondaryActionButtonStyle}"
                                    Height="32" Padding="12,0" FontSize="{Binding Meta, Source={StaticResource FontSizes}}"/>
                            <TextBlock Text="{x:Bind ViewModel.DateDisplay, Mode=OneWay}"
                                       FontFamily="{StaticResource HeadingFont}"
                                       FontSize="{Binding Title, Source={StaticResource FontSizes}}" FontWeight="SemiBold"
                                       Foreground="{StaticResource PrimaryTextBrush}"
                                       VerticalAlignment="Center" Margin="8,0"/>
                            <Button Content="Next  &#x25B6;"
                                    Command="{x:Bind ViewModel.NextDayCommand}"
                                    IsEnabled="{x:Bind ViewModel.CanNavigateForward, Mode=OneWay}"
                                    Style="{StaticResource SecondaryActionButtonStyle}"
                                    Height="32" Padding="12,0" FontSize="{Binding Meta, Source={StaticResource FontSizes}}"/>
                            <Button Content="Today"
                                    Command="{x:Bind ViewModel.GoTodayCommand}"
                                    Style="{StaticResource PrimaryActionButtonStyle}"
                                    Height="32" Padding="14,0" FontSize="{Binding Meta, Source={StaticResource FontSizes}}"/>
                        </StackPanel>
                    </Border>

                    <!-- ГўвЂўВђГўвЂўВђГўвЂўВђ STAT STRIP ГўвЂўВђГўвЂўВђГўвЂўВђ -->
                    <controls:StatStrip>
                        <controls:StatCell Label="Games"
                                           Value="{x:Bind ViewModel.TotalGames, Mode=OneWay}"/>
                        <controls:StatCell Label="Wins"
                                           Value="{x:Bind ViewModel.Wins, Mode=OneWay}"
                                           ValueBrush="{StaticResource WinGreenBrush}"/>
                        <controls:StatCell Label="Losses"
                                           Value="{x:Bind ViewModel.Losses, Mode=OneWay}"
                                           ValueBrush="{StaticResource LossRedBrush}"/>
                        <controls:StatCell Label="Avg Mental"
                                           Value="{x:Bind ViewModel.AvgMental, Mode=OneWay}"/>
                        <controls:StatCell Label="Rule Breaks"
                                           Value="{x:Bind ViewModel.RuleBreaks, Mode=OneWay}"/>
                        <controls:StatCell Label="Adherence"
                                           Value="{x:Bind ViewModel.AdherenceStreak, Mode=OneWay}"
                                           ValueBrush="{StaticResource AccentGoldBrush}"/>
                    </controls:StatStrip>

                    <!-- Session Goal (set) -->
                    <controls:CornerBracketedCard
                        CardBorderBrush="{StaticResource AccentGoldBrush}"
                        Visibility="{x:Bind ViewModel.HasIntention, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                        <StackPanel Spacing="6">
                            <controls:SectionTitle Text="SESSION GOAL"/>
                            <TextBlock Text="{x:Bind ViewModel.SessionIntention, Mode=OneWay}"
                                       FontFamily="{StaticResource BodyFont}"
                                       FontSize="{Binding BodyEmphasis, Source={StaticResource FontSizes}}"
                                       Foreground="{StaticResource PrimaryTextBrush}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </controls:CornerBracketedCard>

                    <!-- Session Goal (input) -->
                    <controls:CornerBracketedCard
                        Visibility="{x:Bind ViewModel.HasIntention, Mode=OneWay, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}">
                        <StackPanel Spacing="10">
                            <controls:SectionTitle Text="SET SESSION GOAL"/>
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         Text="{x:Bind ViewModel.SessionIntention, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         PlaceholderText="What will you focus on this session?"
                                         Background="{StaticResource InputBackgroundBrush}"
                                         Foreground="{StaticResource PrimaryTextBrush}"
                                         BorderBrush="{StaticResource SubtleBorderBrush}"
                                         CornerRadius="2" FontSize="{Binding Body, Source={StaticResource FontSizes}}" Padding="12,8"/>
                                <Button Grid.Column="1"
                                        Content="Save"
                                        Command="{x:Bind ViewModel.SaveIntentionCommand}"
                                        Style="{StaticResource GoldActionButtonStyle}"
                                        Height="34" Padding="14,0" FontSize="{Binding Meta, Source={StaticResource FontSizes}}"/>
                            </Grid>
                        </StackPanel>
                    </controls:CornerBracketedCard>

                    <!-- ГўвЂўВђГўвЂўВђГўвЂўВђ NEEDS REVIEW ГўвЂўВђГўвЂўВђГўвЂўВђ -->
                    <controls:CornerBracketedCard>
                        <StackPanel Spacing="12">
                            <Grid ColumnDefinitions="*,Auto">
                                <controls:SectionTitle Text="NEEDS REVIEW"/>
                                <TextBlock Grid.Column="1"
                                           Text="{x:Bind ViewModel.NeedsReviewCountText, Mode=OneWay}"
                                           FontFamily="{StaticResource MonoFont}"
                                           FontSize="{Binding Meta, Source={StaticResource FontSizes}}" FontWeight="SemiBold"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           VerticalAlignment="Center"/>
                            </Grid>

                            <TextBlock Text="Everything for this day is already reviewed."
                                       FontFamily="{StaticResource MonoFont}"
                                       FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                       Foreground="{StaticResource WinGreenBrush}"
                                       Visibility="{x:Bind ViewModel.HasNeedsReviewGames, Mode=OneWay, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}"/>

                            <ItemsRepeater ItemsSource="{x:Bind ViewModel.NeedsReviewGames, Mode=OneWay}"
                                           Visibility="{x:Bind ViewModel.HasNeedsReviewGames, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                                <ItemsRepeater.Layout>
                                    <StackLayout Spacing="6"/>
                                </ItemsRepeater.Layout>
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate x:DataType="vm:SessionGameEntry">
                                        <Button Style="{StaticResource SecondaryActionButtonStyle}"
                                                Background="{StaticResource CardBackgroundBrush}"
                                                HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Stretch"
                                                Height="Auto" Padding="0"
                                                Tag="{x:Bind GameId}"
                                                Click="ReviewButton_Click">
                                            <Grid ColumnDefinitions="3,*,Auto" ColumnSpacing="12">
                                                <Rectangle Fill="{x:Bind Win, Converter={StaticResource WinLossColor}}"
                                                           Width="3" HorizontalAlignment="Stretch"
                                                           VerticalAlignment="Stretch"/>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center"
                                                            Spacing="3" Padding="0,10">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <TextBlock FontFamily="{StaticResource HeadingFont}"
                                                                   FontSize="{Binding Subtitle, Source={StaticResource FontSizes}}" FontWeight="SemiBold"
                                                                   Foreground="{StaticResource PrimaryTextBrush}">
                                                            <Run Text="{x:Bind ChampionName}"/>
                                                        </TextBlock>
                                                        <TextBlock FontFamily="{StaticResource MonoFont}"
                                                                   FontSize="{Binding Meta, Source={StaticResource FontSizes}}" VerticalAlignment="Center"
                                                                   Foreground="{StaticResource MutedTextBrush}">
                                                            <Run Text="{x:Bind ResultText}"/>
                                                        </TextBlock>
                                                        <Border Background="{StaticResource LossRedBrush}"
                                                                CornerRadius="2" Padding="6,2"
                                                                Visibility="{x:Bind RuleBroken, Converter={StaticResource BoolToVis}}">
                                                            <TextBlock Text="RULE BREAK"
                                                                       FontFamily="{StaticResource MonoFont}"
                                                                       FontSize="{Binding Micro, Source={StaticResource FontSizes}}" FontWeight="Bold"
                                                                       Foreground="White"/>
                                                        </Border>
                                                    </StackPanel>
                                                    <TextBlock Text="{x:Bind ImprovementNote}"
                                                               FontFamily="{StaticResource MonoFont}"
                                                               FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                                               Foreground="{StaticResource MutedTextBrush}"
                                                               TextTrimming="CharacterEllipsis" MaxLines="1"
                                                               Visibility="{x:Bind HasImprovementNote, Converter={StaticResource BoolToVis}}"/>
                                                </StackPanel>

                                                <TextBlock Grid.Column="2"
                                                           Text="{x:Bind MentalText}"
                                                           FontFamily="{StaticResource DisplayFont}"
                                                           FontSize="{Binding Title, Source={StaticResource FontSizes}}" FontWeight="Bold"
                                                           Foreground="{x:Bind MentalRating, Converter={StaticResource MentalColor}}"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,14,0"/>
                                            </Grid>
                                        </Button>
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>
                        </StackPanel>
                    </controls:CornerBracketedCard>

                    <!-- ГўвЂўВђГўвЂўВђГўвЂўВђ REVIEWED ГўвЂўВђГўвЂўВђГўвЂўВђ -->
                    <controls:CornerBracketedCard>
                        <StackPanel Spacing="12">
                            <Grid ColumnDefinitions="*,Auto">
                                <controls:SectionTitle Text="REVIEWED"/>
                                <TextBlock Grid.Column="1"
                                           Text="{x:Bind ViewModel.ReviewedCountText, Mode=OneWay}"
                                           FontFamily="{StaticResource MonoFont}"
                                           FontSize="{Binding Meta, Source={StaticResource FontSizes}}" FontWeight="SemiBold"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           VerticalAlignment="Center"/>
                            </Grid>

                            <TextBlock Text="No reviewed games yet for this day."
                                       FontFamily="{StaticResource MonoFont}"
                                       FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       Visibility="{x:Bind ViewModel.HasReviewedGames, Mode=OneWay, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}"/>

                            <ItemsRepeater ItemsSource="{x:Bind ViewModel.ReviewedGames, Mode=OneWay}"
                                           Visibility="{x:Bind ViewModel.HasReviewedGames, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                                <ItemsRepeater.Layout>
                                    <StackLayout Spacing="6"/>
                                </ItemsRepeater.Layout>
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate x:DataType="vm:SessionGameEntry">
                                        <Button Style="{StaticResource SecondaryActionButtonStyle}"
                                                Background="{StaticResource CardBackgroundBrush}"
                                                HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Stretch"
                                                Height="Auto" Padding="0" Opacity="0.5"
                                                Tag="{x:Bind GameId}"
                                                Click="ReviewButton_Click">
                                            <Grid ColumnDefinitions="3,*,Auto" ColumnSpacing="12">
                                                <Rectangle Fill="{x:Bind Win, Converter={StaticResource WinLossColor}}"
                                                           Width="3" HorizontalAlignment="Stretch"
                                                           VerticalAlignment="Stretch" Opacity="0.5"/>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center"
                                                            Spacing="3" Padding="0,10">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <TextBlock FontFamily="{StaticResource HeadingFont}"
                                                                   FontSize="{Binding Subtitle, Source={StaticResource FontSizes}}" FontWeight="SemiBold"
                                                                   Foreground="{StaticResource PrimaryTextBrush}">
                                                            <Run Text="{x:Bind ChampionName}"/>
                                                        </TextBlock>
                                                        <TextBlock FontFamily="{StaticResource MonoFont}"
                                                                   FontSize="{Binding Meta, Source={StaticResource FontSizes}}" VerticalAlignment="Center"
                                                                   Foreground="{StaticResource MutedTextBrush}">
                                                            <Run Text="{x:Bind ResultText}"/>
                                                        </TextBlock>
                                                    </StackPanel>
                                                    <TextBlock Text="{x:Bind ImprovementNote}"
                                                               FontFamily="{StaticResource MonoFont}"
                                                               FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                                               Foreground="{StaticResource MutedTextBrush}"
                                                               TextTrimming="CharacterEllipsis" MaxLines="1"
                                                               Visibility="{x:Bind HasImprovementNote, Converter={StaticResource BoolToVis}}"/>
                                                </StackPanel>

                                                <TextBlock Grid.Column="2"
                                                           Text="{x:Bind MentalText}"
                                                           FontFamily="{StaticResource DisplayFont}"
                                                           FontSize="{Binding Title, Source={StaticResource FontSizes}}" FontWeight="Bold"
                                                           Foreground="{x:Bind MentalRating, Converter={StaticResource MentalColor}}"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,14,0"/>
                                            </Grid>
                                        </Button>
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>
                        </StackPanel>
                    </controls:CornerBracketedCard>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
