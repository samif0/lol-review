<Page
    x:Class="LoLReview.App.Views.HistoryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:svc="using:LoLReview.App.Services"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:LoLReview.App.ViewModels"
    xmlns:controls="using:LoLReview.App.Controls"
    xmlns:converters="using:LoLReview.App.Converters"
    mc:Ignorable="d"
    Background="Transparent">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <converters:WinLossColorConverter x:Key="WinLossColor"/>
        <converters:KdaColorConverter x:Key="KdaColor"/>
    </Page.Resources>

    <Grid x:Name="RootGrid" Padding="40,30,40,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- â•â•â• Hero â•â•â• -->
        <controls:HeroHeader Grid.Row="0"
                             EyebrowText="MATCH DATABASE"
                             Title="Match History"
                             Subtitle="RECORDED MATCHES // VOD ACCESS"
                             Margin="0,0,0,16"/>

        <!-- Loading overlay -->
        <ProgressRing Grid.Row="1"
                      IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                      HorizontalAlignment="Center" VerticalAlignment="Center"
                      Width="48" Height="48"
                      Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVis}}"/>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

                    <!-- Filter bar -->
                    <Border Grid.Row="0" Margin="0,0,0,12">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <ComboBox ItemsSource="{x:Bind ViewModel.ChampionFilters, Mode=OneWay}"
                                      SelectedItem="{x:Bind ViewModel.SelectedChampionFilter, Mode=TwoWay}"
                                      Width="200"
                                      Background="{StaticResource InputBackgroundBrush}"
                                      BorderBrush="{StaticResource SubtleBorderBrush}"
                                      PlaceholderText="All Champions"
                                      SelectionChanged="OnChampionFilterChanged"/>

                            <ComboBox x:Name="WinLossFilterCombo"
                                      Width="120"
                                      Background="{StaticResource InputBackgroundBrush}"
                                      BorderBrush="{StaticResource SubtleBorderBrush}"
                                      SelectedIndex="{x:Bind ViewModel.SelectedWinLossFilter, Mode=TwoWay}"
                                      SelectionChanged="OnWinLossFilterChanged">
                                <ComboBoxItem Content="All"/>
                                <ComboBoxItem Content="Wins Only"/>
                                <ComboBoxItem Content="Losses Only"/>
                            </ComboBox>
                        </StackPanel>
                    </Border>

                    <!-- Games list -->
                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Spacing="4">
                            <!-- No games message -->
                            <TextBlock Visibility="{x:Bind ViewModel.HasNoGames, Mode=OneWay, Converter={StaticResource BoolToVis}}"
                                       Text="No games recorded yet."
                                       FontSize="{Binding Subtitle, Source={StaticResource FontSizes}}"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       HorizontalAlignment="Center"
                                       Margin="0,40,0,0"/>

                            <!-- Game rows -->
                            <ItemsRepeater ItemsSource="{x:Bind ViewModel.Games, Mode=OneWay}">
                                <ItemsRepeater.Layout>
                                    <StackLayout Spacing="6"/>
                                </ItemsRepeater.Layout>
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate x:DataType="vm:GameDisplayItem">
                                        <controls:GameRowCard Champion="{x:Bind ChampionName}"
                                                              Win="{x:Bind Win}"
                                                              Meta="{x:Bind MetaLine}"
                                                              Kda="{x:Bind KdaText}"
                                                              Stats="{x:Bind StatsLine}">
                                            <controls:GameRowCard.Actions>
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <Button Content="Watch VOD"
                                                            Style="{StaticResource GoldListActionButtonStyle}"
                                                            Tag="{x:Bind GameId}"
                                                            Visibility="{x:Bind HasVod, Converter={StaticResource BoolToVis}}"
                                                            Click="WatchVodButton_Click"/>
                                                    <Button Content="Review"
                                                            Style="{StaticResource ListActionButtonStyle}"
                                                            Tag="{x:Bind GameId}"
                                                            Click="ReviewButton_Click"/>
                                                    <Button Style="{StaticResource GhostIconButtonStyle}"
                                                            Tag="{x:Bind GameId}"
                                                            ToolTipService.ToolTip="Hide this game"
                                                            Click="HideGameButton_Click">
                                                        <FontIcon Glyph="&#xE74D;"
                                                                  FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                                                  FontSize="{Binding BodyEmphasis, Source={StaticResource FontSizes}}"/>
                                                    </Button>
                                                </StackPanel>
                                            </controls:GameRowCard.Actions>
                                        </controls:GameRowCard>
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>

                            <!-- Load More button -->
                            <Button Content="Load More"
                                    Style="{StaticResource PrimaryActionButtonStyle}"
                                    Visibility="{x:Bind ViewModel.HasMorePages, Mode=OneWay, Converter={StaticResource BoolToVis}}"
                                    Command="{x:Bind ViewModel.LoadMoreCommand}"
                                    HorizontalAlignment="Center"
                                    Margin="0,12,0,24"
                                    Height="32" Width="160"
                                    FontSize="{Binding BodyEmphasis, Source={StaticResource FontSizes}}"/>
                        </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
