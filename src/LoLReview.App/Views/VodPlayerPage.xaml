<Page
    x:Name="RootPage"
    x:Class="LoLReview.App.Views.VodPlayerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:LoLReview.App.Controls"
    xmlns:converters="using:LoLReview.App.Converters"
    xmlns:vm="using:LoLReview.App.ViewModels"
    Background="Transparent"
    IsTabStop="True"
    NavigationCacheMode="Disabled">
    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility" />

        <Style x:Key="VodPanelCardStyle" TargetType="Border" BasedOn="{StaticResource ElevatedCardStyle}">
            <Setter Property="Padding" Value="18" />
            <Setter Property="Background" Value="{StaticResource QueuePanelBrush}" />
        </Style>

        <Style x:Key="VodSectionCardStyle" TargetType="Border" BasedOn="{StaticResource CardStyle}">
            <Setter Property="Padding" Value="16" />
            <Setter Property="CornerRadius" Value="2" />
            <Setter Property="Background" Value="{StaticResource SurfaceRaisedBrush}" />
        </Style>

        <Style x:Key="VodTransportButtonStyle" TargetType="Button" BasedOn="{StaticResource GhostIconButtonStyle}">
            <Setter Property="Width" Value="48" />
            <Setter Property="Height" Value="44" />
            <Setter Property="CornerRadius" Value="2" />
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="AllowFocusOnInteraction" Value="False" />
        </Style>

        <Style x:Key="VodBookmarkActionButtonStyle" TargetType="Button" BasedOn="{StaticResource VodTransportButtonStyle}">
            <Setter Property="Width" Value="68" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="FontSize" Value="11" />
        </Style>

        <Style x:Key="VodPlayPauseButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryActionButtonStyle}">
            <Setter Property="Width" Value="64" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="CornerRadius" Value="2" />
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="AllowFocusOnInteraction" Value="False" />
        </Style>

        <Style x:Key="VodOverlayPlayPauseButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="64" />
            <Setter Property="Height" Value="52" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="CornerRadius" Value="2" />
            <Setter Property="Background" Value="#CC000000" />
            <Setter Property="BorderBrush" Value="{StaticResource BrightBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="AllowFocusOnInteraction" Value="False" />
        </Style>

        <Style x:Key="VodSignalButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryActionButtonStyle}">
            <Setter Property="Background" Value="{StaticResource AccentGoldDimBrush}" />
            <Setter Property="Foreground" Value="{StaticResource AccentGoldBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentGoldBrush}" />
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="AllowFocusOnInteraction" Value="False" />
        </Style>

        <Style x:Key="VodQuietActionButtonStyle" TargetType="Button" BasedOn="{StaticResource QuietActionButtonStyle}">
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="AllowFocusOnInteraction" Value="False" />
        </Style>

        <Style x:Key="VodSecondaryActionButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryActionButtonStyle}">
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="AllowFocusOnInteraction" Value="False" />
        </Style>

        <Style x:Key="VodQualityButtonStyle" TargetType="Button" BasedOn="{StaticResource VodSecondaryActionButtonStyle}">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        </Style>

        <Style x:Key="VodQualityChipBorderStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="2" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="MinWidth" Value="0" />
        </Style>

        <Style x:Key="VodPrimaryActionButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryActionButtonStyle}">
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="AllowFocusOnInteraction" Value="False" />
        </Style>

        <Style x:Key="VodInputTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource InputBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource SubtleBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="CornerRadius" Value="2" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="VodComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource InputBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource SubtleBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="CornerRadius" Value="2" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="VodMiniChipStyle" TargetType="Border" BasedOn="{StaticResource TagChipStyle}">
            <Setter Property="Background" Value="{StaticResource SurfaceInsetBrush}" />
            <Setter Property="CornerRadius" Value="2" />
            <Setter Property="Padding" Value="8,4" />
        </Style>

        <Style x:Key="VodStepChipStyle" TargetType="Border" BasedOn="{StaticResource VodMiniChipStyle}">
            <Setter Property="Background" Value="{StaticResource CardAltBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BrightBorderBrush}" />
            <Setter Property="Padding" Value="10,7" />
        </Style>

        <Style x:Key="VodShortcutButtonStyle" TargetType="Button" BasedOn="{StaticResource VodSecondaryActionButtonStyle}">
            <Setter Property="MinHeight" Value="48" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        </Style>

        <Style x:Key="VodShortcutPrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource VodSignalButtonStyle}">
            <Setter Property="MinHeight" Value="48" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        </Style>

        <Style x:Key="VodKeyCapStyle" TargetType="Border" BasedOn="{StaticResource VodMiniChipStyle}">
            <Setter Property="Background" Value="{StaticResource SurfaceHighlightBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BrightBorderBrush}" />
            <Setter Property="Padding" Value="7,2" />
            <Setter Property="CornerRadius" Value="2" />
        </Style>
    </Page.Resources>

    <Grid Background="Transparent">
        <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                      Width="48"
                      Height="48"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />

        <Grid Padding="28,24,28,28"
              RowDefinitions="Auto,*">
            <Border Grid.Row="0"
                    Background="#52000000"
                    BorderBrush="{StaticResource SubtleBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="2"
                    Padding="12,6">
                <Grid ColumnDefinitions="Auto,*,Auto"
                      ColumnSpacing="12">
                    <StackPanel Orientation="Horizontal"
                                Spacing="8"
                                VerticalAlignment="Center">
                        <Button Command="{x:Bind ViewModel.GoBackCommand}"
                                Style="{StaticResource VodQuietActionButtonStyle}"
                                Height="32"
                                Padding="12,0">
                            <StackPanel Orientation="Horizontal"
                                        Spacing="8">
                                <FontIcon Glyph="&#xE72B;"
                                          FontSize="12" />
                                <TextBlock Text="Back" />
                            </StackPanel>
                        </Button>

                        <Border Background="#40000000"
                                BorderBrush="{StaticResource SubtleBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="2"
                                Padding="8,4">
                            <StackPanel Orientation="Horizontal"
                                        Spacing="6">
                                <FontIcon Glyph="&#xE91C;"
                                          FontSize="12"
                                          Foreground="{StaticResource AccentGoldBrush}" />
                                <TextBlock FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource PrimaryTextBrush}">
                                    <Run Text="{x:Bind ViewModel.VodStatusLabel, Mode=OneWay}" />
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                MaxWidth="900"
                                VerticalAlignment="Center">
                        <TextBlock Text="{x:Bind ViewModel.HeaderText, Mode=OneWay}"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis"
                                   Foreground="{StaticResource PrimaryTextBrush}" />
                    </StackPanel>

                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                Spacing="8"
                                VerticalAlignment="Center">
                        <Border Style="{StaticResource VodMiniChipStyle}"
                                Background="#40000000">
                            <TextBlock FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentGoldBrush}">
                                <Run Text="{x:Bind ViewModel.OutcomeLabel, Mode=OneWay}" />
                            </TextBlock>
                        </Border>

                        <Border Style="{StaticResource VodMiniChipStyle}"
                                Background="#40000000">
                            <TextBlock FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource PrimaryTextBrush}">
                                <Run Text="{x:Bind ViewModel.GameEvents.Count, Mode=OneWay}" />
                                <Run Text=" markers" />
                            </TextBlock>
                        </Border>

                        <Border Style="{StaticResource VodMiniChipStyle}"
                                Background="#40000000">
                            <TextBlock FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource PrimaryTextBrush}">
                                <Run Text="{x:Bind ViewModel.Bookmarks.Count, Mode=OneWay}" />
                                <Run Text=" notes" />
                            </TextBlock>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1"
                  Margin="0,18,0,0"
                  ColumnDefinitions="*,392"
                  ColumnSpacing="18">
                <Grid Grid.Column="0"
                      RowDefinitions="Auto,Auto,Auto,Auto"
                      RowSpacing="16">
                    <Border Grid.Row="0"
                            Style="{StaticResource VodPanelCardStyle}">
                        <Grid RowDefinitions="Auto,Auto,Auto"
                              RowSpacing="14">
                            <Grid Grid.Row="0"
                                  ColumnDefinitions="*,Auto"
                                  ColumnSpacing="12">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="PLAYER"
                                               Style="{StaticResource PanelEyebrowStyle}" />
                                    <TextBlock Text="Review the recording and jump fast."
                                               FontSize="12"
                                               Foreground="{StaticResource SecondaryTextBrush}"
                                               TextWrapping="Wrap" />
                                </StackPanel>

                                <StackPanel Grid.Column="1"
                                            Orientation="Horizontal"
                                            Spacing="8"
                                            VerticalAlignment="Center">
                                    <Border Style="{StaticResource VodMiniChipStyle}">
                                        <StackPanel Orientation="Horizontal"
                                                    Spacing="8">
                                            <FontIcon Glyph="&#xE768;"
                                                      FontSize="12"
                                                      Foreground="{StaticResource AccentBlueBrush}" />
                                            <TextBlock Text="{x:Bind ViewModel.PlaybackStateLabel, Mode=OneWay}"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource PrimaryTextBrush}" />
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{StaticResource VodMiniChipStyle}">
                                        <StackPanel Orientation="Horizontal"
                                                    Spacing="8">
                                            <FontIcon Glyph="&#xE823;"
                                                      FontSize="12"
                                                      Foreground="{StaticResource AccentGoldBrush}" />
                                            <TextBlock FontFamily="{StaticResource MonoFont}"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource PrimaryTextBrush}">
                                                <Run Text="{x:Bind ViewModel.CurrentTimeText, Mode=OneWay}" />
                                                <Run Text=" / " />
                                                <Run Text="{x:Bind ViewModel.TotalTimeText, Mode=OneWay}" />
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Grid>

                            <Border Grid.Row="1"
                                    Background="{StaticResource SurfaceInsetBrush}"
                                    BorderBrush="{StaticResource BrightBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="2"
                                    Padding="10">
                                <Grid x:Name="VideoContainer"
                                      AllowFocusOnInteraction="True"
                                      Background="#020405"
                                      IsTabStop="True"
                                      MinHeight="420"
                                      Tapped="OnVideoTapped">
                                    <Grid x:Name="LoadingOverlay"
                                          Background="{StaticResource PanelOverlayBrush}"
                                          Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                                        <Border HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Style="{StaticResource InsetCardStyle}"
                                                Background="{StaticResource SurfaceRaisedBrush}"
                                                Padding="18">
                                            <StackPanel Spacing="10"
                                                        HorizontalAlignment="Center">
                                                <ProgressRing IsActive="True"
                                                              Width="40"
                                                              Height="40" />
                                                <TextBlock Text="Loading recording"
                                                           FontSize="12"
                                                           HorizontalAlignment="Center"
                                                           Foreground="{StaticResource SecondaryTextBrush}" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                    <Border x:Name="NoVodBorder"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Style="{StaticResource InsetCardStyle}"
                                            Background="{StaticResource SurfaceRaisedBrush}"
                                            Visibility="Collapsed">
                                        <TextBlock x:Name="NoVodText"
                                                   Text="No VOD linked to this game"
                                                   FontSize="16"
                                                   TextWrapping="Wrap"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Foreground="{StaticResource SecondaryTextBrush}" />
                                    </Border>

                                    <Button x:Name="VideoPlayPauseButton"
                                            Click="OnVideoPlayPauseClick"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Bottom"
                                            Margin="0,0,0,24"
                                            Style="{StaticResource VodOverlayPlayPauseButtonStyle}"
                                            ToolTipService.ToolTip="Play or pause"
                                            Visibility="{x:Bind ViewModel.HasVod, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                                        <FontIcon x:Name="VideoPlayPauseIcon"
                                                  Glyph="&#xE768;"
                                                  FontSize="22" />
                                    </Button>
                                </Grid>
                            </Border>

                            <Border Grid.Row="2"
                                    Style="{StaticResource VodSectionCardStyle}"
                                    Background="{StaticResource SurfaceInsetBrush}">
                                <Grid RowDefinitions="Auto,Auto"
                                      RowSpacing="10">
                                    <Grid Grid.Row="0"
                                          ColumnDefinitions="*,Auto"
                                          ColumnSpacing="12">
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="EVENT TIMELINE"
                                                       Style="{StaticResource PanelEyebrowStyle}" />
                                            <TextBlock Text="{x:Bind ViewModel.GameEventsStatusText, Mode=OneWay}"
                                                       FontSize="12"
                                                       TextWrapping="Wrap"
                                                       Foreground="{StaticResource SecondaryTextBrush}" />
                                        </StackPanel>

                                        <Border Grid.Column="1"
                                                Style="{StaticResource VodMiniChipStyle}"
                                                VerticalAlignment="Top">
                                            <TextBlock FontSize="11"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource PrimaryTextBrush}">
                                                <Run Text="{x:Bind ViewModel.GameEvents.Count, Mode=OneWay}" />
                                                <Run Text=" markers" />
                                            </TextBlock>
                                        </Border>
                                    </Grid>

                                    <controls:TimelineControl Grid.Row="1"
                                                              x:Name="Timeline"
                                                              Height="104"
                                                              Bookmarks="{x:Bind ViewModel.Bookmarks, Mode=OneWay}"
                                                              ClipEnd="{x:Bind ViewModel.ClipEndS, Mode=OneWay}"
                                                              ClipStart="{x:Bind ViewModel.ClipStartS, Mode=OneWay}"
                                                              DerivedEvents="{x:Bind ViewModel.DerivedEvents, Mode=OneWay}"
                                                              Duration="{x:Bind ViewModel.GameDurationS, Mode=OneWay}"
                                                              Events="{x:Bind ViewModel.GameEvents, Mode=OneWay}"
                                                              Position="{x:Bind ViewModel.CurrentTimeS, Mode=OneWay}" />
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1"
                            Style="{StaticResource VodSectionCardStyle}"
                            Background="{StaticResource SurfaceInsetBrush}">
                        <Grid ColumnDefinitions="Auto,Auto,Auto,*,Auto,Auto,Auto"
                              ColumnSpacing="10">
                            <Button Grid.Column="0"
                                    Command="{x:Bind ViewModel.SeekBackwardCommand}"
                                    Click="OnClipButtonClick"
                                    Style="{StaticResource VodTransportButtonStyle}"
                                    ToolTipService.ToolTip="Seek backward">
                                <FontIcon Glyph="&#xEB9E;"
                                          FontSize="18" />
                            </Button>

                            <Button Grid.Column="1"
                                    Command="{x:Bind ViewModel.PlayPauseCommand}"
                                    Click="OnClipButtonClick"
                                    Style="{StaticResource VodPlayPauseButtonStyle}"
                                    ToolTipService.ToolTip="Play or pause">
                                <FontIcon x:Name="PlayPauseIcon"
                                          Glyph="&#xE768;"
                                          FontSize="22" />
                            </Button>

                            <Button Grid.Column="2"
                                    Command="{x:Bind ViewModel.SeekForwardCommand}"
                                    Click="OnClipButtonClick"
                                    Style="{StaticResource VodTransportButtonStyle}"
                                    ToolTipService.ToolTip="Seek forward">
                                <FontIcon Glyph="&#xEB9D;"
                                          FontSize="18" />
                            </Button>

                            <StackPanel Grid.Column="3"
                                        Orientation="Horizontal"
                                        Spacing="10"
                                        VerticalAlignment="Center">
                                <Border Style="{StaticResource VodMiniChipStyle}">
                                    <TextBlock FontFamily="{StaticResource MonoFont}"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource PrimaryTextBrush}">
                                        <Run Text="{x:Bind ViewModel.CurrentTimeText, Mode=OneWay}" />
                                        <Run Text=" / " />
                                        <Run Text="{x:Bind ViewModel.TotalTimeText, Mode=OneWay}" />
                                    </TextBlock>
                                </Border>

                                <Border Style="{StaticResource VodMiniChipStyle}">
                                    <StackPanel Orientation="Horizontal"
                                                Spacing="6">
                                        <TextBlock Text="Seek"
                                                   FontSize="11"
                                                   Foreground="{StaticResource SecondaryTextBrush}" />
                                        <TextBlock Text="{x:Bind ViewModel.SeekStepText, Mode=OneWay}"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource AccentGoldBrush}" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <StackPanel Grid.Column="4"
                                        Orientation="Horizontal"
                                        Spacing="8"
                                        VerticalAlignment="Center">
                                <TextBlock Text="Speed"
                                           FontSize="12"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource SecondaryTextBrush}" />
                                <ComboBox x:Name="SpeedCombo"
                                          Width="88"
                                          SelectedIndex="2"
                                          SelectionChanged="OnSpeedChanged"
                                          Style="{StaticResource VodComboBoxStyle}">
                                    <ComboBoxItem Content="0.25x" Tag="0.25" />
                                    <ComboBoxItem Content="0.5x" Tag="0.5" />
                                    <ComboBoxItem Content="1.0x" Tag="1.0" />
                                    <ComboBoxItem Content="1.5x" Tag="1.5" />
                                    <ComboBoxItem Content="2.0x" Tag="2.0" />
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Grid.Column="5"
                                        Orientation="Horizontal"
                                        Spacing="8"
                                        VerticalAlignment="Center">
                                <Button x:Name="MuteButton"
                                        Click="OnMuteClick"
                                        Style="{StaticResource VodTransportButtonStyle}"
                                        ToolTipService.ToolTip="Mute or unmute">
                                    <FontIcon x:Name="VolumeIcon"
                                              Glyph="&#xE767;"
                                              FontSize="16" />
                                </Button>

                                <Slider x:Name="VolumeSlider"
                                        Width="96"
                                        Maximum="100"
                                        Minimum="0"
                                        Value="100"
                                        Foreground="{StaticResource AccentBlueBrush}"
                                        ValueChanged="OnVolumeChanged" />
                            </StackPanel>

                            <Button Grid.Column="6"
                                    x:Name="FullscreenButton"
                                    Click="OnFullscreenClick"
                                    Style="{StaticResource VodTransportButtonStyle}"
                                    ToolTipService.ToolTip="Toggle fullscreen (F)">
                                <FontIcon x:Name="FullscreenIcon"
                                          Glyph="&#xE740;"
                                          FontSize="16" />
                            </Button>
                        </Grid>
                    </Border>
                    <Border Grid.Row="2"
                            Style="{StaticResource VodSectionCardStyle}"
                            Background="{StaticResource SurfaceInsetBrush}">
                        <Grid RowDefinitions="Auto,Auto"
                              RowSpacing="12">
                            <Grid Grid.Row="0"
                                  ColumnDefinitions="*,Auto"
                                  ColumnSpacing="12">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="ACTIONS"
                                               Style="{StaticResource PanelEyebrowStyle}" />
                                    <TextBlock Text="Everything here is clickable."
                                               FontSize="12"
                                               TextWrapping="Wrap"
                                               Foreground="{StaticResource SecondaryTextBrush}" />
                                </StackPanel>

                                <Border Grid.Column="1"
                                        Style="{StaticResource VodMiniChipStyle}"
                                        VerticalAlignment="Top">
                                    <TextBlock Text="{x:Bind ViewModel.SeekStepHintText, Mode=OneWay}"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource PrimaryTextBrush}" />
                                </Border>
                            </Grid>

                            <Grid Grid.Row="1"
                                  ColumnSpacing="10"
                                  RowSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Button Grid.Row="0"
                                        Grid.Column="0"
                                        Command="{x:Bind ViewModel.PlayPauseCommand}"
                                        Click="OnClipButtonClick"
                                        Style="{StaticResource VodShortcutButtonStyle}">
                                    <Grid ColumnDefinitions="Auto,*,Auto"
                                          ColumnSpacing="10">
                                        <FontIcon Glyph="&#xE768;"
                                                  FontSize="16"
                                                  Foreground="{StaticResource AccentGoldBrush}"
                                                  VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1"
                                                   Text="Play"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center" />
                                        <Border Grid.Column="2"
                                                Style="{StaticResource VodKeyCapStyle}"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="Space"
                                                       FontSize="10"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource PrimaryTextBrush}" />
                                        </Border>
                                    </Grid>
                                </Button>

                                <Button Grid.Row="0"
                                        Grid.Column="1"
                                        Command="{x:Bind ViewModel.SetClipInCommand}"
                                        Click="OnClipButtonClick"
                                        Style="{StaticResource VodShortcutButtonStyle}">
                                    <Grid ColumnDefinitions="Auto,*,Auto"
                                          ColumnSpacing="10">
                                        <FontIcon Glyph="&#xE8D2;"
                                                  FontSize="16"
                                                  Foreground="{StaticResource AccentGoldBrush}"
                                                  VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{x:Bind ViewModel.ClipStartActionText, Mode=OneWay}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center" />
                                        <Border Grid.Column="2"
                                                Style="{StaticResource VodKeyCapStyle}"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="I"
                                                       FontSize="10"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource PrimaryTextBrush}" />
                                        </Border>
                                    </Grid>
                                </Button>

                                <Button Grid.Row="0"
                                        Grid.Column="2"
                                        Command="{x:Bind ViewModel.SetClipOutCommand}"
                                        Click="OnClipButtonClick"
                                        Style="{StaticResource VodShortcutButtonStyle}">
                                    <Grid ColumnDefinitions="Auto,*,Auto"
                                          ColumnSpacing="10">
                                        <FontIcon Glyph="&#xE8D3;"
                                                  FontSize="16"
                                                  Foreground="{StaticResource AccentGoldBrush}"
                                                  VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{x:Bind ViewModel.ClipEndActionText, Mode=OneWay}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center" />
                                        <Border Grid.Column="2"
                                                Style="{StaticResource VodKeyCapStyle}"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="O"
                                                       FontSize="10"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource PrimaryTextBrush}" />
                                        </Border>
                                    </Grid>
                                </Button>

                                <Button Grid.Row="1"
                                        Grid.Column="0"
                                        Command="{x:Bind ViewModel.AddBookmarkCommand}"
                                        Click="OnClipButtonClick"
                                        Style="{StaticResource VodShortcutButtonStyle}">
                                    <Grid ColumnDefinitions="Auto,*,Auto"
                                          ColumnSpacing="10">
                                        <FontIcon Glyph="&#xE8A4;"
                                                  FontSize="16"
                                                  Foreground="{StaticResource AccentTealBrush}"
                                                  VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1"
                                                   Text="Save Note"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center" />
                                        <Border Grid.Column="2"
                                                Style="{StaticResource VodKeyCapStyle}"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="B"
                                                       FontSize="10"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource PrimaryTextBrush}" />
                                        </Border>
                                    </Grid>
                                </Button>

                                <Button Grid.Row="1"
                                        Grid.Column="1"
                                        Click="OnFullscreenClick"
                                        Style="{StaticResource VodShortcutButtonStyle}">
                                    <Grid ColumnDefinitions="Auto,*,Auto"
                                          ColumnSpacing="10">
                                        <FontIcon Glyph="&#xE740;"
                                                  FontSize="16"
                                                  Foreground="{StaticResource AccentGoldBrush}"
                                                  VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1"
                                                   Text="Full Screen"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center" />
                                        <Border Grid.Column="2"
                                                Style="{StaticResource VodKeyCapStyle}"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="F"
                                                       FontSize="10"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource PrimaryTextBrush}" />
                                        </Border>
                                    </Grid>
                                </Button>

                                <Button Grid.Row="1"
                                        Grid.Column="2"
                                        Command="{x:Bind ViewModel.ExtractClipCommand}"
                                        Click="OnClipButtonClick"
                                        IsEnabled="{x:Bind ViewModel.HasClipRange, Mode=OneWay}"
                                        Style="{StaticResource VodShortcutPrimaryButtonStyle}">
                                    <Grid ColumnDefinitions="Auto,*,Auto"
                                          ColumnSpacing="10">
                                        <FontIcon Glyph="&#xE7C3;"
                                                  FontSize="16"
                                                  VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1"
                                                   Text="Save Clip"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center" />
                                        <Border Grid.Column="2"
                                                Style="{StaticResource VodKeyCapStyle}"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="S"
                                                       FontSize="10"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource PrimaryTextBrush}" />
                                        </Border>
                                    </Grid>
                                </Button>
                            </Grid>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="3"
                          ColumnDefinitions="*,312"
                          ColumnSpacing="16">
                        <Border Grid.Column="0"
                                Style="{StaticResource VodPanelCardStyle}">
                            <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                                  RowSpacing="14">
                                <Grid Grid.Row="0"
                                      ColumnDefinitions="*,Auto"
                                      ColumnSpacing="12">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="CLIP"
                                                   Style="{StaticResource PanelEyebrowStyle}" />
                                        <StackPanel Orientation="Horizontal"
                                                    Spacing="8">
                                            <Border Style="{StaticResource VodStepChipStyle}">
                                                <TextBlock Text="1 Start"
                                                           FontSize="11"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource PrimaryTextBrush}" />
                                            </Border>
                                            <Border Style="{StaticResource VodStepChipStyle}">
                                                <TextBlock Text="2 End"
                                                           FontSize="11"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource PrimaryTextBrush}" />
                                            </Border>
                                            <Border Style="{StaticResource VodStepChipStyle}">
                                                <TextBlock Text="3 Save"
                                                           FontSize="11"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource PrimaryTextBrush}" />
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>

                                    <Border Grid.Column="1"
                                            Background="{StaticResource AccentGoldDimBrush}"
                                            BorderBrush="{StaticResource AccentGoldBrush}"
                                            BorderThickness="1"
                                            CornerRadius="2"
                                            Padding="10,6"
                                            VerticalAlignment="Center"
                                            Visibility="{x:Bind ViewModel.HasClipRange, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                                        <TextBlock Text="READY"
                                                   Style="{StaticResource PanelEyebrowStyle}"
                                                   Foreground="{StaticResource AccentGoldBrush}" />
                                    </Border>
                                </Grid>

                                <Grid Grid.Row="1"
                                      ColumnDefinitions="Auto,Auto,Auto,*,Auto"
                                      ColumnSpacing="8">
                                    <Button Grid.Column="0"
                                            Command="{x:Bind ViewModel.SetClipInCommand}"
                                            Click="OnClipButtonClick"
                                            Style="{StaticResource VodSecondaryActionButtonStyle}">
                                        <StackPanel Orientation="Horizontal"
                                                    Spacing="8">
                                            <FontIcon Glyph="&#xE8D2;"
                                                      FontSize="12"
                                                      Foreground="{StaticResource AccentGoldBrush}" />
                                            <TextBlock Text="{x:Bind ViewModel.ClipStartActionText, Mode=OneWay}" />
                                        </StackPanel>
                                    </Button>

                                    <Button Grid.Column="1"
                                            Command="{x:Bind ViewModel.SetClipOutCommand}"
                                            Click="OnClipButtonClick"
                                            Style="{StaticResource VodSecondaryActionButtonStyle}">
                                        <StackPanel Orientation="Horizontal"
                                                    Spacing="8">
                                            <FontIcon Glyph="&#xE8D3;"
                                                      FontSize="12"
                                                      Foreground="{StaticResource AccentGoldBrush}" />
                                            <TextBlock Text="{x:Bind ViewModel.ClipEndActionText, Mode=OneWay}" />
                                        </StackPanel>
                                    </Button>

                                    <Button Grid.Column="2"
                                            Command="{x:Bind ViewModel.ClearClipCommand}"
                                            Click="OnClipButtonClick"
                                            Style="{StaticResource VodQuietActionButtonStyle}"
                                            Content="Clear" />

                                    <Border Grid.Column="4"
                                            Style="{StaticResource VodMiniChipStyle}"
                                            VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal"
                                                    Spacing="8">
                                            <TextBlock Text="Now"
                                                       FontSize="11"
                                                       Foreground="{StaticResource SecondaryTextBrush}" />
                                            <TextBlock Text="{x:Bind ViewModel.CurrentTimeText, Mode=OneWay}"
                                                       FontFamily="{StaticResource MonoFont}"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource AccentGoldBrush}" />
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <Grid Grid.Row="2"
                                      ColumnDefinitions="*,Auto"
                                      ColumnSpacing="10">
                                    <TextBox Grid.Column="0"
                                             x:Name="ClipNoteBox"
                                             KeyDown="OnQuickClipKeyDown"
                                             PlaceholderText="Add clip note"
                                             Style="{StaticResource VodInputTextBoxStyle}"
                                             Text="{x:Bind ViewModel.ClipNote, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                    <Button Grid.Column="1"
                                            Command="{x:Bind ViewModel.ExtractClipCommand}"
                                            Click="OnClipButtonClick"
                                            IsEnabled="{x:Bind ViewModel.HasClipRange, Mode=OneWay}"
                                            Style="{StaticResource VodSignalButtonStyle}">
                                        <StackPanel Orientation="Horizontal"
                                                    Spacing="8">
                                            <FontIcon Glyph="&#xE7C3;"
                                                      FontSize="12" />
                                            <TextBlock Text="Save Clip" />
                                        </StackPanel>
                                    </Button>
                                </Grid>

                                <Grid Grid.Row="3"
                                      ColumnDefinitions="Auto,*"
                                      ColumnSpacing="12"
                                      VerticalAlignment="Center">
                                    <TextBlock Text="Coach Lab tag"
                                               Style="{StaticResource PanelEyebrowStyle}"
                                               VerticalAlignment="Center" />

                                    <StackPanel Grid.Column="1"
                                                Spacing="10">
                                        <StackPanel Orientation="Horizontal"
                                                    Spacing="6">
                                            <Button Command="{x:Bind ViewModel.SetClipQualityCommand}"
                                                    CommandParameter="good"
                                                    Style="{StaticResource VodQualityButtonStyle}">
                                                <Border Style="{StaticResource VodQualityChipBorderStyle}"
                                                        Background="{x:Bind ViewModel.GoodClipBackgroundBrush, Mode=OneWay}"
                                                        BorderBrush="{x:Bind ViewModel.GoodClipBorderBrush, Mode=OneWay}"
                                                        BorderThickness="{x:Bind ViewModel.GoodClipBorderThickness, Mode=OneWay}">
                                                    <StackPanel Orientation="Horizontal"
                                                                Spacing="6">
                                                        <FontIcon Glyph="&#xE73E;"
                                                                  FontSize="10"
                                                                  Visibility="{x:Bind ViewModel.GoodClipCheckVisibility, Mode=OneWay}"
                                                                  Foreground="{x:Bind ViewModel.GoodClipForegroundBrush, Mode=OneWay}" />
                                                        <TextBlock Text="Good"
                                                                   Foreground="{x:Bind ViewModel.GoodClipForegroundBrush, Mode=OneWay}" />
                                                    </StackPanel>
                                                </Border>
                                            </Button>

                                            <Button Command="{x:Bind ViewModel.SetClipQualityCommand}"
                                                    CommandParameter="neutral"
                                                    Style="{StaticResource VodQualityButtonStyle}">
                                                <Border Style="{StaticResource VodQualityChipBorderStyle}"
                                                        Background="{x:Bind ViewModel.NeutralClipBackgroundBrush, Mode=OneWay}"
                                                        BorderBrush="{x:Bind ViewModel.NeutralClipBorderBrush, Mode=OneWay}"
                                                        BorderThickness="{x:Bind ViewModel.NeutralClipBorderThickness, Mode=OneWay}">
                                                    <StackPanel Orientation="Horizontal"
                                                                Spacing="6">
                                                        <FontIcon Glyph="&#xE73E;"
                                                                  FontSize="10"
                                                                  Visibility="{x:Bind ViewModel.NeutralClipCheckVisibility, Mode=OneWay}"
                                                                  Foreground="{x:Bind ViewModel.NeutralClipForegroundBrush, Mode=OneWay}" />
                                                        <TextBlock Text="Neutral"
                                                                   Foreground="{x:Bind ViewModel.NeutralClipForegroundBrush, Mode=OneWay}" />
                                                    </StackPanel>
                                                </Border>
                                            </Button>

                                            <Button Command="{x:Bind ViewModel.SetClipQualityCommand}"
                                                    CommandParameter="bad"
                                                    Style="{StaticResource VodQualityButtonStyle}">
                                                <Border Style="{StaticResource VodQualityChipBorderStyle}"
                                                        Background="{x:Bind ViewModel.BadClipBackgroundBrush, Mode=OneWay}"
                                                        BorderBrush="{x:Bind ViewModel.BadClipBorderBrush, Mode=OneWay}"
                                                        BorderThickness="{x:Bind ViewModel.BadClipBorderThickness, Mode=OneWay}">
                                                    <StackPanel Orientation="Horizontal"
                                                                Spacing="6">
                                                        <FontIcon Glyph="&#xE73E;"
                                                                  FontSize="10"
                                                                  Visibility="{x:Bind ViewModel.BadClipCheckVisibility, Mode=OneWay}"
                                                                  Foreground="{x:Bind ViewModel.BadClipForegroundBrush, Mode=OneWay}" />
                                                        <TextBlock Text="Bad"
                                                                   Foreground="{x:Bind ViewModel.BadClipForegroundBrush, Mode=OneWay}" />
                                                    </StackPanel>
                                                </Border>
                                            </Button>
                                        </StackPanel>

                                        <TextBlock Text="{x:Bind ViewModel.SelectedClipQualityText, Mode=OneWay}"
                                                   FontSize="11"
                                                   Foreground="{StaticResource SecondaryTextBrush}" />
                                    </StackPanel>
                                </Grid>

                                <Grid Grid.Row="4"
                                      ColumnDefinitions="Auto,Auto,*,Auto"
                                      ColumnSpacing="12"
                                      VerticalAlignment="Center">
                                    <Border Grid.Column="0"
                                            Style="{StaticResource VodMiniChipStyle}">
                                        <StackPanel Orientation="Horizontal"
                                                    Spacing="8">
                                            <TextBlock Text="Range"
                                                       FontSize="11"
                                                       Foreground="{StaticResource SecondaryTextBrush}" />
                                            <TextBlock Text="{x:Bind ViewModel.ClipRangeText, Mode=OneWay}"
                                                       FontFamily="{StaticResource MonoFont}"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource AccentGoldBrush}" />
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="1"
                                            Style="{StaticResource VodMiniChipStyle}">
                                        <StackPanel Orientation="Horizontal"
                                                    Spacing="8">
                                            <TextBlock Text="Length"
                                                       FontSize="11"
                                                       Foreground="{StaticResource SecondaryTextBrush}" />
                                            <TextBlock Text="{x:Bind ViewModel.ClipDurationText, Mode=OneWay}"
                                                       FontFamily="{StaticResource MonoFont}"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource PrimaryTextBrush}" />
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="2"
                                            Background="{StaticResource SurfaceInsetBrush}"
                                            BorderBrush="{StaticResource SubtleBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="2"
                                            Padding="12,10">
                                        <TextBlock Text="{x:Bind ViewModel.ClipStatusText, Mode=OneWay}"
                                                   FontSize="11"
                                                   TextWrapping="Wrap"
                                                   Foreground="{StaticResource SecondaryTextBrush}" />
                                    </Border>

                                     <TextBlock Grid.Column="3"
                                               Text="Enter saves when ready."
                                               FontSize="11"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource SecondaryTextBrush}" />
                                </Grid>
                            </Grid>
                        </Border>

                        <Border Grid.Column="1"
                                Style="{StaticResource VodPanelCardStyle}"
                                Background="{StaticResource FocusPanelBrush}">
                            <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                                  RowSpacing="14">
                                <StackPanel Grid.Row="0"
                                            Spacing="4">
                                    <TextBlock Text="NOTE"
                                               Style="{StaticResource PanelEyebrowStyle}" />
                                    <TextBlock Text="Save a time and note without a clip."
                                               FontSize="12"
                                               TextWrapping="Wrap"
                                               Foreground="{StaticResource SecondaryTextBrush}" />
                                </StackPanel>

                                <Border Grid.Row="1"
                                        Background="{StaticResource SurfaceInsetBrush}"
                                        BorderBrush="{StaticResource BrightBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="2"
                                        Padding="12,10">
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="Current time"
                                                   Style="{StaticResource PanelEyebrowStyle}" />
                                        <TextBlock Text="{x:Bind ViewModel.CurrentTimeText, Mode=OneWay}"
                                                   FontFamily="{StaticResource MonoFont}"
                                                   FontSize="28"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource AccentTealBrush}" />
                                        <TextBlock Text="Enter or Save Note."
                                                   FontSize="11"
                                                   TextWrapping="Wrap"
                                                   Foreground="{StaticResource SecondaryTextBrush}" />
                                    </StackPanel>
                                </Border>

                                <TextBox Grid.Row="2"
                                         x:Name="BookmarkNoteBox"
                                         KeyDown="OnQuickBookmarkKeyDown"
                                         PlaceholderText="Add note"
                                         Style="{StaticResource VodInputTextBoxStyle}"
                                         Text="{x:Bind ViewModel.BookmarkNote, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                <ComboBox Grid.Row="3"
                                          ItemsSource="{x:Bind ViewModel.ObjectiveOptions, Mode=OneWay}"
                                          SelectedValue="{x:Bind ViewModel.SelectedObjectiveId, Mode=TwoWay}"
                                          SelectedValuePath="Id"
                                          DisplayMemberPath="Title"
                                          PlaceholderText="Attach objective"
                                          HorizontalAlignment="Stretch"
                                          FontSize="12"
                                          IsTabStop="False"
                                          Background="{StaticResource InputBackgroundBrush}"
                                          BorderBrush="{StaticResource SubtleBorderBrush}"
                                          Foreground="{StaticResource PrimaryTextBrush}" />

                                <Grid Grid.Row="4"
                                      ColumnDefinitions="*,Auto"
                                      ColumnSpacing="12">
                                    <TextBlock Text="Shows up in Saved on the right."
                                               FontSize="11"
                                               TextWrapping="Wrap"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource SecondaryTextBrush}" />

                                    <Button Grid.Column="1"
                                            Command="{x:Bind ViewModel.AddBookmarkCommand}"
                                            Click="OnClipButtonClick"
                                            Style="{StaticResource VodPrimaryActionButtonStyle}"
                                            VerticalAlignment="Bottom">
                                        <StackPanel Orientation="Horizontal"
                                                    Spacing="8">
                                            <FontIcon Glyph="&#xE8A4;"
                                                      FontSize="12" />
                                            <TextBlock Text="Save Note (B)" />
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>

                <Grid Grid.Column="1"
                      RowDefinitions="Auto,*"
                      RowSpacing="16">
                    <Border Grid.Row="0"
                            Style="{StaticResource VodPanelCardStyle}"
                            Background="{StaticResource FocusPanelBrush}">
                        <Grid RowDefinitions="Auto,Auto,Auto"
                              RowSpacing="14">
                            <Grid Grid.Row="0"
                                  ColumnDefinitions="*,Auto"
                                  ColumnSpacing="12">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="STATUS"
                                               Style="{StaticResource PanelEyebrowStyle}" />
                                    <TextBlock Text="{x:Bind ViewModel.SeekStepHintText, Mode=OneWay}"
                                               FontSize="12"
                                               TextWrapping="Wrap"
                                               Foreground="{StaticResource SecondaryTextBrush}" />
                                </StackPanel>

                                <Border Grid.Column="1"
                                        Style="{StaticResource VodMiniChipStyle}"
                                        VerticalAlignment="Top">
                                    <StackPanel Orientation="Horizontal"
                                                Spacing="8">
                                        <FontIcon Glyph="&#xE7FC;"
                                                  FontSize="12"
                                                  Foreground="{StaticResource AccentGoldBrush}" />
                                        <TextBlock Text="{x:Bind ViewModel.SeekStepText, Mode=OneWay}"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource PrimaryTextBrush}" />
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <Border Grid.Row="1"
                                    Style="{StaticResource InsetCardStyle}"
                                    Background="{StaticResource SurfaceHighlightBrush}"
                                    Padding="12">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="CLIP"
                                               Style="{StaticResource PanelEyebrowStyle}" />
                                    <TextBlock Text="{x:Bind ViewModel.ClipStatusText, Mode=OneWay}"
                                               FontSize="12"
                                               TextWrapping="Wrap"
                                               Foreground="{StaticResource PrimaryTextBrush}" />
                                    <TextBlock x:Name="FfmpegWarning"
                                               Text="ffmpeg not found. Install ffmpeg and add it to PATH for clip saves."
                                               FontSize="11"
                                               TextWrapping="Wrap"
                                               Visibility="Collapsed"
                                               Foreground="{StaticResource LossRedBrush}" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="2"
                                    Background="{StaticResource SurfaceInsetBrush}"
                                    BorderBrush="{StaticResource SubtleBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="2"
                                    Padding="12">
                                <StackPanel Spacing="10">
                                    <TextBlock Text="KEYS"
                                               Style="{StaticResource PanelEyebrowStyle}" />
                                    <Grid ColumnDefinitions="*,Auto"
                                          RowSpacing="8">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0"
                                                   Text="Play"
                                                   FontSize="12"
                                                   Foreground="{StaticResource PrimaryTextBrush}" />
                                        <Border Grid.Row="0"
                                                Grid.Column="1"
                                                Style="{StaticResource VodKeyCapStyle}">
                                            <TextBlock Text="Space"
                                                       FontSize="10"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource PrimaryTextBrush}" />
                                        </Border>

                                        <TextBlock Grid.Row="1"
                                                   Text="Start clip"
                                                   FontSize="12"
                                                   Foreground="{StaticResource PrimaryTextBrush}" />
                                        <Border Grid.Row="1"
                                                Grid.Column="1"
                                                Style="{StaticResource VodKeyCapStyle}">
                                            <TextBlock Text="I"
                                                       FontSize="10"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource PrimaryTextBrush}" />
                                        </Border>

                                        <TextBlock Grid.Row="2"
                                                   Text="End clip"
                                                   FontSize="12"
                                                   Foreground="{StaticResource PrimaryTextBrush}" />
                                        <Border Grid.Row="2"
                                                Grid.Column="1"
                                                Style="{StaticResource VodKeyCapStyle}">
                                            <TextBlock Text="O"
                                                       FontSize="10"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource PrimaryTextBrush}" />
                                        </Border>

                                        <TextBlock Grid.Row="3"
                                                   Text="Save note"
                                                   FontSize="12"
                                                   Foreground="{StaticResource PrimaryTextBrush}" />
                                        <Border Grid.Row="3"
                                                Grid.Column="1"
                                                Style="{StaticResource VodKeyCapStyle}">
                                            <TextBlock Text="B"
                                                       FontSize="10"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource PrimaryTextBrush}" />
                                        </Border>

                                        <TextBlock Grid.Row="4"
                                                   Text="Save clip"
                                                   FontSize="12"
                                                   Foreground="{StaticResource PrimaryTextBrush}" />
                                        <Border Grid.Row="4"
                                                Grid.Column="1"
                                                Style="{StaticResource VodKeyCapStyle}">
                                            <TextBlock Text="S"
                                                       FontSize="10"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource PrimaryTextBrush}" />
                                        </Border>

                                        <TextBlock Grid.Row="5"
                                                   Text="Full screen"
                                                   FontSize="12"
                                                   Foreground="{StaticResource PrimaryTextBrush}" />
                                        <Border Grid.Row="5"
                                                Grid.Column="1"
                                                Style="{StaticResource VodKeyCapStyle}">
                                            <TextBlock Text="F"
                                                       FontSize="10"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource PrimaryTextBrush}" />
                                        </Border>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1"
                            Style="{StaticResource VodSectionCardStyle}">
                        <Grid RowDefinitions="Auto,Auto,*"
                              RowSpacing="10">
                            <Grid Grid.Row="0"
                                  ColumnDefinitions="*,Auto"
                                  ColumnSpacing="12">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="SAVED"
                                               Style="{StaticResource PanelEyebrowStyle}" />
                                    <TextBlock Text="Clips and notes."
                                               FontSize="12"
                                               TextWrapping="Wrap"
                                               Foreground="{StaticResource SecondaryTextBrush}" />
                                </StackPanel>

                                <Border Grid.Column="1"
                                        Style="{StaticResource VodMiniChipStyle}"
                                        VerticalAlignment="Center">
                                    <TextBlock FontSize="11"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource PrimaryTextBrush}">
                                        <Run Text="{x:Bind ViewModel.Bookmarks.Count, Mode=OneWay}" />
                                        <Run Text=" saved" />
                                    </TextBlock>
                                </Border>
                            </Grid>

                            <TextBlock Grid.Row="1"
                                       Text="Use Jump to seek. Edit notes inline."
                                       FontSize="11"
                                       TextWrapping="Wrap"
                                       Foreground="{StaticResource SecondaryTextBrush}" />

                            <ScrollViewer Grid.Row="2"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <ItemsRepeater ItemsSource="{x:Bind ViewModel.Bookmarks, Mode=OneWay}">
                                    <ItemsRepeater.Layout>
                                        <StackLayout Spacing="6" />
                                    </ItemsRepeater.Layout>
                                    <ItemsRepeater.ItemTemplate>
                                        <DataTemplate x:DataType="vm:BookmarkItem">
                                            <Border Background="{x:Bind SurfaceBrush}"
                                                    BorderBrush="{x:Bind AccentBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="2"
                                                    Padding="12,10">
                                                <Grid ColumnDefinitions="Auto,*,Auto"
                                                      ColumnSpacing="10">
                                                    <StackPanel Spacing="8"
                                                                VerticalAlignment="Top">
                                                        <Border Background="{x:Bind AccentBrush}"
                                                                CornerRadius="2"
                                                                Padding="10,5">
                                                            <TextBlock Text="{x:Bind TimeText}"
                                                                       FontFamily="{StaticResource MonoFont}"
                                                                       FontSize="12"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{StaticResource ActionPrimaryForegroundBrush}" />
                                                        </Border>
                                                        <Border Background="{x:Bind SurfaceBrush}"
                                                                BorderBrush="{x:Bind AccentBrush}"
                                                                BorderThickness="1"
                                                                CornerRadius="2"
                                                                Padding="8,4">
                                                            <TextBlock Text="{x:Bind KindLabel}"
                                                                       FontSize="10"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{x:Bind AccentBrush}" />
                                                        </Border>
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="1"
                                                                Spacing="8">
                                                        <TextBox Text="{x:Bind Note, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                 Tag="{x:Bind}"
                                                                 Background="{StaticResource InputBackgroundBrush}"
                                                                 BorderBrush="{StaticResource SubtleBorderBrush}"
                                                                 BorderThickness="1"
                                                                 CornerRadius="2"
                                                                 Foreground="{StaticResource PrimaryTextBrush}"
                                                                 FontSize="12"
                                                                 KeyDown="OnBookmarkNoteKeyDown"
                                                                 LostFocus="OnBookmarkNoteLostFocus"
                                                                 TextChanged="OnBookmarkNoteTextChanged"
                                                                 Padding="10,7"
                                                                 PlaceholderText="Note" />

                                                        <StackPanel Orientation="Horizontal"
                                                                    Spacing="8"
                                                                    Visibility="{x:Bind IsClip, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                                                            <StackPanel Spacing="8">
                                                                <StackPanel Orientation="Horizontal"
                                                                            Spacing="8">
                                                                    <Border Background="{x:Bind SurfaceBrush}"
                                                                            BorderBrush="{x:Bind AccentBrush}"
                                                                            BorderThickness="1"
                                                                            CornerRadius="2"
                                                                            Padding="8,4">
                                                                        <TextBlock Text="{x:Bind ClipRangeText}"
                                                                                   FontFamily="{StaticResource MonoFont}"
                                                                                   FontSize="11"
                                                                                   FontWeight="SemiBold"
                                                                                   Foreground="{x:Bind AccentBrush}" />
                                                                    </Border>

                                                                    <Border Background="{x:Bind QualitySurfaceBrush}"
                                                                            BorderBrush="{x:Bind QualityAccentBrush}"
                                                                            BorderThickness="1"
                                                                            CornerRadius="2"
                                                                            Padding="8,4"
                                                                            Visibility="{x:Bind HasQuality, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                                                                        <TextBlock Text="{x:Bind QualityLabel}"
                                                                                   FontSize="11"
                                                                                   FontWeight="SemiBold"
                                                                                   Foreground="{x:Bind QualityAccentBrush}" />
                                                                    </Border>
                                                                </StackPanel>

                                                                <Grid ColumnDefinitions="Auto,Auto,Auto"
                                                                      ColumnSpacing="5">
                                                                    <Button Grid.Column="0"
                                                                            Tag="good"
                                                                            Click="OnBookmarkQualityClick"
                                                                            Style="{StaticResource VodQualityButtonStyle}">
                                                                        <Border Style="{StaticResource VodQualityChipBorderStyle}"
                                                                                Background="{x:Bind GoodQualityVisual.BackgroundBrush, Mode=OneWay}"
                                                                                BorderBrush="{x:Bind GoodQualityVisual.BorderBrush, Mode=OneWay}"
                                                                                BorderThickness="{x:Bind GoodQualityVisual.BorderThickness, Mode=OneWay}">
                                                                            <StackPanel Orientation="Horizontal"
                                                                                        Spacing="6">
                                                                                <FontIcon Glyph="&#xE73E;"
                                                                                          FontSize="10"
                                                                                          Visibility="{x:Bind GoodQualityVisual.CheckVisibility, Mode=OneWay}"
                                                                                          Foreground="{x:Bind GoodQualityVisual.ForegroundBrush, Mode=OneWay}" />
                                                                                <TextBlock Text="Good"
                                                                                           Foreground="{x:Bind GoodQualityVisual.ForegroundBrush, Mode=OneWay}" />
                                                                            </StackPanel>
                                                                        </Border>
                                                                    </Button>

                                                                    <Button Grid.Column="1"
                                                                            Tag="neutral"
                                                                            Click="OnBookmarkQualityClick"
                                                                            Style="{StaticResource VodQualityButtonStyle}">
                                                                        <Border Style="{StaticResource VodQualityChipBorderStyle}"
                                                                                Background="{x:Bind NeutralQualityVisual.BackgroundBrush, Mode=OneWay}"
                                                                                BorderBrush="{x:Bind NeutralQualityVisual.BorderBrush, Mode=OneWay}"
                                                                                BorderThickness="{x:Bind NeutralQualityVisual.BorderThickness, Mode=OneWay}">
                                                                            <StackPanel Orientation="Horizontal"
                                                                                        Spacing="6">
                                                                                <FontIcon Glyph="&#xE73E;"
                                                                                          FontSize="10"
                                                                                          Visibility="{x:Bind NeutralQualityVisual.CheckVisibility, Mode=OneWay}"
                                                                                          Foreground="{x:Bind NeutralQualityVisual.ForegroundBrush, Mode=OneWay}" />
                                                                                <TextBlock Text="Neutral"
                                                                                           Foreground="{x:Bind NeutralQualityVisual.ForegroundBrush, Mode=OneWay}" />
                                                                            </StackPanel>
                                                                        </Border>
                                                                    </Button>

                                                                    <Button Grid.Column="2"
                                                                            Tag="bad"
                                                                            Click="OnBookmarkQualityClick"
                                                                            Style="{StaticResource VodQualityButtonStyle}">
                                                                        <Border Style="{StaticResource VodQualityChipBorderStyle}"
                                                                                Background="{x:Bind BadQualityVisual.BackgroundBrush, Mode=OneWay}"
                                                                                BorderBrush="{x:Bind BadQualityVisual.BorderBrush, Mode=OneWay}"
                                                                                BorderThickness="{x:Bind BadQualityVisual.BorderThickness, Mode=OneWay}">
                                                                            <StackPanel Orientation="Horizontal"
                                                                                        Spacing="6">
                                                                                <FontIcon Glyph="&#xE73E;"
                                                                                          FontSize="10"
                                                                                          Visibility="{x:Bind BadQualityVisual.CheckVisibility, Mode=OneWay}"
                                                                                          Foreground="{x:Bind BadQualityVisual.ForegroundBrush, Mode=OneWay}" />
                                                                                <TextBlock Text="Bad"
                                                                                           Foreground="{x:Bind BadQualityVisual.ForegroundBrush, Mode=OneWay}" />
                                                                            </StackPanel>
                                                                        </Border>
                                                                    </Button>
                                                                </Grid>
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="2"
                                                                Spacing="8"
                                                                VerticalAlignment="Top">
                                                        <Button Click="OnBookmarkJumpClick"
                                                                Style="{StaticResource VodBookmarkActionButtonStyle}"
                                                                ToolTipService.ToolTip="Jump to this clip">
                                                            <StackPanel Orientation="Horizontal"
                                                                        Spacing="5">
                                                                <FontIcon Glyph="&#xE72B;"
                                                                          FontSize="11" />
                                                                <TextBlock Text="Jump" />
                                                            </StackPanel>
                                                        </Button>

                                                        <Button CommandParameter="{x:Bind Id}"
                                                                Click="OnDeleteBookmark"
                                                                Style="{StaticResource VodBookmarkActionButtonStyle}"
                                                                ToolTipService.ToolTip="Delete this clip">
                                                            <FontIcon Glyph="&#xE74D;"
                                                                      FontSize="14" />
                                                        </Button>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsRepeater.ItemTemplate>
                                </ItemsRepeater>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Page>
