<Page
    x:Name="RootPage"
    x:Class="LoLReview.App.Views.VodPlayerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:LoLReview.App.Controls"
    xmlns:converters="using:LoLReview.App.Converters"
    xmlns:vm="using:LoLReview.App.ViewModels"
    Background="Transparent"
    IsTabStop="True"
    NavigationCacheMode="Disabled">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>

        <Style x:Key="VodInputTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource InputBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource SubtleBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
            <Setter Property="CornerRadius" Value="2"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Page.Resources>

    <Grid x:Name="RootGrid" Background="Transparent">
        <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                      Width="48" Height="48"
                      HorizontalAlignment="Center" VerticalAlignment="Center"
                      Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"/>

        <Grid RowDefinitions="Auto,*" Padding="28,20,28,28">

            <!-- ═══ HERO HEADER ═══ -->
            <Grid Grid.Row="0" Margin="0,0,0,16">
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16">
                    <Button Grid.Column="0"
                            Command="{x:Bind ViewModel.GoBackCommand}"
                            Style="{StaticResource SecondaryActionButtonStyle}"
                            Height="34" Padding="12,0" VerticalAlignment="Center"
                            IsTabStop="False" AllowFocusOnInteraction="False">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE72B;" FontSize="12"
                                      FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"/>
                            <TextBlock Text="Back" FontSize="12"/>
                        </StackPanel>
                    </Button>

                    <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Rectangle Width="20" Height="1"
                                       Fill="{StaticResource AccentBlueBrush}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="VOD ANALYSIS"
                                       Style="{StaticResource PanelEyebrowStyle}"
                                       Foreground="{StaticResource AccentBlueBrush}"/>
                        </StackPanel>
                        <TextBlock Text="{x:Bind ViewModel.HeaderText, Mode=OneWay}"
                                   FontFamily="{StaticResource DisplayFont}"
                                   FontSize="22" FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryTextBrush}"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <Border Background="{StaticResource SurfaceInsetBrush}"
                                BorderBrush="{StaticResource SubtleBorderBrush}"
                                BorderThickness="1" CornerRadius="2" Padding="8,4">
                            <TextBlock FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentGoldBrush}">
                                <Run Text="{x:Bind ViewModel.OutcomeLabel, Mode=OneWay}"/>
                            </TextBlock>
                        </Border>
                        <Border Background="{StaticResource SurfaceInsetBrush}"
                                BorderBrush="{StaticResource SubtleBorderBrush}"
                                BorderThickness="1" CornerRadius="2" Padding="8,4">
                            <TextBlock FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource PrimaryTextBrush}">
                                <Run Text="{x:Bind ViewModel.Bookmarks.Count, Mode=OneWay}"/>
                                <Run Text=" notes"/>
                            </TextBlock>
                        </Border>
                    </StackPanel>
                </Grid>
            </Grid>

            <!-- ═══ MAIN 2-COL LAYOUT ═══ -->
            <Grid Grid.Row="1" ColumnDefinitions="3*,*" ColumnSpacing="16">

                <!-- ── LEFT: Video + Controls + Clip ── -->
                <ScrollViewer Grid.Column="0"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Spacing="12" Padding="0,0,0,40">

                        <!-- Video container -->
                        <Border x:Name="VideoBorder"
                                Background="{StaticResource SurfaceInsetBrush}"
                                BorderBrush="{StaticResource SubtleBorderBrush}"
                                BorderThickness="1" CornerRadius="2" Padding="6"
                                PointerEntered="OnVideoBorderPointerEntered"
                                PointerExited="OnVideoBorderPointerExited">
                            <Grid x:Name="VideoContainer"
                                  AllowFocusOnInteraction="True"
                                  Background="#020405"
                                  IsTabStop="True"
                                  MinHeight="420"
                                  Tapped="OnVideoTapped">
                                <Grid x:Name="LoadingOverlay"
                                      Background="{StaticResource PanelOverlayBrush}"
                                      Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="10">
                                        <ProgressRing IsActive="True" Width="40" Height="40"/>
                                        <TextBlock Text="Loading recording" FontSize="12"
                                                   HorizontalAlignment="Center"
                                                   Foreground="{StaticResource SecondaryTextBrush}"/>
                                    </StackPanel>
                                </Grid>

                                <Border x:Name="NoVodBorder"
                                        HorizontalAlignment="Center" VerticalAlignment="Center"
                                        Background="{StaticResource SurfaceRaisedBrush}"
                                        BorderBrush="{StaticResource SubtleBorderBrush}"
                                        BorderThickness="1" CornerRadius="2" Padding="18"
                                        Visibility="Collapsed">
                                    <TextBlock x:Name="NoVodText"
                                               Text="No VOD linked to this game"
                                               FontSize="16" TextWrapping="Wrap"
                                               HorizontalAlignment="Center"
                                               Foreground="{StaticResource SecondaryTextBrush}"/>
                                </Border>

                                <Button x:Name="VideoPlayPauseButton"
                                        Click="OnVideoPlayPauseClick"
                                        HorizontalAlignment="Center" VerticalAlignment="Bottom"
                                        Margin="0,0,0,24"
                                        Width="64" Height="52" Padding="0" CornerRadius="2"
                                        Background="#CC000000"
                                        BorderBrush="{StaticResource BrightBorderBrush}"
                                        BorderThickness="1"
                                        Foreground="{StaticResource PrimaryTextBrush}"
                                        IsTabStop="False" AllowFocusOnInteraction="False"
                                        Visibility="{x:Bind ViewModel.HasVod, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                                    <FontIcon x:Name="VideoPlayPauseIcon" Glyph="&#xE768;" FontSize="22"
                                              FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"/>
                                </Button>
                            </Grid>
                        </Border>

                        <!-- Transport bar -->
                        <Border Background="{StaticResource SurfaceInsetBrush}"
                                BorderBrush="{StaticResource SubtleBorderBrush}"
                                BorderThickness="1" CornerRadius="2" Padding="12,8">
                            <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,*,Auto,Auto,Auto,Auto,Auto"
                                  ColumnSpacing="8">
                                <Button Grid.Column="0"
                                        Command="{x:Bind ViewModel.SeekBackwardCommand}"
                                        Click="OnClipButtonClick"
                                        Style="{StaticResource GhostIconButtonStyle}"
                                        Width="40" Height="38" IsTabStop="False" AllowFocusOnInteraction="False">
                                    <FontIcon Glyph="&#xEB9E;" FontSize="16"
                                              FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"/>
                                </Button>

                                <Button Grid.Column="1"
                                        Command="{x:Bind ViewModel.PlayPauseCommand}"
                                        Click="OnClipButtonClick"
                                        Style="{StaticResource PrimaryActionButtonStyle}"
                                        Width="56" Padding="0" IsTabStop="False" AllowFocusOnInteraction="False">
                                    <FontIcon x:Name="PlayPauseIcon" Glyph="&#xE768;" FontSize="20"
                                              FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"/>
                                </Button>

                                <Button Grid.Column="2"
                                        Command="{x:Bind ViewModel.SeekForwardCommand}"
                                        Click="OnClipButtonClick"
                                        Style="{StaticResource GhostIconButtonStyle}"
                                        Width="40" Height="38" IsTabStop="False" AllowFocusOnInteraction="False">
                                    <FontIcon Glyph="&#xEB9D;" FontSize="16"
                                              FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"/>
                                </Button>

                                <TextBlock Grid.Column="3"
                                           FontFamily="{StaticResource MonoFont}"
                                           FontSize="11" VerticalAlignment="Center"
                                           Foreground="{StaticResource SecondaryTextBrush}">
                                    <Run Text="{x:Bind ViewModel.CurrentTimeText, Mode=OneWay}"/>
                                    <Run Text=" / "/>
                                    <Run Text="{x:Bind ViewModel.TotalTimeText, Mode=OneWay}"/>
                                </TextBlock>

                                <!-- Spacer -->
                                <Border Grid.Column="4"/>

                                <TextBlock Grid.Column="5" Text="Speed" FontSize="11"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource SecondaryTextBrush}"/>

                                <ComboBox x:Name="SpeedCombo" Grid.Column="6"
                                          Width="80" SelectedIndex="2"
                                          SelectionChanged="OnSpeedChanged"
                                          Background="{StaticResource InputBackgroundBrush}"
                                          BorderBrush="{StaticResource SubtleBorderBrush}"
                                          Foreground="{StaticResource PrimaryTextBrush}"
                                          FontSize="11" CornerRadius="2"
                                          IsTabStop="False">
                                    <ComboBoxItem Content="0.25x" Tag="0.25"/>
                                    <ComboBoxItem Content="0.5x" Tag="0.5"/>
                                    <ComboBoxItem Content="1.0x" Tag="1.0"/>
                                    <ComboBoxItem Content="1.5x" Tag="1.5"/>
                                    <ComboBoxItem Content="2.0x" Tag="2.0"/>
                                </ComboBox>

                                <Button Grid.Column="7" x:Name="MuteButton"
                                        Click="OnMuteClick"
                                        Style="{StaticResource GhostIconButtonStyle}"
                                        Width="38" Height="38" IsTabStop="False" AllowFocusOnInteraction="False">
                                    <FontIcon x:Name="VolumeIcon" Glyph="&#xE767;" FontSize="14"
                                              FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"/>
                                </Button>

                                <Slider Grid.Column="8" x:Name="VolumeSlider"
                                        Width="80" Minimum="0" Maximum="100" Value="100"
                                        Foreground="{StaticResource AccentBlueBrush}"
                                        VerticalAlignment="Center"
                                        ValueChanged="OnVolumeChanged"/>

                                <Button Grid.Column="9" x:Name="FullscreenButton"
                                        Click="OnFullscreenClick"
                                        Style="{StaticResource GhostIconButtonStyle}"
                                        Width="38" Height="38" IsTabStop="False" AllowFocusOnInteraction="False">
                                    <FontIcon x:Name="FullscreenIcon" Glyph="&#xE740;" FontSize="14"
                                              FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"/>
                                </Button>
                            </Grid>
                        </Border>

                        <!-- Timeline -->
                        <Border Background="{StaticResource SurfaceInsetBrush}"
                                BorderBrush="{StaticResource SubtleBorderBrush}"
                                BorderThickness="1" CornerRadius="2" Padding="10">
                            <controls:TimelineControl x:Name="Timeline"
                                                      Height="80"
                                                      Bookmarks="{x:Bind ViewModel.Bookmarks, Mode=OneWay}"
                                                      ClipEnd="{x:Bind ViewModel.ClipEndS, Mode=OneWay}"
                                                      ClipStart="{x:Bind ViewModel.ClipStartS, Mode=OneWay}"
                                                      DerivedEvents="{x:Bind ViewModel.DerivedEvents, Mode=OneWay}"
                                                      Duration="{x:Bind ViewModel.GameDurationS, Mode=OneWay}"
                                                      Events="{x:Bind ViewModel.GameEvents, Mode=OneWay}"
                                                      Position="{x:Bind ViewModel.CurrentTimeS, Mode=OneWay}"/>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

                <!-- ── RIGHT: Bookmark Sidebar ── -->
                <ScrollViewer Grid.Column="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                <StackPanel Spacing="12" Padding="0,0,0,40">

                    <!-- Quick Bookmark -->
                    <controls:CornerBracketedCard CardBackground="{StaticResource FocusPanelBrush}">
                        <StackPanel Spacing="10">
                            <controls:SectionTitle Text="QUICK BOOKMARK"/>

                            <TextBox x:Name="BookmarkNoteBox"
                                     KeyDown="OnQuickBookmarkKeyDown"
                                     PlaceholderText="Note..."
                                     Style="{StaticResource VodInputTextBoxStyle}"
                                     FontSize="11"
                                     Text="{x:Bind ViewModel.BookmarkNote, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
                                <ComboBox Grid.Column="0"
                                          ItemsSource="{x:Bind ViewModel.ObjectiveOptions, Mode=OneWay}"
                                          SelectedValue="{x:Bind ViewModel.SelectedObjectiveId, Mode=TwoWay}"
                                          SelectedValuePath="Id"
                                          DisplayMemberPath="Title"
                                          PlaceholderText="No objective"
                                          HorizontalAlignment="Stretch"
                                          FontSize="11" CornerRadius="2"
                                          IsTabStop="False"
                                          Background="{StaticResource InputBackgroundBrush}"
                                          BorderBrush="{StaticResource SubtleBorderBrush}"
                                          Foreground="{StaticResource PrimaryTextBrush}"/>

                                <Button Grid.Column="1"
                                        Command="{x:Bind ViewModel.AddBookmarkCommand}"
                                        Click="OnClipButtonClick"
                                        Style="{StaticResource PrimaryActionButtonStyle}"
                                        Height="34" Padding="14,0" FontSize="11"
                                        IsTabStop="False" AllowFocusOnInteraction="False"
                                        Content="Add"/>
                            </Grid>
                        </StackPanel>
                    </controls:CornerBracketedCard>

                    <!-- Clip Extraction -->
                    <controls:CornerBracketedCard>
                        <StackPanel Spacing="10">
                            <controls:SectionTitle Text="CLIP"/>

                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Button Command="{x:Bind ViewModel.SetClipInCommand}"
                                        Click="OnClipButtonClick"
                                        Style="{StaticResource SecondaryActionButtonStyle}"
                                        Height="30" Padding="10,0" FontSize="10"
                                        IsTabStop="False" AllowFocusOnInteraction="False"
                                        Content="Start"/>
                                <TextBlock FontFamily="{StaticResource MonoFont}"
                                           FontSize="11" VerticalAlignment="Center"
                                           Foreground="{StaticResource AccentGoldBrush}">
                                    <Run Text="{x:Bind ViewModel.ClipRangeText, Mode=OneWay}"/>
                                </TextBlock>
                                <Button Command="{x:Bind ViewModel.SetClipOutCommand}"
                                        Click="OnClipButtonClick"
                                        Style="{StaticResource SecondaryActionButtonStyle}"
                                        Height="30" Padding="10,0" FontSize="10"
                                        IsTabStop="False" AllowFocusOnInteraction="False"
                                        Content="End"/>
                            </StackPanel>

                            <TextBox x:Name="ClipNoteBox"
                                     KeyDown="OnQuickClipKeyDown"
                                     PlaceholderText="What's happening?"
                                     Style="{StaticResource VodInputTextBoxStyle}"
                                     FontSize="11"
                                     Text="{x:Bind ViewModel.ClipNote, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <Button Command="{x:Bind ViewModel.SetClipQualityCommand}"
                                        CommandParameter="good"
                                        IsTabStop="False" AllowFocusOnInteraction="False"
                                        Background="Transparent" BorderThickness="0" Padding="0" MinWidth="0">
                                    <Border CornerRadius="2" Padding="8,4"
                                            Background="{x:Bind ViewModel.GoodClipBackgroundBrush, Mode=OneWay}"
                                            BorderBrush="{x:Bind ViewModel.GoodClipBorderBrush, Mode=OneWay}"
                                            BorderThickness="{x:Bind ViewModel.GoodClipBorderThickness, Mode=OneWay}">
                                        <TextBlock Text="Good" FontSize="10"
                                                   Foreground="{x:Bind ViewModel.GoodClipForegroundBrush, Mode=OneWay}"/>
                                    </Border>
                                </Button>
                                <Button Command="{x:Bind ViewModel.SetClipQualityCommand}"
                                        CommandParameter="neutral"
                                        IsTabStop="False" AllowFocusOnInteraction="False"
                                        Background="Transparent" BorderThickness="0" Padding="0" MinWidth="0">
                                    <Border CornerRadius="2" Padding="8,4"
                                            Background="{x:Bind ViewModel.NeutralClipBackgroundBrush, Mode=OneWay}"
                                            BorderBrush="{x:Bind ViewModel.NeutralClipBorderBrush, Mode=OneWay}"
                                            BorderThickness="{x:Bind ViewModel.NeutralClipBorderThickness, Mode=OneWay}">
                                        <TextBlock Text="Neutral" FontSize="10"
                                                   Foreground="{x:Bind ViewModel.NeutralClipForegroundBrush, Mode=OneWay}"/>
                                    </Border>
                                </Button>
                                <Button Command="{x:Bind ViewModel.SetClipQualityCommand}"
                                        CommandParameter="bad"
                                        IsTabStop="False" AllowFocusOnInteraction="False"
                                        Background="Transparent" BorderThickness="0" Padding="0" MinWidth="0">
                                    <Border CornerRadius="2" Padding="8,4"
                                            Background="{x:Bind ViewModel.BadClipBackgroundBrush, Mode=OneWay}"
                                            BorderBrush="{x:Bind ViewModel.BadClipBorderBrush, Mode=OneWay}"
                                            BorderThickness="{x:Bind ViewModel.BadClipBorderThickness, Mode=OneWay}">
                                        <TextBlock Text="Bad" FontSize="10"
                                                   Foreground="{x:Bind ViewModel.BadClipForegroundBrush, Mode=OneWay}"/>
                                    </Border>
                                </Button>
                            </StackPanel>

                            <Button Command="{x:Bind ViewModel.ExtractClipCommand}"
                                    Click="OnClipButtonClick"
                                    IsEnabled="{x:Bind ViewModel.HasClipRange, Mode=OneWay}"
                                    Style="{StaticResource GoldActionButtonStyle}"
                                    Height="32" Padding="12,0" FontSize="11"
                                    HorizontalAlignment="Stretch"
                                    IsTabStop="False" AllowFocusOnInteraction="False">
                                <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                                    <FontIcon Glyph="&#xE7C3;" FontSize="12"
                                              FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"/>
                                    <TextBlock Text="Save Clip"/>
                                </StackPanel>
                            </Button>

                            <TextBlock x:Name="FfmpegWarning"
                                       Text="ffmpeg not found — install ffmpeg for clip saves."
                                       FontSize="10" TextWrapping="Wrap" Visibility="Collapsed"
                                       Foreground="{StaticResource LossRedBrush}"/>
                        </StackPanel>
                    </controls:CornerBracketedCard>

                    <!-- Saved bookmarks + clips -->
                    <controls:CornerBracketedCard>
                        <Grid RowDefinitions="Auto,*" RowSpacing="10">
                            <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                                <controls:SectionTitle Text="SAVED"/>
                                <Border Grid.Column="1"
                                        Background="{StaticResource SurfaceInsetBrush}"
                                        BorderBrush="{StaticResource SubtleBorderBrush}"
                                        BorderThickness="1" CornerRadius="2" Padding="8,4">
                                    <TextBlock FontSize="11" FontWeight="SemiBold"
                                               Foreground="{StaticResource PrimaryTextBrush}">
                                        <Run Text="{x:Bind ViewModel.Bookmarks.Count, Mode=OneWay}"/>
                                        <Run Text=" saved"/>
                                    </TextBlock>
                                </Border>
                            </Grid>

                            <ScrollViewer Grid.Row="1"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <ItemsRepeater ItemsSource="{x:Bind ViewModel.Bookmarks, Mode=OneWay}">
                                    <ItemsRepeater.Layout>
                                        <StackLayout Spacing="6"/>
                                    </ItemsRepeater.Layout>
                                    <ItemsRepeater.ItemTemplate>
                                        <DataTemplate x:DataType="vm:BookmarkItem">
                                            <Border Background="{x:Bind SurfaceBrush}"
                                                    BorderBrush="{x:Bind AccentBrush}"
                                                    BorderThickness="1" CornerRadius="2" Padding="12,10">
                                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                                                    <StackPanel Spacing="6" VerticalAlignment="Top">
                                                        <Border Background="{x:Bind AccentBrush}"
                                                                CornerRadius="2" Padding="8,4">
                                                            <TextBlock Text="{x:Bind TimeText}"
                                                                       FontFamily="{StaticResource MonoFont}"
                                                                       FontSize="11" FontWeight="SemiBold"
                                                                       Foreground="{StaticResource ActionPrimaryForegroundBrush}"/>
                                                        </Border>
                                                        <Border Background="{x:Bind SurfaceBrush}"
                                                                BorderBrush="{x:Bind AccentBrush}"
                                                                BorderThickness="1" CornerRadius="2" Padding="6,3">
                                                            <TextBlock Text="{x:Bind KindLabel}" FontSize="9"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{x:Bind AccentBrush}"/>
                                                        </Border>
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="1" Spacing="6">
                                                        <TextBox Text="{x:Bind Note, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                 Tag="{x:Bind}"
                                                                 Background="{StaticResource InputBackgroundBrush}"
                                                                 BorderBrush="{StaticResource SubtleBorderBrush}"
                                                                 BorderThickness="1" CornerRadius="2"
                                                                 Foreground="{StaticResource PrimaryTextBrush}"
                                                                 FontSize="11" Padding="8,6"
                                                                 PlaceholderText="Note"
                                                                 KeyDown="OnBookmarkNoteKeyDown"
                                                                 LostFocus="OnBookmarkNoteLostFocus"
                                                                 TextChanged="OnBookmarkNoteTextChanged"/>

                                                        <StackPanel Orientation="Horizontal" Spacing="6"
                                                                    Visibility="{x:Bind IsClip, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                                                            <Border Background="{x:Bind SurfaceBrush}"
                                                                    BorderBrush="{x:Bind AccentBrush}"
                                                                    BorderThickness="1" CornerRadius="2" Padding="6,3">
                                                                <TextBlock Text="{x:Bind ClipRangeText}"
                                                                           FontFamily="{StaticResource MonoFont}"
                                                                           FontSize="10" FontWeight="SemiBold"
                                                                           Foreground="{x:Bind AccentBrush}"/>
                                                            </Border>
                                                            <Border Background="{x:Bind QualitySurfaceBrush}"
                                                                    BorderBrush="{x:Bind QualityAccentBrush}"
                                                                    BorderThickness="1" CornerRadius="2" Padding="6,3"
                                                                    Visibility="{x:Bind HasQuality, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                                                                <TextBlock Text="{x:Bind QualityLabel}"
                                                                           FontSize="10" FontWeight="SemiBold"
                                                                           Foreground="{x:Bind QualityAccentBrush}"/>
                                                            </Border>
                                                        </StackPanel>

                                                        <!-- Inline quality chips for clips -->
                                                        <StackPanel Orientation="Horizontal" Spacing="4"
                                                                    Visibility="{x:Bind IsClip, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                                                            <Button Tag="good" Click="OnBookmarkQualityClick"
                                                                    Background="Transparent" BorderThickness="0"
                                                                    Padding="0" MinWidth="0">
                                                                <Border CornerRadius="2" Padding="8,4"
                                                                        Background="{x:Bind GoodQualityVisual.BackgroundBrush, Mode=OneWay}"
                                                                        BorderBrush="{x:Bind GoodQualityVisual.BorderBrush, Mode=OneWay}"
                                                                        BorderThickness="{x:Bind GoodQualityVisual.BorderThickness, Mode=OneWay}">
                                                                    <TextBlock Text="Good" FontSize="10"
                                                                               Foreground="{x:Bind GoodQualityVisual.ForegroundBrush, Mode=OneWay}"/>
                                                                </Border>
                                                            </Button>
                                                            <Button Tag="neutral" Click="OnBookmarkQualityClick"
                                                                    Background="Transparent" BorderThickness="0"
                                                                    Padding="0" MinWidth="0">
                                                                <Border CornerRadius="2" Padding="8,4"
                                                                        Background="{x:Bind NeutralQualityVisual.BackgroundBrush, Mode=OneWay}"
                                                                        BorderBrush="{x:Bind NeutralQualityVisual.BorderBrush, Mode=OneWay}"
                                                                        BorderThickness="{x:Bind NeutralQualityVisual.BorderThickness, Mode=OneWay}">
                                                                    <TextBlock Text="Neutral" FontSize="10"
                                                                               Foreground="{x:Bind NeutralQualityVisual.ForegroundBrush, Mode=OneWay}"/>
                                                                </Border>
                                                            </Button>
                                                            <Button Tag="bad" Click="OnBookmarkQualityClick"
                                                                    Background="Transparent" BorderThickness="0"
                                                                    Padding="0" MinWidth="0">
                                                                <Border CornerRadius="2" Padding="8,4"
                                                                        Background="{x:Bind BadQualityVisual.BackgroundBrush, Mode=OneWay}"
                                                                        BorderBrush="{x:Bind BadQualityVisual.BorderBrush, Mode=OneWay}"
                                                                        BorderThickness="{x:Bind BadQualityVisual.BorderThickness, Mode=OneWay}">
                                                                    <TextBlock Text="Bad" FontSize="10"
                                                                               Foreground="{x:Bind BadQualityVisual.ForegroundBrush, Mode=OneWay}"/>
                                                                </Border>
                                                            </Button>
                                                        </StackPanel>
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="2" Spacing="6" VerticalAlignment="Top">
                                                        <Button Click="OnBookmarkJumpClick"
                                                                Style="{StaticResource GhostIconButtonStyle}"
                                                                Width="56" Height="30" Padding="0"
                                                                ToolTipService.ToolTip="Jump to this time">
                                                            <TextBlock Text="Jump" FontSize="10" FontWeight="SemiBold"/>
                                                        </Button>
                                                        <Button CommandParameter="{x:Bind Id}"
                                                                Click="OnDeleteBookmark"
                                                                Style="{StaticResource GhostIconButtonStyle}"
                                                                Width="56" Height="30" Padding="0">
                                                            <FontIcon Glyph="&#xE74D;" FontSize="12"
                                                                      FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"/>
                                                        </Button>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsRepeater.ItemTemplate>
                                </ItemsRepeater>
                            </ScrollViewer>
                        </Grid>
                    </controls:CornerBracketedCard>
                </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</Page>
