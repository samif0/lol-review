<Page
    x:Class="LoLReview.App.Views.ManualEntryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:converters="using:LoLReview.App.Converters"
    xmlns:vm="using:LoLReview.App.ViewModels"
    mc:Ignorable="d"
    Background="Transparent">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Spacing="12" Padding="24,20"
                    MaxWidth="700" HorizontalAlignment="Stretch">

            <!-- ═══ Champion + Result Header ═══ -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Spacing="4">
                    <TextBox Text="{x:Bind ViewModel.ChampionName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             PlaceholderText="Champion Name"
                             FontSize="26" FontWeight="Bold"
                             Background="Transparent"
                             BorderThickness="0,0,0,2"
                             BorderBrush="{StaticResource AccentGoldBrush}"
                             Foreground="{StaticResource AccentGoldBrush}"
                             Padding="0,4" MinWidth="200"/>

                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <RadioButton Content="Victory" GroupName="Result"
                                     IsChecked="{x:Bind ViewModel.IsVictory, Mode=TwoWay}"
                                     Foreground="{StaticResource WinGreenBrush}"
                                     FontSize="14" FontWeight="Bold"/>
                        <RadioButton Content="Defeat" GroupName="Result"
                                     Foreground="{StaticResource LossRedBrush}"
                                     FontSize="14" FontWeight="Bold"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" HorizontalAlignment="Right" Spacing="4">
                    <Grid ColumnSpacing="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Text="{x:Bind ViewModel.KillsText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 PlaceholderText="K" InputScope="Number"
                                 FontSize="22" FontWeight="Bold" TextAlignment="Center"
                                 Background="{StaticResource InputBackgroundBrush}"
                                 BorderBrush="{StaticResource SubtleBorderBrush}"
                                 Foreground="{StaticResource PrimaryTextBrush}"
                                 CornerRadius="2" Height="40"/>
                        <TextBlock Grid.Column="1" Text="/" FontSize="22" FontWeight="Bold"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   VerticalAlignment="Center"/>
                        <TextBox Grid.Column="2"
                                 Text="{x:Bind ViewModel.DeathsText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 PlaceholderText="D" InputScope="Number"
                                 FontSize="22" FontWeight="Bold" TextAlignment="Center"
                                 Background="{StaticResource InputBackgroundBrush}"
                                 BorderBrush="{StaticResource SubtleBorderBrush}"
                                 Foreground="{StaticResource PrimaryTextBrush}"
                                 CornerRadius="2" Height="40"/>
                        <TextBlock Grid.Column="3" Text="/" FontSize="22" FontWeight="Bold"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   VerticalAlignment="Center"/>
                        <TextBox Grid.Column="4"
                                 Text="{x:Bind ViewModel.AssistsText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 PlaceholderText="A" InputScope="Number"
                                 FontSize="22" FontWeight="Bold" TextAlignment="Center"
                                 Background="{StaticResource InputBackgroundBrush}"
                                 BorderBrush="{StaticResource SubtleBorderBrush}"
                                 Foreground="{StaticResource PrimaryTextBrush}"
                                 CornerRadius="2" Height="40"/>
                    </Grid>
                </StackPanel>
            </Grid>

            <!-- Error message -->
            <TextBlock Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                       FontSize="12" Foreground="{StaticResource LossRedBrush}"
                       Visibility="{x:Bind ViewModel.HasError, Mode=OneWay, Converter={StaticResource BoolToVis}}"/>

            <!-- Separator -->
            <Border Height="1" Background="{StaticResource SubtleBorderBrush}"/>

            <!-- ═══ Mental Rating ═══ -->
            <StackPanel Spacing="8">
                <TextBlock Text="MENTAL RATING"
                           FontSize="11" FontWeight="Bold"
                           Foreground="{StaticResource SecondaryTextBrush}"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Slider Grid.Column="0"
                            Value="{x:Bind ViewModel.MentalRating, Mode=TwoWay}"
                            Minimum="1" Maximum="10"
                            StepFrequency="1" TickFrequency="1"
                            TickPlacement="Outside"
                            VerticalAlignment="Center"/>

                    <TextBlock Grid.Column="1"
                               Text="{x:Bind ViewModel.MentalRating, Mode=OneWay}"
                               FontSize="36" FontWeight="Bold"
                               Margin="16,0,0,0"
                               VerticalAlignment="Center"
                               MinWidth="50" TextAlignment="Center"/>
                </Grid>
            </StackPanel>

            <!-- ═══ Learning Objectives ═══ -->
            <StackPanel Spacing="8"
                        Visibility="{x:Bind ViewModel.HasObjectives, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="LEARNING OBJECTIVES"
                           FontSize="11" FontWeight="Bold"
                           Foreground="{StaticResource AccentBlueBrush}"/>

                <ItemsRepeater ItemsSource="{x:Bind ViewModel.Objectives}">
                    <ItemsRepeater.Layout>
                        <StackLayout Spacing="8"/>
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="vm:ObjectiveAssessment">
                            <Border Background="{StaticResource CardBackgroundBrush}"
                                    BorderBrush="{StaticResource AccentBlueBrush}"
                                    BorderThickness="1" CornerRadius="2" Padding="14,10">
                                <StackPanel Spacing="6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Spacing="2">
                                            <TextBlock Text="{x:Bind Title}"
                                                       FontSize="13" FontWeight="Bold"
                                                       Foreground="{StaticResource PrimaryTextBrush}"
                                                       TextWrapping="Wrap"/>
                                            <TextBlock Text="{x:Bind PhaseLabel}"
                                                       FontSize="10"
                                                       Foreground="{StaticResource AccentBlueBrush}"/>
                                            <TextBlock Text="{x:Bind Criteria}"
                                                       FontSize="11"
                                                       Foreground="{StaticResource SecondaryTextBrush}"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <ToggleSwitch Grid.Column="1"
                                                      IsOn="{x:Bind Practiced, Mode=TwoWay}"
                                                      OnContent="Practiced"
                                                      OffContent="Not practiced"
                                                      VerticalAlignment="Center"/>
                                    </Grid>
                                    <TextBox Text="{x:Bind ExecutionNote, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             PlaceholderText="How did you execute on this? (optional)"
                                             FontSize="12"
                                             Background="{StaticResource InputBackgroundBrush}"
                                             BorderBrush="{StaticResource SubtleBorderBrush}"
                                             Foreground="{StaticResource PrimaryTextBrush}"
                                             CornerRadius="2" Height="32"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </StackPanel>

            <!-- Separator -->
            <Border Height="1" Background="{StaticResource SubtleBorderBrush}"/>

            <!-- ═══ Performance Review ═══ -->
            <StackPanel Spacing="10">
                <TextBlock Text="PERFORMANCE REVIEW"
                           FontSize="11" FontWeight="Bold"
                           Foreground="{StaticResource SecondaryTextBrush}"/>

                <TextBlock Text="What went well?" FontSize="13"
                           Foreground="{StaticResource PrimaryTextBrush}"/>
                <TextBox Text="{x:Bind ViewModel.WentWell, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         PlaceholderText="Good plays, decisions, mechanics..."
                         TextWrapping="Wrap" AcceptsReturn="True"
                         MinHeight="70" FontSize="13"
                         Background="{StaticResource InputBackgroundBrush}"
                         BorderBrush="{StaticResource SubtleBorderBrush}"
                         Foreground="{StaticResource PrimaryTextBrush}" CornerRadius="2"/>

                <TextBlock Text="What could improve?" FontSize="13"
                           Foreground="{StaticResource PrimaryTextBrush}"/>
                <TextBox Text="{x:Bind ViewModel.Mistakes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         PlaceholderText="Deaths, missed plays, bad decisions..."
                         TextWrapping="Wrap" AcceptsReturn="True"
                         MinHeight="70" FontSize="13"
                         Background="{StaticResource InputBackgroundBrush}"
                         BorderBrush="{StaticResource SubtleBorderBrush}"
                         Foreground="{StaticResource PrimaryTextBrush}" CornerRadius="2"/>

                <TextBlock Text="Focus for next game" FontSize="13"
                           Foreground="{StaticResource PrimaryTextBrush}"/>
                <TextBox Text="{x:Bind ViewModel.FocusNext, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         PlaceholderText="What will you focus on improving?"
                         FontSize="13" Height="36"
                         Background="{StaticResource InputBackgroundBrush}"
                         BorderBrush="{StaticResource SubtleBorderBrush}"
                         Foreground="{StaticResource PrimaryTextBrush}" CornerRadius="2"/>
            </StackPanel>

            <!-- ═══ Additional Notes ═══ -->
            <StackPanel Spacing="6">
                <TextBlock Text="ADDITIONAL NOTES"
                           FontSize="11" FontWeight="Bold"
                           Foreground="{StaticResource SecondaryTextBrush}"/>
                <TextBox Text="{x:Bind ViewModel.ReviewNotes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         PlaceholderText="Any other notes about this game..."
                         TextWrapping="Wrap" AcceptsReturn="True"
                         MinHeight="70" FontSize="13"
                         Background="{StaticResource InputBackgroundBrush}"
                         BorderBrush="{StaticResource SubtleBorderBrush}"
                         Foreground="{StaticResource PrimaryTextBrush}" CornerRadius="2"/>
            </StackPanel>

            <!-- ═══ Save / Cancel Buttons ═══ -->
            <StackPanel Orientation="Horizontal" Spacing="10"
                        HorizontalAlignment="Center" Margin="0,8,0,16">
                <Button Content="Save Game Entry" Click="OnSaveClick"
                        FontSize="14" Height="36" Padding="24,0"
                        CornerRadius="2"
                        Background="{StaticResource AccentBlueBrush}"
                        Foreground="{StaticResource ActionPrimaryForegroundBrush}" IsTabStop="False"/>
                <Button Content="Cancel" Click="OnCancelClick"
                        FontSize="14" Height="36" Padding="24,0"
                        CornerRadius="2"
                        Background="{StaticResource TagBackgroundBrush}"
                        Foreground="{StaticResource SecondaryTextBrush}"
                        BorderBrush="{StaticResource SubtleBorderBrush}"
                        BorderThickness="1" IsTabStop="False"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>
