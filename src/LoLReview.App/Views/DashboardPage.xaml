<Page
    x:Class="LoLReview.App.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:LoLReview.App.ViewModels"
    xmlns:converters="using:LoLReview.App.Converters"
    mc:Ignorable="d"
    Background="{StaticResource AppBackgroundBrush}">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <converters:WinLossColorConverter x:Key="WinLossColor"/>
        <converters:KdaColorConverter x:Key="KdaColor"/>
    </Page.Resources>

    <Grid>
        <!-- Loading overlay -->
        <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      Width="48" Height="48"
                      Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVis}}"/>

        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="24,24,24,24">
            <StackPanel Spacing="12" MaxWidth="900" HorizontalAlignment="Stretch">

                <!-- ═══ Header Row ═══ -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="{x:Bind ViewModel.Greeting, Mode=OneWay}"
                               FontSize="22" FontWeight="Bold"
                               Foreground="{StaticResource PrimaryTextBrush}"
                               VerticalAlignment="Center"/>

                    <Button Grid.Column="1"
                            Content="Review Inbox"
                            Click="ReviewInboxButton_Click"
                            Height="36"
                            Margin="0,0,8,0"
                            Padding="14,0"
                            Background="{StaticResource AccentBlueBrush}"
                            Foreground="White"
                            BorderThickness="0"
                            CornerRadius="8"/>

                    <Button Grid.Column="2"
                            Content="Tilt Reset"
                            Click="TiltResetButton_Click"
                            Height="36"
                            Margin="0,0,8,0"
                            Padding="14,0"
                            Background="{StaticResource TagBackgroundBrush}"
                            Foreground="{StaticResource PrimaryTextBrush}"
                            BorderBrush="{StaticResource SubtleBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"/>

                    <Button Grid.Column="3"
                            Command="{x:Bind ViewModel.LoadCommand}"
                            Height="36" Width="36" CornerRadius="18"
                            Padding="0"
                            Background="{StaticResource CardBackgroundBrush}"
                            BorderBrush="{StaticResource SubtleBorderBrush}"
                            ToolTipService.ToolTip="Refresh">
                        <FontIcon Glyph="&#xE72C;" FontSize="14"
                                  Foreground="{StaticResource SecondaryTextBrush}"/>
                    </Button>
                </Grid>

                <!-- ═══ Stats Cards Row ═══ -->
                <Border Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Games Today -->
                        <StackPanel Grid.Column="0" HorizontalAlignment="Center" Spacing="2">
                            <TextBlock Text="GAMES"
                                       FontSize="10" FontWeight="Bold"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="{x:Bind ViewModel.TotalGames, Mode=OneWay}"
                                       Style="{StaticResource StatValueStyle}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>

                        <!-- W / L -->
                        <StackPanel Grid.Column="1" HorizontalAlignment="Center" Spacing="2">
                            <TextBlock Text="W / L"
                                       FontSize="10" FontWeight="Bold"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="{x:Bind ViewModel.WinLossText, Mode=OneWay}"
                                       FontSize="28" FontWeight="Bold"
                                       HorizontalAlignment="Center">
                            </TextBlock>
                        </StackPanel>

                        <!-- Avg Mental -->
                        <StackPanel Grid.Column="2" HorizontalAlignment="Center" Spacing="2">
                            <TextBlock Text="AVG MENTAL"
                                       FontSize="10" FontWeight="Bold"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock FontSize="28" FontWeight="Bold"
                                       Foreground="{StaticResource AccentBlueBrush}"
                                       HorizontalAlignment="Center">
                                <Run Text="{x:Bind ViewModel.AvgMental, Mode=OneWay, TargetNullValue='--'}"/><Run Text="/10"/>
                            </TextBlock>
                        </StackPanel>

                        <!-- Adherence Streak -->
                        <StackPanel Grid.Column="3" HorizontalAlignment="Center" Spacing="2">
                            <TextBlock Text="ADHERENCE"
                                       FontSize="10" FontWeight="Bold"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock FontSize="28" FontWeight="Bold"
                                       HorizontalAlignment="Center">
                                <Run Text="{x:Bind ViewModel.AdherenceStreak, Mode=OneWay}"/><Run Text="d"/>
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ═══ Session Banner (conditional) ═══ -->
                <Border Visibility="{x:Bind ViewModel.ShowSessionBanner, Mode=OneWay, Converter={StaticResource BoolToVis}}"
                        CornerRadius="8" Padding="0,10,0,10"
                        HorizontalAlignment="Stretch">
                    <TextBlock Text="{x:Bind ViewModel.SessionBannerText, Mode=OneWay}"
                               FontSize="14" FontWeight="Bold"
                               HorizontalAlignment="Center"/>
                </Border>

                <!-- ═══ Last Focus Card ═══ -->
                <Border Visibility="{x:Bind ViewModel.HasLastFocus, Mode=OneWay, Converter={StaticResource BoolToVis}}"
                        Style="{StaticResource CardStyle}">
                    <StackPanel Spacing="6">
                        <TextBlock Text="FOCUS FOR NEXT GAME"
                                   FontSize="11" FontWeight="Bold"
                                   Foreground="{StaticResource SecondaryTextBrush}"/>
                        <TextBlock Text="{x:Bind ViewModel.LastFocus, Mode=OneWay}"
                                   FontSize="14"
                                   Foreground="{StaticResource AccentGoldBrush}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- ═══ Active Objectives Section ═══ -->
                <Border Style="{StaticResource CardStyle}"
                        Visibility="{x:Bind HasObjectives, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                    <StackPanel Spacing="8">
                        <TextBlock Text="ACTIVE OBJECTIVES"
                                   FontSize="11" FontWeight="Bold"
                                   Foreground="{StaticResource SecondaryTextBrush}"/>

                        <ItemsRepeater ItemsSource="{x:Bind ViewModel.ActiveObjectives, Mode=OneWay}">
                            <ItemsRepeater.Layout>
                                <StackLayout Spacing="6"/>
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="vm:DashboardObjectiveItem">
                                    <StackPanel Spacing="4">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="{x:Bind Title}"
                                                       FontSize="13" FontWeight="Bold"
                                                       Foreground="{StaticResource PrimaryTextBrush}"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="{x:Bind InfoText}"
                                                       FontSize="11"
                                                       Foreground="{StaticResource SecondaryTextBrush}"/>
                                        </Grid>
                                        <ProgressBar Value="{x:Bind Progress}"
                                                     Maximum="1" Minimum="0"
                                                     Height="6" CornerRadius="3"
                                                     Foreground="{x:Bind LevelColorBrush}"
                                                     Background="{StaticResource SubtleBorderBrush}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </StackPanel>
                </Border>

                <!-- ═══ Unreviewed Games Section ═══ -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel Spacing="8">
                        <!-- Header row -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="NEEDS REVIEW"
                                       FontSize="11" FontWeight="Bold"
                                       Foreground="{StaticResource SecondaryTextBrush}"/>
                            <TextBlock Grid.Column="1"
                                       Text="{x:Bind ViewModel.UnreviewedCountText, Mode=OneWay}"
                                       FontSize="11" FontWeight="Bold"/>
                        </Grid>

                        <!-- All caught up message -->
                        <TextBlock Visibility="{x:Bind ViewModel.AllReviewed, Mode=OneWay, Converter={StaticResource BoolToVis}}"
                                   Text="All caught up &#8212; every recent game has been reviewed!"
                                   FontSize="13"
                                   Foreground="{StaticResource WinGreenBrush}"/>

                        <!-- Subtitle when there are unreviewed games -->
                        <TextBlock Text="Review these before you queue up."
                                   FontSize="12"
                                   Foreground="{StaticResource SecondaryTextBrush}">
                            <TextBlock.Visibility>
                                <Binding Path="AllReviewed" Mode="OneWay" Converter="{StaticResource BoolToVis}"
                                         ConverterParameter="Inverse"/>
                            </TextBlock.Visibility>
                        </TextBlock>

                        <!-- Unreviewed game rows -->
                        <ItemsRepeater ItemsSource="{x:Bind ViewModel.UnreviewedGames, Mode=OneWay}">
                            <ItemsRepeater.Layout>
                                <StackLayout Spacing="4"/>
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="vm:GameDisplayItem">
                                    <Border Background="{StaticResource InputBackgroundBrush}"
                                            CornerRadius="6"
                                            BorderThickness="1"
                                            Padding="10,6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Left: W/L + Champion + KDA -->
                                            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8"
                                                        VerticalAlignment="Center">
                                                <TextBlock FontSize="12" FontWeight="Bold">
                                                    <Run Text="{x:Bind WinLossText}"/>
                                                    <Run Text="  "/>
                                                    <Run Text="{x:Bind ChampionName}"/>
                                                    <Run Text="   "/>
                                                    <Run Text="{x:Bind KdaText}"/>
                                                    <Run Text=" "/>
                                                    <Run Text="{x:Bind KdaRatioText}"/>
                                                </TextBlock>
                                            </StackPanel>

                                            <!-- Right: Date + Review button -->
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8"
                                                        VerticalAlignment="Center">
                                                <TextBlock Text="{x:Bind DatePlayed}"
                                                           FontSize="11"
                                                           Foreground="{StaticResource SecondaryTextBrush}"
                                                           VerticalAlignment="Center"/>
                                                <Button Content="Review"
                                                        FontSize="10" Height="24"
                                                        Padding="12,0"
                                                        CornerRadius="5"
                                                        Background="{StaticResource AccentBlueBrush}"
                                                        Foreground="{StaticResource PrimaryTextBrush}"
                                                        Tag="{x:Bind GameId}"
                                                        Click="ReviewButton_Click"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </StackPanel>
                </Border>

                <!-- ═══ Today's Games Section ═══ -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel Spacing="8">
                        <TextBlock Text="TODAY'S GAMES"
                                   FontSize="11" FontWeight="Bold"
                                   Foreground="{StaticResource SecondaryTextBrush}"/>

                        <!-- Empty state -->
                        <TextBlock Text="No games played today yet."
                                   FontSize="13"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   Visibility="{x:Bind HasNoTodaysGames, Mode=OneWay, Converter={StaticResource BoolToVis}}"/>

                        <!-- Game rows -->
                        <ItemsRepeater ItemsSource="{x:Bind ViewModel.TodaysGames, Mode=OneWay}">
                            <ItemsRepeater.Layout>
                                <StackLayout Spacing="4"/>
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="vm:GameDisplayItem">
                                    <Border Background="{StaticResource InputBackgroundBrush}"
                                            CornerRadius="6"
                                            BorderThickness="1"
                                            Padding="12,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- W/L badge -->
                                            <Border Grid.Column="0"
                                                    Width="28" Height="28"
                                                    CornerRadius="14"
                                                    Margin="0,0,10,0"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="{x:Bind WinLossText}"
                                                           FontSize="12" FontWeight="Bold"
                                                           Foreground="White"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>

                                            <!-- Champion + KDA info -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock FontSize="14" FontWeight="Bold"
                                                           Foreground="{StaticResource PrimaryTextBrush}"
                                                           Text="{x:Bind ChampionName}"/>
                                                <TextBlock FontSize="11"
                                                           Foreground="{StaticResource SecondaryTextBrush}">
                                                    <Run Text="{x:Bind KdaText}"/>
                                                    <Run Text="  "/>
                                                    <Run Text="{x:Bind KdaRatioText}"/>
                                                    <Run Text="  "/>
                                                    <Run Text="{x:Bind Duration}"/>
                                                </TextBlock>
                                            </StackPanel>

                                            <!-- Review button -->
                                            <Button Grid.Column="2"
                                                    Content="Review"
                                                    FontSize="11" Height="28"
                                                    Padding="14,0" CornerRadius="6"
                                                    Background="{StaticResource AccentBlueBrush}"
                                                    Foreground="{StaticResource PrimaryTextBrush}"
                                                    VerticalAlignment="Center"
                                                    Tag="{x:Bind GameId}"
                                                    Click="ReviewButton_Click"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </StackPanel>
                </Border>

                <!-- Bottom spacer -->
                <Border Height="24"/>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
