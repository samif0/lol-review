<Page
    x:Class="LoLReview.App.Views.TiltCheckPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:LoLReview.App.ViewModels"
    mc:Ignorable="d"
    Background="#0a0a0f">

    <Page.Resources>
        <!-- Shared styles -->
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="#12121a"/>
            <Setter Property="CornerRadius" Value="2"/>
            <Setter Property="BorderBrush" Value="#2a2a3a"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="20,18"/>
        </Style>

        <Style x:Key="PillButton" TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="MinWidth" Value="100"/>
            <Setter Property="CornerRadius" Value="2"/>
            <Setter Property="Background" Value="#1e1e2e"/>
            <Setter Property="Foreground" Value="#a0a0b8"/>
            <Setter Property="BorderBrush" Value="#2a2a3a"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style x:Key="AccentButton" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="MinWidth" Value="140"/>
            <Setter Property="CornerRadius" Value="2"/>
            <Setter Property="Background" Value="#8b5cf6"/>
            <Setter Property="Foreground" Value="#e8e8f0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,0"/>
        </Style>

        <Style x:Key="DimButton" TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="MinWidth" Value="100"/>
            <Setter Property="CornerRadius" Value="2"/>
            <Setter Property="Background" Value="#1e1e2e"/>
            <Setter Property="Foreground" Value="#a0a0b8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="16,0"/>
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#8b5cf6"/>
        </Style>

        <Style x:Key="SectionSubtitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#a0a0b8"/>
        </Style>

        <Style x:Key="CardLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#e8e8f0"/>
        </Style>

        <Style x:Key="CardHint" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#a0a0b8"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,24,24,24">
        <Grid>
            <!-- ═══════════════════════════════════════════════
                 STEP 0: CHECK IN
                 ═══════════════════════════════════════════════ -->
            <StackPanel x:Name="Step0Panel"
                        Visibility="{x:Bind IsStepVisible(ViewModel.CurrentStep, 0), Mode=OneWay}"
                        Spacing="4">

                <TextBlock Style="{StaticResource SectionTitle}" Text="TILT CHECK"/>
                <TextBlock Style="{StaticResource SectionSubtitle}" Text="A quick guided reset — takes about 2 minutes." Margin="0,0,0,20"/>

                <Border Style="{StaticResource CardBorder}" BorderBrush="#8b5cf6">
                    <StackPanel Spacing="12">
                        <TextBlock Style="{StaticResource CardLabel}" Text="How are you feeling right now?" FontSize="16"/>
                        <TextBlock Style="{StaticResource CardHint}" Text="Name it to tame it — labeling emotions reduces their intensity."/>

                        <!-- Emotion pills row 1 -->
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Style="{StaticResource PillButton}" Content="Angry"
                                    Command="{x:Bind ViewModel.SelectEmotionCommand}" CommandParameter="Angry"/>
                            <Button Style="{StaticResource PillButton}" Content="Frustrated"
                                    Command="{x:Bind ViewModel.SelectEmotionCommand}" CommandParameter="Frustrated"/>
                            <Button Style="{StaticResource PillButton}" Content="Anxious"
                                    Command="{x:Bind ViewModel.SelectEmotionCommand}" CommandParameter="Anxious"/>
                        </StackPanel>
                        <!-- Emotion pills row 2 -->
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Style="{StaticResource PillButton}" Content="Hopeless"
                                    Command="{x:Bind ViewModel.SelectEmotionCommand}" CommandParameter="Hopeless"/>
                            <Button Style="{StaticResource PillButton}" Content="Numb"
                                    Command="{x:Bind ViewModel.SelectEmotionCommand}" CommandParameter="Numb"/>
                            <Button Style="{StaticResource PillButton}" Content="Restless"
                                    Command="{x:Bind ViewModel.SelectEmotionCommand}" CommandParameter="Restless"/>
                        </StackPanel>

                        <!-- Selected emotion display -->
                        <TextBlock Text="{x:Bind ViewModel.SelectedEmotion, Mode=OneWay}"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="#8b5cf6"
                                   Visibility="{x:Bind HasText(ViewModel.SelectedEmotion), Mode=OneWay}"/>

                        <!-- Intensity slider -->
                        <TextBlock Style="{StaticResource CardLabel}" Text="Intensity" Margin="0,8,0,0"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="1" FontSize="11" Foreground="#666680" VerticalAlignment="Center"/>
                            <Slider Grid.Column="1" Minimum="1" Maximum="10" StepFrequency="1"
                                    Value="{x:Bind ViewModel.IntensityBefore, Mode=TwoWay}"
                                    Margin="8,0"/>
                            <TextBlock Grid.Column="2" Text="10" FontSize="11" Foreground="#666680" VerticalAlignment="Center"/>
                        </Grid>
                        <TextBlock Text="{x:Bind ViewModel.IntensityBeforeDisplay, Mode=OneWay}"
                                   FontSize="20" FontWeight="Bold" Foreground="#8b5cf6"/>

                        <!-- Next button -->
                        <StackPanel HorizontalAlignment="Right">
                            <Button Style="{StaticResource AccentButton}" Content="Next &#x2192;"
                                    Command="{x:Bind ViewModel.NextStepCommand}"
                                    IsEnabled="{x:Bind ViewModel.CanGoNext, Mode=OneWay}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- ═══════════════════════════════════════════════
                 STEP 1: BREATHE
                 ═══════════════════════════════════════════════ -->
            <StackPanel x:Name="Step1Panel"
                        Visibility="{x:Bind IsStepVisible(ViewModel.CurrentStep, 1), Mode=OneWay}"
                        Spacing="4">

                <TextBlock Style="{StaticResource SectionTitle}" Text="BREATHE"/>
                <TextBlock Style="{StaticResource SectionSubtitle}"
                           Text="The chemical surge of tilt lasts ~90 seconds. Let's ride it out."
                           Margin="0,0,0,20"/>

                <Border Style="{StaticResource CardBorder}" BorderBrush="#8b5cf6">
                    <StackPanel Spacing="8" HorizontalAlignment="Center">
                        <!-- Breathing circle area -->
                        <ProgressRing IsActive="{x:Bind ViewModel.IsBreathing, Mode=OneWay}"
                                      Width="120" Height="120"
                                      Foreground="#8b5cf6"
                                      Margin="0,16,0,8"/>

                        <TextBlock Text="{x:Bind ViewModel.BreathePhaseText, Mode=OneWay}"
                                   FontSize="28" FontWeight="Bold" Foreground="#e8e8f0"
                                   HorizontalAlignment="Center"/>

                        <TextBlock Text="{x:Bind ViewModel.BreatheCountdown, Mode=OneWay}"
                                   FontSize="48" FontWeight="Bold" Foreground="#8b5cf6"
                                   HorizontalAlignment="Center"/>

                        <TextBlock Text="4-7-8 breathing — exhale longer than you inhale"
                                   FontSize="11" Foreground="#a0a0b8" HorizontalAlignment="Center"/>

                        <!-- Progress bar -->
                        <ProgressBar Value="{x:Bind ViewModel.BreatheProgress, Mode=OneWay}"
                                     Maximum="1" Height="8"
                                     Foreground="#8b5cf6"
                                     Background="#2a2a3a"
                                     Margin="0,12,0,4"/>

                        <TextBlock FontSize="12" Foreground="#a0a0b8" HorizontalAlignment="Center">
                            <Run Text="Cycle "/>
                            <Run Text="{x:Bind ViewModel.CurrentCycle, Mode=OneWay}"/>
                            <Run Text=" of 5"/>
                        </TextBlock>

                        <!-- Skip -->
                        <StackPanel HorizontalAlignment="Right" Margin="0,12,0,0">
                            <Button Style="{StaticResource DimButton}" Content="Skip &#x2192;"
                                    Command="{x:Bind ViewModel.SkipBreathingCommand}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- ═══════════════════════════════════════════════
                 STEP 2: REFRAME
                 ═══════════════════════════════════════════════ -->
            <StackPanel x:Name="Step2Panel"
                        Visibility="{x:Bind IsStepVisible(ViewModel.CurrentStep, 2), Mode=OneWay}"
                        Spacing="4">

                <TextBlock Style="{StaticResource SectionTitle}" Text="REFRAME"/>
                <TextBlock Style="{StaticResource SectionSubtitle}"
                           Text="Catch the thought. Challenge it. Replace it."
                           Margin="0,0,0,20"/>

                <Border Style="{StaticResource CardBorder}" BorderBrush="#8b5cf6">
                    <StackPanel Spacing="12">
                        <TextBlock Style="{StaticResource CardLabel}" Text="What thought keeps replaying?"/>
                        <TextBlock Style="{StaticResource CardHint}"
                                   Text='e.g., "My jungler never ganked" or "I always lose lane"'/>
                        <TextBox Text="{x:Bind ViewModel.ReframeThought, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 PlaceholderText="The thought on repeat..."
                                 TextWrapping="Wrap" AcceptsReturn="True"
                                 MinHeight="60" MaxHeight="100"
                                 Background="#161622" Foreground="#e8e8f0"
                                 BorderBrush="#2a2a3a" CornerRadius="2"/>

                        <TextBlock Style="{StaticResource CardLabel}" Text="Is this a fact, or an interpretation?" Margin="0,8,0,0"/>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Style="{StaticResource PillButton}" Content="Fact" MinWidth="130"
                                    Command="{x:Bind ViewModel.SelectThoughtTypeCommand}" CommandParameter="Fact"/>
                            <Button Style="{StaticResource PillButton}" Content="Interpretation" MinWidth="130"
                                    Command="{x:Bind ViewModel.SelectThoughtTypeCommand}" CommandParameter="Interpretation"/>
                        </StackPanel>

                        <TextBlock Style="{StaticResource CardLabel}"
                                   Text="What would you tell a friend who said this about their game?"
                                   Margin="0,8,0,0"/>
                        <TextBlock Style="{StaticResource CardHint}" Text="Respond with the same kindness you'd give a teammate."/>
                        <TextBox Text="{x:Bind ViewModel.ReframeResponse, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 PlaceholderText="What you'd tell a friend..."
                                 TextWrapping="Wrap" AcceptsReturn="True"
                                 MinHeight="60" MaxHeight="100"
                                 Background="#161622" Foreground="#e8e8f0"
                                 BorderBrush="#2a2a3a" CornerRadius="2"/>

                        <!-- Buttons -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                            <Button Style="{StaticResource AccentButton}" Content="Next &#x2192;"
                                    Command="{x:Bind ViewModel.NextStepCommand}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- ═══════════════════════════════════════════════
                 STEP 3: RESET
                 ═══════════════════════════════════════════════ -->
            <StackPanel x:Name="Step3Panel"
                        Visibility="{x:Bind IsStepVisible(ViewModel.CurrentStep, 3), Mode=OneWay}"
                        Spacing="4">

                <TextBlock Style="{StaticResource SectionTitle}" Text="RESET"/>
                <TextBlock Style="{StaticResource SectionSubtitle}"
                           Text="That game is over. Set your intention for the next one."
                           Margin="0,0,0,20"/>

                <Border Style="{StaticResource CardBorder}" BorderBrush="#8b5cf6">
                    <StackPanel Spacing="12">
                        <TextBlock Style="{StaticResource CardLabel}" Text="Pick one word for your next game:"/>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Style="{StaticResource PillButton}" Content="Calm"
                                    Command="{x:Bind ViewModel.SelectCueWordCommand}" CommandParameter="Calm"/>
                            <Button Style="{StaticResource PillButton}" Content="Patient"
                                    Command="{x:Bind ViewModel.SelectCueWordCommand}" CommandParameter="Patient"/>
                            <Button Style="{StaticResource PillButton}" Content="Focused"
                                    Command="{x:Bind ViewModel.SelectCueWordCommand}" CommandParameter="Focused"/>
                            <Button Style="{StaticResource PillButton}" Content="Aggressive"
                                    Command="{x:Bind ViewModel.SelectCueWordCommand}" CommandParameter="Aggressive"/>
                            <Button Style="{StaticResource PillButton}" Content="Clean"
                                    Command="{x:Bind ViewModel.SelectCueWordCommand}" CommandParameter="Clean"/>
                            <Button Style="{StaticResource PillButton}" Content="Fun"
                                    Command="{x:Bind ViewModel.SelectCueWordCommand}" CommandParameter="Fun"/>
                        </StackPanel>

                        <!-- Selected cue word -->
                        <TextBlock Text="{x:Bind ViewModel.SelectedCueWord, Mode=OneWay}"
                                   FontSize="14" FontWeight="SemiBold" Foreground="#8b5cf6"
                                   Visibility="{x:Bind HasText(ViewModel.SelectedCueWord), Mode=OneWay}"/>

                        <TextBlock Style="{StaticResource CardLabel}"
                                   Text="What's ONE thing in your control to focus on?"
                                   Margin="0,8,0,0"/>
                        <TextBlock Style="{StaticResource CardHint}"
                                   Text='e.g., "CS better in the first 10 minutes" or "Track enemy jungler"'/>
                        <TextBox Text="{x:Bind ViewModel.FocusIntention, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 PlaceholderText="One specific, controllable thing..."
                                 Background="#161622" Foreground="#e8e8f0"
                                 BorderBrush="#2a2a3a" CornerRadius="2"
                                 Height="38"/>

                        <StackPanel HorizontalAlignment="Right">
                            <Button Style="{StaticResource AccentButton}" Content="Finish"
                                    Command="{x:Bind ViewModel.NextStepCommand}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- ═══════════════════════════════════════════════
                 STEP 4: DONE
                 ═══════════════════════════════════════════════ -->
            <StackPanel x:Name="Step4Panel"
                        Visibility="{x:Bind IsStepVisible(ViewModel.CurrentStep, 4), Mode=OneWay}"
                        Spacing="4">

                <TextBlock Text="DONE" FontSize="22" FontWeight="Bold" Foreground="#22c55e" Margin="0,0,0,20"/>

                <Border Style="{StaticResource CardBorder}" BorderBrush="#22c55e">
                    <StackPanel Spacing="12">
                        <!-- Summary -->
                        <TextBlock FontSize="14" Foreground="#e8e8f0">
                            <Run Text="You were feeling: "/>
                            <Run Text="{x:Bind ViewModel.SelectedEmotion, Mode=OneWay}" FontWeight="SemiBold"/>
                            <Run Text=" ("/>
                            <Run Text="{x:Bind ViewModel.IntensityBefore, Mode=OneWay}"/>
                            <Run Text="/10)"/>
                        </TextBlock>

                        <!-- After intensity -->
                        <TextBlock Style="{StaticResource CardLabel}" Text="How intense is the feeling now?"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="1" FontSize="11" Foreground="#666680" VerticalAlignment="Center"/>
                            <Slider Grid.Column="1" Minimum="1" Maximum="10" StepFrequency="1"
                                    Value="{x:Bind ViewModel.IntensityAfter, Mode=TwoWay}"
                                    Margin="8,0"/>
                            <TextBlock Grid.Column="2" Text="10" FontSize="11" Foreground="#666680" VerticalAlignment="Center"/>
                        </Grid>
                        <TextBlock Text="{x:Bind ViewModel.IntensityAfterDisplay, Mode=OneWay}"
                                   FontSize="20" FontWeight="Bold" Foreground="#22c55e"/>

                        <!-- Result message -->
                        <TextBlock Text="{x:Bind ViewModel.ResultMessage, Mode=OneWay}"
                                   FontSize="13" TextWrapping="Wrap"
                                   Foreground="{x:Bind ViewModel.ResultColor, Mode=OneWay}"/>

                        <!-- Encouragement -->
                        <TextBlock Text="Every pro tilts. The difference is what you do next."
                                   FontSize="13" FontStyle="Italic" Foreground="#a0a0b8"
                                   Margin="0,8,0,0"/>

                        <!-- Action buttons -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,12,0,0">
                            <Button Style="{StaticResource DimButton}" Content="Start Over"
                                    Command="{x:Bind ViewModel.StartOverCommand}"/>
                            <Button Style="{StaticResource AccentButton}" Content="Save &amp; Close"
                                    Command="{x:Bind ViewModel.SaveAndCloseCommand}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
