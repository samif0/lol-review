<Page
    x:Class="LoLReview.App.Views.TiltCheckPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:LoLReview.App.ViewModels"
    xmlns:controls="using:LoLReview.App.Controls"
    xmlns:converters="using:LoLReview.App.Converters"
    mc:Ignorable="d"
    Background="Transparent">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>

        <!-- HUD emotion chip: bordered outline, heading font for readability. -->
        <Style x:Key="HudChipStyle" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="MinWidth" Value="110"/>
            <Setter Property="CornerRadius" Value="2"/>
            <Setter Property="Background" Value="{StaticResource TagBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrightBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="FontFamily" Value="{StaticResource HeadingFont}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- HUD menu row: left-aligned, full-width card-style row button. -->
        <Style x:Key="HudMenuButtonStyle" TargetType="Button">
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="MinHeight" Value="46"/>
            <Setter Property="CornerRadius" Value="2"/>
            <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource SubtleBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontFamily" Value="{StaticResource BodyFont}"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
    </Page.Resources>

    <ScrollViewer x:Name="RootScroll"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Spacing="18" Padding="40,20,40,40"
                    MaxWidth="680" HorizontalAlignment="Center">

            <!-- Hero -->
            <controls:HeroHeader EyebrowText="MENTAL RECOVERY"
                                 Title="Tilt Check"
                                 Subtitle="A ~3.5-MINUTE GUIDED RESET"/>

            <Grid>

                <!-- ══════════════════════════════════════════════════════
                     STEP 0 — NAME IT
                     ══════════════════════════════════════════════════════ -->
                <StackPanel x:Name="Step0Panel"
                            Spacing="14"
                            Visibility="{x:Bind IsStepVisible(ViewModel.CurrentStep, 0), Mode=OneWay}">

                    <controls:CornerBracketedCard
                        CardBorderBrush="{StaticResource AccentPurpleBrush}">
                        <StackPanel Spacing="14">
                            <controls:SectionTitle Text="NAME IT"/>
                            <TextBlock Text="Pick up to 3 labels that fit right now. Labeling beats venting."
                                       FontFamily="{StaticResource BodyFont}"
                                       FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       TextWrapping="Wrap"/>

                            <!-- Rotating chip grid -->
                            <ItemsControl ItemsSource="{x:Bind ViewModel.Emotions, Mode=OneWay}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <VariableSizedWrapGrid Orientation="Horizontal"
                                                               ItemHeight="46"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:EmotionOption">
                                        <Button Style="{StaticResource HudChipStyle}"
                                                Margin="0,0,8,8"
                                                Tag="{x:Bind Name}"
                                                Click="OnEmotionChipClick">
                                            <TextBlock Text="{x:Bind Name}"
                                                       TextWrapping="NoWrap"
                                                       TextTrimming="None"/>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Selected labels readout -->
                            <TextBlock Text="{x:Bind ViewModel.SelectedEmotion, Mode=OneWay}"
                                       FontFamily="{StaticResource HeadingFont}"
                                       FontSize="{Binding Subtitle, Source={StaticResource FontSizes}}"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentBlueBrush}"
                                       TextWrapping="Wrap"
                                       Visibility="{x:Bind HasText(ViewModel.SelectedEmotion), Mode=OneWay}"/>

                            <!-- Intensity slider -->
                            <TextBlock Text="INTENSITY"
                                       FontFamily="{StaticResource MonoFont}"
                                       FontSize="{Binding Caption, Source={StaticResource FontSizes}}"
                                       CharacterSpacing="250"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       Margin="0,8,0,0"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Slider Grid.Column="0"
                                        Value="{x:Bind ViewModel.IntensityBefore, Mode=TwoWay}"
                                        Minimum="1" Maximum="10"
                                        StepFrequency="1"
                                        TickFrequency="1"
                                        TickPlacement="Outside"
                                        VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1"
                                           Text="{x:Bind ViewModel.IntensityBefore, Mode=OneWay}"
                                           FontFamily="{StaticResource DisplayFont}"
                                           FontSize="{Binding HeroLarge, Source={StaticResource FontSizes}}"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource AccentBlueBrush}"
                                           Margin="16,0,0,0"
                                           VerticalAlignment="Center"
                                           MinWidth="50"
                                           TextAlignment="Center"/>
                            </Grid>

                            <StackPanel HorizontalAlignment="Right">
                                <Button Content="NEXT →"
                                        Style="{StaticResource PrimaryActionButtonStyle}"
                                        Command="{x:Bind ViewModel.NextStepCommand}"
                                        IsEnabled="{x:Bind ViewModel.CanGoNext, Mode=OneWay}"/>
                            </StackPanel>
                        </StackPanel>
                    </controls:CornerBracketedCard>
                </StackPanel>

                <!-- ══════════════════════════════════════════════════════
                     STEP 1 — BREATHE
                     ══════════════════════════════════════════════════════ -->
                <StackPanel x:Name="Step1Panel"
                            Spacing="14"
                            Visibility="{x:Bind IsStepVisible(ViewModel.CurrentStep, 1), Mode=OneWay}">

                    <controls:CornerBracketedCard
                        CardBorderBrush="{StaticResource AccentBlueBrush}">
                        <StackPanel Spacing="14">
                            <controls:SectionTitle Text="BREATHE"/>
                            <TextBlock Text="Cyclic sighing — exhale longer than you inhale. 80 seconds."
                                       FontFamily="{StaticResource BodyFont}"
                                       FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       TextWrapping="Wrap"/>

                            <!-- Big centered ring with phase label inside -->
                            <Grid Height="220" Margin="0,8,0,0">
                                <controls:HudProgressRing
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Width="200" Height="200"
                                    Progress="{x:Bind ViewModel.BreatheProgress, Mode=OneWay}"
                                    Label="{x:Bind ViewModel.BreathePhaseText, Mode=OneWay}"
                                    AccentBrush="{StaticResource AccentBlueBrush}"/>
                                <TextBlock Text="{x:Bind ViewModel.BreatheCountdown, Mode=OneWay}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Bottom"
                                           Margin="0,0,0,8"
                                           FontFamily="{StaticResource MonoFont}"
                                           FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                           Foreground="{StaticResource SecondaryTextBrush}"/>
                            </Grid>

                            <TextBlock Text="Double-inhale through nose, long exhale through mouth."
                                       HorizontalAlignment="Center"
                                       FontFamily="{StaticResource BodyFont}"
                                       FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       TextWrapping="Wrap"/>

                            <ProgressBar Value="{x:Bind ViewModel.BreatheProgress, Mode=OneWay}"
                                         Maximum="1" Height="4"
                                         Foreground="{StaticResource AccentBlueBrush}"
                                         Background="{StaticResource SubtleBorderBrush}"
                                         Margin="0,4,0,0"/>

                            <TextBlock HorizontalAlignment="Center"
                                       FontFamily="{StaticResource MonoFont}"
                                       FontSize="{Binding Caption, Source={StaticResource FontSizes}}"
                                       CharacterSpacing="200"
                                       Foreground="{StaticResource MutedTextBrush}">
                                <Run Text="CYCLE"/>
                                <Run Text="{x:Bind ViewModel.CurrentCycle, Mode=OneWay}"/>
                            </TextBlock>

                            <StackPanel HorizontalAlignment="Right" Margin="0,4,0,0">
                                <Button Content="SKIP →"
                                        Style="{StaticResource SecondaryActionButtonStyle}"
                                        Command="{x:Bind ViewModel.SkipBreathingCommand}"/>
                            </StackPanel>
                        </StackPanel>
                    </controls:CornerBracketedCard>
                </StackPanel>

                <!-- ══════════════════════════════════════════════════════
                     STEP 2 — REFRAME
                     ══════════════════════════════════════════════════════ -->
                <StackPanel x:Name="Step2Panel"
                            Spacing="14"
                            Visibility="{x:Bind IsStepVisible(ViewModel.CurrentStep, 2), Mode=OneWay}">

                    <controls:CornerBracketedCard
                        CardBorderBrush="{StaticResource AccentGoldBrush}">
                        <StackPanel Spacing="14">
                            <controls:SectionTitle Text="REFRAME"/>
                            <TextBlock Text="Pick the one that lands. You can't argue the feeling away — you can shift the frame."
                                       FontFamily="{StaticResource BodyFont}"
                                       FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       TextWrapping="Wrap"/>

                            <ItemsControl ItemsSource="{x:Bind ViewModel.ReappraisalOptions, Mode=OneWay}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Spacing="8"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="x:String">
                                        <Button Style="{StaticResource HudMenuButtonStyle}"
                                                Content="{x:Bind}"
                                                Tag="{x:Bind}"
                                                Click="OnReframeClick"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Selected reframe readout -->
                            <StackPanel Spacing="4"
                                        Margin="0,6,0,0"
                                        Visibility="{x:Bind HasText(ViewModel.ReframeResponse), Mode=OneWay}">
                                <TextBlock Text="SELECTED"
                                           FontFamily="{StaticResource MonoFont}"
                                           FontSize="{Binding Caption, Source={StaticResource FontSizes}}"
                                           CharacterSpacing="250"
                                           Foreground="{StaticResource MutedTextBrush}"/>
                                <TextBlock Text="{x:Bind ViewModel.ReframeResponse, Mode=OneWay}"
                                           FontFamily="{StaticResource BodyFont}"
                                           FontSize="{Binding BodyEmphasis, Source={StaticResource FontSizes}}"
                                           Foreground="{StaticResource AccentGoldBrush}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>

                            <StackPanel HorizontalAlignment="Right">
                                <Button Content="NEXT →"
                                        Style="{StaticResource PrimaryActionButtonStyle}"
                                        Command="{x:Bind ViewModel.NextStepCommand}"/>
                            </StackPanel>
                        </StackPanel>
                    </controls:CornerBracketedCard>
                </StackPanel>

                <!-- ══════════════════════════════════════════════════════
                     STEP 3 — PLAN (if-then)
                     ══════════════════════════════════════════════════════ -->
                <StackPanel x:Name="Step3Panel"
                            Spacing="14"
                            Visibility="{x:Bind IsStepVisible(ViewModel.CurrentStep, 3), Mode=OneWay}">

                    <controls:CornerBracketedCard
                        CardBorderBrush="{StaticResource AccentPurpleBrush}">
                        <StackPanel Spacing="14">
                            <controls:SectionTitle Text="PLAN"/>
                            <TextBlock Text="One trigger, one response. 'If X then Y' beats willpower."
                                       FontFamily="{StaticResource BodyFont}"
                                       FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       TextWrapping="Wrap"/>

                            <!-- IF -->
                            <TextBlock Text="IF…"
                                       FontFamily="{StaticResource MonoFont}"
                                       FontSize="{Binding Caption, Source={StaticResource FontSizes}}"
                                       CharacterSpacing="250"
                                       Foreground="{StaticResource AccentBlueBrush}"
                                       Margin="0,4,0,0"/>
                            <ItemsControl ItemsSource="{x:Bind ViewModel.IfThenTriggers, Mode=OneWay}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Spacing="8"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="x:String">
                                        <Button Style="{StaticResource HudMenuButtonStyle}"
                                                Content="{x:Bind}"
                                                Tag="{x:Bind}"
                                                Click="OnTriggerClick"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- THEN -->
                            <TextBlock Text="THEN…"
                                       FontFamily="{StaticResource MonoFont}"
                                       FontSize="{Binding Caption, Source={StaticResource FontSizes}}"
                                       CharacterSpacing="250"
                                       Foreground="{StaticResource AccentGoldBrush}"
                                       Margin="0,6,0,0"/>
                            <ItemsControl ItemsSource="{x:Bind ViewModel.IfThenResponses, Mode=OneWay}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Spacing="8"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="x:String">
                                        <Button Style="{StaticResource HudMenuButtonStyle}"
                                                Content="{x:Bind}"
                                                Tag="{x:Bind}"
                                                Click="OnResponseClick"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Your plan -->
                            <StackPanel Spacing="4"
                                        Margin="0,6,0,0"
                                        Visibility="{x:Bind HasText(ViewModel.IfThenPlan), Mode=OneWay}">
                                <TextBlock Text="YOUR PLAN"
                                           FontFamily="{StaticResource MonoFont}"
                                           FontSize="{Binding Caption, Source={StaticResource FontSizes}}"
                                           CharacterSpacing="250"
                                           Foreground="{StaticResource MutedTextBrush}"/>
                                <TextBlock Text="{x:Bind ViewModel.IfThenPlan, Mode=OneWay}"
                                           FontFamily="{StaticResource HeadingFont}"
                                           FontSize="{Binding BodyEmphasis, Source={StaticResource FontSizes}}"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource AccentBlueBrush}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>

                            <StackPanel HorizontalAlignment="Right">
                                <Button Content="NEXT →"
                                        Style="{StaticResource PrimaryActionButtonStyle}"
                                        Command="{x:Bind ViewModel.NextStepCommand}"/>
                            </StackPanel>
                        </StackPanel>
                    </controls:CornerBracketedCard>
                </StackPanel>

                <!-- ══════════════════════════════════════════════════════
                     STEP 4 — DONE / POST-RATE
                     ══════════════════════════════════════════════════════ -->
                <StackPanel x:Name="Step4Panel"
                            Spacing="14"
                            Visibility="{x:Bind IsStepVisible(ViewModel.CurrentStep, 4), Mode=OneWay}">

                    <controls:CornerBracketedCard
                        CardBorderBrush="{StaticResource WinGreenBrush}">
                        <StackPanel Spacing="14">
                            <controls:SectionTitle Text="DONE"/>

                            <!-- You labeled summary -->
                            <TextBlock FontFamily="{StaticResource BodyFont}"
                                       FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                       Foreground="{StaticResource PrimaryTextBrush}"
                                       TextWrapping="Wrap">
                                <Run Text="You labeled: "/>
                                <Run Text="{x:Bind ViewModel.SelectedEmotion, Mode=OneWay}"
                                     FontWeight="SemiBold"/>
                            </TextBlock>

                            <!-- BEFORE → AFTER big-number display -->
                            <Grid Margin="0,4,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- BEFORE -->
                                <StackPanel Grid.Column="0"
                                            Spacing="2"
                                            HorizontalAlignment="Center">
                                    <TextBlock Text="BEFORE"
                                               FontFamily="{StaticResource MonoFont}"
                                               FontSize="{Binding Caption, Source={StaticResource FontSizes}}"
                                               CharacterSpacing="250"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="{x:Bind ViewModel.IntensityBefore, Mode=OneWay}"
                                               FontFamily="{StaticResource DisplayFont}"
                                               FontSize="{Binding Display, Source={StaticResource FontSizes}}"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource LossRedBrush}"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>

                                <!-- arrow -->
                                <TextBlock Grid.Column="1"
                                           Text="→"
                                           FontFamily="{StaticResource DisplayFont}"
                                           FontSize="{Binding Hero, Source={StaticResource FontSizes}}"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           VerticalAlignment="Center"
                                           Margin="12,0"/>

                                <!-- AFTER -->
                                <StackPanel Grid.Column="2"
                                            Spacing="2"
                                            HorizontalAlignment="Center">
                                    <TextBlock Text="AFTER"
                                               FontFamily="{StaticResource MonoFont}"
                                               FontSize="{Binding Caption, Source={StaticResource FontSizes}}"
                                               CharacterSpacing="250"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="{x:Bind ViewModel.IntensityAfter, Mode=OneWay}"
                                               FontFamily="{StaticResource DisplayFont}"
                                               FontSize="{Binding Display, Source={StaticResource FontSizes}}"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource WinGreenBrush}"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Grid>

                            <!-- After slider -->
                            <TextBlock Text="HOW INTENSE IS THE FEELING NOW?"
                                       FontFamily="{StaticResource MonoFont}"
                                       FontSize="{Binding Caption, Source={StaticResource FontSizes}}"
                                       CharacterSpacing="250"
                                       Foreground="{StaticResource SecondaryTextBrush}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Slider Grid.Column="0"
                                        Value="{x:Bind ViewModel.IntensityAfter, Mode=TwoWay}"
                                        Minimum="1" Maximum="10"
                                        StepFrequency="1"
                                        TickFrequency="1"
                                        TickPlacement="Outside"
                                        VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1"
                                           Text="{x:Bind ViewModel.IntensityAfter, Mode=OneWay}"
                                           FontFamily="{StaticResource DisplayFont}"
                                           FontSize="{Binding HeroLarge, Source={StaticResource FontSizes}}"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource WinGreenBrush}"
                                           Margin="16,0,0,0"
                                           VerticalAlignment="Center"
                                           MinWidth="50"
                                           TextAlignment="Center"/>
                            </Grid>

                            <!-- Result message with VM-computed color -->
                            <TextBlock Text="{x:Bind ViewModel.ResultMessage, Mode=OneWay}"
                                       FontFamily="{StaticResource BodyFont}"
                                       FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                       Foreground="{x:Bind ViewModel.ResultColor, Mode=OneWay}"
                                       TextWrapping="Wrap"/>

                            <!-- Actions -->
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        Spacing="8"
                                        Margin="0,8,0,0">
                                <Button Content="START OVER"
                                        Style="{StaticResource SecondaryActionButtonStyle}"
                                        Command="{x:Bind ViewModel.StartOverCommand}"/>
                                <Button Content="SAVE &amp; CLOSE"
                                        Style="{StaticResource PrimaryActionButtonStyle}"
                                        Command="{x:Bind ViewModel.SaveAndCloseCommand}"/>
                            </StackPanel>
                        </StackPanel>
                    </controls:CornerBracketedCard>
                </StackPanel>

            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>
