<Page
    x:Class="LoLReview.App.Views.PostGamePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:converters="using:LoLReview.App.Converters"
    xmlns:controls="using:LoLReview.App.Controls"
    xmlns:vm="using:LoLReview.App.ViewModels"
    mc:Ignorable="d"
    Background="Transparent">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Spacing="12" Padding="24,20"
                    Width="700" HorizontalAlignment="Center">

            <!-- ═══ Champion + Result Header ═══ -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="{x:Bind ReviewVM.ChampionName, Mode=OneWay}"
                               FontSize="28" FontWeight="Bold"
                               Foreground="{StaticResource AccentGoldBrush}"/>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="{x:Bind ReviewVM.ResultText, Mode=OneWay}"
                                   FontSize="16" FontWeight="Bold"/>
                        <TextBlock FontSize="13"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   VerticalAlignment="Center">
                            <Run Text="{x:Bind ReviewVM.DurationText, Mode=OneWay}"/>
                            <Run Text="  "/>
                            <Run Text="{x:Bind ReviewVM.GameModeText, Mode=OneWay}"/>
                        </TextBlock>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                    <TextBlock Text="{x:Bind ReviewVM.KdaText, Mode=OneWay}"
                               FontSize="26" FontWeight="Bold"
                               Foreground="{StaticResource PrimaryTextBrush}"
                               HorizontalAlignment="Right"/>
                    <TextBlock Text="{x:Bind ReviewVM.KdaRatioText, Mode=OneWay}"
                               FontSize="13"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               HorizontalAlignment="Right"/>
                </StackPanel>
            </Grid>

            <!-- Separator -->
            <Border Height="1" Background="{StaticResource SubtleBorderBrush}"/>

            <!-- ═══ VOD Section ═══ -->
            <Border Visibility="{x:Bind ReviewVM.HasVod, Mode=OneWay, Converter={StaticResource BoolToVis}}"
                    Background="{StaticResource CardBackgroundBrush}"
                    CornerRadius="8"
                    Padding="14,12"
                    BorderThickness="1"
                    BorderBrush="{StaticResource AccentGoldBrush}">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <Button Command="{x:Bind ReviewVM.WatchVodCommand}"
                            FontSize="13" FontWeight="SemiBold"
                            Height="36" Padding="16,0"
                            Background="{StaticResource AccentGoldDimBrush}"
                            Foreground="{StaticResource AccentGoldBrush}"
                            BorderBrush="{StaticResource AccentGoldBrush}"
                            BorderThickness="1">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE714;" FontSize="14"/>
                            <TextBlock Text="Review VOD" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <TextBlock FontSize="12"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               VerticalAlignment="Center">
                        <Run Text="{x:Bind ReviewVM.BookmarkCount, Mode=OneWay}"/>
                        <Run Text=" bookmarks"/>
                    </TextBlock>
                </StackPanel>
            </Border>

            <Border Background="{StaticResource CardBackgroundBrush}"
                    CornerRadius="8"
                    Padding="14,12"
                    BorderThickness="1"
                    BorderBrush="{StaticResource SubtleBorderBrush}">
                <StackPanel Spacing="6">
                    <TextBlock Text="SAVE MODE"
                               FontSize="11" FontWeight="Bold"
                               Foreground="{StaticResource SecondaryTextBrush}"/>
                    <TextBlock Text="{x:Bind ReviewVM.SaveBehaviorText, Mode=OneWay}"
                               FontSize="12"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               TextWrapping="Wrap"/>
                    <TextBlock Text="{x:Bind ReviewVM.ValidationMessage, Mode=OneWay}"
                               FontSize="12"
                               Foreground="{StaticResource LossRedBrush}"
                               TextWrapping="Wrap"
                               Visibility="{x:Bind ReviewVM.HasValidationMessage, Mode=OneWay, Converter={StaticResource BoolToVis}}"/>
                </StackPanel>
            </Border>

            <Border Visibility="{x:Bind ReviewVM.HasPriorityObjective, Mode=OneWay, Converter={StaticResource BoolToVis}}"
                    Background="{StaticResource CardBackgroundBrush}"
                    BorderBrush="{StaticResource AccentGoldBrush}"
                    BorderThickness="2"
                    CornerRadius="8"
                    Padding="14,12">
                <StackPanel Spacing="4">
                    <TextBlock Text="PRIORITY OBJECTIVE"
                               FontSize="11"
                               FontWeight="Bold"
                               Foreground="{StaticResource AccentGoldBrush}"/>
                    <TextBlock Text="{x:Bind ReviewVM.PriorityObjectiveTitle, Mode=OneWay}"
                               FontSize="14"
                               FontWeight="Bold"
                               Foreground="{StaticResource PrimaryTextBrush}"
                               TextWrapping="Wrap"/>
                    <TextBlock Text="{x:Bind ReviewVM.PriorityObjectiveCriteria, Mode=OneWay}"
                               FontSize="12"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- ═══ Stats Grid ═══ -->
            <TextBlock Text="GAME STATS"
                       FontSize="11" FontWeight="Bold"
                       Foreground="{StaticResource SecondaryTextBrush}"/>

            <Grid ColumnSpacing="8" RowSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <controls:StatCard Grid.Row="0" Grid.Column="0"
                                   Label="DAMAGE" Value="{x:Bind ReviewVM.DamageText, Mode=OneWay}"/>
                <controls:StatCard Grid.Row="0" Grid.Column="1"
                                   Label="CS" Value="{x:Bind ReviewVM.CsText, Mode=OneWay}"/>
                <controls:StatCard Grid.Row="0" Grid.Column="2"
                                   Label="CS/MIN" Value="{x:Bind ReviewVM.CsPerMinText, Mode=OneWay}"/>
                <controls:StatCard Grid.Row="0" Grid.Column="3"
                                   Label="VISION" Value="{x:Bind ReviewVM.VisionText, Mode=OneWay}"/>

                <controls:StatCard Grid.Row="1" Grid.Column="0"
                                   Label="GOLD" Value="{x:Bind ReviewVM.GoldText, Mode=OneWay}"/>
                <controls:StatCard Grid.Row="1" Grid.Column="1"
                                   Label="KILL PART." Value="{x:Bind ReviewVM.KillParticipationText, Mode=OneWay}"/>
                <controls:StatCard Grid.Row="1" Grid.Column="2"
                                   Label="DMG TAKEN" Value="{x:Bind ReviewVM.DamageTakenText, Mode=OneWay}"/>
                <controls:StatCard Grid.Row="1" Grid.Column="3"
                                   Label="WARDS" Value="{x:Bind ReviewVM.WardsPlacedText, Mode=OneWay}"/>
            </Grid>

            <!-- Separator -->
            <Border Height="1" Background="{StaticResource SubtleBorderBrush}"/>

            <!-- ═══ Mental Rating ═══ -->
            <StackPanel Spacing="8">
                <TextBlock Text="MENTAL RATING"
                           FontSize="11" FontWeight="Bold"
                           Foreground="{StaticResource SecondaryTextBrush}"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Slider Grid.Column="0"
                            Value="{x:Bind ReviewVM.MentalRating, Mode=TwoWay}"
                            Minimum="1" Maximum="10"
                            StepFrequency="1" TickFrequency="1"
                            TickPlacement="Outside"
                            VerticalAlignment="Center"/>

                    <TextBlock Grid.Column="1"
                               Text="{x:Bind ReviewVM.MentalRating, Mode=OneWay}"
                               FontSize="36" FontWeight="Bold"
                               Margin="16,0,0,0"
                               VerticalAlignment="Center"
                               MinWidth="50" TextAlignment="Center"/>
                </Grid>
            </StackPanel>

            <!-- ═══ Mental Reflection ═══ -->
            <Border Visibility="{x:Bind ReviewVM.ShowMentalReflection, Mode=OneWay, Converter={StaticResource BoolToVis}}"
                    Background="{StaticResource CardBackgroundBrush}"
                    BorderBrush="{StaticResource AccentPurpleBrush}"
                    BorderThickness="2" CornerRadius="8" Padding="16">
                <StackPanel Spacing="8">
                    <TextBlock Text="MENTAL REFLECTION"
                               FontSize="11" FontWeight="Bold"
                               Foreground="{StaticResource AccentPurpleBrush}"/>

                    <TextBlock Text="What triggered the tilt?"
                               FontSize="13" Foreground="{StaticResource PrimaryTextBrush}"/>
                    <TextBox Text="{x:Bind ReviewVM.MentalHandled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             PlaceholderText="What happened and how did you handle it?"
                             TextWrapping="Wrap" AcceptsReturn="True"
                             MinHeight="60" FontSize="13"
                             Background="{StaticResource InputBackgroundBrush}"
                             BorderBrush="{StaticResource SubtleBorderBrush}"
                             Foreground="{StaticResource PrimaryTextBrush}" CornerRadius="8"/>
                </StackPanel>
            </Border>

            <!-- ═══ Performance Review ═══ -->
            <StackPanel Spacing="10">
                <TextBlock Text="PERFORMANCE REVIEW"
                           FontSize="11" FontWeight="Bold"
                           Foreground="{StaticResource SecondaryTextBrush}"/>

                <TextBlock Text="What went well?" FontSize="13"
                           Foreground="{StaticResource PrimaryTextBrush}"/>
                <TextBox Text="{x:Bind ReviewVM.WentWell, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         PlaceholderText="Good plays, decisions, mechanics..."
                         TextWrapping="Wrap" AcceptsReturn="True"
                         MinHeight="70" FontSize="13"
                         Background="{StaticResource InputBackgroundBrush}"
                         BorderBrush="{StaticResource SubtleBorderBrush}"
                         Foreground="{StaticResource PrimaryTextBrush}" CornerRadius="8"/>

                <TextBlock Text="What could improve?" FontSize="13"
                           Foreground="{StaticResource PrimaryTextBrush}"/>
                <TextBox Text="{x:Bind ReviewVM.Mistakes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         PlaceholderText="Deaths, missed plays, bad decisions..."
                         TextWrapping="Wrap" AcceptsReturn="True"
                         MinHeight="70" FontSize="13"
                         Background="{StaticResource InputBackgroundBrush}"
                         BorderBrush="{StaticResource SubtleBorderBrush}"
                         Foreground="{StaticResource PrimaryTextBrush}" CornerRadius="8"/>

                <TextBlock Text="Focus for next game" FontSize="13"
                           Foreground="{StaticResource PrimaryTextBrush}"/>
                <TextBox Text="{x:Bind ReviewVM.FocusNext, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         PlaceholderText="What will you focus on improving?"
                         FontSize="13" Height="36"
                         Background="{StaticResource InputBackgroundBrush}"
                         BorderBrush="{StaticResource SubtleBorderBrush}"
                         Foreground="{StaticResource PrimaryTextBrush}" CornerRadius="8"/>
            </StackPanel>

            <!-- ═══ Quick Note ═══ -->
            <Border Background="{StaticResource CardBackgroundBrush}"
                    CornerRadius="8"
                    Padding="14,12"
                    BorderThickness="1"
                    BorderBrush="{StaticResource SubtleBorderBrush}">
                <StackPanel Spacing="10">
                    <TextBlock Text="REVIEW NOTES"
                               FontSize="11" FontWeight="Bold"
                               Foreground="{StaticResource SecondaryTextBrush}"/>

                    <TextBlock Text="Additional review notes"
                               FontSize="13"
                               Foreground="{StaticResource PrimaryTextBrush}"/>
                    <TextBox Text="{x:Bind ReviewVM.ReviewNotes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             PlaceholderText="Anything else you want to remember from this game..."
                             TextWrapping="Wrap" AcceptsReturn="True"
                             MinHeight="70" FontSize="13"
                             Background="{StaticResource InputBackgroundBrush}"
                             BorderBrush="{StaticResource SubtleBorderBrush}"
                             Foreground="{StaticResource PrimaryTextBrush}" CornerRadius="8"/>

                    <TextBlock Text="Spotted problems"
                               FontSize="13"
                               Foreground="{StaticResource PrimaryTextBrush}"/>
                    <TextBox Text="{x:Bind ReviewVM.SpottedProblems, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             PlaceholderText="Patterns or repeated issues worth turning into future objectives..."
                             TextWrapping="Wrap" AcceptsReturn="True"
                             MinHeight="70" FontSize="13"
                             Background="{StaticResource InputBackgroundBrush}"
                             BorderBrush="{StaticResource SubtleBorderBrush}"
                             Foreground="{StaticResource PrimaryTextBrush}" CornerRadius="8"/>
                </StackPanel>
            </Border>

            <Border Background="{StaticResource CardBackgroundBrush}"
                    CornerRadius="8"
                    Padding="14,12"
                    BorderThickness="1"
                    BorderBrush="{StaticResource SubtleBorderBrush}"
                    Visibility="{x:Bind ReviewVM.HasObjectives, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                <StackPanel Spacing="10">
                    <TextBlock Text="OBJECTIVE PRACTICE"
                               FontSize="11" FontWeight="Bold"
                               Foreground="{StaticResource SecondaryTextBrush}"/>
                    <TextBlock Text="Mark whether you actually practiced your active objectives in this game."
                               FontSize="12"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               TextWrapping="Wrap"/>

                    <ItemsRepeater ItemsSource="{x:Bind ReviewVM.ObjectiveAssessments, Mode=OneWay}">
                        <ItemsRepeater.Layout>
                            <StackLayout Spacing="8"/>
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="vm:ObjectiveAssessment">
                                <Border Background="{StaticResource InputBackgroundBrush}"
                                        CornerRadius="8"
                                        BorderThickness="1"
                                        BorderBrush="{StaticResource SubtleBorderBrush}"
                                        Padding="12">
                                    <StackPanel Spacing="8">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <Border Background="{StaticResource AccentGoldBrush}"
                                                    CornerRadius="4"
                                                    Padding="6,2"
                                                    Visibility="{x:Bind IsPriority, Converter={StaticResource BoolToVis}}">
                                                <TextBlock Text="PRIORITY"
                                                           FontSize="9"
                                                           FontWeight="Bold"
                                                           Foreground="Black"/>
                                            </Border>
                                            <CheckBox IsChecked="{x:Bind Practiced, Mode=TwoWay}"
                                                      Content="{x:Bind Title}"
                                                      FontSize="13"
                                                      Foreground="{StaticResource PrimaryTextBrush}"/>
                                        </StackPanel>
                                        <TextBlock Text="{x:Bind Criteria}"
                                                   FontSize="12"
                                                   Foreground="{StaticResource SecondaryTextBrush}"
                                                   TextWrapping="Wrap"/>
                                        <TextBox Text="{x:Bind ExecutionNote, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 PlaceholderText="How did this objective go in the game?"
                                                 TextWrapping="Wrap" AcceptsReturn="True"
                                                 MinHeight="52" FontSize="12"
                                                 Background="{StaticResource CardBackgroundBrush}"
                                                 BorderBrush="{StaticResource SubtleBorderBrush}"
                                                 Foreground="{StaticResource PrimaryTextBrush}"
                                                 CornerRadius="6"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </StackPanel>
            </Border>

            <Border Background="{StaticResource CardBackgroundBrush}"
                    CornerRadius="8"
                    Padding="14,12"
                    BorderThickness="1"
                    BorderBrush="{StaticResource SubtleBorderBrush}">
                <StackPanel Spacing="10">
                    <TextBlock Text="MATCHUP NOTES"
                               FontSize="11" FontWeight="Bold"
                               Foreground="{StaticResource SecondaryTextBrush}"/>
                    <TextBlock Text="{x:Bind ReviewVM.MatchupHeading, Mode=OneWay}"
                               FontSize="14"
                               FontWeight="Bold"
                               Foreground="{StaticResource AccentBlueBrush}"/>

                    <TextBlock Text="Enemy champion"
                               FontSize="13"
                               Foreground="{StaticResource PrimaryTextBrush}"/>
                    <TextBox Text="{x:Bind ReviewVM.EnemyLaner, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             PlaceholderText="Enemy laner or main matchup champion"
                             FontSize="13"
                             Background="{StaticResource InputBackgroundBrush}"
                             BorderBrush="{StaticResource SubtleBorderBrush}"
                             Foreground="{StaticResource PrimaryTextBrush}"
                             CornerRadius="8"
                             Height="36"/>

                    <TextBlock Text="What should you remember for this matchup?"
                               FontSize="13"
                               Foreground="{StaticResource PrimaryTextBrush}"/>
                    <TextBox Text="{x:Bind ReviewVM.MatchupNote, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             PlaceholderText="Lane-specific or matchup-specific reminders..."
                             TextWrapping="Wrap" AcceptsReturn="True"
                             MinHeight="70" FontSize="13"
                             Background="{StaticResource InputBackgroundBrush}"
                             BorderBrush="{StaticResource SubtleBorderBrush}"
                             Foreground="{StaticResource PrimaryTextBrush}" CornerRadius="8"/>

                    <ItemsRepeater ItemsSource="{x:Bind ReviewVM.MatchupHistory, Mode=OneWay}"
                                   Visibility="{x:Bind ReviewVM.HasMatchupHistory, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                        <ItemsRepeater.Layout>
                            <StackLayout Spacing="6"/>
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="vm:MatchupHistoryItem">
                                <Border Background="{StaticResource InputBackgroundBrush}"
                                        CornerRadius="8"
                                        BorderThickness="1"
                                        BorderBrush="{StaticResource SubtleBorderBrush}"
                                        Padding="12">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="{x:Bind MetaText}"
                                                   FontSize="11"
                                                   Foreground="{StaticResource SecondaryTextBrush}"/>
                                        <TextBlock Text="{x:Bind Note}"
                                                   FontSize="12"
                                                   Foreground="{StaticResource PrimaryTextBrush}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </StackPanel>
            </Border>

            <StackPanel Spacing="6">
                <TextBlock Text="SESSION NOTE"
                           FontSize="11" FontWeight="Bold"
                           Foreground="{StaticResource SecondaryTextBrush}"/>
                <TextBox Text="{x:Bind ReviewVM.ImprovementNote, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         PlaceholderText="Quick note for your session log..."
                         FontSize="13" Height="36"
                         Background="{StaticResource InputBackgroundBrush}"
                         BorderBrush="{StaticResource SubtleBorderBrush}"
                         Foreground="{StaticResource PrimaryTextBrush}" CornerRadius="8"/>
            </StackPanel>

            <!-- ═══ Save / Skip Buttons ═══ -->
            <StackPanel Orientation="Horizontal" Spacing="10"
                        HorizontalAlignment="Center" Margin="0,8,0,16">
                <Button Content="Save Review" Click="OnSaveClick"
                        FontSize="14" Height="36" Padding="24,0"
                        CornerRadius="8"
                        Background="{StaticResource AccentBlueBrush}"
                        Foreground="{StaticResource ActionPrimaryForegroundBrush}" IsTabStop="False"/>
                <Button Content="Skip" Click="OnSkipClick"
                        FontSize="14" Height="36" Padding="24,0"
                        CornerRadius="8"
                        Background="{StaticResource TagBackgroundBrush}"
                        Foreground="{StaticResource SecondaryTextBrush}"
                        BorderBrush="{StaticResource SubtleBorderBrush}"
                        BorderThickness="1" IsTabStop="False"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>
