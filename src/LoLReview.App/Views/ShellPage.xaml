<Page
    x:Class="LoLReview.App.Views.ShellPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:LoLReview.App.Controls"
    xmlns:converters="using:LoLReview.App.Converters"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <Style x:Key="NavItemStyle" TargetType="Button" BasedOn="{StaticResource SidebarNavButtonStyle}">
            <Setter Property="Margin" Value="0,0,0,2"/>
        </Style>
    </Page.Resources>

    <Grid Background="{StaticResource ShellCanvasBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="3"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Connection indicator strip -->
        <Rectangle x:Name="ConnectionIndicator"
                   Grid.Row="0"
                   Fill="{StaticResource LossRedBrush}"
                   HorizontalAlignment="Stretch"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="72"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ═══ SIDEBAR: Collapsed icon rail ═══ -->
            <Border Grid.Column="0"
                    Background="{StaticResource SidebarBackgroundBrush}"
                    BorderBrush="{StaticResource SubtleBorderBrush}"
                    BorderThickness="0,0,1,0">
                <Grid x:Name="SidebarRoot">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Energy drain trails canvas -->
                    <Canvas x:Name="EnergyCanvas"
                            Grid.RowSpan="3"
                            IsHitTestVisible="False"
                            Canvas.ZIndex="15"/>

                    <!-- Logo -->
                    <StackPanel Grid.Row="0"
                                Margin="0,20,0,16"
                                HorizontalAlignment="Center">
                        <TextBlock Text="LR"
                                   FontFamily="{StaticResource DisplayFont}"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource AccentBlueBrush}"
                                   HorizontalAlignment="Center"
                                   CharacterSpacing="200"/>
                        <TextBlock Text="2.6"
                                   FontFamily="{StaticResource MonoFont}"
                                   FontSize="8"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,2,0,0"/>
                    </StackPanel>

                    <!-- Nav buttons -->
                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Hidden"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel x:Name="NavPanel"
                                    Margin="14,0"
                                    Spacing="2">

                            <!-- WORKSPACE section -->
                            <Border Height="1"
                                    Background="{StaticResource SubtleBorderBrush}"
                                    Margin="6,4,6,8"/>

                            <Button x:Name="NavDashboard"
                                    Tag="dashboard"
                                    Style="{StaticResource NavItemStyle}"
                                    Click="OnNavClick"
                                    ToolTipService.ToolTip="Dashboard"
                                    IsTabStop="False">
                                <FontIcon Glyph="&#xE80F;"
                                          FontSize="15"
                                          FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"/>
                            </Button>

                            <Button x:Name="NavSession"
                                    Tag="session"
                                    Style="{StaticResource NavItemStyle}"
                                    Click="OnNavClick"
                                    ToolTipService.ToolTip="Review"
                                    IsTabStop="False">
                                <Grid>
                                    <FontIcon Glyph="&#xE768;"
                                              FontSize="15"
                                              FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"/>
                                    <!-- Unreviewed badge -->
                                    <Border Width="8" Height="8"
                                            CornerRadius="4"
                                            Background="{StaticResource LossRedBrush}"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Top"
                                            Margin="0,-2,-2,0"
                                            Visibility="{x:Bind ViewModel.HasUnreviewedGames, Mode=OneWay, Converter={StaticResource BoolToVis}}"/>
                                </Grid>
                            </Button>

                            <Button x:Name="NavObjectives"
                                    Tag="objectives"
                                    Style="{StaticResource NavItemStyle}"
                                    Click="OnNavClick"
                                    ToolTipService.ToolTip="Objectives"
                                    IsTabStop="False">
                                <FontIcon Glyph="&#xF16B;"
                                          FontSize="15"
                                          FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"/>
                            </Button>

                            <!-- INSIGHTS section -->
                            <Border Height="1"
                                    Background="{StaticResource SubtleBorderBrush}"
                                    Margin="6,8,6,8"/>

                            <Button x:Name="NavHistory"
                                    Tag="history"
                                    Style="{StaticResource NavItemStyle}"
                                    Click="OnNavClick"
                                    ToolTipService.ToolTip="Archive"
                                    IsTabStop="False">
                                <FontIcon Glyph="&#xE81C;"
                                          FontSize="15"
                                          FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"/>
                            </Button>

                            <Button x:Name="NavAnalytics"
                                    Tag="analytics"
                                    Style="{StaticResource NavItemStyle}"
                                    Click="OnNavClick"
                                    ToolTipService.ToolTip="Trends"
                                    IsTabStop="False">
                                <FontIcon Glyph="&#xE9D9;"
                                          FontSize="15"
                                          FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"/>
                            </Button>

                            <Button x:Name="NavVodPlayer"
                                    Tag="vodplayer"
                                    Style="{StaticResource NavItemStyle}"
                                    Click="OnNavClick"
                                    ToolTipService.ToolTip="VOD Player"
                                    IsTabStop="False"
                                    Visibility="Collapsed">
                                <FontIcon Glyph="&#xE714;"
                                          FontSize="15"
                                          FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"/>
                            </Button>

                            <Button x:Name="NavCoachLab"
                                    Tag="coachlab"
                                    Style="{StaticResource NavItemStyle}"
                                    Click="OnNavClick"
                                    ToolTipService.ToolTip="Coach Lab"
                                    IsTabStop="False"
                                    Visibility="Collapsed">
                                <FontIcon Glyph="&#xE7EF;"
                                          FontSize="15"
                                          FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"/>
                            </Button>

                            <!-- DISCIPLINE section -->
                            <Border Height="1"
                                    Background="{StaticResource SubtleBorderBrush}"
                                    Margin="6,8,6,8"/>

                            <Button x:Name="NavRules"
                                    Tag="rules"
                                    Style="{StaticResource NavItemStyle}"
                                    Click="OnNavClick"
                                    ToolTipService.ToolTip="Rules"
                                    IsTabStop="False"
                                    Visibility="Collapsed">
                                <FontIcon Glyph="&#xE7BA;"
                                          FontSize="15"
                                          FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"/>
                            </Button>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Footer: status + settings -->
                    <StackPanel Grid.Row="2"
                                Margin="14,0,14,16"
                                Spacing="4">

                        <!-- Settings button -->
                        <Button x:Name="NavSettings"
                                Tag="settings"
                                Style="{StaticResource NavItemStyle}"
                                Click="OnNavClick"
                                ToolTipService.ToolTip="Settings"
                                IsTabStop="False">
                            <Grid>
                                <FontIcon Glyph="&#xE713;"
                                          FontSize="15"
                                          FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"/>
                                <!-- Update badge -->
                                <Border Width="8" Height="8"
                                        CornerRadius="4"
                                        Background="{StaticResource AccentGoldBrush}"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Top"
                                        Margin="0,-2,-2,0"
                                        Visibility="{x:Bind ViewModel.ShowSettingsUpdateBadge, Mode=OneWay, Converter={StaticResource BoolToVis}}"/>
                            </Grid>
                        </Button>

                        <!-- Connection status -->
                        <StackPanel HorizontalAlignment="Center"
                                    Spacing="4"
                                    Margin="0,8,0,0">
                            <Border x:Name="StatusDot"
                                    Width="6" Height="6"
                                    CornerRadius="3"
                                    Background="{StaticResource LossRedBrush}"
                                    HorizontalAlignment="Center"/>
                            <TextBlock x:Name="ConnectionStatusText"
                                       Text="LCU"
                                       FontFamily="{StaticResource MonoFont}"
                                       FontSize="7"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       HorizontalAlignment="Center"
                                       CharacterSpacing="100"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>


            <!-- ═══ CONTENT AREA ═══ -->
            <Grid Grid.Column="1">
                <!-- Ambient decorative shapes -->
                <Rectangle Width="420"
                           Height="154"
                           RadiusX="2"
                           RadiusY="2"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Top"
                           Margin="0,-58,-136,0"
                           Fill="{StaticResource AccentBlueDimBrush}"
                           Opacity="0.18"
                           RenderTransformOrigin="0.5,0.5">
                    <Rectangle.RenderTransform>
                        <RotateTransform Angle="14"/>
                    </Rectangle.RenderTransform>
                </Rectangle>

                <Rectangle Width="280"
                           Height="120"
                           RadiusX="2"
                           RadiusY="2"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Bottom"
                           Margin="-80,0,0,-48"
                           Fill="{StaticResource AccentGoldDimBrush}"
                           Opacity="0.14"
                           RenderTransformOrigin="0.5,0.5">
                    <Rectangle.RenderTransform>
                        <RotateTransform Angle="-10"/>
                    </Rectangle.RenderTransform>
                </Rectangle>

                <Border Background="{StaticResource ShellContentBackgroundBrush}"
                        BorderBrush="{StaticResource SubtleBorderBrush}"
                        BorderThickness="0"/>

                <Grid x:Name="ContentViewport"
                      Margin="0"
                      SizeChanged="OnContentViewportSizeChanged">
                    <Frame x:Name="ContentFrame"/>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Page>
