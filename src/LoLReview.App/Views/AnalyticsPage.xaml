<Page
    x:Class="LoLReview.App.Views.AnalyticsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:converters="using:LoLReview.App.Converters"
    xmlns:vm="using:LoLReview.App.ViewModels"
    mc:Ignorable="d"
    Background="{StaticResource AppBackgroundBrush}"
    Loaded="OnPageLoaded">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <Style x:Key="SectionCard" TargetType="Border" BasedOn="{StaticResource CardStyle}">
            <Setter Property="Background" Value="{StaticResource SurfaceRaisedBrush}"/>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="BorderBrush" Value="{StaticResource SubtleBorderBrush}"/>
            <Setter Property="Padding" Value="18,16"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <Style x:Key="StatValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
        </Style>

        <Style x:Key="StatLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}"/>
        </Style>

        <Style x:Key="TableHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}"/>
        </Style>

        <Style x:Key="TableCell" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Page.Resources>

    <Grid Padding="24,24,24,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <TextBlock Text="Trends" FontSize="22" FontWeight="Bold" Foreground="{StaticResource PrimaryTextBrush}"/>
                <TextBlock Text="Patterns, mental splits, and concept signals" FontSize="13" Foreground="{StaticResource SecondaryTextBrush}"
                           VerticalAlignment="Center"/>
            </StackPanel>
            <Button Content="&#xE72C;" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                    Style="{StaticResource GhostIconButtonStyle}"
                    HorizontalAlignment="Right" VerticalAlignment="Center"
                    ToolTipService.ToolTip="Refresh"
                    Command="{x:Bind ViewModel.LoadCommand}"/>
        </Grid>

        <!-- Loading -->
        <ProgressRing Grid.Row="1"
                      IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                      Width="40" Height="40"
                      Foreground="{StaticResource AccentBlueBrush}"
                      HorizontalAlignment="Center" VerticalAlignment="Center"/>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="0">

                <!-- ═══════════════════════════════════════════
                     OVERALL STATS
                     ═══════════════════════════════════════════ -->
                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionHeader}" Text="OVERALL STATS"/>
                        <StackPanel Orientation="Horizontal" Spacing="32">
                            <StackPanel>
                                <TextBlock Style="{StaticResource StatValue}" Text="{x:Bind ViewModel.TotalGames, Mode=OneWay}"/>
                                <TextBlock Style="{StaticResource StatLabel}" Text="Total Games"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Style="{StaticResource StatValue}"
                                           Text="{x:Bind ViewModel.Winrate, Mode=OneWay}"
                                           Foreground="{x:Bind ViewModel.WinrateColor, Mode=OneWay}"/>
                                <TextBlock Style="{StaticResource StatLabel}" Text="Win Rate"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Style="{StaticResource StatValue}" Text="{x:Bind ViewModel.Wins, Mode=OneWay}"
                                           Foreground="{StaticResource WinGreenBrush}"/>
                                <TextBlock Style="{StaticResource StatLabel}" Text="Wins"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Style="{StaticResource StatValue}" Text="{x:Bind ViewModel.Losses, Mode=OneWay}"
                                           Foreground="{StaticResource LossRedBrush}"/>
                                <TextBlock Style="{StaticResource StatLabel}" Text="Losses"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Style="{StaticResource StatValue}" Text="{x:Bind ViewModel.AvgKda, Mode=OneWay}"
                                           Foreground="{StaticResource AccentBlueBrush}"/>
                                <TextBlock Style="{StaticResource StatLabel}" Text="Avg KDA"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Style="{StaticResource StatValue}" Text="{x:Bind ViewModel.AvgCsMin, Mode=OneWay}"/>
                                <TextBlock Style="{StaticResource StatLabel}" Text="CS/min"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Style="{StaticResource StatValue}" Text="{x:Bind ViewModel.AvgVision, Mode=OneWay}"/>
                                <TextBlock Style="{StaticResource StatLabel}" Text="Vision"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ═══════════════════════════════════════════
                     MENTAL vs WIN RATE
                     ═══════════════════════════════════════════ -->
                <Border Style="{StaticResource SectionCard}"
                        Visibility="{x:Bind HasItems(ViewModel.MentalBrackets.Count), Mode=OneWay}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionHeader}" Text="MENTAL vs WIN RATE"/>
                        <ItemsRepeater ItemsSource="{x:Bind ViewModel.MentalBrackets, Mode=OneWay}">
                            <ItemsRepeater.Layout>
                                <StackLayout Spacing="8"/>
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="vm:MentalBracketRow">
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="60"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{x:Bind Bracket}"
                                                   FontSize="12" Foreground="{StaticResource AccentBlueBrush}"
                                                   VerticalAlignment="Center"/>
                                        <Border Grid.Column="1" Height="20" CornerRadius="4"
                                                Background="{StaticResource NeutralSurfaceBrush}" HorizontalAlignment="Left">
                                            <Border Background="{x:Bind WinrateColor}"
                                                    CornerRadius="4"
                                                    Width="{x:Bind BarWidth}"
                                                    HorizontalAlignment="Left"/>
                                        </Border>
                                        <TextBlock Grid.Column="2" Text="{x:Bind WinrateDisplay}"
                                                   FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{x:Bind WinrateColor}"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SectionCard}"
                        Visibility="{x:Bind ViewModel.HasTiltStats, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionHeader}" Text="TILT CHECK STATS"/>
                        <StackPanel Orientation="Horizontal" Spacing="32">
                            <StackPanel>
                                <TextBlock Style="{StaticResource StatValue}" Text="{x:Bind ViewModel.TiltCheckCount, Mode=OneWay}"/>
                                <TextBlock Style="{StaticResource StatLabel}" Text="Checks"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Style="{StaticResource StatValue}" Text="{x:Bind ViewModel.AvgTiltBefore, Mode=OneWay}" Foreground="{StaticResource LossRedBrush}"/>
                                <TextBlock Style="{StaticResource StatLabel}" Text="Avg Before"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Style="{StaticResource StatValue}" Text="{x:Bind ViewModel.AvgTiltAfter, Mode=OneWay}" Foreground="{StaticResource WinGreenBrush}"/>
                                <TextBlock Style="{StaticResource StatLabel}" Text="Avg After"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Style="{StaticResource StatValue}" Text="{x:Bind ViewModel.AvgTiltReduction, Mode=OneWay}" Foreground="{StaticResource AccentTealBrush}"/>
                                <TextBlock Style="{StaticResource StatLabel}" Text="Avg Reduction"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Style="{StaticResource StatValue}" Text="{x:Bind ViewModel.TopTiltEmotion, Mode=OneWay}"/>
                                <TextBlock Style="{StaticResource StatLabel}" Text="Top Emotion"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ═══════════════════════════════════════════
                     CHAMPION PERFORMANCE
                     ═══════════════════════════════════════════ -->
                <Border Style="{StaticResource SectionCard}"
                        Visibility="{x:Bind HasItems(ViewModel.ChampionStats.Count), Mode=OneWay}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionHeader}" Text="CHAMPION PERFORMANCE"/>

                        <!-- Table header -->
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Style="{StaticResource TableHeader}" Text="Champion"/>
                            <TextBlock Grid.Column="1" Style="{StaticResource TableHeader}" Text="Games"/>
                            <TextBlock Grid.Column="2" Style="{StaticResource TableHeader}" Text="WR%"/>
                            <TextBlock Grid.Column="3" Style="{StaticResource TableHeader}" Text="KDA"/>
                            <TextBlock Grid.Column="4" Style="{StaticResource TableHeader}" Text="CS/m"/>
                        </Grid>

                        <ItemsRepeater ItemsSource="{x:Bind ViewModel.ChampionStats, Mode=OneWay}">
                            <ItemsRepeater.Layout>
                                <StackLayout Spacing="2"/>
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="vm:ChampionStatRow">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="60"/>
                                            <ColumnDefinition Width="60"/>
                                            <ColumnDefinition Width="60"/>
                                            <ColumnDefinition Width="60"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Style="{StaticResource TableCell}" Text="{x:Bind ChampionName}"/>
                                        <TextBlock Grid.Column="1" Style="{StaticResource TableCell}" Text="{x:Bind Games}"/>
                                        <TextBlock Grid.Column="2" Style="{StaticResource TableCell}"
                                                   Text="{x:Bind WinrateDisplay}"
                                                   Foreground="{x:Bind WinrateColor}"/>
                                        <TextBlock Grid.Column="3" Style="{StaticResource TableCell}" Text="{x:Bind AvgKda}"/>
                                        <TextBlock Grid.Column="4" Style="{StaticResource TableCell}" Text="{x:Bind AvgCsMin}"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </StackPanel>
                </Border>

                <!-- ═══════════════════════════════════════════
                     CONCEPT TAG FREQUENCY
                     ═══════════════════════════════════════════ -->
                <Border Style="{StaticResource SectionCard}"
                        Visibility="{x:Bind HasItems(ViewModel.TagFrequencies.Count), Mode=OneWay}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionHeader}" Text="CONCEPT TAG FREQUENCY"/>
                        <ItemsRepeater ItemsSource="{x:Bind ViewModel.TagFrequencies, Mode=OneWay}">
                            <ItemsRepeater.Layout>
                                <StackLayout Spacing="6"/>
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="vm:TagFrequencyRow">
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="40"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{x:Bind Name}"
                                                   FontSize="12" Foreground="{StaticResource PrimaryTextBrush}"
                                                   VerticalAlignment="Center"/>
                                        <Border Grid.Column="1" Height="16" CornerRadius="3"
                                                Background="{StaticResource NeutralSurfaceBrush}" HorizontalAlignment="Left">
                                            <Border Background="{x:Bind BarColor}"
                                                    CornerRadius="3"
                                                    Width="{x:Bind BarWidth}"
                                                    HorizontalAlignment="Left"/>
                                        </Border>
                                        <TextBlock Grid.Column="2" Text="{x:Bind Count}"
                                                   FontSize="11" Foreground="{StaticResource SecondaryTextBrush}"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </StackPanel>
                </Border>

                <!-- ═══════════════════════════════════════════
                     MATCHUP STATS
                     ═══════════════════════════════════════════ -->
                <Border Style="{StaticResource SectionCard}"
                        Visibility="{x:Bind HasItems(ViewModel.MatchupStats.Count), Mode=OneWay}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionHeader}" Text="MATCHUP ANALYSIS (Worst First)"/>

                        <!-- Table header -->
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Style="{StaticResource TableHeader}" Text="You"/>
                            <TextBlock Grid.Column="1" Style="{StaticResource TableHeader}" Text="vs"/>
                            <TextBlock Grid.Column="2" Style="{StaticResource TableHeader}" Text="Games"/>
                            <TextBlock Grid.Column="3" Style="{StaticResource TableHeader}" Text="WR%"/>
                            <TextBlock Grid.Column="4" Style="{StaticResource TableHeader}" Text="KDA"/>
                        </Grid>

                        <ItemsRepeater ItemsSource="{x:Bind ViewModel.MatchupStats, Mode=OneWay}">
                            <ItemsRepeater.Layout>
                                <StackLayout Spacing="2"/>
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="vm:MatchupStatRow">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="60"/>
                                            <ColumnDefinition Width="60"/>
                                            <ColumnDefinition Width="60"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Style="{StaticResource TableCell}" Text="{x:Bind YourChampion}"/>
                                        <TextBlock Grid.Column="1" Style="{StaticResource TableCell}" Text="{x:Bind EnemyChampion}"/>
                                        <TextBlock Grid.Column="2" Style="{StaticResource TableCell}" Text="{x:Bind Games}"/>
                                        <TextBlock Grid.Column="3" Style="{StaticResource TableCell}"
                                                   Text="{x:Bind WinrateDisplay}"
                                                   Foreground="{x:Bind WinrateColor}"/>
                                        <TextBlock Grid.Column="4" Style="{StaticResource TableCell}" Text="{x:Bind AvgKda}"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
