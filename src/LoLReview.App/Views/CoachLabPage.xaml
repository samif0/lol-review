<Page
    x:Class="LoLReview.App.Views.CoachLabPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:converters="using:LoLReview.App.Converters"
    xmlns:controls="using:LoLReview.App.Controls"
    xmlns:vm="using:LoLReview.App.ViewModels"
    mc:Ignorable="d"
    Background="Transparent"
    Loaded="Page_Loaded">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </Page.Resources>

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Hero -->
        <Grid Grid.Row="0" Margin="40,24,40,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <controls:HeroHeader Grid.Column="0"
                                 EyebrowText="AI COACHING"
                                 Title="Coach Lab"
                                 Subtitle="REVIEW CLIPS // TRAIN MODEL // PATTERN READ"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8"
                        VerticalAlignment="Top" Margin="0,16,0,0">
                <Button Content="Refresh Read"
                        Command="{x:Bind ViewModel.RefreshRecommendationCommand}"
                        Style="{StaticResource SecondaryActionButtonStyle}"
                        Height="34" Padding="12,0" FontSize="11"/>
                <Button Content="Sync Clips"
                        Command="{x:Bind ViewModel.SyncCommand}"
                        Style="{StaticResource PrimaryActionButtonStyle}"
                        Height="34" Padding="14,0" FontSize="11"/>
                <Button Content="Train Model"
                        Command="{x:Bind ViewModel.TrainCommand}"
                        Style="{StaticResource GoldActionButtonStyle}"
                        Height="34" Padding="14,0" FontSize="11"/>
                <ProgressRing Width="24" Height="24" Margin="4,0,0,0"
                              IsActive="{x:Bind ViewModel.IsWorking, Mode=OneWay}"/>
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="40,0,40,40">
            <StackPanel Spacing="14">

                <Border Style="{StaticResource CardStyle}"
                        Visibility="{x:Bind ViewModel.IsEnabled, Mode=OneWay, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}">
                    <TextBlock Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                               FontSize="14"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               TextWrapping="Wrap"/>
                </Border>

                <StackPanel Spacing="14"
                            Visibility="{x:Bind ViewModel.IsEnabled, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                    <controls:CornerBracketedCard>
                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Spacing="6">
                                <TextBlock Text="{x:Bind ViewModel.ModeText, Mode=OneWay}"
                                           FontSize="11"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource AccentGoldBrush}"/>
                                <TextBlock Text="{x:Bind ViewModel.ActiveObjectiveTitle, Mode=OneWay}"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource PrimaryTextBrush}"/>
                                <TextBlock Text="{x:Bind ViewModel.RecommendationSummary, Mode=OneWay}"
                                           FontSize="13"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Spacing="6">
                                <TextBlock Text="{x:Bind ViewModel.WatchItemTitle, Mode=OneWay}"
                                           FontSize="11"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource AccentBlueBrush}"/>
                                <TextBlock Text="{x:Bind ViewModel.WatchItemSummary, Mode=OneWay}"
                                           FontSize="13"
                                           Foreground="{StaticResource PrimaryTextBrush}"
                                           TextWrapping="Wrap"/>
                                <TextBlock Text="{x:Bind ViewModel.TrainingSummary, Mode=OneWay}"
                                           FontSize="12"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>

                            <Grid Grid.Column="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0"
                                        Background="{StaticResource InputBackgroundBrush}"
                                        CornerRadius="2"
                                        Padding="12"
                                        Margin="0,0,8,0">
                                    <StackPanel Spacing="2">
                                        <TextBlock Text="Moments"
                                                   FontSize="11"
                                                   Foreground="{StaticResource SecondaryTextBrush}"/>
                                        <TextBlock Text="{x:Bind ViewModel.TotalMoments, Mode=OneWay}"
                                                   FontSize="22"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource PrimaryTextBrush}"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="1"
                                        Background="{StaticResource InputBackgroundBrush}"
                                        CornerRadius="2"
                                        Padding="12"
                                        Margin="0,0,8,0">
                                    <StackPanel Spacing="2">
                                        <TextBlock Text="Reviewed"
                                                   FontSize="11"
                                                   Foreground="{StaticResource SecondaryTextBrush}"/>
                                        <TextBlock Text="{x:Bind ViewModel.ReviewedMoments, Mode=OneWay}"
                                                   FontSize="22"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource WinGreenBrush}"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="2"
                                        Background="{StaticResource InputBackgroundBrush}"
                                        CornerRadius="2"
                                        Padding="12">
                                    <StackPanel Spacing="2">
                                        <TextBlock Text="Pending"
                                                   FontSize="11"
                                                   Foreground="{StaticResource SecondaryTextBrush}"/>
                                        <TextBlock Text="{x:Bind ViewModel.PendingMoments, Mode=OneWay}"
                                                   FontSize="22"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource AccentGoldBrush}"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Grid>
                    </controls:CornerBracketedCard>

                    <TextBlock Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                               FontFamily="{StaticResource MonoFont}"
                               FontSize="11"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               TextWrapping="Wrap"/>

                    <controls:CornerBracketedCard>
                        <StackPanel Spacing="10">
                            <controls:SectionTitle Text="PATTERN READ"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="Pattern Read"
                                           Style="{StaticResource PanelTitleStyle}"
                                           VerticalAlignment="Center"/>

                                <Button Grid.Column="1"
                                        Content="Find Problems"
                                        Command="{x:Bind ViewModel.FindProblemsCommand}"
                                        Margin="8,0,0,0"
                                        Style="{StaticResource ToolbarButtonStyle}"
                                        IsEnabled="{x:Bind ViewModel.HasGemmaModel, Mode=OneWay}"/>
                                <Button Grid.Column="2"
                                        Content="Suggest Objective"
                                        Command="{x:Bind ViewModel.SuggestObjectiveCommand}"
                                        Margin="8,0,0,0"
                                        Style="{StaticResource PrimaryActionButtonStyle}"
                                        IsEnabled="{x:Bind ViewModel.HasGemmaModel, Mode=OneWay}"/>
                            </Grid>

                            <Button Content="{x:Bind ViewModel.SuggestedObjectiveButtonText, Mode=OneWay}"
                                    Command="{x:Bind ViewModel.AddSuggestedObjectiveCommand}"
                                    HorizontalAlignment="Left"
                                    Style="{StaticResource SecondaryActionButtonStyle}"
                                    Visibility="{x:Bind ViewModel.CanCreateSuggestedObjective, Mode=OneWay, Converter={StaticResource BoolToVis}}"/>

                            <TextBlock Text="{x:Bind ViewModel.ModelOutputTitle, Mode=OneWay}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentGoldBrush}"/>
                            <TextBlock Text="{x:Bind ViewModel.ModelOutputSummary, Mode=OneWay}"
                                       FontSize="13"
                                       Foreground="{StaticResource PrimaryTextBrush}"
                                       TextWrapping="WrapWholeWords"/>
                        </StackPanel>
                    </controls:CornerBracketedCard>

                    <Grid ColumnSpacing="14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="390"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <controls:CornerBracketedCard Grid.Column="0"
                                CardBackground="{StaticResource QueuePanelBrush}">
                            <StackPanel Spacing="12">
                                <Grid ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="180"/>
                                    </Grid.ColumnDefinitions>

                                    <controls:SectionTitle Grid.Column="0" Text="CLIP QUEUE"
                                               VerticalAlignment="Center"/>

                                    <ComboBox Grid.Column="1"
                                              Header="State"
                                              ItemsSource="{x:Bind ViewModel.QueueManualLabelOptions, Mode=OneWay}"
                                              DisplayMemberPath="Label"
                                              SelectedValuePath="Key"
                                              SelectedValue="{x:Bind ViewModel.SelectedQueueManualLabelKey, Mode=TwoWay}"
                                              Background="{StaticResource InputBackgroundBrush}"/>

                                    <ComboBox Grid.Column="2"
                                              Header="Objective"
                                              ItemsSource="{x:Bind ViewModel.QueueObjectiveOptions, Mode=OneWay}"
                                              DisplayMemberPath="Label"
                                              SelectedValuePath="Key"
                                              SelectedValue="{x:Bind ViewModel.SelectedQueueObjectiveKey, Mode=TwoWay}"
                                              Background="{StaticResource InputBackgroundBrush}"/>
                                </Grid>

                                <Grid ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                               Text="{x:Bind ViewModel.MomentPageSummary, Mode=OneWay}"
                                               FontSize="12"
                                               Foreground="{StaticResource SecondaryTextBrush}"
                                               VerticalAlignment="Center"/>

                                    <Button Grid.Column="1"
                                            Content="Previous"
                                            Command="{x:Bind ViewModel.PreviousMomentPageCommand}"
                                            Style="{StaticResource ToolbarButtonStyle}"/>

                                    <Button Grid.Column="2"
                                            Content="Next"
                                            Command="{x:Bind ViewModel.NextMomentPageCommand}"
                                            Style="{StaticResource ToolbarButtonStyle}"/>
                                </Grid>

                                <ListView ItemsSource="{x:Bind ViewModel.Moments, Mode=OneWay}"
                                          SelectedItem="{x:Bind ViewModel.SelectedMoment, Mode=TwoWay}"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          MinHeight="580">
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="vm:CoachMomentItem">
                                            <Border Style="{StaticResource QueueItemCardStyle}"
                                                    Margin="0,0,0,10">
                                                <StackPanel Spacing="8">
                                                    <Grid ColumnSpacing="6">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>

                                                        <Border Grid.Column="0"
                                                                Background="{StaticResource AccentBlueDimBrush}"
                                                                CornerRadius="2"
                                                                Padding="7,3">
                                                            <TextBlock Text="{x:Bind SourceBadge}"
                                                                       FontSize="10"
                                                                       Foreground="{StaticResource AccentBlueBrush}"/>
                                                        </Border>

                                                        <Border Grid.Column="1"
                                                                Background="{StaticResource WarningSurfaceBrush}"
                                                                CornerRadius="2"
                                                                Padding="7,3"
                                                                Visibility="{x:Bind HasManualLabel, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}">
                                                            <TextBlock Text="Needs review"
                                                                       FontSize="10"
                                                                       Foreground="{StaticResource AccentGoldBrush}"/>
                                                        </Border>

                                                        <Border Grid.Column="1"
                                                                Background="{StaticResource SuccessSurfaceBrush}"
                                                                CornerRadius="2"
                                                                Padding="7,3"
                                                                Visibility="{x:Bind HasManualLabel, Converter={StaticResource BoolToVis}}">
                                                            <TextBlock Text="Reviewed"
                                                                       FontSize="10"
                                                                       Foreground="{StaticResource WinGreenBrush}"/>
                                                        </Border>

                                                        <TextBlock Grid.Column="2"
                                                                   Text="{x:Bind Champion}"
                                                                   FontSize="14"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{StaticResource PrimaryTextBrush}"
                                                                   VerticalAlignment="Center"/>

                                                        <TextBlock Grid.Column="3"
                                                                   Text="{x:Bind TimeText}"
                                                                   FontSize="12"
                                                                   Foreground="{StaticResource SecondaryTextBrush}"
                                                                   VerticalAlignment="Center"/>
                                                    </Grid>

                                                    <TextBlock Text="{x:Bind NoteText}"
                                                               FontSize="13"
                                                               Foreground="{StaticResource PrimaryTextBrush}"
                                                               TextWrapping="Wrap"
                                                               MaxLines="3"/>

                                                    <Border Background="{StaticResource TagBackgroundBrush}"
                                                            CornerRadius="2"
                                                            Padding="8,6">
                                                        <TextBlock Text="{x:Bind DraftSummary}"
                                                                   FontSize="11"
                                                                   Foreground="{StaticResource AccentGoldBrush}"
                                                                   TextWrapping="Wrap"
                                                                   MaxLines="2"/>
                                                    </Border>

                                                    <Grid ColumnSpacing="8">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>

                                                        <Border Grid.Column="0"
                                                                Background="{StaticResource TagBackgroundBrush}"
                                                                CornerRadius="2"
                                                                Padding="7,3">
                                                            <TextBlock Text="{x:Bind QueueObjectiveBadgeText}"
                                                                       FontSize="10"
                                                                       Foreground="{StaticResource PrimaryTextBrush}"/>
                                                        </Border>

                                                        <TextBlock Grid.Column="1"
                                                                   Text="{x:Bind LabelSummary}"
                                                                   FontSize="11"
                                                                   Foreground="{StaticResource SecondaryTextBrush}"
                                                                   TextWrapping="Wrap"
                                                                   MaxLines="2"/>
                                                    </Grid>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </StackPanel>
                        </controls:CornerBracketedCard>

                        <controls:CornerBracketedCard Grid.Column="1"
                                CardBackground="{StaticResource FocusPanelBrush}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel Spacing="14">
                                    <Grid ColumnSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" Spacing="4">
                                            <controls:SectionTitle Text="REVIEW STATION"/>
                                            <TextBlock Text="{x:Bind ViewModel.SelectedMomentProgressText, Mode=OneWay}"
                                                       FontSize="12"
                                                       Foreground="{StaticResource SecondaryTextBrush}"/>
                                        </StackPanel>

                                        <Button Grid.Column="1"
                                                Content="Previous Clip"
                                                Command="{x:Bind ViewModel.SelectPreviousMomentCommand}"
                                                Style="{StaticResource ToolbarButtonStyle}"/>

                                        <Button Grid.Column="2"
                                                Content="Next Clip"
                                                Command="{x:Bind ViewModel.SelectNextMomentCommand}"
                                                Style="{StaticResource ToolbarButtonStyle}"/>
                                    </Grid>

                                    <StackPanel Visibility="{x:Bind ViewModel.HasSelection, Mode=OneWay, Converter={StaticResource BoolToVis}}"
                                                Spacing="14">
                                        <Border Style="{StaticResource InsetCardStyle}">
                                            <Grid ColumnSpacing="12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" Spacing="5">
                                                    <TextBlock Text="{x:Bind ViewModel.SelectedMomentChampion, Mode=OneWay}"
                                                               FontSize="20"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource PrimaryTextBrush}"/>
                                                    <TextBlock Text="{x:Bind ViewModel.SelectedMomentSourceText, Mode=OneWay}"
                                                               FontSize="11"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource AccentBlueBrush}"/>
                                                    <TextBlock Text="{x:Bind ViewModel.SelectedMomentTimeText, Mode=OneWay}"
                                                               FontSize="12"
                                                               Foreground="{StaticResource SecondaryTextBrush}"/>
                                                    <TextBlock Text="{x:Bind ViewModel.SelectedMomentDraftRationale, Mode=OneWay}"
                                                               FontSize="13"
                                                               Foreground="{StaticResource SecondaryTextBrush}"
                                                               TextWrapping="Wrap"/>
                                                </StackPanel>
                                                <Button Grid.Column="1"
                                                        Content="Play Clip"
                                                        Command="{x:Bind ViewModel.PlayClipFileCommand}"
                                                        Style="{StaticResource SecondaryActionButtonStyle}"/>
                                                <Button Grid.Column="2"
                                                        Content="Open Clip In VOD"
                                                        Command="{x:Bind ViewModel.OpenSelectedClipCommand}"
                                                        Style="{StaticResource SecondaryActionButtonStyle}"/>
                                                <Button Grid.Column="3"
                                                        Content="Open VOD"
                                                        Command="{x:Bind ViewModel.OpenSelectedVodCommand}"
                                                        Style="{StaticResource ToolbarButtonStyle}"/>
                                            </Grid>
                                        </Border>

                                        <Grid ColumnSpacing="10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0"
                                                    Style="{StaticResource InsetCardStyle}">
                                                <StackPanel Spacing="6">
                                                    <TextBlock Text="Draft Read"
                                                               Style="{StaticResource PanelEyebrowStyle}"/>
                                                    <TextBlock Text="{x:Bind ViewModel.SelectedMomentDraftSummary, Mode=OneWay}"
                                                               FontSize="13"
                                                               Foreground="{StaticResource AccentGoldBrush}"
                                                               TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </Border>

                                            <Border Grid.Column="1"
                                                    Style="{StaticResource InsetCardStyle}">
                                                <StackPanel Spacing="6">
                                                    <TextBlock Text="Saved Review"
                                                               Style="{StaticResource PanelEyebrowStyle}"/>
                                                    <TextBlock Text="{x:Bind ViewModel.SelectedMomentLabelSummary, Mode=OneWay}"
                                                               FontSize="13"
                                                               Foreground="{StaticResource PrimaryTextBrush}"
                                                               TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </Border>
                                        </Grid>

                                        <Grid ColumnSpacing="10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="2*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0"
                                                    Style="{StaticResource InsetCardStyle}">
                                                <Button Command="{x:Bind ViewModel.OpenStoryboardCommand}"
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        Padding="0"
                                                        HorizontalAlignment="Stretch">
                                                    <StackPanel Spacing="6">
                                                        <TextBlock Text="Storyboard"
                                                                   Style="{StaticResource PanelEyebrowStyle}"/>
                                                        <Image Source="{x:Bind ViewModel.SelectedStoryboardImage, Mode=OneWay}"
                                                               Height="220"
                                                               Stretch="Uniform"/>
                                                        <TextBlock Text="Open full image"
                                                                   FontSize="11"
                                                                   Foreground="{StaticResource AccentBlueBrush}"/>
                                                    </StackPanel>
                                                </Button>
                                            </Border>

                                            <Border Grid.Column="1"
                                                    Style="{StaticResource InsetCardStyle}">
                                                <Button Command="{x:Bind ViewModel.OpenMinimapCommand}"
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        Padding="0"
                                                        HorizontalAlignment="Stretch">
                                                    <StackPanel Spacing="6">
                                                        <TextBlock Text="Minimap"
                                                                   Style="{StaticResource PanelEyebrowStyle}"/>
                                                        <Image Source="{x:Bind ViewModel.SelectedMinimapImage, Mode=OneWay}"
                                                               Height="220"
                                                               Stretch="Uniform"/>
                                                        <TextBlock Text="Open full image"
                                                                   FontSize="11"
                                                                   Foreground="{StaticResource AccentBlueBrush}"/>
                                                    </StackPanel>
                                                </Button>
                                            </Border>
                                        </Grid>

                                        <Grid ColumnSpacing="10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0"
                                                    Style="{StaticResource InsetCardStyle}">
                                                <StackPanel Spacing="6">
                                                    <TextBlock Text="Clip Note"
                                                               Style="{StaticResource PanelEyebrowStyle}"/>
                                                    <TextBlock Text="{x:Bind ViewModel.SelectedMomentNoteText, Mode=OneWay}"
                                                               FontSize="13"
                                                               Foreground="{StaticResource PrimaryTextBrush}"
                                                               TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </Border>

                                            <Border Grid.Column="1"
                                                    Style="{StaticResource InsetCardStyle}">
                                                <StackPanel Spacing="6">
                                                    <TextBlock Text="Review Context"
                                                               Style="{StaticResource PanelEyebrowStyle}"/>
                                                    <TextBlock Text="{x:Bind ViewModel.SelectedMomentContextText, Mode=OneWay}"
                                                               FontSize="12"
                                                               Foreground="{StaticResource PrimaryTextBrush}"
                                                               TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </Border>
                                        </Grid>

                                        <Grid ColumnSpacing="10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0"
                                                    Style="{StaticResource InsetCardStyle}">
                                                <StackPanel Spacing="8">
                                                    <TextBlock Text="{x:Bind ViewModel.ReviewActionTitle, Mode=OneWay}"
                                                               Style="{StaticResource PanelTitleStyle}"/>
                                                    <ComboBox Header="Moment Quality"
                                                              ItemsSource="{x:Bind ViewModel.QualityOptions, Mode=OneWay}"
                                                              DisplayMemberPath="Label"
                                                              SelectedValuePath="Key"
                                                              SelectedValue="{x:Bind ViewModel.SelectedLabelQuality, Mode=TwoWay}"
                                                              Background="{StaticResource InputBackgroundBrush}"/>
                                                    <ComboBox Header="Objective Attachment"
                                                              ItemsSource="{x:Bind ViewModel.ObjectiveOptions, Mode=OneWay}"
                                                              DisplayMemberPath="Label"
                                                              SelectedValuePath="Key"
                                                              SelectedValue="{x:Bind ViewModel.SelectedAttachedObjectiveId, Mode=TwoWay}"
                                                              Background="{StaticResource InputBackgroundBrush}"/>
                                                    <TextBlock Text="The clip note is the main explanation. Attach an objective only when it clearly helps."
                                                               FontSize="12"
                                                               Foreground="{StaticResource SecondaryTextBrush}"
                                                               TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </Border>

                                            <Border Grid.Column="1"
                                                    Style="{StaticResource InsetCardStyle}">
                                                <StackPanel Spacing="8">
                                                    <TextBlock Text="Optional Clarifier"
                                                               Style="{StaticResource PanelTitleStyle}"/>
                                                    <TextBlock Text="Use this only when the clip note and context still leave the moment ambiguous."
                                                               FontSize="12"
                                                               Foreground="{StaticResource SecondaryTextBrush}"
                                                               TextWrapping="Wrap"/>
                                                    <TextBox Text="{x:Bind ViewModel.SelectedExplanation, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                             PlaceholderText="Short clarifying note"
                                                             AcceptsReturn="True"
                                                             TextWrapping="Wrap"
                                                             MinHeight="120"
                                                             Background="{StaticResource InputBackgroundBrush}"/>
                                                    <Slider Minimum="0.2"
                                                            Maximum="1.0"
                                                            SmallChange="0.05"
                                                            StepFrequency="0.05"
                                                            Value="{x:Bind ViewModel.SelectedConfidence, Mode=TwoWay}"/>
                                                    <TextBlock Text="{x:Bind ViewModel.SelectedConfidenceText, Mode=OneWay}"
                                                               FontSize="12"
                                                               Foreground="{StaticResource SecondaryTextBrush}"/>
                                                </StackPanel>
                                            </Border>
                                        </Grid>

                                        <StackPanel Orientation="Horizontal"
                                                    Spacing="10">
                                            <Button Content="Save Review"
                                                    Command="{x:Bind ViewModel.SaveLabelCommand}"
                                                    Style="{StaticResource PrimaryActionButtonStyle}"/>
                                            <Button Content="Save + Next"
                                                    Command="{x:Bind ViewModel.SaveAndNextCommand}"
                                                    Style="{StaticResource SecondaryActionButtonStyle}"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <TextBlock Visibility="{x:Bind ViewModel.HasSelection, Mode=OneWay, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}"
                                               Text="Pick a clip from the queue to inspect it, save a review, and move to the next one."
                                               FontSize="13"
                                               Foreground="{StaticResource SecondaryTextBrush}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </ScrollViewer>
                        </controls:CornerBracketedCard>
                    </Grid>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
