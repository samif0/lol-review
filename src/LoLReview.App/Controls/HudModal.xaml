<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="LoLReview.App.Controls.HudModal"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Visibility="Collapsed"
    IsTabStop="False">

    <Grid x:Name="RootGrid" Tapped="OnBackdropTapped">
        <!-- ── Backdrop: deep near-black with subtle radial violet wash.
             Dims the app and adds some atmosphere so the modal doesn't
             float in a plain grey void. ── -->
        <Grid.Background>
            <RadialGradientBrush Center="0.5,0.5"
                                 GradientOrigin="0.5,0.5"
                                 RadiusX="0.85"
                                 RadiusY="0.85">
                <GradientStop Color="#14050412" Offset="0"/>
                <GradientStop Color="#B8000000" Offset="0.55"/>
                <GradientStop Color="#E6000000" Offset="1"/>
            </RadialGradientBrush>
        </Grid.Background>

        <!-- Violet glow under the card — renders BEHIND the card via
             Grid.ZIndex. A wide low-opacity gradient that hints the card
             is emitting light. -->
        <Border HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Margin="0"
                Padding="36"
                IsHitTestVisible="False"
                MinWidth="520"
                MinHeight="240"
                Canvas.ZIndex="0">
            <Border.Background>
                <RadialGradientBrush Center="0.5,0.5"
                                     GradientOrigin="0.5,0.5"
                                     RadiusX="0.75"
                                     RadiusY="0.75">
                    <GradientStop Color="#33A78BFA" Offset="0"/>
                    <GradientStop Color="#10A78BFA" Offset="0.45"/>
                    <GradientStop Color="#00A78BFA" Offset="1"/>
                </RadialGradientBrush>
            </Border.Background>
        </Border>

        <!-- ── Main modal card (bracketed frame + inner card) ── -->
        <Grid x:Name="CardFrame"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              MinWidth="460"
              MaxWidth="920"
              MinHeight="180"
              MaxHeight="760"
              Canvas.ZIndex="1"
              Tapped="OnCardTapped">

            <Border x:Name="CardBorder"
                    Background="{StaticResource CardBackgroundBrush}"
                    BorderBrush="{StaticResource AccentPurpleBrush}"
                    BorderThickness="1"
                    CornerRadius="2">
                <Grid RowDefinitions="Auto,Auto,*,Auto">

                    <!-- Eyebrow strip — tiny monospace breadcrumb above
                         the title. Reads like a HUD status line. -->
                    <Grid Grid.Row="0"
                          Background="{StaticResource SurfaceInsetBrush}"
                          Padding="16,8,14,4"
                          ColumnDefinitions="Auto,*,Auto">
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8"
                                    VerticalAlignment="Center">
                            <Rectangle Width="22" Height="1"
                                       Fill="{StaticResource AccentPurpleBrush}"
                                       VerticalAlignment="Center"/>
                            <TextBlock x:Name="EyebrowText"
                                       Text="MODAL"
                                       FontFamily="{StaticResource MonoFont}"
                                       FontSize="10"
                                       CharacterSpacing="300"
                                       Foreground="{StaticResource AccentPurpleBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <Button Grid.Column="2"
                                Click="OnCloseClick"
                                Style="{StaticResource GhostIconButtonStyle}"
                                Width="28" Height="28"
                                Padding="0"
                                ToolTipService.ToolTip="Close (Esc)">
                            <FontIcon Glyph="&#xE711;"
                                      FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                      FontSize="11"/>
                        </Button>
                    </Grid>

                    <!-- Title row: larger, display font. -->
                    <Grid Grid.Row="1"
                          Background="{StaticResource SurfaceInsetBrush}"
                          Padding="16,0,16,12"
                          ColumnDefinitions="*">
                        <TextBlock x:Name="TitleText"
                                   Text="Title"
                                   FontFamily="{StaticResource DisplayFont}"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource PrimaryTextBrush}"
                                   CharacterSpacing="100"/>
                    </Grid>

                    <!-- Thin divider line -->
                    <Rectangle Grid.Row="1"
                               Height="1"
                               VerticalAlignment="Bottom"
                               Fill="{StaticResource AccentPurpleBrush}"
                               Opacity="0.35"
                               HorizontalAlignment="Stretch"/>

                    <!-- Body slot — scrollable. -->
                    <ScrollViewer Grid.Row="2"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Padding="18,16,18,16">
                        <ContentPresenter x:Name="BodyPresenter"/>
                    </ScrollViewer>

                    <!-- Footer slot. -->
                    <Border Grid.Row="3"
                            x:Name="FooterBorder"
                            BorderBrush="{StaticResource SubtleBorderBrush}"
                            BorderThickness="0,1,0,0"
                            Background="{StaticResource SurfaceInsetBrush}"
                            Padding="16,10,16,10"
                            Visibility="Collapsed">
                        <ContentPresenter x:Name="FooterPresenter"/>
                    </Border>
                </Grid>
            </Border>

            <!-- ── Corner brackets, permanently visible on the modal
                 (unlike CornerBracketedCard which shows on hover). ── -->
            <Border Width="14" Height="14"
                    HorizontalAlignment="Left" VerticalAlignment="Top"
                    Margin="-4,-4,0,0"
                    BorderBrush="{StaticResource AccentPurpleBrush}"
                    BorderThickness="2,2,0,0"
                    IsHitTestVisible="False"/>
            <Border Width="14" Height="14"
                    HorizontalAlignment="Right" VerticalAlignment="Top"
                    Margin="0,-4,-4,0"
                    BorderBrush="{StaticResource AccentPurpleBrush}"
                    BorderThickness="0,2,2,0"
                    IsHitTestVisible="False"/>
            <Border Width="14" Height="14"
                    HorizontalAlignment="Left" VerticalAlignment="Bottom"
                    Margin="-4,0,0,-4"
                    BorderBrush="{StaticResource AccentPurpleBrush}"
                    BorderThickness="2,0,0,2"
                    IsHitTestVisible="False"/>
            <Border Width="14" Height="14"
                    HorizontalAlignment="Right" VerticalAlignment="Bottom"
                    Margin="0,0,-4,-4"
                    BorderBrush="{StaticResource AccentPurpleBrush}"
                    BorderThickness="0,0,2,2"
                    IsHitTestVisible="False"/>
        </Grid>
    </Grid>
</UserControl>
