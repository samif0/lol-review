<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="LoLReview.App.Controls.HudModal"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Visibility="Collapsed"
    IsTabStop="False">

    <Grid x:Name="RootGrid" Background="#C8000000" Tapped="OnBackdropTapped">
        <!-- Violet-accent card at the center, constrained to a readable
             max width. Clicks inside the card are swallowed so the
             backdrop-tap-to-close only fires on the backdrop. -->
        <Border x:Name="CardBorder"
                Background="{StaticResource CardBackgroundBrush}"
                BorderBrush="{StaticResource AccentPurpleBrush}"
                BorderThickness="1"
                CornerRadius="2"
                MinWidth="420"
                MaxWidth="860"
                MinHeight="140"
                MaxHeight="720"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Padding="0"
                Tapped="OnCardTapped">

            <Grid RowDefinitions="Auto,*,Auto">
                <!-- ── Title bar with violet accent rail ── -->
                <Grid Grid.Row="0" ColumnDefinitions="3,*,Auto"
                      Background="{StaticResource SurfaceInsetBrush}">
                    <Rectangle Grid.Column="0"
                               Fill="{StaticResource AccentPurpleBrush}"
                               HorizontalAlignment="Left"
                               Width="3"/>
                    <TextBlock Grid.Column="1"
                               x:Name="TitleText"
                               Text="Title"
                               FontFamily="{StaticResource MonoFont}"
                               FontWeight="SemiBold"
                               CharacterSpacing="200"
                               Foreground="{StaticResource PrimaryTextBrush}"
                               Padding="16,12,12,12"
                               VerticalAlignment="Center"/>
                    <Button Grid.Column="2"
                            Click="OnCloseClick"
                            Style="{StaticResource GhostIconButtonStyle}"
                            Width="40" Height="40"
                            Padding="0"
                            Margin="0,4,4,4"
                            ToolTipService.ToolTip="Close">
                        <FontIcon Glyph="&#xE711;"
                                  FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                  FontSize="12"/>
                    </Button>
                </Grid>

                <!-- ── Body slot ── -->
                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="16,14,16,14">
                    <ContentPresenter x:Name="BodyPresenter"/>
                </ScrollViewer>

                <!-- ── Footer slot (optional, e.g. Regenerate / Close buttons) ── -->
                <Border Grid.Row="2"
                        x:Name="FooterBorder"
                        BorderBrush="{StaticResource SubtleBorderBrush}"
                        BorderThickness="0,1,0,0"
                        Background="{StaticResource SurfaceInsetBrush}"
                        Padding="14,10"
                        Visibility="Collapsed">
                    <ContentPresenter x:Name="FooterPresenter"/>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
