<UserControl
    x:Class="LoLReview.App.Controls.HeroHeader"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="0,0,0,4">
        <!-- Subtle gradient wash backdrop — soft radial fade, no hard edges -->
        <Border x:Name="WashRect"
                HorizontalAlignment="Stretch"
                Height="180"
                VerticalAlignment="Top"
                IsHitTestVisible="False">
            <Border.Background>
                <RadialGradientBrush Center="0.3,0.3"
                                      RadiusX="0.8"
                                      RadiusY="1.2"
                                      MappingMode="RelativeToBoundingBox">
                    <GradientStop Color="#0AA78BFA" Offset="0"/>
                    <GradientStop Color="#05A78BFA" Offset="0.5"/>
                    <GradientStop Color="#00000000" Offset="1"/>
                </RadialGradientBrush>
            </Border.Background>
        </Border>

        <StackPanel Spacing="6" Margin="0,0,0,2">
            <!-- Eyebrow row: leading dash + label + blinking cursor -->
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Rectangle Width="20"
                           Height="1"
                           Fill="{StaticResource AccentBlueBrush}"
                           VerticalAlignment="Center"/>
                <TextBlock x:Name="EyebrowTextBlock"
                           Style="{StaticResource PanelEyebrowStyle}"
                           Foreground="{StaticResource AccentBlueBrush}"
                           VerticalAlignment="Center"/>
                <TextBlock x:Name="CursorTextBlock"
                           Text="_"
                           FontFamily="{StaticResource MonoFont}"
                           FontSize="10"
                           Foreground="{StaticResource AccentBlueBrush}"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <TextBlock x:Name="TitleTextBlock"
                       Style="{StaticResource HeroTitleStyle}"
                       TextWrapping="Wrap"/>

            <TextBlock x:Name="SubtitleTextBlock"
                       FontFamily="{StaticResource MonoFont}"
                       FontSize="11"
                       Foreground="{StaticResource MutedTextBrush}"
                       Visibility="Collapsed"
                       TextWrapping="Wrap"/>
        </StackPanel>
    </Grid>
</UserControl>
