<UserControl
    x:Class="LoLReview.App.Controls.MoodSelector"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <StackPanel Orientation="Horizontal" Spacing="4">
        <!-- Tilted (1) -->
        <Button x:Name="TiltedBtn"
                Content="Tilted"
                Click="OnMoodClick" Tag="1"
                FontSize="11" Height="28" MinWidth="70"
                CornerRadius="14" Padding="10,0"
                Background="{StaticResource TagBackgroundBrush}"
                Foreground="{StaticResource SecondaryTextBrush}"
                BorderBrush="{StaticResource SubtleBorderBrush}"
                BorderThickness="1"/>

        <!-- Off (2) -->
        <Button x:Name="OffBtn"
                Content="Off"
                Click="OnMoodClick" Tag="2"
                FontSize="11" Height="28" MinWidth="70"
                CornerRadius="14" Padding="10,0"
                Background="{StaticResource TagBackgroundBrush}"
                Foreground="{StaticResource SecondaryTextBrush}"
                BorderBrush="{StaticResource SubtleBorderBrush}"
                BorderThickness="1"/>

        <!-- Neutral (3) -->
        <Button x:Name="NeutralBtn"
                Content="Neutral"
                Click="OnMoodClick" Tag="3"
                FontSize="11" Height="28" MinWidth="70"
                CornerRadius="14" Padding="10,0"
                Background="{StaticResource TagBackgroundBrush}"
                Foreground="{StaticResource SecondaryTextBrush}"
                BorderBrush="{StaticResource SubtleBorderBrush}"
                BorderThickness="1"/>

        <!-- Good (4) -->
        <Button x:Name="GoodBtn"
                Content="Good"
                Click="OnMoodClick" Tag="4"
                FontSize="11" Height="28" MinWidth="70"
                CornerRadius="14" Padding="10,0"
                Background="{StaticResource TagBackgroundBrush}"
                Foreground="{StaticResource SecondaryTextBrush}"
                BorderBrush="{StaticResource SubtleBorderBrush}"
                BorderThickness="1"/>

        <!-- Locked In (5) -->
        <Button x:Name="LockedInBtn"
                Content="Locked In"
                Click="OnMoodClick" Tag="5"
                FontSize="11" Height="28" MinWidth="70"
                CornerRadius="14" Padding="10,0"
                Background="{StaticResource TagBackgroundBrush}"
                Foreground="{StaticResource SecondaryTextBrush}"
                BorderBrush="{StaticResource SubtleBorderBrush}"
                BorderThickness="1"/>
    </StackPanel>
</UserControl>
