<UserControl
    x:Class="LoLReview.App.Controls.StatCell"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:LoLReview.App.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Border x:Name="OuterBorder"
            Background="{StaticResource CardBackgroundBrush}"
            BorderBrush="{StaticResource SubtleBorderBrush}"
            BorderThickness="1,1,0,1"
            CornerRadius="0"
            Padding="18,14">
        <Grid x:Name="LayoutRoot">

            <Border x:Name="GlowOverlay"
                    IsHitTestVisible="False"
                    Opacity="0">
                <Border.Background>
                    <RadialGradientBrush x:Name="GlowBrush"
                                         Center="0.5,0.5"
                                         GradientOrigin="0.5,0.5"
                                         RadiusX="0.9"
                                         RadiusY="0.9">
                        <GradientStop Color="#12A78BFA" Offset="0"/>
                        <GradientStop Color="#06A78BFA" Offset="0.42"/>
                        <GradientStop Color="#00A78BFA" Offset="1"/>
                    </RadialGradientBrush>
                </Border.Background>
            </Border>

            <StackPanel x:Name="ContentPanel" Spacing="4" VerticalAlignment="Center">
                <TextBlock x:Name="LabelTextBlock"
                           Style="{StaticResource StatLabelStyle}"/>
                <TextBlock x:Name="ValueTextBlock"
                           Style="{StaticResource StatValueStyle}"
                           FontSize="22"/>
                <TextBlock x:Name="SubTextBlock"
                           FontFamily="{StaticResource MonoFont}"
                           FontSize="9"
                           Foreground="{StaticResource MutedTextBrush}"
                           Visibility="Collapsed"/>
            </StackPanel>

            <Rectangle x:Name="AccentLine"
                       Height="1"
                       VerticalAlignment="Bottom"
                       HorizontalAlignment="Stretch"
                       Opacity="0"
                       IsHitTestVisible="False">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#00A78BFA" Offset="0"/>
                        <GradientStop Color="#A78BFA" Offset="0.5"/>
                        <GradientStop Color="#00A78BFA" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>
        </Grid>
    </Border>
</UserControl>
