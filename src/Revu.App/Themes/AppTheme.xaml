<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:svc="using:Revu.App.Services">

    <!-- Futuristic HUD palette:
         deep violet shells, luminous violet (#A78BFA) primary actions,
         alloy bronze (#C9956A) for focus/priority, muted rose/green for outcomes. -->

    <!-- ••• Font Families ••• -->
    <FontFamily x:Key="DisplayFont">ms-appx:///Assets/Fonts/Orbitron.ttf#Orbitron</FontFamily>
    <FontFamily x:Key="HeadingFont">ms-appx:///Assets/Fonts/Rajdhani-SemiBold.ttf#Rajdhani</FontFamily>
    <FontFamily x:Key="HeadingBoldFont">ms-appx:///Assets/Fonts/Rajdhani-Bold.ttf#Rajdhani</FontFamily>
    <FontFamily x:Key="MonoFont">ms-appx:///Assets/Fonts/ShareTechMono-Regular.ttf#Share Tech Mono</FontFamily>
    <FontFamily x:Key="BodyFont">ms-appx:///Assets/Fonts/Exo2.ttf#Exo 2</FontFamily>

    <!-- ••• Backgrounds ••• -->
    <SolidColorBrush x:Key="AppBackgroundBrush" Color="#07060B"/>
    <SolidColorBrush x:Key="ShellCanvasBrush" Color="#050409"/>
    <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="#0C0B12"/>
    <SolidColorBrush x:Key="SidebarSecondaryBackgroundBrush" Color="#100F18"/>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#14121E"/>
    <SolidColorBrush x:Key="CardAltBackgroundBrush" Color="#18162A"/>
    <SolidColorBrush x:Key="CardHoverBackgroundBrush" Color="#1A1828"/>
    <SolidColorBrush x:Key="InputBackgroundBrush" Color="#110F1A"/>
    <SolidColorBrush x:Key="PanelOverlayBrush" Color="#D90C0B12"/>
    <SolidColorBrush x:Key="ShellFrameBackgroundBrush" Color="#0C0B12"/>
    <SolidColorBrush x:Key="SurfaceRaisedBrush" Color="#18162A"/>
    <SolidColorBrush x:Key="SurfaceInsetBrush" Color="#0A0918"/>
    <SolidColorBrush x:Key="SurfaceHighlightBrush" Color="#1C1A30"/>
    <SolidColorBrush x:Key="InfoSurfaceBrush" Color="#161428"/>
    <SolidColorBrush x:Key="NeutralSurfaceBrush" Color="#13111E"/>
    <SolidColorBrush x:Key="SuccessSurfaceBrush" Color="#0F1E18"/>
    <SolidColorBrush x:Key="WarningSurfaceBrush" Color="#221A12"/>
    <SolidColorBrush x:Key="DangerSurfaceBrush" Color="#221418"/>

    <!-- ••• Borders ••• -->
    <SolidColorBrush x:Key="SubtleBorderBrush" Color="#24203A"/>
    <SolidColorBrush x:Key="BrightBorderBrush" Color="#3D3660"/>

    <!-- ••• Text ••• -->
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="#F0EEF8"/>
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="#7A6E96"/>
    <SolidColorBrush x:Key="MutedTextBrush" Color="#4A3E60"/>

    <!-- ••• Accents ••• -->
    <SolidColorBrush x:Key="NeutralAccentBrush" Color="#8A80A8"/>
    <SolidColorBrush x:Key="AccentBlueBrush" Color="#A78BFA"/>
    <SolidColorBrush x:Key="AccentBlueDimBrush" Color="#1A1430"/>
    <SolidColorBrush x:Key="AccentGoldBrush" Color="#C9956A"/>
    <SolidColorBrush x:Key="AccentGoldDimBrush" Color="#261C12"/>
    <SolidColorBrush x:Key="AccentPurpleBrush" Color="#A78BFA"/>
    <SolidColorBrush x:Key="AccentTealBrush" Color="#8A7AF2"/>
    <SolidColorBrush x:Key="AccentTealDimBrush" Color="#181430"/>

    <!-- ••• Outcomes ••• -->
    <SolidColorBrush x:Key="WinGreenBrush" Color="#7EC9A0"/>
    <SolidColorBrush x:Key="WinGreenDimBrush" Color="#0F1E18"/>
    <SolidColorBrush x:Key="LossRedBrush" Color="#D38C90"/>
    <SolidColorBrush x:Key="LossRedDimBrush" Color="#2A1820"/>

    <!-- ••• Objective Levels ••• -->
    <SolidColorBrush x:Key="ObjectiveExploringBrush" Color="#8A80A8"/>
    <SolidColorBrush x:Key="ObjectiveDrillingBrush" Color="#A78BFA"/>
    <SolidColorBrush x:Key="ObjectiveIngrainingBrush" Color="#8A7AF2"/>
    <SolidColorBrush x:Key="ObjectiveReadyBrush" Color="#C9956A"/>

    <!-- ••• UI Elements ••• -->
    <SolidColorBrush x:Key="TagBackgroundBrush" Color="#110F1A"/>
    <SolidColorBrush x:Key="StarActiveBrush" Color="#C9956A"/>
    <SolidColorBrush x:Key="StarInactiveBrush" Color="#24203A"/>
    <SolidColorBrush x:Key="SidebarActiveBrush" Color="#161430"/>
    <SolidColorBrush x:Key="SidebarHoverBrush" Color="#110F1E"/>
    <SolidColorBrush x:Key="SidebarActiveBorderBrush" Color="#A78BFA"/>
    <SolidColorBrush x:Key="ActionPrimaryForegroundBrush" Color="#07060B"/>

    <!-- ••• Gradient Panels ••• -->
    <LinearGradientBrush x:Key="HeroPanelBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#1A1630" Offset="0"/>
        <GradientStop Color="#12101E" Offset="0.48"/>
        <GradientStop Color="#0A0918" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="SidebarHeroBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#161428" Offset="0"/>
        <GradientStop Color="#100F18" Offset="0.62"/>
        <GradientStop Color="#0A0918" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="ShellContentBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#12101E" Offset="0"/>
        <GradientStop Color="#0E0C18" Offset="0.56"/>
        <GradientStop Color="#07060B" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="CommandCenterPanelBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#1C1832" Offset="0"/>
        <GradientStop Color="#141220" Offset="0.5"/>
        <GradientStop Color="#0C0B14" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="QueuePanelBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#181428" Offset="0"/>
        <GradientStop Color="#12101E" Offset="0.52"/>
        <GradientStop Color="#0B0A14" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="FocusPanelBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#281E14" Offset="0"/>
        <GradientStop Color="#1A1614" Offset="0.55"/>
        <GradientStop Color="#121110" Offset="1"/>
    </LinearGradientBrush>

    <!-- ••• System Overrides ••• -->
    <SolidColorBrush x:Key="ApplicationPageBackgroundThemeBrush" Color="#07060B"/>
    <SolidColorBrush x:Key="LayerFillColorDefaultBrush" Color="#14121E"/>
    <SolidColorBrush x:Key="NavigationViewDefaultPaneBackground" Color="#0C0B12"/>
    <SolidColorBrush x:Key="NavigationViewExpandedPaneBackground" Color="#0C0B12"/>
    <SolidColorBrush x:Key="NavigationViewContentBackground" Color="#07060B"/>

    <!-- ••• Card Styles ••• -->
    <Style x:Key="CardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource SubtleBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="2"/>
        <Setter Property="Padding" Value="18"/>
    </Style>

    <Style x:Key="ElevatedCardStyle" TargetType="Border" BasedOn="{StaticResource CardStyle}">
        <Setter Property="Background" Value="{StaticResource CardAltBackgroundBrush}"/>
        <Setter Property="CornerRadius" Value="2"/>
        <Setter Property="Padding" Value="20"/>
    </Style>

    <Style x:Key="InsetCardStyle" TargetType="Border" BasedOn="{StaticResource CardStyle}">
        <Setter Property="Background" Value="{StaticResource SurfaceInsetBrush}"/>
        <Setter Property="CornerRadius" Value="2"/>
        <Setter Property="Padding" Value="16"/>
    </Style>

    <Style x:Key="EmphasisCardStyle" TargetType="Border" BasedOn="{StaticResource ElevatedCardStyle}">
        <Setter Property="Background" Value="{StaticResource SurfaceRaisedBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BrightBorderBrush}"/>
        <Setter Property="CornerRadius" Value="2"/>
        <Setter Property="Padding" Value="22"/>
    </Style>

    <Style x:Key="MetricCardStyle" TargetType="Border" BasedOn="{StaticResource CardStyle}">
        <Setter Property="Background" Value="{StaticResource SurfaceRaisedBrush}"/>
        <Setter Property="Padding" Value="18"/>
        <Setter Property="CornerRadius" Value="2"/>
    </Style>

    <Style x:Key="QueueItemCardStyle" TargetType="Border" BasedOn="{StaticResource CardStyle}">
        <Setter Property="Background" Value="{StaticResource InputBackgroundBrush}"/>
        <Setter Property="CornerRadius" Value="2"/>
        <Setter Property="Padding" Value="14"/>
    </Style>

    <!-- ••• Typography ••• -->
    <Style x:Key="StatValueStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource DisplayFont}"/>
        <Setter Property="FontSize" Value="28"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
    </Style>

    <Style x:Key="StatLabelStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource MonoFont}"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="CharacterSpacing" Value="200"/>
        <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}"/>
    </Style>

    <Style x:Key="PanelEyebrowStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource MonoFont}"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="CharacterSpacing" Value="200"/>
        <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}"/>
    </Style>

    <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource HeadingBoldFont}"/>
        <Setter Property="FontSize" Value="20"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
    </Style>

    <Style x:Key="PanelTitleStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource HeadingFont}"/>
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
    </Style>

    <Style x:Key="HeroTitleStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource DisplayFont}"/>
        <Setter Property="FontSize" Value="28"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
    </Style>

    <!-- ••• Buttons ••• -->
    <RadialGradientBrush x:Key="ButtonHoverGlow"
                         Center="0.5,0.5"
                         GradientOrigin="0.5,0.5"
                         RadiusX="0.95"
                         RadiusY="1.1">
        <GradientStop Color="#18A78BFA" Offset="0"/>
        <GradientStop Color="#0CA78BFA" Offset="0.6"/>
        <GradientStop Color="#00A78BFA" Offset="1"/>
    </RadialGradientBrush>

    <SolidColorBrush x:Key="ButtonHoverWash" Color="#08A78BFA"/>

    <LinearGradientBrush x:Key="ButtonTopEdgeBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#00A78BFA" Offset="0"/>
        <GradientStop Color="#88A78BFA" Offset="0.5"/>
        <GradientStop Color="#00A78BFA" Offset="1"/>
    </LinearGradientBrush>

    <ControlTemplate x:Key="PrimaryHudButtonTemplate" TargetType="Button">
        <Grid Background="Transparent">
            <Border x:Name="GlowChrome"
                    Margin="-4"
                    Background="{StaticResource ButtonHoverGlow}"
                    CornerRadius="{TemplateBinding CornerRadius}"
                    Opacity="0"
                    IsHitTestVisible="False"/>

            <Border x:Name="Chrome"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="{TemplateBinding CornerRadius}">
                <Border.RenderTransform>
                    <CompositeTransform x:Name="ChromeTransform"/>
                </Border.RenderTransform>
                <Grid>
                    <Rectangle x:Name="SheenOverlay"
                               Opacity="0"
                               IsHitTestVisible="False">
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#00FFFFFF" Offset="0"/>
                                <GradientStop Color="#10FFFFFF" Offset="0.5"/>
                                <GradientStop Color="#00FFFFFF" Offset="1"/>
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                        <Rectangle.RenderTransform>
                            <TranslateTransform x:Name="SheenTransform" X="-96"/>
                        </Rectangle.RenderTransform>
                    </Rectangle>

                    <Rectangle x:Name="HoverWash"
                               Opacity="0"
                               IsHitTestVisible="False"
                               Fill="{StaticResource ButtonHoverWash}"/>

                    <Rectangle x:Name="TopEdge"
                               Height="1"
                               Margin="1,0,1,0"
                               VerticalAlignment="Top"
                               Opacity="0.18"
                               IsHitTestVisible="False"
                               Fill="{StaticResource ButtonTopEdgeBrush}"/>

                    <ContentPresenter x:Name="ContentPresenter"
                                      Margin="{TemplateBinding Padding}"
                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                      Content="{TemplateBinding Content}"
                                      ContentTemplate="{TemplateBinding ContentTemplate}"
                                      ContentTransitions="{TemplateBinding ContentTransitions}"/>
                </Grid>
            </Border>

            <VisualStateManager.VisualStateGroups>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal">
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetName="ChromeTransform"
                                             Storyboard.TargetProperty="TranslateY"
                                             To="0"
                                             Duration="0:0:0.14"
                                             EnableDependentAnimation="True"/>
                            <DoubleAnimation Storyboard.TargetName="GlowChrome"
                                             Storyboard.TargetProperty="Opacity"
                                             To="0"
                                             Duration="0:0:0.14"/>
                            <DoubleAnimation Storyboard.TargetName="SheenOverlay"
                                             Storyboard.TargetProperty="Opacity"
                                             To="0"
                                             Duration="0:0:0.12"/>
                            <DoubleAnimation Storyboard.TargetName="HoverWash"
                                             Storyboard.TargetProperty="Opacity"
                                             To="0"
                                             Duration="0:0:0.12"/>
                            <DoubleAnimation Storyboard.TargetName="TopEdge"
                                             Storyboard.TargetProperty="Opacity"
                                             To="0.18"
                                             Duration="0:0:0.12"/>
                            <DoubleAnimation Storyboard.TargetName="SheenTransform"
                                             Storyboard.TargetProperty="X"
                                             To="-96"
                                             Duration="0:0:0.01"
                                             EnableDependentAnimation="True"/>
                        </Storyboard>
                    </VisualState>

                    <VisualState x:Name="PointerOver">
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetName="ChromeTransform"
                                             Storyboard.TargetProperty="TranslateY"
                                             To="-1"
                                             Duration="0:0:0.14"
                                             EnableDependentAnimation="True"/>
                            <DoubleAnimation Storyboard.TargetName="GlowChrome"
                                             Storyboard.TargetProperty="Opacity"
                                             To="1"
                                             Duration="0:0:0.14"/>
                            <DoubleAnimation Storyboard.TargetName="SheenOverlay"
                                             Storyboard.TargetProperty="Opacity"
                                             To="1"
                                             Duration="0:0:0.1"/>
                            <DoubleAnimation Storyboard.TargetName="HoverWash"
                                             Storyboard.TargetProperty="Opacity"
                                             To="0.85"
                                             Duration="0:0:0.1"/>
                            <DoubleAnimation Storyboard.TargetName="TopEdge"
                                             Storyboard.TargetProperty="Opacity"
                                             To="0.6"
                                             Duration="0:0:0.1"/>
                            <DoubleAnimation Storyboard.TargetName="SheenTransform"
                                             Storyboard.TargetProperty="X"
                                             To="96"
                                             Duration="0:0:0.36"
                                             EnableDependentAnimation="True"/>
                        </Storyboard>
                    </VisualState>

                    <VisualState x:Name="Pressed">
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetName="ChromeTransform"
                                             Storyboard.TargetProperty="TranslateY"
                                             To="0"
                                             Duration="0:0:0.08"
                                             EnableDependentAnimation="True"/>
                            <DoubleAnimation Storyboard.TargetName="GlowChrome"
                                             Storyboard.TargetProperty="Opacity"
                                             To="0.45"
                                             Duration="0:0:0.08"/>
                            <DoubleAnimation Storyboard.TargetName="SheenOverlay"
                                             Storyboard.TargetProperty="Opacity"
                                             To="0.18"
                                             Duration="0:0:0.08"/>
                            <DoubleAnimation Storyboard.TargetName="HoverWash"
                                             Storyboard.TargetProperty="Opacity"
                                             To="0.28"
                                             Duration="0:0:0.08"/>
                            <DoubleAnimation Storyboard.TargetName="TopEdge"
                                             Storyboard.TargetProperty="Opacity"
                                             To="0.34"
                                             Duration="0:0:0.08"/>
                        </Storyboard>
                    </VisualState>

                    <VisualState x:Name="Disabled">
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetName="GlowChrome"
                                             Storyboard.TargetProperty="Opacity"
                                             To="0"
                                             Duration="0:0:0.08"/>
                            <DoubleAnimation Storyboard.TargetName="HoverWash"
                                             Storyboard.TargetProperty="Opacity"
                                             To="0"
                                             Duration="0:0:0.08"/>
                            <DoubleAnimation Storyboard.TargetName="TopEdge"
                                             Storyboard.TargetProperty="Opacity"
                                             To="0.1"
                                             Duration="0:0:0.08"/>
                        </Storyboard>
                        <VisualState.Setters>
                            <Setter Target="Chrome.Opacity" Value="0.45"/>
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateManager.VisualStateGroups>
        </Grid>
    </ControlTemplate>

    <ControlTemplate x:Key="NeutralHudButtonTemplate" TargetType="Button">
        <Grid Background="Transparent">
            <Border x:Name="Chrome"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="{TemplateBinding CornerRadius}">
                <Grid>
                    <Rectangle x:Name="HoverWash"
                               Opacity="0"
                               IsHitTestVisible="False"
                               Fill="{StaticResource ButtonHoverWash}"/>

                    <Rectangle x:Name="TopEdge"
                               Height="1"
                               Margin="1,0,1,0"
                               VerticalAlignment="Top"
                               Opacity="0"
                               IsHitTestVisible="False"
                               Fill="{StaticResource ButtonTopEdgeBrush}"/>

                    <ContentPresenter x:Name="ContentPresenter"
                                      Margin="{TemplateBinding Padding}"
                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                      Content="{TemplateBinding Content}"
                                      ContentTemplate="{TemplateBinding ContentTemplate}"
                                      ContentTransitions="{TemplateBinding ContentTransitions}"/>
                </Grid>
            </Border>

            <VisualStateManager.VisualStateGroups>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal">
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetName="HoverWash"
                                             Storyboard.TargetProperty="Opacity"
                                             To="0"
                                             Duration="0:0:0.12"/>
                            <DoubleAnimation Storyboard.TargetName="TopEdge"
                                             Storyboard.TargetProperty="Opacity"
                                             To="0"
                                             Duration="0:0:0.12"/>
                        </Storyboard>
                    </VisualState>

                    <VisualState x:Name="PointerOver">
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetName="HoverWash"
                                             Storyboard.TargetProperty="Opacity"
                                             To="0.8"
                                             Duration="0:0:0.12"/>
                            <DoubleAnimation Storyboard.TargetName="TopEdge"
                                             Storyboard.TargetProperty="Opacity"
                                             To="0.42"
                                             Duration="0:0:0.12"/>
                        </Storyboard>
                    </VisualState>

                    <VisualState x:Name="Pressed">
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetName="HoverWash"
                                             Storyboard.TargetProperty="Opacity"
                                             To="0.28"
                                             Duration="0:0:0.08"/>
                            <DoubleAnimation Storyboard.TargetName="TopEdge"
                                             Storyboard.TargetProperty="Opacity"
                                             To="0.22"
                                             Duration="0:0:0.08"/>
                        </Storyboard>
                    </VisualState>

                    <VisualState x:Name="Disabled">
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetName="HoverWash"
                                             Storyboard.TargetProperty="Opacity"
                                             To="0"
                                             Duration="0:0:0.08"/>
                            <DoubleAnimation Storyboard.TargetName="TopEdge"
                                             Storyboard.TargetProperty="Opacity"
                                             To="0"
                                             Duration="0:0:0.08"/>
                        </Storyboard>
                        <VisualState.Setters>
                            <Setter Target="Chrome.Opacity" Value="0.45"/>
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateManager.VisualStateGroups>
        </Grid>
    </ControlTemplate>

    <Style x:Key="PrimaryActionButtonStyle" TargetType="Button">
        <Setter Property="Height" Value="40"/>
        <Setter Property="Padding" Value="18,0"/>
        <Setter Property="CornerRadius" Value="2"/>
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#261D42" Offset="0"/>
                    <GradientStop Color="#1B1432" Offset="1"/>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
        <Setter Property="Foreground" Value="{StaticResource AccentBlueBrush}"/>
        <Setter Property="BorderBrush" Value="#40A78BFA"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="FontFamily" Value="{StaticResource HeadingFont}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Template" Value="{StaticResource PrimaryHudButtonTemplate}"/>
    </Style>

    <Style x:Key="GoldActionButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryActionButtonStyle}">
        <Setter Property="Foreground" Value="{StaticResource AccentGoldBrush}"/>
        <Setter Property="BorderBrush" Value="#4FC9956A"/>
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#2A2018" Offset="0"/>
                    <GradientStop Color="#1B1511" Offset="1"/>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SecondaryActionButtonStyle" TargetType="Button">
        <Setter Property="Height" Value="40"/>
        <Setter Property="Padding" Value="18,0"/>
        <Setter Property="CornerRadius" Value="2"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource SubtleBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="FontFamily" Value="{StaticResource HeadingFont}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Template" Value="{StaticResource NeutralHudButtonTemplate}"/>
    </Style>

    <Style x:Key="DangerActionButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryActionButtonStyle}">
        <Setter Property="Foreground" Value="{StaticResource LossRedBrush}"/>
        <Setter Property="BorderBrush" Value="#88D38C90"/>
    </Style>

    <Style x:Key="ToolbarButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryActionButtonStyle}">
        <Setter Property="Height" Value="34"/>
        <Setter Property="Padding" Value="12,0"/>
        <Setter Property="FontSize" Value="12"/>
    </Style>

    <Style x:Key="QuietActionButtonStyle" TargetType="Button" BasedOn="{StaticResource ToolbarButtonStyle}">
        <Setter Property="Background" Value="{StaticResource TagBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
    </Style>

    <Style x:Key="GhostIconButtonStyle" TargetType="Button">
        <Setter Property="Width" Value="36"/>
        <Setter Property="Height" Value="36"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="CornerRadius" Value="2"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource SubtleBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Template" Value="{StaticResource NeutralHudButtonTemplate}"/>
    </Style>

    <Style x:Key="ListActionButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryActionButtonStyle}">
        <Setter Property="Height" Value="34"/>
        <Setter Property="Padding" Value="14,0"/>
        <Setter Property="FontSize" Value="12"/>
    </Style>

    <Style x:Key="GoldListActionButtonStyle" TargetType="Button" BasedOn="{StaticResource GoldActionButtonStyle}">
        <Setter Property="Height" Value="34"/>
        <Setter Property="Padding" Value="14,0"/>
        <Setter Property="FontSize" Value="12"/>
    </Style>

    <Style x:Key="CommandPanelButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryActionButtonStyle}">
        <Setter Property="Height" Value="72"/>
        <Setter Property="Padding" Value="14"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="VerticalContentAlignment" Value="Stretch"/>
    </Style>

    <Style x:Key="SidebarNavButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="Width" Value="44"/>
        <Setter Property="Height" Value="44"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="Margin" Value="0,0,0,2"/>
        <Setter Property="Template" Value="{StaticResource NeutralHudButtonTemplate}"/>
    </Style>

    <!-- ••• Chips and Badges ••• -->
    <Style x:Key="TagChipStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource TagBackgroundBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource SubtleBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="2"/>
        <Setter Property="Padding" Value="10,5"/>
    </Style>

    <Style x:Key="MetaChipStyle" TargetType="Border" BasedOn="{StaticResource TagChipStyle}">
        <Setter Property="Background" Value="{StaticResource InputBackgroundBrush}"/>
    </Style>

    <Style x:Key="SidebarGlyphBadgeStyle" TargetType="Border">
        <Setter Property="Width" Value="28"/>
        <Setter Property="Height" Value="28"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Background" Value="{StaticResource InputBackgroundBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource SubtleBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <Style x:Key="MetricGlyphBadgeStyle" TargetType="Border">
        <Setter Property="Width" Value="40"/>
        <Setter Property="Height" Value="40"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Background" Value="{StaticResource SurfaceHighlightBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource SubtleBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <Style x:Key="MetricGlyphBadgeSuccessStyle" TargetType="Border" BasedOn="{StaticResource MetricGlyphBadgeStyle}">
        <Setter Property="Background" Value="{StaticResource WinGreenDimBrush}"/>
    </Style>

    <Style x:Key="MetricGlyphBadgeGoldStyle" TargetType="Border" BasedOn="{StaticResource MetricGlyphBadgeStyle}">
        <Setter Property="Background" Value="{StaticResource AccentGoldDimBrush}"/>
    </Style>

    <Style x:Key="MetricGlyphBadgeDangerStyle" TargetType="Border" BasedOn="{StaticResource MetricGlyphBadgeStyle}">
        <Setter Property="Background" Value="{StaticResource LossRedDimBrush}"/>
    </Style>

    <!-- ••• HUD Practiced Toggle ••• -->
    <Style x:Key="HudPracticedToggleStyle" TargetType="ToggleButton">
        <Setter Property="Height" Value="30"/>
        <Setter Property="MinWidth" Value="110"/>
        <Setter Property="Padding" Value="12,0"/>
        <Setter Property="CornerRadius" Value="2"/>
        <Setter Property="FontFamily" Value="{StaticResource HeadingFont}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="HorizontalAlignment" Value="Right"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Grid Background="Transparent">
                        <!-- Glow layer (checked only) -->
                        <Border x:Name="GlowBorder"
                                Margin="-3"
                                CornerRadius="4"
                                Opacity="0"
                                IsHitTestVisible="False">
                            <Border.Background>
                                <SolidColorBrush Color="#20C9956A"/>
                            </Border.Background>
                        </Border>

                        <!-- Main chrome -->
                        <Border x:Name="Chrome"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                BorderThickness="1"
                                Padding="{TemplateBinding Padding}">
                            <Border.Background>
                                <SolidColorBrush x:Name="ChromeBg" Color="Transparent"/>
                            </Border.Background>
                            <Border.BorderBrush>
                                <SolidColorBrush x:Name="ChromeBorder" Color="#24203A"/>
                            </Border.BorderBrush>

                            <StackPanel Orientation="Horizontal"
                                        Spacing="6"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <!-- Checkmark glyph -->
                                <FontIcon x:Name="CheckGlyph"
                                          Glyph="&#xE73E;"
                                          FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                          Foreground="{StaticResource AccentGoldBrush}"
                                          Visibility="Collapsed"/>
                                <!-- Diamond glyph (unchecked) -->
                                <FontIcon x:Name="DiamondGlyph"
                                          Glyph="&#xE7C1;"
                                          FontSize="{Binding Micro, Source={StaticResource FontSizes}}"
                                          Foreground="{StaticResource MutedTextBrush}"/>
                                <TextBlock x:Name="Label"
                                           Text="PRACTICED"
                                           FontFamily="{StaticResource HeadingFont}"
                                           FontWeight="SemiBold"
                                           FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal"/>
                                <VisualState x:Name="PointerOver">
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="ChromeBorder"
                                                        Storyboard.TargetProperty="Color"
                                                        To="#60C9956A"
                                                        Duration="0:0:0.12"/>
                                        <ColorAnimation Storyboard.TargetName="ChromeBg"
                                                        Storyboard.TargetProperty="Color"
                                                        To="#0AC9956A"
                                                        Duration="0:0:0.12"/>
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="ChromeBorder"
                                                        Storyboard.TargetProperty="Color"
                                                        To="#80C9956A"
                                                        Duration="0:0:0.06"/>
                                        <ColorAnimation Storyboard.TargetName="ChromeBg"
                                                        Storyboard.TargetProperty="Color"
                                                        To="#18C9956A"
                                                        Duration="0:0:0.06"/>
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Disabled">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Chrome"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0.4"
                                                         Duration="0:0:0.1"/>
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Checked">
                                    <VisualState.Setters>
                                        <Setter Target="CheckGlyph.Visibility" Value="Visible"/>
                                        <Setter Target="DiamondGlyph.Visibility" Value="Collapsed"/>
                                        <Setter Target="Label.Foreground" Value="{StaticResource AccentGoldBrush}"/>
                                    </VisualState.Setters>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="ChromeBorder"
                                                        Storyboard.TargetProperty="Color"
                                                        To="#80C9956A"
                                                        Duration="0:0:0.14"/>
                                        <ColorAnimation Storyboard.TargetName="ChromeBg"
                                                        Storyboard.TargetProperty="Color"
                                                        To="#18C9956A"
                                                        Duration="0:0:0.14"/>
                                        <DoubleAnimation Storyboard.TargetName="GlowBorder"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="1"
                                                         Duration="0:0:0.2"/>
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="CheckedPointerOver">
                                    <VisualState.Setters>
                                        <Setter Target="CheckGlyph.Visibility" Value="Visible"/>
                                        <Setter Target="DiamondGlyph.Visibility" Value="Collapsed"/>
                                        <Setter Target="Label.Foreground" Value="{StaticResource AccentGoldBrush}"/>
                                    </VisualState.Setters>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="ChromeBorder"
                                                        Storyboard.TargetProperty="Color"
                                                        To="#A0C9956A"
                                                        Duration="0:0:0.1"/>
                                        <ColorAnimation Storyboard.TargetName="ChromeBg"
                                                        Storyboard.TargetProperty="Color"
                                                        To="#22C9956A"
                                                        Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetName="GlowBorder"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="1"
                                                         Duration="0:0:0.1"/>
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="CheckedPressed">
                                    <VisualState.Setters>
                                        <Setter Target="CheckGlyph.Visibility" Value="Visible"/>
                                        <Setter Target="DiamondGlyph.Visibility" Value="Collapsed"/>
                                        <Setter Target="Label.Foreground" Value="{StaticResource AccentGoldBrush}"/>
                                    </VisualState.Setters>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="ChromeBorder"
                                                        Storyboard.TargetProperty="Color"
                                                        To="#C0C9956A"
                                                        Duration="0:0:0.04"/>
                                        <ColorAnimation Storyboard.TargetName="ChromeBg"
                                                        Storyboard.TargetProperty="Color"
                                                        To="#30C9956A"
                                                        Duration="0:0:0.04"/>
                                        <DoubleAnimation Storyboard.TargetName="GlowBorder"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="1"
                                                         Duration="0:0:0.04"/>
                                    </Storyboard>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═════ HUD-themed tooltip ═════
         Overrides the default light Windows tooltip with a dark sidebar-
         toned background and the Revu purple accent border. Applied
         globally via the implicit ToolTip style. -->
    <SolidColorBrush x:Key="ToolTipForeground" Color="#F0EEF8"/>
    <SolidColorBrush x:Key="ToolTipBackground" Color="#0C0B12"/>
    <SolidColorBrush x:Key="ToolTipBorderBrush" Color="#A78BFA"/>
    <Thickness x:Key="ToolTipBorderThemePadding">10,6,10,6</Thickness>

    <Style TargetType="ToolTip">
        <Setter Property="Background" Value="{StaticResource ToolTipBackground}"/>
        <Setter Property="Foreground" Value="{StaticResource ToolTipForeground}"/>
        <Setter Property="BorderBrush" Value="{StaticResource ToolTipBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="{StaticResource ToolTipBorderThemePadding}"/>
        <Setter Property="FontFamily" Value="{StaticResource MonoFont}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="CharacterSpacing" Value="80"/>
        <Setter Property="CornerRadius" Value="0"/>
    </Style>

    <!-- v2.15.7: HUD-themed AutoSuggestBox. The default Fluent style has
         rounded corners, a wide padding, and a light-theme popup — looks
         out of place in our dark violet UI. This style flattens it:
         square corners, HUD input surface, mono font, subtle border. -->
    <Style x:Key="HudSuggestBoxStyle" TargetType="AutoSuggestBox">
        <Setter Property="Background" Value="{StaticResource InputBackgroundBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource SubtleBorderBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource MonoFont}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="CornerRadius" Value="2"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="MinHeight" Value="32"/>
    </Style>

    <!-- v2.15.7: ListViewItem container style for the ObjectivePicker popup.
         Flatter hover + selection states so the "row is hovered" feedback
         doesn't fight with mouse positioning on single-click select. -->
    <Style x:Key="HudSuggestListItemStyle" TargetType="ListViewItem">
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Margin" Value="0"/>
        <Setter Property="MinHeight" Value="30"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="UseSystemFocusVisuals" Value="False"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListViewItem">
                    <Grid x:Name="Root" Background="Transparent">
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal"/>
                                <VisualState x:Name="PointerOver">
                                    <VisualState.Setters>
                                        <Setter Target="Root.Background" Value="#2218162A"/>
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <VisualState.Setters>
                                        <Setter Target="Root.Background" Value="#44A78BFA"/>
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Selected">
                                    <VisualState.Setters>
                                        <Setter Target="Root.Background" Value="#33A78BFA"/>
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="PointerOverSelected">
                                    <VisualState.Setters>
                                        <Setter Target="Root.Background" Value="#44A78BFA"/>
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                        <ContentPresenter HorizontalContentAlignment="Stretch"
                                          VerticalContentAlignment="Center"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- v2.15.7: keep the AutoSuggestBox style for other surfaces, but the
         three objective pickers on VodPlayer use the custom ObjectivePicker
         UserControl because AutoSuggestBox had a two-click-to-select quirk. -->
    <SolidColorBrush x:Key="AutoSuggestBoxSuggestionsListBackground"
                     Color="#14121E"/>
    <SolidColorBrush x:Key="AutoSuggestBoxSuggestionsListBorderBrush"
                     Color="#33A78BFA"/>
    <Thickness x:Key="AutoSuggestListViewPopupBorderThickness">1</Thickness>
    <CornerRadius x:Key="AutoSuggestListCornerRadius">2</CornerRadius>
    <CornerRadius x:Key="OverlayCornerRadius">2</CornerRadius>

</ResourceDictionary>
