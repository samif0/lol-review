<UserControl
    x:Class="Revu.App.Controls.CornerBracketedCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Revu.App.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="LayoutRoot" Padding="4,4">
        <Grid x:Name="HoverSurface"
              PointerEntered="OnPointerEntered"
              PointerMoved="OnPointerMoved"
              PointerExited="OnPointerExited">
            <Border x:Name="MainBorder"
                    Background="{StaticResource CardBackgroundBrush}"
                    BorderBrush="{StaticResource SubtleBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="0"
                    Padding="20">
                <Grid>
                    <Border x:Name="GlowOverlay"
                            CornerRadius="2"
                            IsHitTestVisible="False"
                            Opacity="0">
                        <Border.Background>
                            <RadialGradientBrush x:Name="GlowBrush"
                                                 Center="0.5,0.5"
                                                 GradientOrigin="0.5,0.5"
                                                 RadiusX="0.95"
                                                 RadiusY="0.95">
                                <GradientStop Color="#08A78BFA" Offset="0"/>
                                <GradientStop Color="#03A78BFA" Offset="0.4"/>
                                <GradientStop Color="#00A78BFA" Offset="1"/>
                            </RadialGradientBrush>
                        </Border.Background>
                    </Border>
                    <ContentPresenter x:Name="ContentHost"
                                      HorizontalAlignment="Stretch"
                                      VerticalAlignment="Stretch"/>
                </Grid>
            </Border>

            <Border x:Name="TopLeft"
                    Width="10"
                    Height="10"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Margin="6,6,0,0"
                    BorderBrush="{StaticResource BrightBorderBrush}"
                    BorderThickness="1,1,0,0"
                    IsHitTestVisible="False"
                    Opacity="0"/>

            <Border x:Name="TopRight"
                    Width="10"
                    Height="10"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,6,6,0"
                    BorderBrush="{StaticResource BrightBorderBrush}"
                    BorderThickness="0,1,1,0"
                    IsHitTestVisible="False"
                    Opacity="0"/>

            <Border x:Name="BottomLeft"
                    Width="10"
                    Height="10"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Bottom"
                    Margin="6,0,0,6"
                    BorderBrush="{StaticResource BrightBorderBrush}"
                    BorderThickness="1,0,0,1"
                    IsHitTestVisible="False"
                    Opacity="0"/>

            <Border x:Name="BottomRight"
                    Width="10"
                    Height="10"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Margin="0,0,6,6"
                    BorderBrush="{StaticResource BrightBorderBrush}"
                    BorderThickness="0,0,1,1"
                    IsHitTestVisible="False"
                    Opacity="0"/>
        </Grid>
    </Grid>
</UserControl>
