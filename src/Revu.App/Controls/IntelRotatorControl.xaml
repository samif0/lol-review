<UserControl
    x:Class="Revu.App.Controls.IntelRotatorControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources>
        <!-- ‹ › step buttons that flank the card. Ghost look so they read as
             chrome, not content; sized to the card height by their column. -->
        <Style x:Key="IntelStepButtonStyle" TargetType="Button" BasedOn="{StaticResource GhostIconButtonStyle}">
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontFamily" Value="{StaticResource HeadingFont}"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}"/>
        </Style>
    </UserControl.Resources>

    <Border Background="{StaticResource SurfaceInsetBrush}"
            BorderBrush="{StaticResource SubtleBorderBrush}"
            BorderThickness="1"
            CornerRadius="0"
            MinHeight="120"
            Padding="10,14">
        <Grid ColumnDefinitions="Auto,*,Auto">
            <!-- Prev arrow -->
            <Button x:Name="PrevButton"
                    Grid.Column="0"
                    Style="{StaticResource IntelStepButtonStyle}"
                    Content="&#x2039;"
                    Click="OnPrevClick"
                    Visibility="Collapsed"
                    AutomationProperties.Name="Previous intel card"
                    ToolTipService.ToolTip="Previous (←)"/>

            <Grid Grid.Column="1" Margin="8,0">
                <StackPanel x:Name="EmptyHint"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            Spacing="4"
                            Visibility="Collapsed">
                    <TextBlock Text="LOADING INTEL..."
                               FontFamily="{StaticResource MonoFont}"
                               FontSize="10"
                               CharacterSpacing="300"
                               Foreground="{StaticResource MutedTextBrush}"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <StackPanel x:Name="CardSurface" Spacing="6">
                    <TextBlock x:Name="EyebrowText"
                               FontFamily="{StaticResource MonoFont}"
                               FontSize="10"
                               CharacterSpacing="300"
                               Foreground="{StaticResource AccentGoldBrush}"/>
                    <TextBlock x:Name="HeadlineText"
                               FontFamily="{StaticResource HeadingFont}"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryTextBrush}"
                               TextWrapping="Wrap"/>
                    <TextBlock x:Name="BodyText"
                               FontFamily="{StaticResource MonoFont}"
                               FontSize="11"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <!-- Pagination dots -->
                <StackPanel x:Name="DotsRow"
                            Orientation="Horizontal"
                            Spacing="4"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Bottom"/>
            </Grid>

            <!-- Next arrow -->
            <Button x:Name="NextButton"
                    Grid.Column="2"
                    Style="{StaticResource IntelStepButtonStyle}"
                    Content="&#x203A;"
                    Click="OnNextClick"
                    Visibility="Collapsed"
                    AutomationProperties.Name="Next intel card"
                    ToolTipService.ToolTip="Next (→)"/>
        </Grid>
    </Border>
</UserControl>
