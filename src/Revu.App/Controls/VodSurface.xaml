<UserControl
    x:Class="Revu.App.Controls.VodSurface"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Revu.App.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <!-- Shared VOD playback surface: video + transport + timeline. The playback
         core (MediaPlayer setup, stable-file load, duration probe, seek,
         position tick) is lifted verbatim from VodPlayerPage so playback here is
         identical. Page-specific chrome (clip extraction, theater mode, moments
         inbox) stays on the host page, not here. -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Video -->
        <Border x:Name="VideoBorder"
                Grid.Row="0"
                Background="{StaticResource SurfaceInsetBrush}"
                BorderBrush="{StaticResource SubtleBorderBrush}"
                BorderThickness="1" CornerRadius="2" Padding="6"
                PointerEntered="OnVideoBorderPointerEntered"
                PointerExited="OnVideoBorderPointerExited">
            <Grid x:Name="VideoContainer"
                  AllowFocusOnInteraction="True"
                  Background="#020405"
                  IsTabStop="True"
                  MinHeight="360"
                  Tapped="OnVideoTapped">
                <Grid x:Name="LoadingOverlay"
                      Background="{StaticResource PanelOverlayBrush}"
                      Visibility="Collapsed">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="10">
                        <ProgressRing IsActive="True" Width="40" Height="40"/>
                        <TextBlock Text="Loading recording"
                                   FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                   HorizontalAlignment="Center"
                                   Foreground="{StaticResource SecondaryTextBrush}"/>
                    </StackPanel>
                </Grid>

                <Border x:Name="NoVodBorder"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        Background="{StaticResource SurfaceRaisedBrush}"
                        BorderBrush="{StaticResource SubtleBorderBrush}"
                        BorderThickness="1" CornerRadius="2" Padding="22,18"
                        MaxWidth="420"
                        Visibility="Collapsed">
                    <TextBlock x:Name="NoVodText"
                               Text="No recording for this game."
                               FontSize="{Binding Title, Source={StaticResource FontSizes}}"
                               TextWrapping="Wrap"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               Foreground="{StaticResource SecondaryTextBrush}"/>
                </Border>

                <Button x:Name="VideoPlayPauseButton"
                        Click="OnVideoPlayPauseClick"
                        HorizontalAlignment="Center" VerticalAlignment="Bottom"
                        Margin="0,0,0,24"
                        Width="64" Height="52" Padding="0" CornerRadius="2"
                        Background="#CC000000"
                        BorderBrush="{StaticResource BrightBorderBrush}"
                        BorderThickness="1"
                        Foreground="{StaticResource PrimaryTextBrush}"
                        IsTabStop="False" AllowFocusOnInteraction="False"
                        Visibility="Collapsed">
                    <FontIcon x:Name="VideoPlayPauseIcon" Glyph="&#xE768;"
                              FontSize="{Binding TitleLarge, Source={StaticResource FontSizes}}"
                              FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"/>
                </Button>
            </Grid>
        </Border>

        <!-- Transport -->
        <Border x:Name="TransportBar"
                Grid.Row="1"
                Margin="0,12,0,0"
                Background="{StaticResource SurfaceInsetBrush}"
                BorderBrush="{StaticResource SubtleBorderBrush}"
                BorderThickness="1" CornerRadius="2" Padding="12,8">
            <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,*,Auto,Auto,Auto,Auto" ColumnSpacing="8">
                <Button Grid.Column="0"
                        Click="OnSeekBackClick"
                        Style="{StaticResource GhostIconButtonStyle}"
                        Width="40" Height="38" IsTabStop="False" AllowFocusOnInteraction="False">
                    <FontIcon Glyph="&#xEB9E;" FontSize="{Binding Title, Source={StaticResource FontSizes}}"
                              FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"/>
                </Button>

                <Button Grid.Column="1"
                        Click="OnTransportPlayPauseClick"
                        Style="{StaticResource PrimaryActionButtonStyle}"
                        Width="56" Padding="0" IsTabStop="False" AllowFocusOnInteraction="False">
                    <FontIcon x:Name="PlayPauseIcon" Glyph="&#xE768;"
                              FontSize="{Binding TitleLarge, Source={StaticResource FontSizes}}"
                              FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"/>
                </Button>

                <Button Grid.Column="2"
                        Click="OnSeekForwardClick"
                        Style="{StaticResource GhostIconButtonStyle}"
                        Width="40" Height="38" IsTabStop="False" AllowFocusOnInteraction="False">
                    <FontIcon Glyph="&#xEB9D;" FontSize="{Binding Title, Source={StaticResource FontSizes}}"
                              FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"/>
                </Button>

                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="CurrentTimeText" Text="0:00"
                               FontFamily="{StaticResource MonoFont}"
                               FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                               Foreground="{StaticResource SecondaryTextBrush}"/>
                    <TextBlock Text=" / "
                               FontFamily="{StaticResource MonoFont}"
                               FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                               Foreground="{StaticResource SecondaryTextBrush}"/>
                    <TextBlock x:Name="TotalTimeText" Text="0:00"
                               FontFamily="{StaticResource MonoFont}"
                               FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                               Foreground="{StaticResource SecondaryTextBrush}"/>
                </StackPanel>

                <Border Grid.Column="4"/>

                <TextBlock Grid.Column="5" Text="Speed"
                           FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource SecondaryTextBrush}"/>

                <ComboBox x:Name="SpeedCombo" Grid.Column="6"
                          Width="80" SelectedIndex="2"
                          SelectionChanged="OnSpeedChanged"
                          Background="{StaticResource InputBackgroundBrush}"
                          BorderBrush="{StaticResource SubtleBorderBrush}"
                          Foreground="{StaticResource PrimaryTextBrush}"
                          FontSize="{Binding Meta, Source={StaticResource FontSizes}}" CornerRadius="2"
                          IsTabStop="False">
                    <ComboBoxItem Content="0.25x" Tag="0.25"/>
                    <ComboBoxItem Content="0.5x" Tag="0.5"/>
                    <ComboBoxItem Content="1.0x" Tag="1.0"/>
                    <ComboBoxItem Content="1.5x" Tag="1.5"/>
                    <ComboBoxItem Content="2.0x" Tag="2.0"/>
                </ComboBox>

                <Button Grid.Column="7" x:Name="MuteButton"
                        Click="OnMuteClick"
                        Style="{StaticResource GhostIconButtonStyle}"
                        Width="38" Height="38" IsTabStop="False" AllowFocusOnInteraction="False">
                    <FontIcon x:Name="VolumeIcon" Glyph="&#xE767;"
                              FontSize="{Binding Subtitle, Source={StaticResource FontSizes}}"
                              FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"/>
                </Button>

                <Slider Grid.Column="8" x:Name="VolumeSlider"
                        Width="80" Minimum="0" Maximum="100" Value="100"
                        Foreground="{StaticResource AccentBlueBrush}"
                        VerticalAlignment="Center"
                        ValueChanged="OnVolumeChanged"/>
            </Grid>
        </Border>

        <!-- Slim scrub bar, built from primitives to match the HUD (the default
             Slider chrome doesn't). Thin dark inset track + accent fill + a small
             playhead. The hit area is the full-height grid so clicking anywhere
             seeks; SizeChanged keeps the geometry in sync. -->
        <Grid x:Name="ScrubBar"
              Grid.Row="2"
              Height="14"
              Margin="2,10,2,2"
              Background="Transparent"
              SizeChanged="OnScrubSizeChanged"
              PointerPressed="OnScrubPointerPressed"
              PointerMoved="OnScrubPointerMoved"
              PointerReleased="OnScrubPointerReleased"
              PointerCanceled="OnScrubPointerReleased"
              PointerCaptureLost="OnScrubPointerReleased">
            <Border x:Name="ScrubTrack"
                    Height="4"
                    VerticalAlignment="Center"
                    CornerRadius="2"
                    Background="{StaticResource SurfaceInsetBrush}"
                    BorderBrush="{StaticResource SubtleBorderBrush}"
                    BorderThickness="1"/>
            <Border x:Name="ScrubFill"
                    Height="4"
                    Width="0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    CornerRadius="2"
                    Background="{StaticResource AccentBlueBrush}"/>
            <Border x:Name="ScrubThumb"
                    Width="3" Height="14"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    CornerRadius="1"
                    Background="{StaticResource AccentBlueBrush}"/>
        </Grid>
    </Grid>
</UserControl>
