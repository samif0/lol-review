<UserControl
    x:Class="Revu.App.Controls.BannerControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:svc="using:Revu.App.Services"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Border x:Name="OuterBorder"
            Background="{StaticResource SurfaceRaisedBrush}"
            BorderBrush="{StaticResource SubtleBorderBrush}"
            BorderThickness="0"
            CornerRadius="2"
            Padding="0">
        <Grid ColumnSpacing="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Tone-colored left bar (pulses) -->
            <Rectangle x:Name="ToneBar"
                       Grid.Column="0"
                       HorizontalAlignment="Stretch"
                       VerticalAlignment="Stretch"
                       Fill="{StaticResource AccentBlueBrush}"/>

            <!-- Content -->
            <Grid Grid.Column="1" ColumnSpacing="12" Padding="14,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <FontIcon x:Name="IconGlyph"
                          Grid.Column="0"
                          FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                          Glyph="&#xE946;"
                          FontSize="{Binding Subtitle, Source={StaticResource FontSizes}}"
                          VerticalAlignment="Center"
                          Foreground="{StaticResource AccentBlueBrush}"/>

                <TextBlock x:Name="MessageTextBlock"
                           Grid.Column="1"
                           FontFamily="{StaticResource HeadingFont}"
                           FontSize="{Binding BodyEmphasis, Source={StaticResource FontSizes}}"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource PrimaryTextBrush}"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap"/>
            </Grid>
        </Grid>
    </Border>
</UserControl>
