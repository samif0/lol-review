<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Revu.App.Controls.ObjectiveEditForm"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Revu.App.ViewModels"
    xmlns:converters="using:Revu.App.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <!--
        v2.18: shared objective create/edit form, extracted from ObjectivesPage so
        it can render BOTH as the top-of-page "New Objective" form AND inline inside
        the card being edited (F4: edit-in-place). Bound to ObjectivesViewModel via
        ViewModel (set from the host's DataContext). One instance is visible at a
        time, so they safely share the ViewModel's New* form state.
    -->

    <!-- A UserControl does NOT inherit the host Page's Page.Resources, and
         BoolToVis is declared per-page (not app-wide), so the StaticResource
         lookups below must be satisfied locally. Without this, building the
         control threw XamlParseException ("Cannot find a Resource ... BoolToVis"),
         which bubbled up and made navigating to the Objectives page fail. -->
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Border Style="{StaticResource CardStyle}"
            BorderBrush="{StaticResource AccentBlueBrush}">
        <StackPanel Spacing="12">
            <TextBlock Text="{Binding ObjectiveFormTitle, Mode=OneWay}"
                       FontSize="{Binding Title, Source={StaticResource FontSizes}}" FontWeight="SemiBold"
                       Foreground="{StaticResource PrimaryTextBrush}"/>

            <!-- Title -->
            <StackPanel Spacing="4">
                <TextBlock Text="Title *" FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                           Foreground="{StaticResource SecondaryTextBrush}"/>
                <TextBox Text="{Binding NewTitle, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         PlaceholderText="e.g., Improve wave management"
                         Background="{StaticResource InputBackgroundBrush}"
                         Foreground="{StaticResource PrimaryTextBrush}"
                         BorderBrush="{StaticResource SubtleBorderBrush}"
                         CornerRadius="2"/>
            </StackPanel>

            <!-- Skill Area -->
            <StackPanel Spacing="4">
                <TextBlock Text="Skill Area" FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                           Foreground="{StaticResource SecondaryTextBrush}"/>
                <TextBox Text="{Binding NewSkillArea, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         PlaceholderText="e.g., Laning, Macro, Teamfighting"
                         Background="{StaticResource InputBackgroundBrush}"
                         Foreground="{StaticResource PrimaryTextBrush}"
                         BorderBrush="{StaticResource SubtleBorderBrush}"
                         CornerRadius="2"/>
            </StackPanel>

            <!-- Type -->
            <StackPanel Spacing="4">
                <TextBlock Text="Type" FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                           Foreground="{StaticResource SecondaryTextBrush}"/>
                <ComboBox SelectedIndex="{Binding NewTypeIndex, Mode=TwoWay}"
                          Background="{StaticResource InputBackgroundBrush}"
                          Foreground="{StaticResource PrimaryTextBrush}"
                          BorderBrush="{StaticResource SubtleBorderBrush}"
                          CornerRadius="2" MinWidth="200">
                    <ComboBoxItem Content="Gameplay"/>
                    <ComboBoxItem Content="Mental"/>
                    <!-- v2.17.7: short-horizon focus for N games. Auto-archives. -->
                    <ComboBoxItem Content="Mini focus (next N games)"/>
                </ComboBox>
            </StackPanel>

            <!-- v2.17.7: target-games stepper, only meaningful for Mini focus. -->
            <StackPanel Spacing="4"
                        Visibility="{Binding ShowTargetGameCount, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="Focus for this many games"
                           FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                           Foreground="{StaticResource SecondaryTextBrush}"/>
                <TextBlock Text="Mini focus auto-archives once you've recorded this many games against it. Use it for skills you want to drill briefly — e.g. flash usage for the next 3 games."
                           FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                           Foreground="{StaticResource MutedTextBrush}"
                           TextWrapping="Wrap"/>
                <NumberBox Value="{Binding NewTargetGameCount, Mode=TwoWay}"
                           Minimum="1" Maximum="20"
                           SpinButtonPlacementMode="Inline"
                           Background="{StaticResource InputBackgroundBrush}"
                           Foreground="{StaticResource PrimaryTextBrush}"
                           BorderBrush="{StaticResource SubtleBorderBrush}"
                           MinWidth="160" HorizontalAlignment="Left"/>
            </StackPanel>

            <!-- v2.15.0: multi-phase practice. Objective can practice any subset. -->
            <StackPanel Spacing="4">
                <TextBlock Text="Practice during" FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                           Foreground="{StaticResource SecondaryTextBrush}"/>
                <TextBlock Text="Pick one or more phases where this objective applies. Prompts you design below will only render in the phases you check here."
                           FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                           Foreground="{StaticResource MutedTextBrush}"
                           TextWrapping="Wrap"/>
                <StackPanel Orientation="Horizontal" Spacing="16">
                    <CheckBox Content="Pre-Game"
                              IsChecked="{Binding NewPracticePre, Mode=TwoWay}"
                              Foreground="{StaticResource PrimaryTextBrush}"/>
                    <CheckBox Content="In-Game"
                              IsChecked="{Binding NewPracticeIn, Mode=TwoWay}"
                              Foreground="{StaticResource PrimaryTextBrush}"/>
                    <CheckBox Content="Post-Game"
                              IsChecked="{Binding NewPracticePost, Mode=TwoWay}"
                              Foreground="{StaticResource PrimaryTextBrush}"/>
                </StackPanel>
            </StackPanel>

            <!-- v2.18 (F2): game-phase focus, used to match auto-clips to this objective. -->
            <StackPanel Spacing="4">
                <TextBlock Text="Focus phase (for auto-clips)" FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                           Foreground="{StaticResource SecondaryTextBrush}"/>
                <TextBlock Text="Which part of the game this objective is about. Auto-picked clips are matched to it — Laning surfaces early-game moments, Teamfighting/Mid-Late surfaces skirmishes and objective fights. 'Auto' infers from the title."
                           FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                           Foreground="{StaticResource MutedTextBrush}"
                           TextWrapping="Wrap"/>
                <ComboBox SelectedIndex="{Binding NewFocusPhaseIndex, Mode=TwoWay}"
                          Background="{StaticResource InputBackgroundBrush}"
                          Foreground="{StaticResource PrimaryTextBrush}"
                          BorderBrush="{StaticResource SubtleBorderBrush}"
                          CornerRadius="2" MinWidth="200">
                    <ComboBoxItem Content="Auto (infer from title)"/>
                    <ComboBoxItem Content="Laning / early game"/>
                    <ComboBoxItem Content="Mid / late game"/>
                    <ComboBoxItem Content="Teamfighting"/>
                    <ComboBoxItem Content="Any phase"/>
                </ComboBox>
            </StackPanel>

            <!-- v2.18 (schema v5): measured success criterion. When a metric is
                 picked, every game that practices this objective gets an
                 automatic pass/fail against the threshold from its post-game
                 stats — the card then shows a real hit rate instead of a
                 decorative sentence. -->
            <StackPanel Spacing="4">
                <TextBlock Text="Measured criterion" FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                           Foreground="{StaticResource SecondaryTextBrush}"/>
                <TextBlock Text="Pick a stat and a threshold and Revu checks it automatically after every practiced game. Leave on 'Free text only' to keep the criterion as words."
                           FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                           Foreground="{StaticResource MutedTextBrush}"
                           TextWrapping="Wrap"/>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <ComboBox ItemsSource="{Binding CriteriaMetricOptions, Mode=OneWay}"
                              SelectedIndex="{Binding NewCriteriaMetricIndex, Mode=TwoWay}"
                              Background="{StaticResource InputBackgroundBrush}"
                              Foreground="{StaticResource PrimaryTextBrush}"
                              BorderBrush="{StaticResource SubtleBorderBrush}"
                              CornerRadius="2" MinWidth="200"/>
                    <ComboBox SelectedIndex="{Binding NewCriteriaOpIndex, Mode=TwoWay}"
                              Background="{StaticResource InputBackgroundBrush}"
                              Foreground="{StaticResource PrimaryTextBrush}"
                              BorderBrush="{StaticResource SubtleBorderBrush}"
                              CornerRadius="2" MinWidth="110"
                              Visibility="{Binding ShowCriteriaBuilderValue, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                        <ComboBoxItem Content="At least"/>
                        <ComboBoxItem Content="At most"/>
                    </ComboBox>
                    <TextBox Text="{Binding NewCriteriaValueText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             PlaceholderText="7"
                             MinWidth="80"
                             Background="{StaticResource InputBackgroundBrush}"
                             Foreground="{StaticResource PrimaryTextBrush}"
                             BorderBrush="{StaticResource SubtleBorderBrush}"
                             CornerRadius="2"
                             Visibility="{Binding ShowCriteriaBuilderValue, Mode=OneWay, Converter={StaticResource BoolToVis}}"/>
                </StackPanel>
            </StackPanel>

            <!-- Completion Criteria -->
            <StackPanel Spacing="4">
                <TextBlock Text="Completion Criteria" FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                           Foreground="{StaticResource SecondaryTextBrush}"/>
                <TextBox Text="{Binding NewCriteria, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         PlaceholderText="How will you know you've mastered this?"
                         Background="{StaticResource InputBackgroundBrush}"
                         Foreground="{StaticResource PrimaryTextBrush}"
                         BorderBrush="{StaticResource SubtleBorderBrush}"
                         CornerRadius="2"/>
            </StackPanel>

            <!-- Description -->
            <StackPanel Spacing="4">
                <TextBlock Text="Description" FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                           Foreground="{StaticResource SecondaryTextBrush}"/>
                <TextBox Text="{Binding NewDescription, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         PlaceholderText="Additional notes..."
                         Background="{StaticResource InputBackgroundBrush}"
                         Foreground="{StaticResource PrimaryTextBrush}"
                         BorderBrush="{StaticResource SubtleBorderBrush}"
                         CornerRadius="2"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         MinHeight="60"/>
            </StackPanel>

            <!-- v2.15.0: CUSTOM PROMPTS editor. -->
            <StackPanel Spacing="8">
                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <Rectangle Width="18" Height="1"
                               Fill="{StaticResource AccentPurpleBrush}"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="CUSTOM PROMPTS"
                               FontFamily="{StaticResource MonoFont}"
                               FontSize="{Binding Caption, Source={StaticResource FontSizes}}"
                               CharacterSpacing="300"
                               Foreground="{StaticResource AccentPurpleBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Text="Add labeled text fields you'll answer during the selected phases. Use these to prompt yourself with specific details — e.g. 'Key spells during trading', 'Expected wave state at 3:00'. Blank labels are ignored on save."
                           FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                           Foreground="{StaticResource MutedTextBrush}"
                           TextWrapping="Wrap"/>

                <ItemsRepeater ItemsSource="{Binding NewPrompts, Mode=OneWay}">
                    <ItemsRepeater.Layout>
                        <StackLayout Spacing="8"/>
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="vm:PromptDraftItem">
                            <Border Background="{StaticResource InputBackgroundBrush}"
                                    BorderBrush="{StaticResource SubtleBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="2"
                                    Padding="10,8">
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <ComboBox Grid.Column="0"
                                              SelectedIndex="{x:Bind PhaseIndex, Mode=TwoWay}"
                                              MinWidth="110"
                                              VerticalAlignment="Top">
                                        <ComboBoxItem Content="Pre-Game"/>
                                        <ComboBoxItem Content="In-Game"/>
                                        <ComboBoxItem Content="Post-Game"/>
                                    </ComboBox>

                                    <TextBox Grid.Column="1"
                                             Text="{x:Bind Label, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             PlaceholderText="e.g. How will the 2v2 go? What spells are key?"
                                             Background="{StaticResource InputBackgroundBrush}"
                                             Foreground="{StaticResource PrimaryTextBrush}"
                                             BorderBrush="{StaticResource SubtleBorderBrush}"
                                             AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             MinHeight="36"/>

                                    <Button Grid.Column="2"
                                            Click="RemovePromptDraftButton_Click"
                                            Tag="{x:Bind}"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Padding="8,4"
                                            ToolTipService.ToolTip="Remove this prompt">
                                        <FontIcon Glyph="&#xE74D;"
                                                  FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                                  FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                                  Foreground="{StaticResource LossRedBrush}"/>
                                    </Button>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>

                <Button Content="+ ADD PROMPT"
                        Command="{Binding AddPromptCommand}"
                        Background="Transparent"
                        BorderBrush="{StaticResource AccentPurpleBrush}"
                        BorderThickness="1"
                        Foreground="{StaticResource AccentPurpleBrush}"
                        FontFamily="{StaticResource MonoFont}"
                        FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                        CharacterSpacing="200"
                        CornerRadius="2"
                        Padding="14,6"
                        HorizontalAlignment="Left"/>
            </StackPanel>

            <!-- v2.15.0: CHAMPIONS filter. Empty = applies to all champions. -->
            <StackPanel Spacing="8">
                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <Rectangle Width="18" Height="1"
                               Fill="{StaticResource AccentTealBrush}"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="CHAMPIONS"
                               FontFamily="{StaticResource MonoFont}"
                               FontSize="{Binding Caption, Source={StaticResource FontSizes}}"
                               CharacterSpacing="300"
                               Foreground="{StaticResource AccentTealBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Text="Optional. Leave empty to apply this objective to every champion. Pick one or more champions below to only surface this objective when you're on one of them."
                           FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                           Foreground="{StaticResource MutedTextBrush}"
                           TextWrapping="Wrap"/>

                <!-- Picked champions as chips. UniformGridLayout wraps to the next row
                     when it runs out of width — StackLayout clips instead. -->
                <ItemsRepeater ItemsSource="{Binding NewChampions, Mode=OneWay}"
                               Visibility="{Binding HasNewChampions, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                    <ItemsRepeater.Layout>
                        <UniformGridLayout Orientation="Horizontal"
                                           MinItemWidth="110"
                                           MinItemHeight="30"
                                           MinColumnSpacing="6"
                                           MinRowSpacing="6"
                                           ItemsJustification="Start"
                                           ItemsStretch="None"/>
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="x:String">
                            <Button Background="{StaticResource TagBackgroundBrush}"
                                    BorderBrush="{StaticResource AccentTealBrush}"
                                    BorderThickness="1"
                                    Foreground="{StaticResource PrimaryTextBrush}"
                                    Click="RemoveChampionChip_Click"
                                    Tag="{x:Bind}"
                                    CornerRadius="2"
                                    Padding="10,4"
                                    Height="28"
                                    ToolTipService.ToolTip="Click to remove">
                                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                    <TextBlock Text="{x:Bind}"
                                               FontFamily="{StaticResource MonoFont}"
                                               FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="×"
                                               FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                               Foreground="{StaticResource LossRedBrush}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>

                <!-- v2.15.1: type-to-filter search replaces the chip grid. Shorter,
                     scales to any champion count, doesn't eat vertical space. -->
                <AutoSuggestBox x:Name="ChampionSearchBox"
                                Style="{StaticResource HudSuggestBoxStyle}"
                                PlaceholderText="Search champion..."
                                TextChanged="ChampionSearchBox_TextChanged"
                                SuggestionChosen="ChampionSearchBox_SuggestionChosen"
                                QuerySubmitted="ChampionSearchBox_QuerySubmitted"
                                MinWidth="240"
                                HorizontalAlignment="Stretch"/>
            </StackPanel>

            <!-- Action Buttons -->
            <StackPanel Orientation="Horizontal" Spacing="8"
                        HorizontalAlignment="Right">
                <Button Content="Cancel"
                        Command="{Binding ToggleCreateFormCommand}"
                        Background="{StaticResource TagBackgroundBrush}"
                        Foreground="{StaticResource PrimaryTextBrush}"
                        CornerRadius="2" Height="32"
                        BorderThickness="0"/>
                <Button Content="{Binding SaveObjectiveButtonText, Mode=OneWay}"
                        Command="{Binding CreateObjectiveCommand}"
                        IsEnabled="{Binding CanCreate, Mode=OneWay}"
                        Background="{StaticResource AccentBlueBrush}"
                        Foreground="{StaticResource ActionPrimaryForegroundBrush}"
                        CornerRadius="2" Height="32"
                        BorderThickness="0"/>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
