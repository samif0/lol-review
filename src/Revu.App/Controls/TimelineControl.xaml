<UserControl
    x:Class="Revu.App.Controls.TimelineControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:svc="using:Revu.App.Services"
    MinHeight="104"
    PointerPressed="OnPointerPressed"
    PointerMoved="OnPointerMoved"
    PointerReleased="OnPointerReleased"
    PointerExited="OnPointerExited"
    SizeChanged="OnSizeChanged">

    <Canvas x:Name="TimelineCanvas"
            Background="Transparent">
        <Border x:Name="TimelineFrame"
                Canvas.Top="0"
                CornerRadius="2"
                Background="{StaticResource CardBackgroundBrush}"
                BorderBrush="{StaticResource SubtleBorderBrush}"
                BorderThickness="1" />

        <Border x:Name="TrackShell"
                Canvas.Top="22"
                Height="36"
                CornerRadius="2"
                Background="{StaticResource SurfaceInsetBrush}"
                BorderBrush="{StaticResource SubtleBorderBrush}"
                BorderThickness="1" />

        <Border x:Name="TrackBg"
                Canvas.Top="34"
                Height="12"
                CornerRadius="2"
                Background="{StaticResource TagBackgroundBrush}" />

        <Border x:Name="ClipOverlay"
                Canvas.Top="31"
                Height="18"
                Background="{StaticResource AccentGoldBrush}"
                Opacity="0.24"
                Visibility="Collapsed" />

        <Border x:Name="ClipInMarker"
                Canvas.Top="24"
                Width="2"
                Height="32"
                Background="{StaticResource AccentGoldBrush}"
                Visibility="Collapsed" />

        <Border x:Name="ClipOutMarker"
                Canvas.Top="24"
                Width="2"
                Height="32"
                Background="{StaticResource AccentGoldBrush}"
                Visibility="Collapsed" />

        <Border x:Name="ProgressBar"
                Canvas.Top="34"
                Height="12"
                CornerRadius="2"
                Background="{StaticResource AccentBlueBrush}" />

        <Canvas x:Name="MarkerCanvas" />

        <Border x:Name="Tooltip"
                Canvas.Top="8"
                MaxWidth="260"
                Padding="8,4"
                CornerRadius="2"
                Background="{StaticResource CardBackgroundBrush}"
                BorderBrush="{StaticResource BrightBorderBrush}"
                BorderThickness="1"
                Visibility="Collapsed">
            <TextBlock x:Name="TooltipText"
                       FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                       TextWrapping="Wrap"
                       Foreground="{StaticResource PrimaryTextBrush}" />
        </Border>
    </Canvas>
</UserControl>
