<ContentDialog
    x:Class="Revu.App.Dialogs.EndBlockDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:converters="using:Revu.App.Converters"
    xmlns:controls="using:Revu.App.Controls"
    mc:Ignorable="d"
    Title=""
    FullSizeDesired="False"
    Background="{StaticResource ShellCanvasBrush}"
    Foreground="{StaticResource PrimaryTextBrush}"
    BorderBrush="{StaticResource SubtleBorderBrush}"
    CornerRadius="0">

    <ContentDialog.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </ContentDialog.Resources>

    <Grid MaxWidth="460" MinWidth="420">
        <StackPanel Spacing="14">

            <!-- Hero block: eyebrow + title + today's record -->
            <Grid ColumnSpacing="14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Spacing="2">
                    <TextBlock Text="POST-SESSION RITUAL"
                               FontFamily="{StaticResource MonoFont}"
                               FontSize="10"
                               CharacterSpacing="300"
                               Foreground="{StaticResource AccentGoldBrush}"/>
                    <TextBlock Text="End Block"
                               FontFamily="{StaticResource DisplayFont}"
                               FontSize="26"
                               FontWeight="Bold"
                               Foreground="{StaticResource PrimaryTextBrush}"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Spacing="2" HorizontalAlignment="Right">
                    <TextBlock Text="TODAY"
                               FontFamily="{StaticResource MonoFont}"
                               FontSize="9"
                               CharacterSpacing="250"
                               Foreground="{StaticResource MutedTextBrush}"
                               HorizontalAlignment="Right"/>
                    <TextBlock x:Name="TodayLineText"
                               Text=""
                               FontFamily="{StaticResource DisplayFont}"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="{StaticResource AccentGoldBrush}"
                               HorizontalAlignment="Right"/>
                </StackPanel>
            </Grid>

            <Border Height="1" Background="{StaticResource SubtleBorderBrush}"/>

            <TextBlock Text="Close the loop before you log off. Rate the session against the intent you set, then leave one line for tomorrow-you to read."
                       FontFamily="{StaticResource BodyFont}"
                       FontSize="12"
                       TextWrapping="Wrap"
                       Foreground="{StaticResource SecondaryTextBrush}"/>

            <!-- Today's locked intent, so the rating is anchored to something
                 concrete rather than a vague feeling about the session. -->
            <controls:CornerBracketedCard CardPadding="16"
                                          CardBorderBrush="{StaticResource AccentGoldBrush}"
                                          Visibility="{x:Bind HasIntention, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                <StackPanel Spacing="6">
                    <controls:SectionTitle Text="YOUR INTENT"/>
                    <TextBlock Text="{x:Bind IntentionText, Mode=OneWay}"
                               FontFamily="{StaticResource HeadingFont}"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryTextBrush}"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </controls:CornerBracketedCard>

            <Border Padding="14,10"
                    Background="{StaticResource InfoSurfaceBrush}"
                    BorderBrush="{StaticResource SubtleBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="0"
                    Visibility="{x:Bind HasIntention, Mode=OneWay, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}">
                <TextBlock Text="No intent was locked for today. Rate the session anyway — and start tomorrow with a block."
                           FontFamily="{StaticResource MonoFont}"
                           FontSize="11"
                           CharacterSpacing="120"
                           Foreground="{StaticResource MutedTextBrush}"
                           TextWrapping="Wrap"/>
            </Border>

            <!-- Adherence rating 1-10 -->
            <controls:CornerBracketedCard CardPadding="16">
                <StackPanel Spacing="8">
                    <controls:SectionTitle Text="DID YOU STICK TO IT?"/>
                    <Grid ColumnSpacing="14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Slider x:Name="RatingSlider"
                                Grid.Column="0"
                                Minimum="1"
                                Maximum="10"
                                StepFrequency="1"
                                TickFrequency="1"
                                TickPlacement="Outside"
                                Value="5"
                                ValueChanged="OnRatingChanged"
                                VerticalAlignment="Center"/>
                        <TextBlock x:Name="RatingValueText"
                                   Grid.Column="1"
                                   Text="5"
                                   FontFamily="{StaticResource DisplayFont}"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource AccentGoldBrush}"
                                   VerticalAlignment="Center"
                                   MinWidth="34"
                                   TextAlignment="Right"/>
                    </Grid>
                    <Grid>
                        <TextBlock Text="1 — ABANDONED IT"
                                   FontFamily="{StaticResource MonoFont}"
                                   FontSize="9"
                                   CharacterSpacing="150"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   HorizontalAlignment="Left"/>
                        <TextBlock Text="10 — LOCKED IN"
                                   FontFamily="{StaticResource MonoFont}"
                                   FontSize="9"
                                   CharacterSpacing="150"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   HorizontalAlignment="Right"/>
                    </Grid>
                </StackPanel>
            </controls:CornerBracketedCard>

            <!-- One-line debrief note: resurfaced inside tomorrow's Start Block. -->
            <controls:CornerBracketedCard CardPadding="16">
                <StackPanel Spacing="8">
                    <controls:SectionTitle Text="ONE LINE FOR TOMORROW"/>
                    <TextBox x:Name="NoteBox"
                             PlaceholderText="What did this session teach you? What should the next block focus on?"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             MinHeight="60"
                             FontFamily="{StaticResource BodyFont}"
                             FontSize="13"
                             Background="{StaticResource InputBackgroundBrush}"
                             BorderBrush="{StaticResource SubtleBorderBrush}"
                             Foreground="{StaticResource PrimaryTextBrush}"
                             CornerRadius="0"/>
                </StackPanel>
            </controls:CornerBracketedCard>

            <!-- Primary + Cancel live inside the content because the
                 ContentDialog button slots' theme resources override the HUD
                 styles with the default pastel violet/grey block. -->
            <Grid ColumnSpacing="10" Margin="0,4,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0"
                        x:Name="CloseBlockButton"
                        Content="CLOSE BLOCK"
                        Click="OnCloseBlockClick"
                        Style="{StaticResource GoldActionButtonStyle}"
                        HorizontalAlignment="Stretch"/>
                <Button Grid.Column="1"
                        Content="CANCEL"
                        Click="OnCancelClick"
                        Style="{StaticResource SecondaryActionButtonStyle}"
                        HorizontalAlignment="Stretch"/>
            </Grid>

        </StackPanel>
    </Grid>
</ContentDialog>
