<ContentDialog
    x:Name="RootDialog"
    x:Class="Revu.App.Dialogs.LoginDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:converters="using:Revu.App.Converters"
    mc:Ignorable="d"
    Title=""
    CloseButtonText="Close"
    DefaultButton="None">

    <ContentDialog.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <converters:InverseBoolConverter x:Key="InverseBool"/>
    </ContentDialog.Resources>

    <StackPanel Spacing="14" MinWidth="360" MaxWidth="420">

        <!-- ••• Header ••• -->
        <StackPanel Spacing="2">
            <TextBlock Text="SIGN IN TO REVU"
                       FontFamily="{StaticResource HeadingFont}"
                       FontSize="{Binding TitleLarge, Source={StaticResource FontSizes}}"
                       FontWeight="SemiBold"
                       CharacterSpacing="100"
                       Foreground="{StaticResource AccentBlueBrush}"/>
            <TextBlock Text="Sign in to share clips and load your match history."
                       FontFamily="{StaticResource MonoFont}"
                       FontSize="{Binding Caption, Source={StaticResource FontSizes}}"
                       Foreground="{StaticResource SecondaryTextBrush}"
                       TextWrapping="Wrap"/>
        </StackPanel>

        <!-- Step indicator (mono, terminal-style) -->
        <TextBlock FontFamily="{StaticResource MonoFont}"
                   FontSize="{Binding Caption, Source={StaticResource FontSizes}}"
                   Foreground="{StaticResource MutedTextBrush}">
            <Run Text="STEP"/>
            <Run Text="{x:Bind ViewModel.StepLabel, Mode=OneWay}"/>
        </TextBlock>

        <!-- ••• Status / error lines ••• -->
        <TextBlock Text="{x:Bind ViewModel.Info, Mode=OneWay}"
                   FontFamily="{StaticResource MonoFont}"
                   FontSize="{Binding Caption, Source={StaticResource FontSizes}}"
                   Foreground="{StaticResource WinGreenBrush}"
                   TextWrapping="Wrap"
                   Visibility="{x:Bind ViewModel.HasInfo, Mode=OneWay, Converter={StaticResource BoolToVis}}"/>
        <TextBlock Text="{x:Bind ViewModel.Error, Mode=OneWay}"
                   FontFamily="{StaticResource MonoFont}"
                   FontSize="{Binding Caption, Source={StaticResource FontSizes}}"
                   Foreground="{StaticResource LossRedBrush}"
                   TextWrapping="Wrap"
                   Visibility="{x:Bind ViewModel.HasError, Mode=OneWay, Converter={StaticResource BoolToVis}}"/>

        <!-- ••• STEP 1: Email ••• -->
        <StackPanel Spacing="8" Visibility="{x:Bind ViewModel.IsEmailStep, Mode=OneWay, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="EMAIL"
                       FontFamily="{StaticResource MonoFont}"
                       FontSize="{Binding Caption, Source={StaticResource FontSizes}}"
                       Foreground="{StaticResource SecondaryTextBrush}"/>
            <TextBox Text="{x:Bind ViewModel.Email, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     PlaceholderText="you@email.com"
                     IsEnabled="{x:Bind ViewModel.Busy, Mode=OneWay, Converter={StaticResource InverseBool}}"
                     Background="{StaticResource InputBackgroundBrush}"
                     BorderBrush="{StaticResource SubtleBorderBrush}"
                     Foreground="{StaticResource PrimaryTextBrush}"
                     CornerRadius="2"/>
            <Button Content="Send code"
                    Command="{x:Bind ViewModel.SendCodeCommand}"
                    IsEnabled="{x:Bind ViewModel.Busy, Mode=OneWay, Converter={StaticResource InverseBool}}"
                    Style="{StaticResource GoldActionButtonStyle}"
                    HorizontalAlignment="Stretch"
                    Height="34"/>
        </StackPanel>

        <!-- ••• STEP 2: OTP code ••• -->
        <StackPanel Spacing="8" Visibility="{x:Bind ViewModel.IsCodeStep, Mode=OneWay, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="VERIFICATION CODE"
                       FontFamily="{StaticResource MonoFont}"
                       FontSize="{Binding Caption, Source={StaticResource FontSizes}}"
                       Foreground="{StaticResource SecondaryTextBrush}"/>
            <TextBox Text="{x:Bind ViewModel.OtpCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     PlaceholderText="Paste code"
                     IsEnabled="{x:Bind ViewModel.Busy, Mode=OneWay, Converter={StaticResource InverseBool}}"
                     Background="{StaticResource InputBackgroundBrush}"
                     BorderBrush="{StaticResource SubtleBorderBrush}"
                     Foreground="{StaticResource PrimaryTextBrush}"
                     CornerRadius="2"/>
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="Verify"
                        Command="{x:Bind ViewModel.VerifyCodeCommand}"
                        IsEnabled="{x:Bind ViewModel.Busy, Mode=OneWay, Converter={StaticResource InverseBool}}"
                        Style="{StaticResource GoldActionButtonStyle}"
                        Height="34" Padding="16,0"/>
                <Button Content="Back"
                        Command="{x:Bind ViewModel.BackToEmailCommand}"
                        Style="{StaticResource SecondaryActionButtonStyle}"
                        Height="34" Padding="16,0"/>
            </StackPanel>
        </StackPanel>

        <!-- ••• STEP 3: Riot ID + region ••• -->
        <StackPanel Spacing="8" Visibility="{x:Bind ViewModel.IsAccountStep, Mode=OneWay, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="IN-GAME NAME"
                       FontFamily="{StaticResource MonoFont}"
                       FontSize="{Binding Caption, Source={StaticResource FontSizes}}"
                       Foreground="{StaticResource SecondaryTextBrush}"/>
            <TextBox Text="{x:Bind ViewModel.RiotId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     PlaceholderText="GameName#TAG"
                     IsEnabled="{x:Bind ViewModel.Busy, Mode=OneWay, Converter={StaticResource InverseBool}}"
                     Background="{StaticResource InputBackgroundBrush}"
                     BorderBrush="{StaticResource SubtleBorderBrush}"
                     Foreground="{StaticResource PrimaryTextBrush}"
                     CornerRadius="2"/>
            <TextBlock Text="REGION"
                       FontFamily="{StaticResource MonoFont}"
                       FontSize="{Binding Caption, Source={StaticResource FontSizes}}"
                       Foreground="{StaticResource SecondaryTextBrush}"/>
            <ComboBox SelectedValue="{x:Bind ViewModel.RiotRegion, Mode=TwoWay}"
                      HorizontalAlignment="Stretch"
                      IsEnabled="{x:Bind ViewModel.Busy, Mode=OneWay, Converter={StaticResource InverseBool}}">
                <x:String>na1</x:String>
                <x:String>br1</x:String>
                <x:String>la1</x:String>
                <x:String>la2</x:String>
                <x:String>euw1</x:String>
                <x:String>eun1</x:String>
                <x:String>tr1</x:String>
                <x:String>ru</x:String>
                <x:String>kr</x:String>
                <x:String>jp1</x:String>
                <x:String>oc1</x:String>
                <x:String>ph2</x:String>
                <x:String>sg2</x:String>
                <x:String>th2</x:String>
                <x:String>tw2</x:String>
                <x:String>vn2</x:String>
            </ComboBox>
            <Button Content="Save &amp; finish"
                    Command="{x:Bind ViewModel.SaveAccountCommand}"
                    IsEnabled="{x:Bind ViewModel.Busy, Mode=OneWay, Converter={StaticResource InverseBool}}"
                    Style="{StaticResource GoldActionButtonStyle}"
                    HorizontalAlignment="Stretch"
                    Height="34"/>
        </StackPanel>

    </StackPanel>
</ContentDialog>
