<Page
    x:Class="Revu.App.Views.ObjectivesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:svc="using:Revu.App.Services"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:converters="using:Revu.App.Converters"
    xmlns:controls="using:Revu.App.Controls"
    xmlns:vm="using:Revu.App.ViewModels"
    mc:Ignorable="d"
    Loaded="Page_Loaded">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <converters:InverseBoolConverter x:Key="InverseBool"/>
    </Page.Resources>

    <Grid x:Name="RootGrid" Background="Transparent">
        <Grid.Resources>
            <Storyboard x:Name="CelebrationEnterStoryboard">
                <DoubleAnimation Storyboard.TargetName="CelebrationOverlay"
                                 Storyboard.TargetProperty="Opacity"
                                 From="0" To="1" Duration="0:0:0.35">
                    <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut"/>
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation Storyboard.TargetName="CelebrationCardTransform"
                                 Storyboard.TargetProperty="ScaleX"
                                 From="0.85" To="1" Duration="0:0:0.45">
                    <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut"/>
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation Storyboard.TargetName="CelebrationCardTransform"
                                 Storyboard.TargetProperty="ScaleY"
                                 From="0.85" To="1" Duration="0:0:0.45">
                    <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut"/>
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
            </Storyboard>
        </Grid.Resources>

        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Padding="40,30,40,40" Spacing="14">

                <!-- ••• Hero ••• -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <controls:HeroHeader Grid.Column="0"
                                         EyebrowText="LEARNING"
                                         Title="Objectives"
                                         Subtitle="MASTER ONE SKILL AT A TIME"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8"
                                VerticalAlignment="Top" Margin="0,16,0,0">
                        <Button x:Name="GenerateWithCoachButton"
                                Content="Generate with coach"
                                Click="OnGenerateObjectiveClick"
                                Style="{StaticResource QuietActionButtonStyle}"
                                Height="36" Padding="16,0" CornerRadius="2"
                                Visibility="Collapsed"/>
                        <Button Content="+ New Objective"
                                Command="{x:Bind ViewModel.ToggleCreateFormCommand}"
                                Style="{StaticResource PrimaryActionButtonStyle}"/>
                    </StackPanel>
                </Grid>

                <!-- Create Form (collapsible) -->
                <Border Style="{StaticResource CardStyle}"
                        BorderBrush="{StaticResource AccentBlueBrush}"
                        Visibility="{x:Bind ViewModel.IsCreating, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                    <StackPanel Spacing="12">
                        <TextBlock Text="{x:Bind ViewModel.ObjectiveFormTitle, Mode=OneWay}"
                                   FontSize="{Binding Title, Source={StaticResource FontSizes}}" FontWeight="SemiBold"
                                   Foreground="{StaticResource PrimaryTextBrush}"/>

                        <!-- Title -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="Title *" FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                       Foreground="{StaticResource SecondaryTextBrush}"/>
                            <TextBox Text="{x:Bind ViewModel.NewTitle, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     PlaceholderText="e.g., Improve wave management"
                                     Background="{StaticResource InputBackgroundBrush}"
                                     Foreground="{StaticResource PrimaryTextBrush}"
                                     BorderBrush="{StaticResource SubtleBorderBrush}"
                                     CornerRadius="2"/>
                        </StackPanel>

                        <!-- Skill Area -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="Skill Area" FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                       Foreground="{StaticResource SecondaryTextBrush}"/>
                            <TextBox Text="{x:Bind ViewModel.NewSkillArea, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     PlaceholderText="e.g., Laning, Macro, Teamfighting"
                                     Background="{StaticResource InputBackgroundBrush}"
                                     Foreground="{StaticResource PrimaryTextBrush}"
                                     BorderBrush="{StaticResource SubtleBorderBrush}"
                                     CornerRadius="2"/>
                        </StackPanel>

                        <!-- Type -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="Type" FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                       Foreground="{StaticResource SecondaryTextBrush}"/>
                            <ComboBox SelectedIndex="{x:Bind ViewModel.NewTypeIndex, Mode=TwoWay}"
                                      Background="{StaticResource InputBackgroundBrush}"
                                      Foreground="{StaticResource PrimaryTextBrush}"
                                      BorderBrush="{StaticResource SubtleBorderBrush}"
                                      CornerRadius="2" MinWidth="200">
                                <ComboBoxItem Content="Gameplay"/>
                                <ComboBoxItem Content="Mental"/>
                            </ComboBox>
                        </StackPanel>

                        <!-- v2.15.0: multi-phase practice. Objective can practice any subset. -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="Practice during" FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                       Foreground="{StaticResource SecondaryTextBrush}"/>
                            <TextBlock Text="Pick one or more phases where this objective applies. Prompts you design below will only render in the phases you check here."
                                       FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       TextWrapping="Wrap"/>
                            <StackPanel Orientation="Horizontal" Spacing="16">
                                <CheckBox Content="Pre-Game"
                                          IsChecked="{x:Bind ViewModel.NewPracticePre, Mode=TwoWay}"
                                          Foreground="{StaticResource PrimaryTextBrush}"/>
                                <CheckBox Content="In-Game"
                                          IsChecked="{x:Bind ViewModel.NewPracticeIn, Mode=TwoWay}"
                                          Foreground="{StaticResource PrimaryTextBrush}"/>
                                <CheckBox Content="Post-Game"
                                          IsChecked="{x:Bind ViewModel.NewPracticePost, Mode=TwoWay}"
                                          Foreground="{StaticResource PrimaryTextBrush}"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Completion Criteria -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="Completion Criteria" FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                       Foreground="{StaticResource SecondaryTextBrush}"/>
                            <TextBox Text="{x:Bind ViewModel.NewCriteria, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     PlaceholderText="How will you know you've mastered this?"
                                     Background="{StaticResource InputBackgroundBrush}"
                                     Foreground="{StaticResource PrimaryTextBrush}"
                                     BorderBrush="{StaticResource SubtleBorderBrush}"
                                     CornerRadius="2"/>
                        </StackPanel>

                        <!-- Description -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="Description" FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                       Foreground="{StaticResource SecondaryTextBrush}"/>
                            <TextBox Text="{x:Bind ViewModel.NewDescription, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     PlaceholderText="Additional notes..."
                                     Background="{StaticResource InputBackgroundBrush}"
                                     Foreground="{StaticResource PrimaryTextBrush}"
                                     BorderBrush="{StaticResource SubtleBorderBrush}"
                                     CornerRadius="2"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     MinHeight="60"/>
                        </StackPanel>

                        <!-- v2.15.0: CUSTOM PROMPTS editor. -->
                        <StackPanel Spacing="8">
                            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                <Rectangle Width="18" Height="1"
                                           Fill="{StaticResource AccentPurpleBrush}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="CUSTOM PROMPTS"
                                           FontFamily="{StaticResource MonoFont}"
                                           FontSize="{Binding Caption, Source={StaticResource FontSizes}}"
                                           CharacterSpacing="300"
                                           Foreground="{StaticResource AccentPurpleBrush}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="Add labeled text fields you'll answer during the selected phases. Use these to prompt yourself with specific details — e.g. 'Key spells during trading', 'Expected wave state at 3:00'. Blank labels are ignored on save."
                                       FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       TextWrapping="Wrap"/>

                            <ItemsRepeater ItemsSource="{x:Bind ViewModel.NewPrompts, Mode=OneWay}">
                                <ItemsRepeater.Layout>
                                    <StackLayout Spacing="8"/>
                                </ItemsRepeater.Layout>
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate x:DataType="vm:PromptDraftItem">
                                        <Border Background="{StaticResource InputBackgroundBrush}"
                                                BorderBrush="{StaticResource SubtleBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="2"
                                                Padding="10,8">
                                            <Grid ColumnSpacing="8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <ComboBox Grid.Column="0"
                                                          SelectedIndex="{x:Bind PhaseIndex, Mode=TwoWay}"
                                                          MinWidth="110"
                                                          VerticalAlignment="Top">
                                                    <ComboBoxItem Content="Pre-Game"/>
                                                    <ComboBoxItem Content="In-Game"/>
                                                    <ComboBoxItem Content="Post-Game"/>
                                                </ComboBox>

                                                <TextBox Grid.Column="1"
                                                         Text="{x:Bind Label, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                         PlaceholderText="e.g. How will the 2v2 go? What spells are key?"
                                                         Background="{StaticResource InputBackgroundBrush}"
                                                         Foreground="{StaticResource PrimaryTextBrush}"
                                                         BorderBrush="{StaticResource SubtleBorderBrush}"
                                                         AcceptsReturn="True"
                                                         TextWrapping="Wrap"
                                                         MinHeight="36"/>

                                                <Button Grid.Column="2"
                                                        Click="RemovePromptDraftButton_Click"
                                                        Tag="{x:Bind}"
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        Padding="8,4"
                                                        ToolTipService.ToolTip="Remove this prompt">
                                                    <FontIcon Glyph="&#xE74D;"
                                                              FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                                              FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                                              Foreground="{StaticResource LossRedBrush}"/>
                                                </Button>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>

                            <Button Content="+ ADD PROMPT"
                                    Command="{x:Bind ViewModel.AddPromptCommand}"
                                    Background="Transparent"
                                    BorderBrush="{StaticResource AccentPurpleBrush}"
                                    BorderThickness="1"
                                    Foreground="{StaticResource AccentPurpleBrush}"
                                    FontFamily="{StaticResource MonoFont}"
                                    FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                    CharacterSpacing="200"
                                    CornerRadius="2"
                                    Padding="14,6"
                                    HorizontalAlignment="Left"/>
                        </StackPanel>

                        <!-- v2.15.0: CHAMPIONS filter. Empty = applies to all champions. -->
                        <StackPanel Spacing="8">
                            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                <Rectangle Width="18" Height="1"
                                           Fill="{StaticResource AccentTealBrush}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="CHAMPIONS"
                                           FontFamily="{StaticResource MonoFont}"
                                           FontSize="{Binding Caption, Source={StaticResource FontSizes}}"
                                           CharacterSpacing="300"
                                           Foreground="{StaticResource AccentTealBrush}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="Optional. Leave empty to apply this objective to every champion. Pick one or more champions below to only surface this objective when you're on one of them."
                                       FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       TextWrapping="Wrap"/>

                            <!-- Picked champions as chips. UniformGridLayout wraps to the next row
                                 when it runs out of width — StackLayout clips instead. -->
                            <ItemsRepeater ItemsSource="{x:Bind ViewModel.NewChampions, Mode=OneWay}"
                                           Visibility="{x:Bind ViewModel.HasNewChampions, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                                <ItemsRepeater.Layout>
                                    <UniformGridLayout Orientation="Horizontal"
                                                       MinItemWidth="110"
                                                       MinItemHeight="30"
                                                       MinColumnSpacing="6"
                                                       MinRowSpacing="6"
                                                       ItemsJustification="Start"
                                                       ItemsStretch="None"/>
                                </ItemsRepeater.Layout>
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate x:DataType="x:String">
                                        <Button Background="{StaticResource TagBackgroundBrush}"
                                                BorderBrush="{StaticResource AccentTealBrush}"
                                                BorderThickness="1"
                                                Foreground="{StaticResource PrimaryTextBrush}"
                                                Click="RemoveChampionChip_Click"
                                                Tag="{x:Bind}"
                                                CornerRadius="2"
                                                Padding="10,4"
                                                Height="28"
                                                ToolTipService.ToolTip="Click to remove">
                                            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                                <TextBlock Text="{x:Bind}"
                                                           FontFamily="{StaticResource MonoFont}"
                                                           FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Text="×"
                                                           FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                                           Foreground="{StaticResource LossRedBrush}"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>

                            <!-- v2.15.1: type-to-filter search replaces the chip grid. Shorter,
                                 scales to any champion count, doesn't eat vertical space. -->
                            <AutoSuggestBox x:Name="ChampionSearchBox"
                                            Style="{StaticResource HudSuggestBoxStyle}"
                                            PlaceholderText="Search champion..."
                                            TextChanged="ChampionSearchBox_TextChanged"
                                            SuggestionChosen="ChampionSearchBox_SuggestionChosen"
                                            QuerySubmitted="ChampionSearchBox_QuerySubmitted"
                                            MinWidth="240"
                                            HorizontalAlignment="Stretch"/>
                        </StackPanel>

                        <!-- Action Buttons -->
                        <StackPanel Orientation="Horizontal" Spacing="8"
                                    HorizontalAlignment="Right">
                            <Button Content="Cancel"
                                    Command="{x:Bind ViewModel.ToggleCreateFormCommand}"
                                    Background="{StaticResource TagBackgroundBrush}"
                                    Foreground="{StaticResource PrimaryTextBrush}"
                                    CornerRadius="2" Height="32"
                                    BorderThickness="0"/>
                            <Button Content="{x:Bind ViewModel.SaveObjectiveButtonText, Mode=OneWay}"
                                    Command="{x:Bind ViewModel.CreateObjectiveCommand}"
                                    IsEnabled="{x:Bind ViewModel.CanCreate, Mode=OneWay}"
                                    Background="{StaticResource AccentBlueBrush}"
                                    Foreground="{StaticResource ActionPrimaryForegroundBrush}"
                                    CornerRadius="2" Height="32"
                                    BorderThickness="0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Empty State -->
                <Border Style="{StaticResource CardStyle}"
                        Visibility="{x:Bind ViewModel.HasObjectives, Mode=OneWay, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}">
                    <TextBlock Text="No objectives yet.&#x0a;&#x0a;Create your first learning objective to start tracking progress."
                               FontSize="{Binding Subtitle, Source={StaticResource FontSizes}}"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               Margin="20,30"/>
                </Border>

                <!-- Active Objectives Section Header -->
                <controls:SectionTitle Text="ACTIVE"
                           Visibility="{x:Bind ViewModel.HasActiveObjectives, Mode=OneWay, Converter={StaticResource BoolToVis}}"/>

                <!-- Active Objectives List -->
                <ItemsRepeater ItemsSource="{x:Bind ViewModel.ActiveObjectives, Mode=OneWay}"
                               Visibility="{x:Bind ViewModel.HasActiveObjectives, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                    <ItemsRepeater.Layout>
                        <StackLayout Spacing="10"/>
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="vm:ObjectiveDisplayItem">
                            <controls:CornerBracketedCard CardBorderBrush="{x:Bind LevelColorBrush}">
                                <StackPanel Spacing="8">
                                    <!-- Title Row: Type Badge + Title -->
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Border Background="{x:Bind PriorityBadgeBackgroundBrush}"
                                                CornerRadius="2" Padding="6,2"
                                                Visibility="{x:Bind IsPriority, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Text="{x:Bind PriorityBadge}"
                                                       FontSize="{Binding Caption, Source={StaticResource FontSizes}}" FontWeight="Bold"
                                                       Foreground="{x:Bind PriorityBadgeForegroundBrush}"/>
                                        </Border>
                                        <Border Background="{x:Bind TypeBadgeBackgroundBrush}"
                                                CornerRadius="2" Padding="6,2">
                                            <TextBlock Text="{x:Bind TypeBadge}"
                                                       FontSize="{Binding Caption, Source={StaticResource FontSizes}}" FontWeight="Bold"
                                                       Foreground="{x:Bind TypeBadgeForegroundBrush}"/>
                                        </Border>
                                        <TextBlock Text="{x:Bind Title}"
                                                   FontSize="{Binding Title, Source={StaticResource FontSizes}}" FontWeight="Bold"
                                                   Foreground="{StaticResource PrimaryTextBrush}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <!-- Skill Area -->
                                    <TextBlock Text="{x:Bind SkillArea}"
                                               FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                               Foreground="{StaticResource SecondaryTextBrush}"
                                               Visibility="{x:Bind HasSkillArea, Converter={StaticResource BoolToVis}}"/>

                                    <!-- Completion Criteria -->
                                    <TextBlock Text="{x:Bind CriteriaText}"
                                               FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                               Foreground="{StaticResource SecondaryTextBrush}"
                                               TextWrapping="Wrap"
                                               Visibility="{x:Bind HasCriteria, Converter={StaticResource BoolToVis}}"/>

                                    <Grid ColumnSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="220"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="When"
                                                   FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                                   Foreground="{StaticResource SecondaryTextBrush}"
                                                   VerticalAlignment="Center"/>
                                        <!-- v2.15.1: objectives now support any subset of pre/in/post
                                             phases — the old single-value ComboBox can't represent
                                             that. Show the multi-phase summary ("PRE + IN", etc.)
                                             read-only; use the Edit button to change it. -->
                                        <TextBlock Grid.Column="1"
                                                   Text="{x:Bind PhasesSummary}"
                                                   FontFamily="{StaticResource MonoFont}"
                                                   FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                                   CharacterSpacing="200"
                                                   Foreground="{StaticResource AccentBlueBrush}"
                                                   VerticalAlignment="Center"/>
                                    </Grid>

                                    <!-- Level + Score Row -->
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="{x:Bind LevelName}"
                                                   FontSize="{Binding Subtitle, Source={StaticResource FontSizes}}" FontWeight="Bold"
                                                   Foreground="{x:Bind LevelColorBrush}"/>
                                        <TextBlock Text="{x:Bind ScoreText}"
                                                   FontSize="{Binding BodyEmphasis, Source={StaticResource FontSizes}}"
                                                   Foreground="{StaticResource SecondaryTextBrush}"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="{x:Bind ProgressText}"
                                                   FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                                   Foreground="{StaticResource MutedTextBrush}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <!-- Progress Bar + Sparkline -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="80"/>
                                        </Grid.ColumnDefinitions>
                                        <controls:ObjectiveProgressBar Grid.Column="0"
                                                                       Progress="{x:Bind Progress}"
                                                                       BarHeight="8"
                                                                       BarCornerRadius="2"
                                                                       MinimumVisibleFillWidth="6"
                                                                       FillBrush="{x:Bind LevelColorBrush}"
                                                                       TrackBrush="{StaticResource SubtleBorderBrush}"/>
                                        <controls:MiniSparkline Grid.Column="1"
                                                                DataPoints="{x:Bind ScoreHistory}"
                                                                LineColor="{x:Bind LevelColorBrush}"
                                                                LineThickness="1.5"
                                                                Height="28"
                                                                Margin="8,0,0,0"
                                                                Visibility="{x:Bind HasScoreHistory, Converter={StaticResource BoolToVis}}"/>
                                    </Grid>

                                    <!-- v2.16: visible level ladder so users can predict the
                                         next threshold (Exploring 0 → Drilling 15 → … → Ready 50). -->
                                    <ItemsRepeater ItemsSource="{x:Bind LevelLadder}">
                                        <ItemsRepeater.Layout>
                                            <StackLayout Orientation="Horizontal" Spacing="14"/>
                                        </ItemsRepeater.Layout>
                                        <ItemsRepeater.ItemTemplate>
                                            <DataTemplate x:DataType="vm:LevelLadderStep">
                                                <TextBlock Text="{x:Bind Label}"
                                                           FontFamily="{StaticResource MonoFont}"
                                                           FontSize="{Binding Caption, Source={StaticResource FontSizes}}"
                                                           CharacterSpacing="120"
                                                           Foreground="{x:Bind ForegroundBrush}"
                                                           FontWeight="{x:Bind FontWeight}"/>
                                            </DataTemplate>
                                        </ItemsRepeater.ItemTemplate>
                                    </ItemsRepeater>

                                    <!-- Action Row -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Suggest Complete message -->
                                        <TextBlock Grid.Column="0"
                                                   Text="Ready to complete! You've mastered this objective."
                                                   FontSize="{Binding Body, Source={StaticResource FontSizes}}" FontWeight="Bold"
                                                   Foreground="{StaticResource AccentGoldBrush}"
                                                   VerticalAlignment="Center"
                                                   Visibility="{x:Bind SuggestComplete, Converter={StaticResource BoolToVis}}"/>

                                        <!-- Remaining games if not completable -->
                                        <TextBlock Grid.Column="0"
                                                   Text="{x:Bind RemainingText}"
                                                   FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                                   Foreground="{StaticResource SecondaryTextBrush}"
                                                   VerticalAlignment="Center"
                                                   Visibility="{x:Bind CanComplete, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}"/>

                                        <!-- Buttons -->
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                                            <Button Content="Edit"
                                                    Style="{StaticResource SecondaryActionButtonStyle}"
                                                    Height="30" Padding="12,0" FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                                    Tag="{x:Bind Id}"
                                                    Click="EditObjective_Click"/>
                                            <Button Content="View Games"
                                                    Style="{StaticResource SecondaryActionButtonStyle}"
                                                    Height="30" Padding="12,0" FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                                    Tag="{x:Bind Id}"
                                                    Click="ViewObjectiveGames_Click"/>
                                            <Button Content="Set Priority"
                                                    Style="{StaticResource GoldActionButtonStyle}"
                                                    Height="30" Padding="12,0" FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                                    Visibility="{x:Bind IsPriority, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}"
                                                    Tag="{x:Bind Id}"
                                                    Click="SetPriority_Click"/>
                                            <Button Content="Delete"
                                                    Style="{StaticResource DangerActionButtonStyle}"
                                                    Height="30" Padding="12,0" FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                                    Tag="{x:Bind Id}"
                                                    Click="DeleteObjective_Click"/>
                                            <Button Content="Mark Complete"
                                                    Background="{StaticResource WinGreenBrush}"
                                                    Foreground="White"
                                                    CornerRadius="2" Height="30"
                                                    Padding="12,0" FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                                    BorderThickness="0"
                                                    Visibility="{x:Bind CanComplete, Converter={StaticResource BoolToVis}}"
                                                    Tag="{x:Bind Id}"
                                                    Click="MarkComplete_Click"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </controls:CornerBracketedCard>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>

                <controls:SectionTitle Text="GUARDRAILS"/>

                <controls:CornerBracketedCard>
                    <StackPanel Spacing="10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Spacing="3">
                                <TextBlock Text="Session rules now live here."
                                           FontSize="{Binding Subtitle, Source={StaticResource FontSizes}}"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource PrimaryTextBrush}"/>
                                <TextBlock Text="Use guardrails to protect the priority objective and shut down self-sabotage."
                                           FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Content="+ New Guardrail"
                                    Command="{x:Bind RulesVM.ToggleCreateFormCommand}"
                                    Background="{StaticResource AccentBlueBrush}"
                                    Foreground="{StaticResource ActionPrimaryForegroundBrush}"
                                    CornerRadius="2"
                                    Height="34"
                                    BorderThickness="0"/>
                        </Grid>

                        <Border Background="{StaticResource DangerSurfaceBrush}"
                                CornerRadius="2"
                                Padding="16,12"
                                BorderThickness="2"
                                BorderBrush="{StaticResource LossRedBrush}"
                                Visibility="{x:Bind RulesVM.HasViolations, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                            <StackPanel Spacing="8">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE7BA;" FontSize="{Binding Title, Source={StaticResource FontSizes}}"
                                              Foreground="{StaticResource LossRedBrush}"/>
                                    <TextBlock Text="ACTIVE VIOLATIONS"
                                               FontSize="{Binding BodyEmphasis, Source={StaticResource FontSizes}}" FontWeight="Bold"
                                               Foreground="{StaticResource LossRedBrush}"/>
                                </StackPanel>
                                <ItemsRepeater ItemsSource="{x:Bind RulesVM.Violations, Mode=OneWay}">
                                    <ItemsRepeater.Layout>
                                        <StackLayout Spacing="4"/>
                                    </ItemsRepeater.Layout>
                                    <ItemsRepeater.ItemTemplate>
                                        <DataTemplate x:DataType="vm:ViolationBannerItem">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <TextBlock Text="{x:Bind RuleName}"
                                                           FontSize="{Binding Body, Source={StaticResource FontSizes}}" FontWeight="SemiBold"
                                                           Foreground="{StaticResource PrimaryTextBrush}"/>
                                                <TextBlock Text="&#x2014;"
                                                           FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                                           Foreground="{StaticResource SecondaryTextBrush}"/>
                                                <TextBlock Text="{x:Bind Reason}"
                                                           FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                                           Foreground="{StaticResource LossRedBrush}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsRepeater.ItemTemplate>
                                </ItemsRepeater>
                            </StackPanel>
                        </Border>

                        <Border Background="{StaticResource InputBackgroundBrush}"
                                CornerRadius="2"
                                Padding="14"
                                BorderThickness="1"
                                BorderBrush="{StaticResource AccentBlueBrush}"
                                Visibility="{x:Bind RulesVM.IsCreating, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                            <StackPanel Spacing="12">
                                <TextBlock Text="{x:Bind RulesVM.FormTitle, Mode=OneWay}"
                                           FontSize="{Binding Title, Source={StaticResource FontSizes}}"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource PrimaryTextBrush}"/>

                                <StackPanel Spacing="4">
                                    <TextBlock Text="Name *"
                                               FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                               Foreground="{StaticResource SecondaryTextBrush}"/>
                                    <TextBox Text="{x:Bind RulesVM.NewRuleName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             PlaceholderText="e.g., Stop after 2 losses"
                                             Background="{StaticResource InputBackgroundBrush}"
                                             Foreground="{StaticResource PrimaryTextBrush}"
                                             BorderBrush="{StaticResource SubtleBorderBrush}"
                                             CornerRadius="2"/>
                                </StackPanel>

                                <StackPanel Spacing="4">
                                    <TextBlock Text="Type"
                                               FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                               Foreground="{StaticResource SecondaryTextBrush}"/>
                                    <ComboBox ItemsSource="{x:Bind RulesVM.RuleTypeOptions}"
                                              SelectedIndex="{x:Bind RulesVM.NewRuleTypeIndex, Mode=TwoWay}"
                                              Background="{StaticResource InputBackgroundBrush}"
                                              Foreground="{StaticResource PrimaryTextBrush}"
                                              BorderBrush="{StaticResource SubtleBorderBrush}"
                                              CornerRadius="2"
                                              MinWidth="250"/>
                                </StackPanel>

                                <StackPanel Spacing="4"
                                            Visibility="{x:Bind RulesVM.ShowConditionField, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="{x:Bind RulesVM.ConditionLabel, Mode=OneWay}"
                                               FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                               Foreground="{StaticResource SecondaryTextBrush}"/>
                                    <TextBox Text="{x:Bind RulesVM.NewConditionValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             PlaceholderText="{x:Bind RulesVM.ConditionPlaceholder, Mode=OneWay}"
                                             Background="{StaticResource InputBackgroundBrush}"
                                             Foreground="{StaticResource PrimaryTextBrush}"
                                             BorderBrush="{StaticResource SubtleBorderBrush}"
                                             CornerRadius="2"/>
                                </StackPanel>

                                <StackPanel Spacing="4"
                                            Visibility="{x:Bind RulesVM.ShowLossStreakCooldown, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="Cooldown (minutes)"
                                               FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                               Foreground="{StaticResource SecondaryTextBrush}"/>
                                    <TextBox Text="{x:Bind RulesVM.NewLossStreakCooldown, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             PlaceholderText="Blank = rest of day. e.g., 120 for 2 hours"
                                             Background="{StaticResource InputBackgroundBrush}"
                                             Foreground="{StaticResource PrimaryTextBrush}"
                                             BorderBrush="{StaticResource SubtleBorderBrush}"
                                             CornerRadius="2"/>
                                    <TextBlock Text="How long the guardrail stays active after your last loss. After this much time, you can queue again."
                                               FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                               Foreground="{StaticResource SecondaryTextBrush}"
                                               TextWrapping="Wrap"
                                               FontStyle="Italic"/>
                                </StackPanel>

                                <StackPanel Spacing="4">
                                    <TextBlock Text="Description"
                                               FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                               Foreground="{StaticResource SecondaryTextBrush}"/>
                                    <TextBox Text="{x:Bind RulesVM.NewDescription, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             PlaceholderText="Why this guardrail matters"
                                             Background="{StaticResource InputBackgroundBrush}"
                                             Foreground="{StaticResource PrimaryTextBrush}"
                                             BorderBrush="{StaticResource SubtleBorderBrush}"
                                             CornerRadius="2"
                                             AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             MinHeight="60"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal"
                                            Spacing="8"
                                            HorizontalAlignment="Right">
                                    <Button Content="Cancel"
                                            Command="{x:Bind RulesVM.ToggleCreateFormCommand}"
                                            Background="{StaticResource TagBackgroundBrush}"
                                            Foreground="{StaticResource PrimaryTextBrush}"
                                            CornerRadius="2"
                                            Height="32"
                                            BorderThickness="0"/>
                                    <Button Content="{x:Bind RulesVM.FormSubmitLabel, Mode=OneWay}"
                                            Command="{x:Bind RulesVM.CreateRuleCommand}"
                                            IsEnabled="{x:Bind RulesVM.CanCreate, Mode=OneWay}"
                                            Background="{StaticResource AccentBlueBrush}"
                                            Foreground="{StaticResource ActionPrimaryForegroundBrush}"
                                            CornerRadius="2"
                                            Height="32"
                                            BorderThickness="0"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="No guardrails yet. Add one if you want structure around loss streaks, time limits, or mindset."
                                   FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   Visibility="{x:Bind RulesVM.HasRules, Mode=OneWay, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}"/>

                        <ItemsRepeater ItemsSource="{x:Bind RulesVM.ActiveRules, Mode=OneWay}"
                                       Visibility="{x:Bind RulesVM.HasActiveRules, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                            <ItemsRepeater.Layout>
                                <StackLayout Spacing="8"/>
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="vm:RuleDisplayItem">
                                    <Border Background="{StaticResource InputBackgroundBrush}"
                                            CornerRadius="2"
                                            Padding="14,12"
                                            BorderThickness="1"
                                            BorderBrush="{StaticResource SubtleBorderBrush}">
                                        <StackPanel Spacing="4">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <Border Grid.Column="0"
                                                        Background="{StaticResource InfoSurfaceBrush}"
                                                        CornerRadius="2"
                                                        Padding="6,2"
                                                        Margin="0,0,8,0">
                                                    <TextBlock Text="{x:Bind TypeBadge}"
                                                               FontSize="{Binding Caption, Source={StaticResource FontSizes}}"
                                                               FontWeight="Bold"
                                                               Foreground="{StaticResource AccentBlueBrush}"/>
                                                </Border>
                                                <TextBlock Grid.Column="1"
                                                           Text="{x:Bind Name}"
                                                           FontSize="{Binding Subtitle, Source={StaticResource FontSizes}}"
                                                           FontWeight="Bold"
                                                           Foreground="{StaticResource PrimaryTextBrush}"
                                                           VerticalAlignment="Center"/>
                                                <StackPanel Grid.Column="2"
                                                            Orientation="Horizontal">
                                                    <Border Background="{StaticResource LossRedBrush}"
                                                            CornerRadius="2"
                                                            Padding="8,2"
                                                            Visibility="{x:Bind IsViolated, Converter={StaticResource BoolToVis}}">
                                                        <TextBlock Text="VIOLATED"
                                                                   FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                                                   FontWeight="Bold"
                                                                   Foreground="White"/>
                                                    </Border>
                                                    <Border Background="{StaticResource WinGreenBrush}"
                                                            CornerRadius="2"
                                                            Padding="8,2"
                                                            Visibility="{x:Bind IsOk, Converter={StaticResource BoolToVis}}">
                                                        <TextBlock Text="OK"
                                                                   FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                                                   FontWeight="Bold"
                                                                   Foreground="White"/>
                                                    </Border>
                                                </StackPanel>
                                            </Grid>

                                            <TextBlock Text="{x:Bind ViolationReason}"
                                                       FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                                       Foreground="{StaticResource LossRedBrush}"
                                                       Visibility="{x:Bind HasViolationReason, Converter={StaticResource BoolToVis}}"/>
                                            <TextBlock Text="{x:Bind Description}"
                                                       FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                                       Foreground="{StaticResource SecondaryTextBrush}"
                                                       TextWrapping="Wrap"
                                                       Visibility="{x:Bind HasDescription, Converter={StaticResource BoolToVis}}"/>
                                            <TextBlock Text="{x:Bind ConditionText}"
                                                       FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       Visibility="{x:Bind HasCondition, Converter={StaticResource BoolToVis}}"/>

                                            <StackPanel Orientation="Horizontal"
                                                        Spacing="6"
                                                        HorizontalAlignment="Right"
                                                        Margin="0,4,0,0">
                                                <Button Content="Delete"
                                                        Background="Transparent"
                                                        Foreground="{StaticResource LossRedBrush}"
                                                        BorderBrush="{StaticResource LossRedBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="2"
                                                        Height="28"
                                                        FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                                        Tag="{x:Bind Id}"
                                                        Click="DeleteRule_Click"/>
                                                <Button Content="Edit"
                                                        Background="Transparent"
                                                        Foreground="{StaticResource SecondaryTextBrush}"
                                                        BorderBrush="{StaticResource SubtleBorderBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="2"
                                                        Height="28"
                                                        FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                                        Tag="{x:Bind Id}"
                                                        Click="EditRule_Click"/>
                                                <Button Content="{x:Bind ToggleText}"
                                                        Background="Transparent"
                                                        Foreground="{StaticResource SecondaryTextBrush}"
                                                        BorderBrush="{StaticResource SubtleBorderBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="2"
                                                        Height="28"
                                                        FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                                        Tag="{x:Bind Id}"
                                                        Click="ToggleRule_Click"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>

                        <ItemsRepeater ItemsSource="{x:Bind RulesVM.InactiveRules, Mode=OneWay}"
                                       Visibility="{x:Bind RulesVM.HasInactiveRules, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                            <ItemsRepeater.Layout>
                                <StackLayout Spacing="8"/>
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="vm:RuleDisplayItem">
                                    <Border Background="{StaticResource CardBackgroundBrush}"
                                            CornerRadius="2"
                                            Padding="14,12"
                                            BorderThickness="1"
                                            BorderBrush="{StaticResource SubtleBorderBrush}"
                                            Opacity="0.7">
                                        <StackPanel Spacing="4">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <Border Background="{StaticResource InfoSurfaceBrush}"
                                                        CornerRadius="2"
                                                        Padding="6,2"
                                                        Opacity="0.6">
                                                    <TextBlock Text="{x:Bind TypeBadge}"
                                                               FontSize="{Binding Caption, Source={StaticResource FontSizes}}"
                                                               FontWeight="Bold"
                                                               Foreground="{StaticResource AccentBlueBrush}"/>
                                                </Border>
                                                <TextBlock Text="{x:Bind Name}"
                                                           FontSize="{Binding Subtitle, Source={StaticResource FontSizes}}"
                                                           FontWeight="Bold"
                                                           Foreground="{StaticResource SecondaryTextBrush}"/>
                                            </StackPanel>
                                            <TextBlock Text="{x:Bind Description}"
                                                       FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       TextWrapping="Wrap"
                                                       Visibility="{x:Bind HasDescription, Converter={StaticResource BoolToVis}}"/>
                                            <TextBlock Text="{x:Bind ConditionText}"
                                                       FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       Visibility="{x:Bind HasCondition, Converter={StaticResource BoolToVis}}"/>
                                            <StackPanel Orientation="Horizontal"
                                                        Spacing="6"
                                                        HorizontalAlignment="Right"
                                                        Margin="0,4,0,0">
                                                <Button Content="Delete"
                                                        Background="Transparent"
                                                        Foreground="{StaticResource LossRedBrush}"
                                                        BorderBrush="{StaticResource LossRedBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="2"
                                                        Height="28"
                                                        FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                                        Tag="{x:Bind Id}"
                                                        Click="DeleteRule_Click"/>
                                                <Button Content="Edit"
                                                        Background="Transparent"
                                                        Foreground="{StaticResource SecondaryTextBrush}"
                                                        BorderBrush="{StaticResource SubtleBorderBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="2"
                                                        Height="28"
                                                        FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                                        Tag="{x:Bind Id}"
                                                        Click="EditRule_Click"/>
                                                <Button Content="{x:Bind ToggleText}"
                                                        Background="Transparent"
                                                        Foreground="{StaticResource WinGreenBrush}"
                                                        BorderBrush="{StaticResource SubtleBorderBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="2"
                                                        Height="28"
                                                        FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                                        Tag="{x:Bind Id}"
                                                        Click="ToggleRule_Click"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </StackPanel>
                </controls:CornerBracketedCard>

                <controls:CornerBracketedCard
                        CardBorderBrush="{StaticResource AccentGoldBrush}"
                        Visibility="{x:Bind ViewModel.HasSpottedProblems, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                    <StackPanel Spacing="10">
                        <controls:SectionTitle Text="SPOTTED PROBLEMS"/>
                        <TextBlock Text="Problems noted in reviews. Use these as raw material for future learning objectives."
                                   FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   TextWrapping="Wrap"/>

                        <ItemsRepeater ItemsSource="{x:Bind ViewModel.SpottedProblems, Mode=OneWay}">
                            <ItemsRepeater.Layout>
                                <StackLayout Spacing="8"/>
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="vm:SpottedProblemItem">
                                    <Border Background="{StaticResource InputBackgroundBrush}"
                                            CornerRadius="2"
                                            Padding="12"
                                            BorderThickness="1"
                                            BorderBrush="{StaticResource AccentGoldBrush}">
                                        <StackPanel Spacing="4">
                                            <TextBlock FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                                       Foreground="{StaticResource SecondaryTextBrush}">
                                                <Run Text="{x:Bind ChampionDisplay}"/>
                                                <Run Text="  •  "/>
                                                <Run Text="{x:Bind DatePlayed}"/>
                                            </TextBlock>
                                            <TextBlock Text="{x:Bind ProblemText}"
                                                       FontSize="{Binding BodyEmphasis, Source={StaticResource FontSizes}}"
                                                       Foreground="{StaticResource PrimaryTextBrush}"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </StackPanel>
                </controls:CornerBracketedCard>

                <!-- Completed Objectives Toggle -->
                <Button Visibility="{x:Bind ViewModel.HasCompletedObjectives, Mode=OneWay, Converter={StaticResource BoolToVis}}"
                        Command="{x:Bind ViewModel.ToggleCompletedCommand}"
                        Background="Transparent"
                        Foreground="{StaticResource SecondaryTextBrush}"
                        BorderThickness="0"
                        HorizontalAlignment="Left"
                        Margin="0,8,0,0">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE70D;" FontSize="{Binding Body, Source={StaticResource FontSizes}}"/>
                        <TextBlock Text="Show Completed"
                                   FontSize="{Binding Meta, Source={StaticResource FontSizes}}" FontWeight="Bold"
                                   Foreground="{StaticResource SecondaryTextBrush}"/>
                    </StackPanel>
                </Button>

                <!-- Completed Objectives List -->
                <ItemsRepeater ItemsSource="{x:Bind ViewModel.CompletedObjectives, Mode=OneWay}"
                               Visibility="{x:Bind ViewModel.ShowCompleted, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                    <ItemsRepeater.Layout>
                        <StackLayout Spacing="6"/>
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="vm:CompletedObjectiveItem">
                            <Border Background="{StaticResource CardBackgroundBrush}"
                                    CornerRadius="2"
                                    Padding="14,10"
                                    BorderThickness="1"
                                    BorderBrush="{StaticResource SubtleBorderBrush}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0"
                                                Spacing="2"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="{x:Bind Title}"
                                                   FontSize="{Binding Subtitle, Source={StaticResource FontSizes}}"
                                                   Foreground="{StaticResource SecondaryTextBrush}"/>
                                        <TextBlock Text="{x:Bind PhaseLabel}"
                                                   FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                                   Foreground="{StaticResource MutedTextBrush}"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1"
                                               Text="{x:Bind SummaryText}"
                                               FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                               Foreground="{StaticResource SecondaryTextBrush}"
                                               VerticalAlignment="Center"
                                               Margin="12,0"/>
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                        <Button Content="Edit"
                                                Background="{StaticResource TagBackgroundBrush}"
                                                Foreground="{StaticResource PrimaryTextBrush}"
                                                BorderBrush="{StaticResource SubtleBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="2" Height="28"
                                                FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                                Tag="{x:Bind Id}"
                                                Click="EditObjective_Click"/>
                                        <Button Content="View Games"
                                                Background="{StaticResource TagBackgroundBrush}"
                                                Foreground="{StaticResource SecondaryTextBrush}"
                                                BorderBrush="{StaticResource SubtleBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="2" Height="28"
                                                FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                                Tag="{x:Bind Id}"
                                                Click="ViewObjectiveGames_Click"/>
                                        <Button Content="View Notes"
                                                Background="{StaticResource TagBackgroundBrush}"
                                                Foreground="{StaticResource AccentGoldBrush}"
                                                BorderBrush="{StaticResource SubtleBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="2" Height="28"
                                                FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                                Tag="{x:Bind Id}"
                                                Click="ViewObjectiveNotes_Click"/>
                                        <Border Background="{StaticResource SuccessSurfaceBrush}"
                                                CornerRadius="2" Padding="6,2">
                                            <TextBlock Text="DONE"
                                                       FontSize="{Binding Meta, Source={StaticResource FontSizes}}" FontWeight="Bold"
                                                       Foreground="{StaticResource WinGreenBrush}"/>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>

                <!-- Loading indicator -->
                <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                              Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVis}}"
                              HorizontalAlignment="Center"
                              Width="40" Height="40"
                              Margin="0,20"/>

            </StackPanel>
        </ScrollViewer>

        <!-- ••• Celebration Overlay ••• -->
        <Grid x:Name="CelebrationOverlay"
              Visibility="{x:Bind ViewModel.ShowCelebration, Mode=OneWay, Converter={StaticResource BoolToVis}}"
              Background="#CC060B0B">
            <Border MaxWidth="420"
                    Background="{StaticResource CardAltBackgroundBrush}"
                    BorderBrush="{StaticResource AccentGoldBrush}"
                    BorderThickness="2"
                    CornerRadius="2"
                    Padding="36,32"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform>
                    <CompositeTransform x:Name="CelebrationCardTransform"/>
                </Border.RenderTransform>

                <StackPanel Spacing="16" HorizontalAlignment="Center">
                    <!-- Trophy icon -->
                    <FontIcon Glyph="&#xE735;" FontSize="{Binding Display, Source={StaticResource FontSizes}}"
                              Foreground="{StaticResource AccentGoldBrush}"
                              HorizontalAlignment="Center"/>

                    <!-- Heading -->
                    <TextBlock Text="OBJECTIVE MASTERED"
                               FontSize="{Binding TitleLarge, Source={StaticResource FontSizes}}" FontWeight="Bold"
                               Foreground="{StaticResource AccentGoldBrush}"
                               HorizontalAlignment="Center"
                               CharacterSpacing="80"/>

                    <!-- Objective title -->
                    <TextBlock Text="{x:Bind ViewModel.CelebrationTitle, Mode=OneWay}"
                               FontSize="{Binding Title, Source={StaticResource FontSizes}}" FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryTextBrush}"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               TextWrapping="Wrap"/>

                    <!-- Stats -->
                    <TextBlock Text="{x:Bind ViewModel.CelebrationStats, Mode=OneWay}"
                               FontSize="{Binding Subtitle, Source={StaticResource FontSizes}}"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               HorizontalAlignment="Center"/>

                    <!-- Separator -->
                    <Border Height="1" Width="120"
                            Background="{StaticResource AccentGoldDimBrush}"
                            HorizontalAlignment="Center"/>

                    <!-- Motivational text -->
                    <TextBlock Text="Skill acquired. On to the next challenge."
                               FontSize="{Binding BodyEmphasis, Source={StaticResource FontSizes}}"
                               Foreground="{StaticResource MutedTextBrush}"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"/>

                    <!-- Dismiss button -->
                    <Button Content="Continue"
                            Command="{x:Bind ViewModel.DismissCelebrationCommand}"
                            Background="{StaticResource AccentGoldDimBrush}"
                            Foreground="{StaticResource AccentGoldBrush}"
                            BorderBrush="{StaticResource AccentGoldBrush}"
                            BorderThickness="1"
                            CornerRadius="2"
                            Height="38"
                            Padding="28,0"
                            HorizontalAlignment="Center"
                            FontSize="{Binding Subtitle, Source={StaticResource FontSizes}}"
                            FontWeight="SemiBold"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- HUD-themed proposals modal. Lives at the root so it
             overlays the whole page (including celebration storyboard).
             Visibility toggled via IsOpen from the code-behind. -->
        <controls:HudModal x:Name="ProposalsModal"
                           Title="COACH PROPOSALS"
                           CloseRequested="OnProposalsModalClose"/>
    </Grid>
</Page>
