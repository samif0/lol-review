<Page
    x:Class="Revu.App.Views.ManualEntryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:svc="using:Revu.App.Services"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:converters="using:Revu.App.Converters"
    xmlns:controls="using:Revu.App.Controls"
    xmlns:vm="using:Revu.App.ViewModels"
    mc:Ignorable="d"
    Background="Transparent">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </Page.Resources>

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <controls:HeroHeader Grid.Row="0"
                             EyebrowText="MANUAL ENTRY"
                             Title="Log a Game"
                             Margin="40,16,40,8"/>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="40,0,40,40">
            <StackPanel Spacing="14" MaxWidth="700" HorizontalAlignment="Center">

                <!-- Error message -->
                <TextBlock Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                           FontFamily="{StaticResource MonoFont}"
                           FontSize="{Binding Meta, Source={StaticResource FontSizes}}" Foreground="{StaticResource LossRedBrush}"
                           Visibility="{x:Bind ViewModel.HasError, Mode=OneWay, Converter={StaticResource BoolToVis}}"/>

                <!-- ••• Champion + Result + KDA ••• -->
                <controls:CornerBracketedCard CardBorderBrush="{StaticResource AccentGoldBrush}">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Spacing="8">
                            <TextBox Text="{x:Bind ViewModel.ChampionName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     PlaceholderText="Champion Name"
                                     FontFamily="{StaticResource DisplayFont}"
                                     FontSize="{Binding TitleLarge, Source={StaticResource FontSizes}}" FontWeight="Bold"
                                     Background="Transparent"
                                     BorderThickness="0,0,0,2"
                                     BorderBrush="{StaticResource AccentGoldBrush}"
                                     Foreground="{StaticResource AccentGoldBrush}"
                                     Padding="0,4" MinWidth="180"/>

                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <RadioButton Content="Victory" GroupName="Result"
                                             IsChecked="{x:Bind ViewModel.IsVictory, Mode=TwoWay}"
                                             Foreground="{StaticResource WinGreenBrush}"
                                             FontSize="{Binding BodyEmphasis, Source={StaticResource FontSizes}}" FontWeight="SemiBold"/>
                                <RadioButton Content="Defeat" GroupName="Result"
                                             Foreground="{StaticResource LossRedBrush}"
                                             FontSize="{Binding BodyEmphasis, Source={StaticResource FontSizes}}" FontWeight="SemiBold"/>
                            </StackPanel>
                        </StackPanel>

                        <Grid Grid.Column="1" ColumnSpacing="6" VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="50"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Text="{x:Bind ViewModel.KillsText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     PlaceholderText="K" InputScope="Number"
                                     FontFamily="{StaticResource DisplayFont}"
                                     FontSize="{Binding TitleLarge, Source={StaticResource FontSizes}}" FontWeight="Bold" TextAlignment="Center"
                                     Background="{StaticResource InputBackgroundBrush}"
                                     BorderBrush="{StaticResource SubtleBorderBrush}"
                                     Foreground="{StaticResource PrimaryTextBrush}"
                                     CornerRadius="2" Height="40"/>
                            <TextBlock Grid.Column="1" Text="/"
                                       FontFamily="{StaticResource DisplayFont}"
                                       FontSize="{Binding TitleLarge, Source={StaticResource FontSizes}}" FontWeight="Bold"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       VerticalAlignment="Center"/>
                            <TextBox Grid.Column="2"
                                     Text="{x:Bind ViewModel.DeathsText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     PlaceholderText="D" InputScope="Number"
                                     FontFamily="{StaticResource DisplayFont}"
                                     FontSize="{Binding TitleLarge, Source={StaticResource FontSizes}}" FontWeight="Bold" TextAlignment="Center"
                                     Background="{StaticResource InputBackgroundBrush}"
                                     BorderBrush="{StaticResource SubtleBorderBrush}"
                                     Foreground="{StaticResource PrimaryTextBrush}"
                                     CornerRadius="2" Height="40"/>
                            <TextBlock Grid.Column="3" Text="/"
                                       FontFamily="{StaticResource DisplayFont}"
                                       FontSize="{Binding TitleLarge, Source={StaticResource FontSizes}}" FontWeight="Bold"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       VerticalAlignment="Center"/>
                            <TextBox Grid.Column="4"
                                     Text="{x:Bind ViewModel.AssistsText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     PlaceholderText="A" InputScope="Number"
                                     FontFamily="{StaticResource DisplayFont}"
                                     FontSize="{Binding TitleLarge, Source={StaticResource FontSizes}}" FontWeight="Bold" TextAlignment="Center"
                                     Background="{StaticResource InputBackgroundBrush}"
                                     BorderBrush="{StaticResource SubtleBorderBrush}"
                                     Foreground="{StaticResource PrimaryTextBrush}"
                                     CornerRadius="2" Height="40"/>
                        </Grid>
                    </Grid>
                </controls:CornerBracketedCard>

                <!-- ••• Mental Rating ••• -->
                <controls:CornerBracketedCard>
                    <StackPanel Spacing="10">
                        <controls:SectionTitle Text="MENTAL RATING"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Slider Grid.Column="0"
                                    Value="{x:Bind ViewModel.MentalRating, Mode=TwoWay}"
                                    Minimum="1" Maximum="10"
                                    StepFrequency="1" TickFrequency="1"
                                    TickPlacement="Outside"
                                    VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1"
                                       Text="{x:Bind ViewModel.MentalRating, Mode=OneWay}"
                                       FontFamily="{StaticResource DisplayFont}"
                                       FontSize="{Binding HeroLarge, Source={StaticResource FontSizes}}" FontWeight="Bold"
                                       Margin="16,0,0,0"
                                       VerticalAlignment="Center"
                                       MinWidth="44" TextAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </controls:CornerBracketedCard>

                <!-- ••• Learning Objectives ••• -->
                <controls:CornerBracketedCard
                    CardBorderBrush="{StaticResource AccentBlueBrush}"
                    Visibility="{x:Bind ViewModel.HasObjectives, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                    <StackPanel Spacing="10">
                        <controls:SectionTitle Text="LEARNING OBJECTIVES"/>
                        <ItemsRepeater ItemsSource="{x:Bind ViewModel.Objectives}">
                            <ItemsRepeater.Layout>
                                <StackLayout Spacing="8"/>
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="vm:ObjectiveAssessment">
                                    <Border Background="{StaticResource SurfaceInsetBrush}"
                                            BorderBrush="{StaticResource SubtleBorderBrush}"
                                            BorderThickness="1" CornerRadius="0" Padding="14,10">
                                        <StackPanel Spacing="6">
                                            <Grid ColumnDefinitions="*,Auto">
                                                <StackPanel Spacing="2">
                                                    <TextBlock Text="{x:Bind Title}"
                                                               FontFamily="{StaticResource HeadingFont}"
                                                               FontSize="{Binding Subtitle, Source={StaticResource FontSizes}}" FontWeight="SemiBold"
                                                               Foreground="{StaticResource PrimaryTextBrush}"
                                                               TextWrapping="Wrap"/>
                                                    <TextBlock Text="{x:Bind PhaseLabel}"
                                                               FontFamily="{StaticResource MonoFont}"
                                                               FontSize="{Binding Caption, Source={StaticResource FontSizes}}"
                                                               Foreground="{StaticResource AccentBlueBrush}"/>
                                                </StackPanel>
                                                <ToggleSwitch Grid.Column="1"
                                                              IsOn="{x:Bind Practiced, Mode=TwoWay}"
                                                              OnContent="Practiced"
                                                              OffContent="Not practiced"
                                                              VerticalAlignment="Center"/>
                                            </Grid>
                                            <TextBox Text="{x:Bind ExecutionNote, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     PlaceholderText="How did you execute on this?"
                                                     FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                                     Background="{StaticResource InputBackgroundBrush}"
                                                     BorderBrush="{StaticResource SubtleBorderBrush}"
                                                     Foreground="{StaticResource PrimaryTextBrush}"
                                                     CornerRadius="2" Height="32"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </StackPanel>
                </controls:CornerBracketedCard>

                <!-- ••• Performance Review ••• -->
                <controls:CornerBracketedCard>
                    <StackPanel Spacing="10">
                        <controls:SectionTitle Text="PERFORMANCE REVIEW"/>

                        <TextBlock Text="What went well?" FontSize="{Binding BodyEmphasis, Source={StaticResource FontSizes}}"
                                   Foreground="{StaticResource PrimaryTextBrush}"/>
                        <TextBox Text="{x:Bind ViewModel.WentWell, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 PlaceholderText="Good plays, decisions, mechanics..."
                                 TextWrapping="Wrap" AcceptsReturn="True"
                                 MinHeight="70" FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                 Background="{StaticResource InputBackgroundBrush}"
                                 BorderBrush="{StaticResource SubtleBorderBrush}"
                                 Foreground="{StaticResource PrimaryTextBrush}" CornerRadius="2"/>

                        <TextBlock Text="What could improve?" FontSize="{Binding BodyEmphasis, Source={StaticResource FontSizes}}"
                                   Foreground="{StaticResource PrimaryTextBrush}"/>
                        <TextBox Text="{x:Bind ViewModel.Mistakes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 PlaceholderText="Deaths, missed plays, bad decisions..."
                                 TextWrapping="Wrap" AcceptsReturn="True"
                                 MinHeight="70" FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                 Background="{StaticResource InputBackgroundBrush}"
                                 BorderBrush="{StaticResource SubtleBorderBrush}"
                                 Foreground="{StaticResource PrimaryTextBrush}" CornerRadius="2"/>

                        <TextBlock Text="Focus for next game" FontSize="{Binding BodyEmphasis, Source={StaticResource FontSizes}}"
                                   Foreground="{StaticResource PrimaryTextBrush}"/>
                        <TextBox Text="{x:Bind ViewModel.FocusNext, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 PlaceholderText="What will you focus on improving?"
                                 FontSize="{Binding Body, Source={StaticResource FontSizes}}" Height="36"
                                 Background="{StaticResource InputBackgroundBrush}"
                                 BorderBrush="{StaticResource SubtleBorderBrush}"
                                 Foreground="{StaticResource PrimaryTextBrush}" CornerRadius="2"/>
                    </StackPanel>
                </controls:CornerBracketedCard>

                <!-- ••• Additional Notes ••• -->
                <controls:CornerBracketedCard>
                    <StackPanel Spacing="8">
                        <controls:SectionTitle Text="ADDITIONAL NOTES"/>
                        <TextBox Text="{x:Bind ViewModel.ReviewNotes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 PlaceholderText="Any other notes about this game..."
                                 TextWrapping="Wrap" AcceptsReturn="True"
                                 MinHeight="70" FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                 Background="{StaticResource InputBackgroundBrush}"
                                 BorderBrush="{StaticResource SubtleBorderBrush}"
                                 Foreground="{StaticResource PrimaryTextBrush}" CornerRadius="2"/>
                    </StackPanel>
                </controls:CornerBracketedCard>

                <!-- ••• Action Buttons ••• -->
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="Cancel" Click="OnCancelClick"
                            Style="{StaticResource SecondaryActionButtonStyle}"
                            FontSize="{Binding Subtitle, Source={StaticResource FontSizes}}" Height="44"
                            HorizontalAlignment="Stretch"/>
                    <Button Grid.Column="1" Content="Save Game Entry" Click="OnSaveClick"
                            Style="{StaticResource PrimaryActionButtonStyle}"
                            FontSize="{Binding Subtitle, Source={StaticResource FontSizes}}" FontWeight="Bold" Height="44"
                            HorizontalAlignment="Stretch"/>
                </Grid>

                <Border Height="20"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
