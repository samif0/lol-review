<Page
    x:Class="Revu.App.Views.PatternReviewPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:Revu.App.Controls"
    xmlns:converters="using:Revu.App.Converters"
    xmlns:vm="using:Revu.App.ViewModels"
    mc:Ignorable="d"
    Background="Transparent">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </Page.Resources>

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Padding="28,18,28,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Command="{x:Bind ViewModel.GoBackCommand}"
                    Style="{StaticResource GhostIconButtonStyle}"
                    VerticalAlignment="Center"
                    Margin="0,0,12,0"
                    ToolTipService.ToolTip="Back">
                <FontIcon Glyph="&#xE72B;" FontSize="{Binding BodyEmphasis, Source={StaticResource FontSizes}}"/>
            </Button>

            <StackPanel Grid.Column="1" Spacing="3" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <Rectangle Width="18" Height="1" Fill="{x:Bind ViewModel.SeverityBrush, Mode=OneWay}" VerticalAlignment="Center"/>
                    <TextBlock FontFamily="{StaticResource MonoFont}"
                               FontSize="{Binding Caption, Source={StaticResource FontSizes}}"
                               CharacterSpacing="300"
                               Foreground="{x:Bind ViewModel.SeverityBrush, Mode=OneWay}"
                               VerticalAlignment="Center">
                        <Run Text="PATTERN REVIEW"/><Run Text="  &#183;  "/><Run Text="{x:Bind ViewModel.SeverityLabel, Mode=OneWay}"/>
                    </TextBlock>
                </StackPanel>
                <TextBlock Text="{x:Bind ViewModel.PatternTitle, Mode=OneWay}"
                           FontFamily="{StaticResource DisplayFont}"
                           FontSize="{Binding TitleLarge, Source={StaticResource FontSizes}}" FontWeight="Bold"
                           Foreground="{StaticResource PrimaryTextBrush}"/>
                <TextBlock Text="{x:Bind ViewModel.PatternSubtitle, Mode=OneWay}"
                           FontFamily="{StaticResource BodyFont}"
                           FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                           Foreground="{StaticResource SecondaryTextBrush}"/>
            </StackPanel>

            <Border Grid.Column="2"
                    VerticalAlignment="Center"
                    Background="{StaticResource SurfaceInsetBrush}"
                    BorderBrush="{StaticResource SubtleBorderBrush}"
                    BorderThickness="1" CornerRadius="2" Padding="10,5"
                    Visibility="{x:Bind ViewModel.HasMoments, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="{x:Bind ViewModel.CounterText, Mode=OneWay}"
                           FontFamily="{StaticResource MonoFont}"
                           FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                           CharacterSpacing="150"
                           Foreground="{StaticResource SecondaryTextBrush}"/>
            </Border>
        </Grid>

        <!-- Loading -->
        <ProgressRing Grid.Row="1"
                      IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                      Width="44" Height="44"
                      HorizontalAlignment="Center" VerticalAlignment="Center"
                      Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVis}}"/>

        <!-- Empty -->
        <TextBlock Grid.Row="1"
                   Text="No pending moments for this pattern. It may have already been reviewed."
                   FontSize="{Binding Subtitle, Source={StaticResource FontSizes}}"
                   Foreground="{StaticResource SecondaryTextBrush}"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   TextWrapping="Wrap" MaxWidth="420" TextAlignment="Center"
                   Visibility="{x:Bind ViewModel.IsEmpty, Mode=OneWay, Converter={StaticResource BoolToVis}}"/>

        <!-- Main: player left, pattern rail right -->
        <Grid Grid.Row="1"
              Padding="28,4,28,24"
              ColumnSpacing="14"
              Visibility="{x:Bind ViewModel.HasMoments, Mode=OneWay, Converter={StaticResource BoolToVis}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <!-- Player column -->
            <Grid Grid.Column="0" RowSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Active-moment header strip over the surface -->
                <Grid Grid.Row="0" RowSpacing="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="{StaticResource SurfaceInsetBrush}"
                            BorderBrush="{StaticResource SubtleBorderBrush}"
                            BorderThickness="1" CornerRadius="2" Padding="12,8">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0"
                                    Background="{StaticResource TagBackgroundBrush}"
                                    BorderBrush="{x:Bind ViewModel.CurrentMoment.ResultBrush, Mode=OneWay}"
                                    BorderThickness="1" CornerRadius="2" Padding="7,2" VerticalAlignment="Center">
                                <TextBlock Text="{x:Bind ViewModel.CurrentMoment.ResultLabel, Mode=OneWay}"
                                           FontFamily="{StaticResource MonoFont}"
                                           FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                           Foreground="{x:Bind ViewModel.CurrentMoment.ResultBrush, Mode=OneWay}"/>
                            </Border>
                            <TextBlock Grid.Column="1"
                                       Text="{x:Bind ViewModel.CurrentMoment.Title, Mode=OneWay}"
                                       FontFamily="{StaticResource BodyFont}"
                                       FontSize="{Binding BodyEmphasis, Source={StaticResource FontSizes}}"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource PrimaryTextBrush}"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Grid.Column="2"
                                       Text="{x:Bind ViewModel.CurrentMoment.GameLabel, Mode=OneWay}"
                                       FontFamily="{StaticResource MonoFont}"
                                       FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                       Foreground="{StaticResource AccentGoldBrush}"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <controls:VodSurface x:Name="Surface" Grid.Row="1"/>
                </Grid>

                <!-- This-moment work panel: just the note. The moment is already
                     a clip-sized window, so saving a note auto-clips it on the
                     backend — no manual clip/bookmark controls. -->
                <Border Grid.Row="1"
                        Background="{StaticResource SurfaceInsetBrush}"
                        BorderBrush="{StaticResource SubtleBorderBrush}"
                        BorderThickness="1" CornerRadius="2" Padding="16,14">
                    <StackPanel Spacing="8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="YOUR NOTE ON THIS MOMENT"
                                       FontFamily="{StaticResource MonoFont}"
                                       FontSize="{Binding Caption, Source={StaticResource FontSizes}}"
                                       CharacterSpacing="200"
                                       Foreground="{StaticResource AccentGoldBrush}"
                                       VerticalAlignment="Center"/>
                            <!-- Autosave indicator (no Save button — notes save as you type). -->
                            <TextBlock Grid.Column="1"
                                       Text="{x:Bind ViewModel.MomentStatus, Mode=OneWay}"
                                       FontFamily="{StaticResource MonoFont}"
                                       FontSize="{Binding Caption, Source={StaticResource FontSizes}}"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       VerticalAlignment="Center"
                                       Visibility="{x:Bind ViewModel.HasMomentStatus, Mode=OneWay, Converter={StaticResource BoolToVis}}"/>
                        </Grid>

                        <TextBox Text="{x:Bind ViewModel.MomentNote, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 PlaceholderText="What happened here, and what will you do differently? Notes save automatically and keep a clip of this moment."
                                 TextWrapping="Wrap" AcceptsReturn="True"
                                 MinHeight="100"
                                 FontSize="{Binding BodyEmphasis, Source={StaticResource FontSizes}}"
                                 Background="{StaticResource InputBackgroundBrush}"
                                 BorderBrush="{StaticResource SubtleBorderBrush}"
                                 Foreground="{StaticResource PrimaryTextBrush}"
                                 CornerRadius="2"
                                 Padding="12,10"/>
                    </StackPanel>
                </Border>

                <!-- Prev / Next moment -->
                <Grid Grid.Row="2" ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0"
                            Command="{x:Bind ViewModel.PrevMomentCommand}"
                            Style="{StaticResource SecondaryActionButtonStyle}"
                            HorizontalAlignment="Stretch" Height="40">
                        <TextBlock Text="&#8592; PREV MOMENT"
                                   FontFamily="{StaticResource MonoFont}"
                                   FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                   CharacterSpacing="100"/>
                    </Button>
                    <Button Grid.Column="1"
                            Command="{x:Bind ViewModel.NextMomentCommand}"
                            Style="{StaticResource GoldActionButtonStyle}"
                            HorizontalAlignment="Stretch" Height="40">
                        <TextBlock Text="NEXT MOMENT &#8594;"
                                   FontFamily="{StaticResource MonoFont}"
                                   FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                   CharacterSpacing="100"/>
                    </Button>
                </Grid>
            </Grid>

            <!-- Pattern rail -->
            <Grid Grid.Column="1" RowSpacing="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="THE PATTERN"
                           FontFamily="{StaticResource MonoFont}"
                           FontSize="{Binding Caption, Source={StaticResource FontSizes}}"
                           CharacterSpacing="200"
                           Foreground="{StaticResource AccentBlueBrush}"/>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <ItemsRepeater ItemsSource="{x:Bind ViewModel.Moments, Mode=OneWay}">
                        <ItemsRepeater.Layout>
                            <StackLayout Spacing="5"/>
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="vm:PatternMomentItem">
                                <Button Background="Transparent" BorderThickness="0" Padding="0"
                                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                                        DataContext="{x:Bind}"
                                        Click="OnMomentClick">
                                    <Border Background="{StaticResource SurfaceInsetBrush}"
                                            BorderBrush="{x:Bind AccentBrush, Mode=OneWay}"
                                            BorderThickness="2,1,1,1" CornerRadius="2" Padding="8,7"
                                            Opacity="{x:Bind RowOpacity, Mode=OneWay}">
                                        <StackPanel Spacing="2">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{x:Bind GameLabel}"
                                                           FontFamily="{StaticResource MonoFont}"
                                                           FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                                           Foreground="{StaticResource SecondaryTextBrush}"/>
                                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                                    <TextBlock Text="{x:Bind ClipStateLabel, Mode=OneWay}"
                                                               FontFamily="{StaticResource MonoFont}"
                                                               FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                                               Foreground="{StaticResource AccentGoldBrush}"
                                                               Visibility="{x:Bind HasClip, Mode=OneWay, Converter={StaticResource BoolToVis}}"/>
                                                    <TextBlock Text="{x:Bind PolarityLabel, Mode=OneWay}"
                                                               FontFamily="{StaticResource MonoFont}"
                                                               FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                                               FontWeight="SemiBold"
                                                               Foreground="{x:Bind AccentBrush, Mode=OneWay}"/>
                                                </StackPanel>
                                            </Grid>
                                            <TextBlock Text="{x:Bind Title}"
                                                       FontFamily="{StaticResource BodyFont}"
                                                       FontSize="{Binding Subtitle, Source={StaticResource FontSizes}}"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource PrimaryTextBrush}"
                                                       TextWrapping="Wrap"/>
                                            <TextBlock Text="{x:Bind Note, Mode=OneWay}"
                                                       FontFamily="{StaticResource BodyFont}"
                                                       FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                                       Foreground="{StaticResource AccentBlueBrush}"
                                                       FontStyle="Italic"
                                                       TextWrapping="Wrap"
                                                       Visibility="{x:Bind HasNote, Mode=OneWay, Converter={StaticResource BoolToVis}}"/>
                                        </StackPanel>
                                    </Border>
                                </Button>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </ScrollViewer>

                <!-- Carry-forward / mark reviewed -->
                <StackPanel Grid.Row="2" Spacing="7">
                    <Border Height="1" Background="{StaticResource SubtleBorderBrush}"/>
                    <TextBlock Text="REVIEWED"
                               FontFamily="{StaticResource MonoFont}"
                               FontSize="{Binding Caption, Source={StaticResource FontSizes}}"
                               CharacterSpacing="200"
                               Foreground="{StaticResource WinGreenBrush}"
                               Visibility="{x:Bind ViewModel.IsReviewed, Mode=OneWay, Converter={StaticResource BoolToVis}}"/>
                    <Button Command="{x:Bind ViewModel.MarkReviewedCommand}"
                            Style="{StaticResource PrimaryActionButtonStyle}"
                            HorizontalAlignment="Stretch" Height="42"
                            ToolTipService.ToolTip="Mark this pattern worked through — it leaves your Patterns To Review and ticks Patterns Reviewed on the dashboard.">
                        <TextBlock Text="MARK PATTERN REVIEWED"
                                   FontFamily="{StaticResource MonoFont}"
                                   FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                   CharacterSpacing="100"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Page>
