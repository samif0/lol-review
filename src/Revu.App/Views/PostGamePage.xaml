<Page
    x:Class="Revu.App.Views.PostGamePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:svc="using:Revu.App.Services"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:converters="using:Revu.App.Converters"
    xmlns:controls="using:Revu.App.Controls"
    xmlns:vm="using:Revu.App.ViewModels"
    mc:Ignorable="d"
    Background="Transparent">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </Page.Resources>

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ••• Hero ••• -->
        <Grid Grid.Row="0" Margin="40,16,40,8" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- v2.15.9: paired with VodPlayerPage's "Open Review" button. The
                 same WatchVodCommand the hero card uses, surfaced top-left so
                 the user can flip back to the VOD without scrolling. Gated on
                 HasVod since flipping there is meaningless without a recording. -->
            <Button Grid.Column="0"
                    Command="{x:Bind ReviewVM.WatchVodCommand}"
                    Style="{StaticResource GoldActionButtonStyle}"
                    Height="34" Padding="14,0" VerticalAlignment="Center"
                    FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                    Visibility="{x:Bind ReviewVM.HasVod, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE714;"
                              FontSize="{Binding BodyEmphasis, Source={StaticResource FontSizes}}"
                              FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"/>
                    <TextBlock Text="Back to VOD" FontSize="{Binding Body, Source={StaticResource FontSizes}}"/>
                </StackPanel>
            </Button>

            <controls:HeroHeader Grid.Column="1"
                                 EyebrowText="POST GAME"
                                 Title="{x:Bind ReviewVM.HeaderText, Mode=OneWay}"/>
        </Grid>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="40,0,40,40">
            <StackPanel Spacing="14" HorizontalAlignment="Stretch">

                <!-- ••• Champion Hero Card ••• -->
                <controls:CornerBracketedCard CardBorderBrush="{StaticResource AccentGoldBrush}">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Spacing="4">
                            <TextBlock Text="{x:Bind ReviewVM.ChampionName, Mode=OneWay}"
                                       FontFamily="{StaticResource DisplayFont}"
                                       FontSize="{Binding Hero, Source={StaticResource FontSizes}}" FontWeight="Bold"
                                       Foreground="{StaticResource AccentGoldBrush}"/>
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="{x:Bind ReviewVM.ResultText, Mode=OneWay}"
                                           FontFamily="{StaticResource HeadingFont}"
                                           FontSize="{Binding Subtitle, Source={StaticResource FontSizes}}" FontWeight="Bold"/>
                                <TextBlock FontFamily="{StaticResource MonoFont}"
                                           FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           VerticalAlignment="Center">
                                    <Run Text="{x:Bind ReviewVM.DurationText, Mode=OneWay}"/>
                                    <Run Text="  "/>
                                    <Run Text="{x:Bind ReviewVM.GameModeText, Mode=OneWay}"/>
                                </TextBlock>
                            </StackPanel>
                            <!-- VOD button -->
                            <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,6,0,0"
                                        Visibility="{x:Bind ReviewVM.HasVod, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                                <Button Command="{x:Bind ReviewVM.WatchVodCommand}"
                                        Style="{StaticResource GoldActionButtonStyle}"
                                        Height="34" Padding="14,0" FontSize="{Binding Body, Source={StaticResource FontSizes}}">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon Glyph="&#xE714;" FontSize="{Binding BodyEmphasis, Source={StaticResource FontSizes}}"
                                                  FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"/>
                                        <TextBlock Text="Review VOD"/>
                                    </StackPanel>
                                </Button>
                                <TextBlock FontFamily="{StaticResource MonoFont}"
                                           FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           VerticalAlignment="Center">
                                    <Run Text="{x:Bind ReviewVM.BookmarkCount, Mode=OneWay}"/>
                                    <Run Text=" bookmarks"/>
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Column="1" HorizontalAlignment="Right"
                                    VerticalAlignment="Center" Spacing="2">
                            <TextBlock Text="{x:Bind ReviewVM.KdaText, Mode=OneWay}"
                                       FontFamily="{StaticResource DisplayFont}"
                                       FontSize="{Binding TitleLarge, Source={StaticResource FontSizes}}" FontWeight="Bold"
                                       Foreground="{StaticResource PrimaryTextBrush}"
                                       HorizontalAlignment="Right"/>
                            <TextBlock Text="{x:Bind ReviewVM.KdaRatioText, Mode=OneWay}"
                                       FontFamily="{StaticResource MonoFont}"
                                       FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       HorizontalAlignment="Right"/>
                        </StackPanel>
                    </Grid>
                </controls:CornerBracketedCard>

                <!-- ••• Game Stats ••• -->
                <controls:SectionTitle Text="GAME STATS"/>
                <Grid ColumnSpacing="8" RowSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <controls:StatCard Grid.Row="0" Grid.Column="0" Label="DAMAGE" Value="{x:Bind ReviewVM.DamageText, Mode=OneWay}"/>
                    <controls:StatCard Grid.Row="0" Grid.Column="1" Label="CS" Value="{x:Bind ReviewVM.CsText, Mode=OneWay}"/>
                    <controls:StatCard Grid.Row="0" Grid.Column="2" Label="CS/MIN" Value="{x:Bind ReviewVM.CsPerMinText, Mode=OneWay}"/>
                    <controls:StatCard Grid.Row="0" Grid.Column="3" Label="VISION" Value="{x:Bind ReviewVM.VisionText, Mode=OneWay}"/>
                    <controls:StatCard Grid.Row="1" Grid.Column="0" Label="GOLD" Value="{x:Bind ReviewVM.GoldText, Mode=OneWay}"/>
                    <controls:StatCard Grid.Row="1" Grid.Column="1" Label="KILL PART." Value="{x:Bind ReviewVM.KillParticipationText, Mode=OneWay}"/>
                    <controls:StatCard Grid.Row="1" Grid.Column="2" Label="DMG TAKEN" Value="{x:Bind ReviewVM.DamageTakenText, Mode=OneWay}"/>
                    <controls:StatCard Grid.Row="1" Grid.Column="3" Label="WARDS" Value="{x:Bind ReviewVM.WardsPlacedText, Mode=OneWay}"/>
                </Grid>

                <!-- ••• Priority Objective ••• -->
                <controls:CornerBracketedCard
                    CardBorderBrush="{StaticResource AccentGoldBrush}"
                    Visibility="{x:Bind ReviewVM.HasPriorityObjective, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                    <StackPanel Spacing="4">
                        <controls:SectionTitle Text="PRIORITY OBJECTIVE"/>
                        <TextBlock Text="{x:Bind ReviewVM.PriorityObjectiveTitle, Mode=OneWay}"
                                   FontFamily="{StaticResource HeadingFont}"
                                   FontSize="{Binding Subtitle, Source={StaticResource FontSizes}}" FontWeight="SemiBold"
                                   Foreground="{StaticResource PrimaryTextBrush}" TextWrapping="Wrap"/>
                        <TextBlock Text="{x:Bind ReviewVM.PriorityObjectiveCriteria, Mode=OneWay}"
                                   FontFamily="{StaticResource MonoFont}"
                                   FontSize="{Binding Meta, Source={StaticResource FontSizes}}" Foreground="{StaticResource SecondaryTextBrush}" TextWrapping="Wrap"/>
                    </StackPanel>
                </controls:CornerBracketedCard>

                <!-- ••• Mental Rating ••• -->
                <controls:CornerBracketedCard>
                    <StackPanel Spacing="10">
                        <controls:SectionTitle Text="MENTAL RATING"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Slider Value="{x:Bind ReviewVM.MentalRating, Mode=TwoWay}"
                                    Minimum="1" Maximum="10" StepFrequency="1"
                                    TickFrequency="1" TickPlacement="Outside"
                                    VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1"
                                       Text="{x:Bind ReviewVM.MentalRating, Mode=OneWay}"
                                       FontFamily="{StaticResource DisplayFont}"
                                       FontSize="{Binding HeroLarge, Source={StaticResource FontSizes}}" FontWeight="Bold"
                                       Margin="16,0,0,0" VerticalAlignment="Center"
                                       MinWidth="44" TextAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </controls:CornerBracketedCard>

                <!-- ••• Mental Reflection (low mental) ••• -->
                <controls:CornerBracketedCard
                    CardBorderBrush="{StaticResource AccentPurpleBrush}"
                    Visibility="{x:Bind ReviewVM.ShowMentalReflection, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                    <StackPanel Spacing="8">
                        <controls:SectionTitle Text="MENTAL REFLECTION"/>
                        <TextBox Text="{x:Bind ReviewVM.MentalHandled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 PlaceholderText="What triggered the tilt? How did you handle it?"
                                 TextWrapping="Wrap" AcceptsReturn="True"
                                 MinHeight="60" FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                 Background="{StaticResource InputBackgroundBrush}"
                                 BorderBrush="{StaticResource SubtleBorderBrush}"
                                 Foreground="{StaticResource PrimaryTextBrush}" CornerRadius="2"/>
                    </StackPanel>
                </controls:CornerBracketedCard>

                <!-- ••• Performance Review ••• -->
                <controls:CornerBracketedCard>
                    <StackPanel Spacing="10">
                        <controls:SectionTitle Text="PERFORMANCE REVIEW"/>
                        <TextBlock Text="What went well?" FontSize="{Binding BodyEmphasis, Source={StaticResource FontSizes}}" Foreground="{StaticResource PrimaryTextBrush}"/>
                        <TextBox Text="{x:Bind ReviewVM.WentWell, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 PlaceholderText="Good plays, decisions, mechanics..."
                                 TextWrapping="Wrap" AcceptsReturn="True" MinHeight="60" FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                 Background="{StaticResource InputBackgroundBrush}"
                                 BorderBrush="{StaticResource SubtleBorderBrush}"
                                 Foreground="{StaticResource PrimaryTextBrush}" CornerRadius="2"/>
                        <TextBlock Text="What could improve?" FontSize="{Binding BodyEmphasis, Source={StaticResource FontSizes}}" Foreground="{StaticResource PrimaryTextBrush}"/>
                        <TextBox Text="{x:Bind ReviewVM.Mistakes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 PlaceholderText="Deaths, missed plays, bad decisions..."
                                 TextWrapping="Wrap" AcceptsReturn="True" MinHeight="60" FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                 Background="{StaticResource InputBackgroundBrush}"
                                 BorderBrush="{StaticResource SubtleBorderBrush}"
                                 Foreground="{StaticResource PrimaryTextBrush}" CornerRadius="2"/>
                        <TextBlock Text="Focus for next game" FontSize="{Binding BodyEmphasis, Source={StaticResource FontSizes}}" Foreground="{StaticResource PrimaryTextBrush}"/>
                        <TextBox Text="{x:Bind ReviewVM.FocusNext, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 PlaceholderText="What will you focus on?" FontSize="{Binding Body, Source={StaticResource FontSizes}}" Height="36"
                                 Background="{StaticResource InputBackgroundBrush}"
                                 BorderBrush="{StaticResource SubtleBorderBrush}"
                                 Foreground="{StaticResource PrimaryTextBrush}" CornerRadius="2"/>
                    </StackPanel>
                </controls:CornerBracketedCard>

                <!-- ••• Objective Practice ••• -->
                <controls:CornerBracketedCard
                    CardBorderBrush="{StaticResource AccentBlueBrush}"
                    Visibility="{x:Bind ReviewVM.HasObjectives, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                    <StackPanel Spacing="10">
                        <controls:SectionTitle Text="OBJECTIVE PRACTICE"/>
                        <ItemsRepeater ItemsSource="{x:Bind ReviewVM.ObjectiveAssessments, Mode=OneWay}">
                            <ItemsRepeater.Layout>
                                <StackLayout Spacing="8"/>
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="vm:ObjectiveAssessment">
                                    <Border Background="{StaticResource SurfaceInsetBrush}"
                                            BorderBrush="{StaticResource SubtleBorderBrush}"
                                            BorderThickness="1" Padding="12">
                                        <StackPanel Spacing="6">
                                            <Grid ColumnDefinitions="*,Auto">
                                                <TextBlock Text="{x:Bind Title}"
                                                           FontFamily="{StaticResource HeadingFont}"
                                                           FontSize="{Binding Subtitle, Source={StaticResource FontSizes}}" FontWeight="SemiBold"
                                                           Foreground="{StaticResource PrimaryTextBrush}"/>
                                                <ToggleButton Grid.Column="1"
                                                              IsChecked="{x:Bind Practiced, Mode=TwoWay}"
                                                              Style="{StaticResource HudPracticedToggleStyle}"/>
                                            </Grid>
                                            <TextBox Text="{x:Bind ExecutionNote, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     PlaceholderText="How did this objective go?"
                                                     TextWrapping="Wrap" AcceptsReturn="True" MinHeight="40" FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                                     Background="{StaticResource InputBackgroundBrush}"
                                                     BorderBrush="{StaticResource SubtleBorderBrush}"
                                                     Foreground="{StaticResource PrimaryTextBrush}" CornerRadius="2"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </StackPanel>
                </controls:CornerBracketedCard>

                <!-- ••• Matchup + Notes ••• -->
                <controls:CornerBracketedCard>
                    <StackPanel Spacing="10">
                        <controls:SectionTitle Text="MATCHUP NOTES"/>
                        <TextBlock Text="{x:Bind ReviewVM.MatchupHeading, Mode=OneWay}"
                                   FontFamily="{StaticResource HeadingFont}"
                                   FontSize="{Binding Subtitle, Source={StaticResource FontSizes}}" FontWeight="SemiBold"
                                   Foreground="{StaticResource AccentBlueBrush}"/>
                        <TextBox Text="{x:Bind ReviewVM.EnemyLaner, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 PlaceholderText="Enemy laner" FontSize="{Binding Body, Source={StaticResource FontSizes}}" Height="36"
                                 Background="{StaticResource InputBackgroundBrush}"
                                 BorderBrush="{StaticResource SubtleBorderBrush}"
                                 Foreground="{StaticResource PrimaryTextBrush}" CornerRadius="2"/>
                        <TextBox Text="{x:Bind ReviewVM.MatchupNote, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 PlaceholderText="Matchup reminders..."
                                 TextWrapping="Wrap" AcceptsReturn="True" MinHeight="60" FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                 Background="{StaticResource InputBackgroundBrush}"
                                 BorderBrush="{StaticResource SubtleBorderBrush}"
                                 Foreground="{StaticResource PrimaryTextBrush}" CornerRadius="2"/>
                    </StackPanel>
                </controls:CornerBracketedCard>

                <!-- ••• Notes + Session Note ••• -->
                <controls:CornerBracketedCard>
                    <StackPanel Spacing="10">
                        <controls:SectionTitle Text="REVIEW NOTES"/>
                        <TextBox Text="{x:Bind ReviewVM.ReviewNotes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 PlaceholderText="Anything else from this game..."
                                 TextWrapping="Wrap" AcceptsReturn="True" MinHeight="60" FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                 Background="{StaticResource InputBackgroundBrush}"
                                 BorderBrush="{StaticResource SubtleBorderBrush}"
                                 Foreground="{StaticResource PrimaryTextBrush}" CornerRadius="2"/>
                        <TextBox Text="{x:Bind ReviewVM.SpottedProblems, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 PlaceholderText="Spotted problems..."
                                 TextWrapping="Wrap" AcceptsReturn="True" MinHeight="60" FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                 Background="{StaticResource InputBackgroundBrush}"
                                 BorderBrush="{StaticResource SubtleBorderBrush}"
                                 Foreground="{StaticResource PrimaryTextBrush}" CornerRadius="2"/>
                        <controls:SectionTitle Text="SESSION NOTE"/>
                        <TextBox Text="{x:Bind ReviewVM.ImprovementNote, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 PlaceholderText="Quick note for session log..."
                                 FontSize="{Binding Body, Source={StaticResource FontSizes}}" Height="36"
                                 Background="{StaticResource InputBackgroundBrush}"
                                 BorderBrush="{StaticResource SubtleBorderBrush}"
                                 Foreground="{StaticResource PrimaryTextBrush}" CornerRadius="2"/>
                    </StackPanel>
                </controls:CornerBracketedCard>

                <!-- ••• Action Buttons ••• -->
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="Skip" Click="OnSkipClick"
                            Style="{StaticResource SecondaryActionButtonStyle}"
                            FontSize="{Binding Subtitle, Source={StaticResource FontSizes}}" Height="44" HorizontalAlignment="Stretch"/>
                    <Button Grid.Column="1" Content="Save Review" Click="OnSaveClick"
                            Style="{StaticResource PrimaryActionButtonStyle}"
                            FontSize="{Binding Subtitle, Source={StaticResource FontSizes}}" FontWeight="Bold" Height="44"
                            HorizontalAlignment="Stretch"/>
                </Grid>

                <Border Height="20"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
