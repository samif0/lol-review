<Page
    x:Name="RootPage"
    x:Class="Revu.App.Views.VodPlayerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:svc="using:Revu.App.Services"
    xmlns:controls="using:Revu.App.Controls"
    xmlns:converters="using:Revu.App.Converters"
    xmlns:vm="using:Revu.App.ViewModels"
    Background="Transparent"
    IsTabStop="True"
    NavigationCacheMode="Disabled">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:InverseBoolConverter x:Key="InverseBool"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>

        <Style x:Key="VodInputTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource InputBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource SubtleBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
            <Setter Property="CornerRadius" Value="2"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Page.Resources>

    <Grid x:Name="RootGrid" Background="Transparent">
        <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                      Width="48" Height="48"
                      HorizontalAlignment="Center" VerticalAlignment="Center"
                      Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"/>

        <Grid x:Name="VodPageLayout" RowDefinitions="Auto,*" Padding="28,20,28,28">

            <!-- ••• HERO HEADER ••• -->
            <Grid x:Name="VodHeader" Grid.Row="0" Margin="0,0,0,16">
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16">
                    <!-- v2.15.9: post-game now lands on the VOD viewer; the
                         primary navigation from here is into the review (paired
                         with ReviewPage's "Review VOD" button on the other
                         side). The shell sidebar still owns global back-nav. -->
                    <Button Grid.Column="0"
                            Command="{x:Bind ViewModel.OpenReviewCommand}"
                            Style="{StaticResource GoldActionButtonStyle}"
                            Height="34" Padding="14,0" VerticalAlignment="Center"
                            FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                            IsTabStop="False" AllowFocusOnInteraction="False">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE70B;"
                                      FontSize="{Binding BodyEmphasis, Source={StaticResource FontSizes}}"
                                      FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"/>
                            <TextBlock Text="Open review" FontSize="{Binding Body, Source={StaticResource FontSizes}}"/>
                        </StackPanel>
                    </Button>

                    <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Rectangle Width="20" Height="1"
                                       Fill="{StaticResource AccentBlueBrush}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="VOD ANALYSIS"
                                       Style="{StaticResource PanelEyebrowStyle}"
                                       Foreground="{StaticResource AccentBlueBrush}"/>
                        </StackPanel>
                        <TextBlock Text="{x:Bind ViewModel.HeaderText, Mode=OneWay}"
                                   FontFamily="{StaticResource DisplayFont}"
                                   FontSize="{Binding TitleLarge, Source={StaticResource FontSizes}}" FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryTextBrush}"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <Border Background="{StaticResource SurfaceInsetBrush}"
                                BorderBrush="{StaticResource SubtleBorderBrush}"
                                BorderThickness="1" CornerRadius="2" Padding="8,4">
                            <TextBlock FontSize="{Binding Meta, Source={StaticResource FontSizes}}" FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentGoldBrush}">
                                <Run Text="{x:Bind ViewModel.OutcomeLabel, Mode=OneWay}"/>
                            </TextBlock>
                        </Border>
                        <Border Background="{StaticResource SurfaceInsetBrush}"
                                BorderBrush="{StaticResource SubtleBorderBrush}"
                                BorderThickness="1" CornerRadius="2" Padding="8,4">
                            <TextBlock FontSize="{Binding Meta, Source={StaticResource FontSizes}}" FontWeight="SemiBold"
                                       Foreground="{StaticResource PrimaryTextBrush}">
                                <Run Text="{x:Bind ViewModel.Bookmarks.Count, Mode=OneWay}"/>
                                <Run Text=" notes"/>
                            </TextBlock>
                        </Border>
                    </StackPanel>
                </Grid>
            </Grid>

            <!-- ••• MAIN 2-COL LAYOUT ••• -->
            <!-- v2.16: bookmark/clip sidebar gets a hard MinWidth so the tag
                 picker + quality chips never clip at smaller window widths. -->
            <Grid x:Name="VodMainLayout" Grid.Row="1" ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="VideoColumnDefinition" Width="2.4*"/>
                    <ColumnDefinition x:Name="SidebarColumnDefinition" Width="*" MinWidth="380"/>
                </Grid.ColumnDefinitions>

                <!-- â”€â”€ LEFT: Video + Controls + Clip â”€â”€ -->
                <ScrollViewer x:Name="VideoColumnScrollViewer"
                              Grid.Column="0"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="VideoColumnStack" Spacing="12" Padding="0,0,0,40">

                        <!-- Video container -->
                        <Border x:Name="VideoBorder"
                                Background="{StaticResource SurfaceInsetBrush}"
                                BorderBrush="{StaticResource SubtleBorderBrush}"
                                BorderThickness="1" CornerRadius="2" Padding="6"
                                PointerEntered="OnVideoBorderPointerEntered"
                                PointerExited="OnVideoBorderPointerExited">
                            <Grid x:Name="VideoContainer"
                                  AllowFocusOnInteraction="True"
                                  Background="#020405"
                                  IsTabStop="True"
                                  MinHeight="420"
                                  Tapped="OnVideoTapped">
                                <Grid x:Name="LoadingOverlay"
                                      Background="{StaticResource PanelOverlayBrush}"
                                      Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="10">
                                        <ProgressRing IsActive="True" Width="40" Height="40"/>
                                        <TextBlock Text="Loading recording" FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                                   HorizontalAlignment="Center"
                                                   Foreground="{StaticResource SecondaryTextBrush}"/>
                                    </StackPanel>
                                </Grid>

                                <Border x:Name="NoVodBorder"
                                        HorizontalAlignment="Center" VerticalAlignment="Center"
                                        Background="{StaticResource SurfaceRaisedBrush}"
                                        BorderBrush="{StaticResource SubtleBorderBrush}"
                                        BorderThickness="1" CornerRadius="2" Padding="22,18"
                                        MaxWidth="420"
                                        Visibility="Collapsed">
                                    <StackPanel Spacing="10" HorizontalAlignment="Center">
                                        <TextBlock x:Name="NoVodText"
                                                   Text="{x:Bind ViewModel.VodAvailabilityText, Mode=OneWay}"
                                                   FontSize="{Binding Title, Source={StaticResource FontSizes}}"
                                                   TextWrapping="Wrap"
                                                   HorizontalAlignment="Center"
                                                   Foreground="{StaticResource SecondaryTextBrush}"/>
                                        <TextBlock Text="Ascent may still be encoding the recording, or the file lives outside your configured folder. If saved clips exist, use Play on a clip card."
                                                   FontFamily="{StaticResource BodyFont}"
                                                   FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                                   TextWrapping="Wrap"
                                                   HorizontalAlignment="Center"
                                                   TextAlignment="Center"
                                                   Foreground="{StaticResource MutedTextBrush}"/>
                                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                            <Button x:Name="RetryVodLinkButton"
                                                    Content="Try linking again"
                                                    Click="OnRetryVodLinkClick"
                                                    Style="{StaticResource PrimaryActionButtonStyle}"
                                                    FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                                    Height="32" Padding="14,0" CornerRadius="2"/>
                                            <Button Content="Open Settings"
                                                    Click="OnOpenSettingsFromNoVodClick"
                                                    Style="{StaticResource QuietActionButtonStyle}"
                                                    FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                                    Height="32" Padding="14,0" CornerRadius="2"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <Button x:Name="VideoPlayPauseButton"
                                        Click="OnVideoPlayPauseClick"
                                        HorizontalAlignment="Center" VerticalAlignment="Bottom"
                                        Margin="0,0,0,24"
                                        Width="64" Height="52" Padding="0" CornerRadius="2"
                                        Background="#CC000000"
                                        BorderBrush="{StaticResource BrightBorderBrush}"
                                        BorderThickness="1"
                                        Foreground="{StaticResource PrimaryTextBrush}"
                                        IsTabStop="False" AllowFocusOnInteraction="False"
                                        Visibility="{x:Bind ViewModel.HasVod, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                                    <FontIcon x:Name="VideoPlayPauseIcon" Glyph="&#xE768;" FontSize="{Binding TitleLarge, Source={StaticResource FontSizes}}"
                                              FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"/>
                                </Button>

                                <!-- v2.17.7: fullscreen timeline overlay shrinks to a slim
                                     dot-marker strip while playing so it doesn't obscure the
                                     video, and expands back to the full 80px event timeline
                                     on pause. Driven from VM IsPlaying via code-behind. -->
                                <Border x:Name="FullscreenTimelineOverlay"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Bottom"
                                        Margin="18"
                                        Padding="10,8"
                                        Background="#D006050C"
                                        BorderBrush="{StaticResource BrightBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="2"
                                        Visibility="Collapsed">
                                    <controls:TimelineControl x:Name="FullscreenTimeline"
                                                              Height="80"
                                                              Bookmarks="{x:Bind ViewModel.Bookmarks, Mode=OneWay}"
                                                              ClipEnd="{x:Bind ViewModel.ClipEndS, Mode=OneWay}"
                                                              ClipStart="{x:Bind ViewModel.ClipStartS, Mode=OneWay}"
                                                              DerivedEvents="{x:Bind ViewModel.DerivedEvents, Mode=OneWay}"
                                                              Duration="{x:Bind ViewModel.GameDurationS, Mode=OneWay}"
                                                              Events="{x:Bind ViewModel.GameEvents, Mode=OneWay}"
                                                              Position="{x:Bind ViewModel.CurrentTimeS, Mode=OneWay}"/>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- Transport bar -->
                        <Border x:Name="TransportBar"
                                Background="{StaticResource SurfaceInsetBrush}"
                                BorderBrush="{StaticResource SubtleBorderBrush}"
                                BorderThickness="1" CornerRadius="2" Padding="12,8">
                            <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,*,Auto,Auto,Auto,Auto,Auto"
                                  ColumnSpacing="8">
                                <Button Grid.Column="0"
                                        Command="{x:Bind ViewModel.SeekBackwardCommand}"
                                        Click="OnClipButtonClick"
                                        Style="{StaticResource GhostIconButtonStyle}"
                                        Width="40" Height="38" IsTabStop="False" AllowFocusOnInteraction="False">
                                    <FontIcon Glyph="&#xEB9E;" FontSize="{Binding Title, Source={StaticResource FontSizes}}"
                                              FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"/>
                                </Button>

                                <Button Grid.Column="1"
                                        Command="{x:Bind ViewModel.PlayPauseCommand}"
                                        Click="OnClipButtonClick"
                                        Style="{StaticResource PrimaryActionButtonStyle}"
                                        Width="56" Padding="0" IsTabStop="False" AllowFocusOnInteraction="False">
                                    <FontIcon x:Name="PlayPauseIcon" Glyph="&#xE768;" FontSize="{Binding TitleLarge, Source={StaticResource FontSizes}}"
                                              FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"/>
                                </Button>

                                <Button Grid.Column="2"
                                        Command="{x:Bind ViewModel.SeekForwardCommand}"
                                        Click="OnClipButtonClick"
                                        Style="{StaticResource GhostIconButtonStyle}"
                                        Width="40" Height="38" IsTabStop="False" AllowFocusOnInteraction="False">
                                    <FontIcon Glyph="&#xEB9D;" FontSize="{Binding Title, Source={StaticResource FontSizes}}"
                                              FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"/>
                                </Button>

                                <TextBlock Grid.Column="3"
                                           FontFamily="{StaticResource MonoFont}"
                                           FontSize="{Binding Meta, Source={StaticResource FontSizes}}" VerticalAlignment="Center"
                                           Foreground="{StaticResource SecondaryTextBrush}">
                                    <Run Text="{x:Bind ViewModel.CurrentTimeText, Mode=OneWay}"/>
                                    <Run Text=" / "/>
                                    <Run Text="{x:Bind ViewModel.TotalTimeText, Mode=OneWay}"/>
                                    <Run Text="    "/>
                                    <!-- v2.15.8: persistent seek-step indicator. Up/Down arrows
                                         change the step; Left/Right scrubs by it. Showing it
                                         inline beats a transient toast that's easy to miss. -->
                                    <Run Text="step "
                                         Foreground="{StaticResource MutedTextBrush}"/>
                                    <Run Text="{x:Bind ViewModel.SeekStepText, Mode=OneWay}"
                                         Foreground="{StaticResource AccentPurpleBrush}"
                                         FontWeight="SemiBold"/>
                                </TextBlock>

                                <!-- Spacer -->
                                <Border Grid.Column="4"/>

                                <TextBlock Grid.Column="5" Text="Speed" FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource SecondaryTextBrush}"/>

                                <ComboBox x:Name="SpeedCombo" Grid.Column="6"
                                          Width="80" SelectedIndex="2"
                                          SelectionChanged="OnSpeedChanged"
                                          Background="{StaticResource InputBackgroundBrush}"
                                          BorderBrush="{StaticResource SubtleBorderBrush}"
                                          Foreground="{StaticResource PrimaryTextBrush}"
                                          FontSize="{Binding Meta, Source={StaticResource FontSizes}}" CornerRadius="2"
                                          IsTabStop="False">
                                    <ComboBoxItem Content="0.25x" Tag="0.25"/>
                                    <ComboBoxItem Content="0.5x" Tag="0.5"/>
                                    <ComboBoxItem Content="1.0x" Tag="1.0"/>
                                    <ComboBoxItem Content="1.5x" Tag="1.5"/>
                                    <ComboBoxItem Content="2.0x" Tag="2.0"/>
                                </ComboBox>

                                <Button Grid.Column="7" x:Name="MuteButton"
                                        Click="OnMuteClick"
                                        Style="{StaticResource GhostIconButtonStyle}"
                                        Width="38" Height="38" IsTabStop="False" AllowFocusOnInteraction="False">
                                    <FontIcon x:Name="VolumeIcon" Glyph="&#xE767;" FontSize="{Binding Subtitle, Source={StaticResource FontSizes}}"
                                              FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"/>
                                </Button>

                                <Slider Grid.Column="8" x:Name="VolumeSlider"
                                        Width="80" Minimum="0" Maximum="100" Value="100"
                                        Foreground="{StaticResource AccentBlueBrush}"
                                        VerticalAlignment="Center"
                                        ValueChanged="OnVolumeChanged"/>

                                <Button Grid.Column="9" x:Name="FullscreenButton"
                                        Click="OnFullscreenClick"
                                        Style="{StaticResource GhostIconButtonStyle}"
                                        Width="38" Height="38" IsTabStop="False" AllowFocusOnInteraction="False">
                                    <FontIcon x:Name="FullscreenIcon" Glyph="&#xE740;" FontSize="{Binding Subtitle, Source={StaticResource FontSizes}}"
                                              FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"/>
                                </Button>
                            </Grid>
                        </Border>

                        <!-- Timeline -->
                        <Border x:Name="TimelineBar"
                                Background="{StaticResource SurfaceInsetBrush}"
                                BorderBrush="{StaticResource SubtleBorderBrush}"
                                BorderThickness="1" CornerRadius="2" Padding="10">
                            <Grid>
                                <controls:TimelineControl x:Name="Timeline"
                                                          Height="80"
                                                          Bookmarks="{x:Bind ViewModel.Bookmarks, Mode=OneWay}"
                                                          ClipEnd="{x:Bind ViewModel.ClipEndS, Mode=OneWay}"
                                                          ClipStart="{x:Bind ViewModel.ClipStartS, Mode=OneWay}"
                                                          DerivedEvents="{x:Bind ViewModel.DerivedEvents, Mode=OneWay}"
                                                          Duration="{x:Bind ViewModel.GameDurationS, Mode=OneWay}"
                                                          Events="{x:Bind ViewModel.GameEvents, Mode=OneWay}"
                                                          Position="{x:Bind ViewModel.CurrentTimeS, Mode=OneWay}"/>
                                <TextBlock Text="No timeline events — Revu must be running during the game to capture kills, deaths, and objectives."
                                           Visibility="{x:Bind ViewModel.ShowNoEventsHint, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"
                                           FontFamily="{StaticResource MonoFont}"
                                           FontSize="{Binding Caption, Source={StaticResource FontSizes}}"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Bottom"
                                           Margin="0,0,0,4"
                                           TextWrapping="Wrap"/>
                            </Grid>
                        </Border>

                        <Grid x:Name="TimelineActionGrid"
                              ColumnDefinitions="1*,1.25*"
                              ColumnSpacing="12">
                            <!-- Quick Bookmark -->
                            <controls:CornerBracketedCard Grid.Column="0"
                                                          CardBackground="{StaticResource FocusPanelBrush}">
                                <StackPanel Spacing="10">
                                    <controls:SectionTitle Text="QUICK BOOKMARK"/>

                                    <TextBox x:Name="BookmarkNoteBox"
                                             KeyDown="OnQuickBookmarkKeyDown"
                                             PlaceholderText="Note..."
                                             Style="{StaticResource VodInputTextBoxStyle}"
                                             FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                             Text="{x:Bind ViewModel.BookmarkNote, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                                    <!-- v2.15.7: ObjectivePicker (custom TextBox+Popup+ListView). Replaces
                                             AutoSuggestBox because its flyout had a two-click-to-select + hover
                                             confusion bug. Single-click commits immediately. -->
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
                                        <controls:ObjectivePicker x:Name="NewBookmarkObjectivePicker"
                                                                  Grid.Column="0"
                                                                  Source="{x:Bind ViewModel.TagOptions, Mode=OneWay}"
                                                                  PlaceholderText="Tag an objective or prompt..."
                                                                  TagChosen="OnNewBookmarkTagChosen"
                                                                  HorizontalAlignment="Stretch"/>

                                        <Button Grid.Column="1"
                                                Command="{x:Bind ViewModel.AddBookmarkCommand}"
                                                Click="OnClipButtonClick"
                                                Style="{StaticResource PrimaryActionButtonStyle}"
                                                Height="34" Padding="14,0" FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                                IsTabStop="False" AllowFocusOnInteraction="False"
                                                Content="Add"/>
                                    </Grid>
                                </StackPanel>
                            </controls:CornerBracketedCard>

                            <!-- Clip Extraction -->
                            <controls:CornerBracketedCard Grid.Column="1">
                                <StackPanel Spacing="10">
                                    <controls:SectionTitle Text="CLIP"/>

                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <!-- v2.15.10: surface the I / O keyboard shortcuts as
                                             keycap chips next to the buttons. Users were
                                             bouncing between bookmark + clip because the
                                             in/out trigger wasn't discoverable. -->
                                        <Button Command="{x:Bind ViewModel.SetClipInCommand}"
                                                Click="OnClipButtonClick"
                                                Style="{StaticResource SecondaryActionButtonStyle}"
                                                Height="30" Padding="10,0" FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                                IsTabStop="False" AllowFocusOnInteraction="False">
                                            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                                <TextBlock Text="Start" VerticalAlignment="Center"/>
                                                <Border Background="{StaticResource AccentGoldBrush}"
                                                        CornerRadius="2" Padding="6,1"
                                                        VerticalAlignment="Center">
                                                    <!-- v2.15.10: serif/mono I and O are nearly indistinguishable
                                                         (Orbitron's I has no serifs, looks like a vertical line that
                                                         reads as | or 1). Switch to Segoe UI sans-serif so the cap
                                                         letterforms are unambiguous keycaps. -->
                                                    <TextBlock Text="I"
                                                               FontFamily="Segoe UI"
                                                               FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                                               FontWeight="Bold"
                                                               Foreground="{StaticResource ActionPrimaryForegroundBrush}"/>
                                                </Border>
                                            </StackPanel>
                                        </Button>
                                        <TextBlock FontFamily="{StaticResource MonoFont}"
                                                   FontSize="{Binding Meta, Source={StaticResource FontSizes}}" VerticalAlignment="Center"
                                                   Foreground="{StaticResource AccentGoldBrush}">
                                            <Run Text="{x:Bind ViewModel.ClipRangeText, Mode=OneWay}"/>
                                        </TextBlock>
                                        <Button Command="{x:Bind ViewModel.SetClipOutCommand}"
                                                Click="OnClipButtonClick"
                                                Style="{StaticResource SecondaryActionButtonStyle}"
                                                Height="30" Padding="10,0" FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                                IsTabStop="False" AllowFocusOnInteraction="False">
                                            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                                <TextBlock Text="End" VerticalAlignment="Center"/>
                                                <Border Background="{StaticResource AccentGoldBrush}"
                                                        CornerRadius="2" Padding="6,1"
                                                        VerticalAlignment="Center">
                                                    <TextBlock Text="O"
                                                               FontFamily="Segoe UI"
                                                               FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                                               FontWeight="Bold"
                                                               Foreground="{StaticResource ActionPrimaryForegroundBrush}"/>
                                                </Border>
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>

                                    <TextBox x:Name="ClipNoteBox"
                                             KeyDown="OnQuickClipKeyDown"
                                             PlaceholderText="What's happening?"
                                             Style="{StaticResource VodInputTextBoxStyle}"
                                             FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                             Text="{x:Bind ViewModel.ClipNote, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <Button Command="{x:Bind ViewModel.SetClipQualityCommand}"
                                                CommandParameter="good"
                                                IsTabStop="False" AllowFocusOnInteraction="False"
                                                Background="Transparent" BorderThickness="0" Padding="0" MinWidth="0">
                                            <Border CornerRadius="2" Padding="8,4"
                                                    Background="{x:Bind ViewModel.GoodClipBackgroundBrush, Mode=OneWay}"
                                                    BorderBrush="{x:Bind ViewModel.GoodClipBorderBrush, Mode=OneWay}"
                                                    BorderThickness="{x:Bind ViewModel.GoodClipBorderThickness, Mode=OneWay}">
                                                <TextBlock Text="Good" FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                                           Foreground="{x:Bind ViewModel.GoodClipForegroundBrush, Mode=OneWay}"/>
                                            </Border>
                                        </Button>
                                        <Button Command="{x:Bind ViewModel.SetClipQualityCommand}"
                                                CommandParameter="neutral"
                                                IsTabStop="False" AllowFocusOnInteraction="False"
                                                Background="Transparent" BorderThickness="0" Padding="0" MinWidth="0">
                                            <Border CornerRadius="2" Padding="8,4"
                                                    Background="{x:Bind ViewModel.NeutralClipBackgroundBrush, Mode=OneWay}"
                                                    BorderBrush="{x:Bind ViewModel.NeutralClipBorderBrush, Mode=OneWay}"
                                                    BorderThickness="{x:Bind ViewModel.NeutralClipBorderThickness, Mode=OneWay}">
                                                <TextBlock Text="Neutral" FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                                           Foreground="{x:Bind ViewModel.NeutralClipForegroundBrush, Mode=OneWay}"/>
                                            </Border>
                                        </Button>
                                        <Button Command="{x:Bind ViewModel.SetClipQualityCommand}"
                                                CommandParameter="bad"
                                                IsTabStop="False" AllowFocusOnInteraction="False"
                                                Background="Transparent" BorderThickness="0" Padding="0" MinWidth="0">
                                            <Border CornerRadius="2" Padding="8,4"
                                                    Background="{x:Bind ViewModel.BadClipBackgroundBrush, Mode=OneWay}"
                                                    BorderBrush="{x:Bind ViewModel.BadClipBorderBrush, Mode=OneWay}"
                                                    BorderThickness="{x:Bind ViewModel.BadClipBorderThickness, Mode=OneWay}">
                                                <TextBlock Text="Bad" FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                                           Foreground="{x:Bind ViewModel.BadClipForegroundBrush, Mode=OneWay}"/>
                                            </Border>
                                        </Button>
                                    </StackPanel>

                                    <controls:ObjectivePicker x:Name="NewClipObjectivePicker"
                                                              Source="{x:Bind ViewModel.TagOptions, Mode=OneWay}"
                                                              PlaceholderText="Tag an objective or prompt..."
                                                              TagChosen="OnNewBookmarkTagChosen"
                                                              HorizontalAlignment="Stretch"/>

                                    <Button Command="{x:Bind ViewModel.ExtractClipCommand}"
                                            Click="OnClipButtonClick"
                                            IsEnabled="{x:Bind ViewModel.HasClipRange, Mode=OneWay}"
                                            Style="{StaticResource GoldActionButtonStyle}"
                                            Height="32" Padding="12,0" FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                            HorizontalAlignment="Stretch"
                                            IsTabStop="False" AllowFocusOnInteraction="False">
                                        <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                                            <FontIcon Glyph="&#xE7C3;" FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                                      FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"/>
                                            <TextBlock Text="Save Clip"/>
                                        </StackPanel>
                                    </Button>

                                    <TextBlock x:Name="FfmpegWarning"
                                               Text="ffmpeg not found — install ffmpeg for clip saves."
                                               FontSize="{Binding Meta, Source={StaticResource FontSizes}}" TextWrapping="Wrap" Visibility="Collapsed"
                                               Foreground="{StaticResource LossRedBrush}"/>

                                    <!-- Inline login-to-share prompt. Appears when the user clicks
                                         Share on a clip while logged out; reuses the magic-link
                                         email->OTP flow, then uploads the pending clip. -->
                                    <StackPanel x:Name="ShareLoginPanel"
                                                Spacing="6" Margin="0,4,0,0"
                                                Visibility="{x:Bind ViewModel.ShareLoginVisible, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                                        <TextBlock Text="LOG IN TO SHARE"
                                                   FontFamily="{StaticResource MonoFont}"
                                                   FontSize="{Binding Caption, Source={StaticResource FontSizes}}"
                                                   Foreground="{StaticResource SecondaryTextBrush}"/>
                                        <TextBlock Text="{x:Bind ViewModel.ShareStatusText, Mode=OneWay}"
                                                   FontFamily="{StaticResource MonoFont}"
                                                   FontSize="{Binding Caption, Source={StaticResource FontSizes}}"
                                                   Foreground="{StaticResource MutedTextBrush}"
                                                   TextWrapping="Wrap"/>

                                        <!-- Step 1: email -->
                                        <StackPanel Spacing="6"
                                                    Visibility="{x:Bind ViewModel.ShareAwaitingOtp, Mode=OneWay, Converter={StaticResource InverseBoolToVisibility}}">
                                            <TextBox Style="{StaticResource VodInputTextBoxStyle}"
                                                     PlaceholderText="you@email.com"
                                                     Text="{x:Bind ViewModel.ShareEmail, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <Button Command="{x:Bind ViewModel.SendShareOtpCommand}"
                                                        IsEnabled="{x:Bind ViewModel.ShareBusy, Mode=OneWay, Converter={StaticResource InverseBool}}"
                                                        Style="{StaticResource GoldActionButtonStyle}"
                                                        Height="30" Padding="12,0"
                                                        FontSize="{Binding Meta, Source={StaticResource FontSizes}}">
                                                    <TextBlock Text="Send code"/>
                                                </Button>
                                                <Button Command="{x:Bind ViewModel.CancelShareLoginCommand}"
                                                        Style="{StaticResource QuietActionButtonStyle}"
                                                        Height="30" Padding="12,0"
                                                        FontSize="{Binding Meta, Source={StaticResource FontSizes}}">
                                                    <TextBlock Text="Cancel"/>
                                                </Button>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- Step 2: OTP -->
                                        <StackPanel Spacing="6"
                                                    Visibility="{x:Bind ViewModel.ShareAwaitingOtp, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                                            <TextBox Style="{StaticResource VodInputTextBoxStyle}"
                                                     PlaceholderText="Paste code"
                                                     Text="{x:Bind ViewModel.ShareOtp, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <Button Command="{x:Bind ViewModel.VerifyShareOtpCommand}"
                                                        IsEnabled="{x:Bind ViewModel.ShareBusy, Mode=OneWay, Converter={StaticResource InverseBool}}"
                                                        Style="{StaticResource GoldActionButtonStyle}"
                                                        Height="30" Padding="12,0"
                                                        FontSize="{Binding Meta, Source={StaticResource FontSizes}}">
                                                    <TextBlock Text="Verify &amp; share"/>
                                                </Button>
                                                <Button Command="{x:Bind ViewModel.CancelShareLoginCommand}"
                                                        Style="{StaticResource QuietActionButtonStyle}"
                                                        Height="30" Padding="12,0"
                                                        FontSize="{Binding Meta, Source={StaticResource FontSizes}}">
                                                    <TextBlock Text="Cancel"/>
                                                </Button>
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </controls:CornerBracketedCard>
                        </Grid>

                    </StackPanel>
                </ScrollViewer>

                <!-- â”€â”€ RIGHT: Bookmark Sidebar â”€â”€ -->
                <!-- v2.17.17: the right column is a fixed Grid, NOT an outer
                     ScrollViewer. The Moments-to-Review ListView is the only
                     vertical scroller on this side, so the mouse wheel reaches
                     it directly (no parent ScrollViewer to fight) and ListView
                     virtualization gets a bounded height from the * row. The
                     MOMENTS card takes the * row and flexes; the hint and SAVED
                     LIBRARY claim their natural Auto heights below it. -->
                <Grid x:Name="BookmarkSidebar"
                      Grid.Column="1"
                      RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <controls:CornerBracketedCard Grid.Row="0"
                        CardBackground="{StaticResource QueuePanelBrush}">
                        <Grid RowDefinitions="Auto,Auto,Auto,*" RowSpacing="10">
                            <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                                <StackPanel Spacing="2">
                                    <controls:SectionTitle Text="MOMENTS TO REVIEW"/>
                                    <TextBlock Text="Auto-picked moments, saved clips, and bookmarks."
                                               FontFamily="{StaticResource MonoFont}"
                                               FontSize="{Binding Caption, Source={StaticResource FontSizes}}"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                                <Border Grid.Column="1"
                                        Background="{StaticResource SurfaceInsetBrush}"
                                        BorderBrush="{StaticResource BrightBorderBrush}"
                                        BorderThickness="1" CornerRadius="2" Padding="8,4"
                                        VerticalAlignment="Top">
                                    <TextBlock FontSize="{Binding Meta, Source={StaticResource FontSizes}}" FontWeight="SemiBold"
                                               Foreground="{StaticResource PrimaryTextBrush}">
                                        <Run Text="{x:Bind ViewModel.EvidenceInbox.Count, Mode=OneWay}"/>
                                        <Run Text=" open"/>
                                    </TextBlock>
                                </Border>
                            </Grid>

                            <!-- 3-way filter: Auto · Clips · Bookmarks — underline tab style -->
                            <Grid Grid.Row="1" ColumnDefinitions="*,*,*">
                                <!-- Auto tab -->
                                <Button Grid.Column="0"
                                        Command="{x:Bind ViewModel.SetReviewMomentFilterCommand}"
                                        CommandParameter="auto"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Padding="0"
                                        MinWidth="0"
                                        HorizontalAlignment="Stretch"
                                        IsTabStop="False"
                                        AllowFocusOnInteraction="False">
                                    <StackPanel Spacing="0" HorizontalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Spacing="4"
                                                    Padding="4,8,4,6" HorizontalAlignment="Center">
                                            <TextBlock FontFamily="{StaticResource HeadingFont}"
                                                       FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                                       FontWeight="SemiBold"
                                                       Foreground="{x:Bind ViewModel.AutoTabForegroundBrush, Mode=OneWay}">
                                                <Run Text="Auto"/>
                                            </TextBlock>
                                            <TextBlock FontFamily="{StaticResource MonoFont}"
                                                       FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                                       Foreground="{x:Bind ViewModel.AutoTabForegroundBrush, Mode=OneWay}"
                                                       Opacity="0.65">
                                                <Run Text="("/>
                                                <Run Text="{x:Bind ViewModel.AutoReviewMomentCount, Mode=OneWay}"/>
                                                <Run Text=")"/>
                                            </TextBlock>
                                        </StackPanel>
                                        <Border Height="2" HorizontalAlignment="Stretch" CornerRadius="1"
                                                Background="{StaticResource AccentBlueBrush}"
                                                Visibility="{x:Bind ViewModel.IsAutoReviewMomentFilterSelected, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"/>
                                    </StackPanel>
                                </Button>

                                <!-- Clips tab -->
                                <Button Grid.Column="1"
                                        Command="{x:Bind ViewModel.SetReviewMomentFilterCommand}"
                                        CommandParameter="saved"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Padding="0"
                                        MinWidth="0"
                                        HorizontalAlignment="Stretch"
                                        IsTabStop="False"
                                        AllowFocusOnInteraction="False">
                                    <StackPanel Spacing="0" HorizontalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Spacing="4"
                                                    Padding="4,8,4,6" HorizontalAlignment="Center">
                                            <TextBlock FontFamily="{StaticResource HeadingFont}"
                                                       FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                                       FontWeight="SemiBold"
                                                       Foreground="{x:Bind ViewModel.SavedTabForegroundBrush, Mode=OneWay}">
                                                <Run Text="Clips"/>
                                            </TextBlock>
                                            <TextBlock FontFamily="{StaticResource MonoFont}"
                                                       FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                                       Foreground="{x:Bind ViewModel.SavedTabForegroundBrush, Mode=OneWay}"
                                                       Opacity="0.65">
                                                <Run Text="("/>
                                                <Run Text="{x:Bind ViewModel.SavedClipReviewMomentCount, Mode=OneWay}"/>
                                                <Run Text=")"/>
                                            </TextBlock>
                                        </StackPanel>
                                        <Border Height="2" HorizontalAlignment="Stretch" CornerRadius="1"
                                                Background="{StaticResource AccentGoldBrush}"
                                                Visibility="{x:Bind ViewModel.IsSavedReviewMomentFilterSelected, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"/>
                                    </StackPanel>
                                </Button>

                                <!-- Bookmarks tab -->
                                <Button Grid.Column="2"
                                        Command="{x:Bind ViewModel.SetReviewMomentFilterCommand}"
                                        CommandParameter="bookmarks"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Padding="0"
                                        MinWidth="0"
                                        HorizontalAlignment="Stretch"
                                        IsTabStop="False"
                                        AllowFocusOnInteraction="False">
                                    <StackPanel Spacing="0" HorizontalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Spacing="4"
                                                    Padding="4,8,4,6" HorizontalAlignment="Center">
                                            <TextBlock FontFamily="{StaticResource HeadingFont}"
                                                       FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                                       FontWeight="SemiBold"
                                                       Foreground="{x:Bind ViewModel.BookmarkTabForegroundBrush, Mode=OneWay}">
                                                <Run Text="Bookmarks"/>
                                            </TextBlock>
                                            <TextBlock FontFamily="{StaticResource MonoFont}"
                                                       FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                                       Foreground="{x:Bind ViewModel.BookmarkTabForegroundBrush, Mode=OneWay}"
                                                       Opacity="0.65">
                                                <Run Text="("/>
                                                <Run Text="{x:Bind ViewModel.BookmarkReviewMomentCount, Mode=OneWay}"/>
                                                <Run Text=")"/>
                                            </TextBlock>
                                        </StackPanel>
                                        <Border Height="2" HorizontalAlignment="Stretch" CornerRadius="1"
                                                Background="{StaticResource AccentTealBrush}"
                                                Visibility="{x:Bind ViewModel.IsBookmarkReviewMomentFilterSelected, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"/>
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <!-- Empty-state / fallback banner (rows 2–3 share this slot) -->
                            <StackPanel Grid.Row="2" Spacing="6">
                                <!-- No-VOD fallback: shown on Clips tab when VOD is unavailable -->
                                <Border Background="{StaticResource SurfaceInsetBrush}"
                                        BorderBrush="{StaticResource AccentGoldBrush}"
                                        BorderThickness="1" CornerRadius="2" Padding="9,7"
                                        Visibility="{x:Bind ViewModel.ShowClipFallbackHint, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                                    <TextBlock Text="Full VOD unavailable. Play saved clips from this list."
                                               FontFamily="{StaticResource MonoFont}"
                                               FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                               Foreground="{StaticResource AccentGoldBrush}"
                                               TextWrapping="Wrap"/>
                                </Border>

                                <!-- Empty state for Auto/Clips tabs -->
                                <Border Background="{StaticResource SurfaceInsetBrush}"
                                        BorderBrush="{StaticResource SubtleBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="2"
                                        Padding="14,12"
                                        Visibility="{x:Bind ViewModel.ShowEmptyReviewMomentsState, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                                    <TextBlock Text="{x:Bind ViewModel.EmptyReviewMomentsText, Mode=OneWay}"
                                               FontFamily="{StaticResource MonoFont}"
                                               FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                               Foreground="{StaticResource SecondaryTextBrush}"
                                               TextWrapping="Wrap"/>
                                </Border>

                                <!-- Empty state for Bookmarks tab -->
                                <Border Background="{StaticResource SurfaceInsetBrush}"
                                        BorderBrush="{StaticResource SubtleBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="2"
                                        Padding="14,12"
                                        Visibility="{x:Bind ViewModel.IsBookmarkReviewMomentFilterSelected, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                                    <TextBlock Text="No plain bookmarks saved yet."
                                               FontFamily="{StaticResource MonoFont}"
                                               FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                               Foreground="{StaticResource SecondaryTextBrush}"
                                               TextWrapping="Wrap"
                                               Visibility="{x:Bind ViewModel.HasVisibleBookmarkItems, Mode=OneWay, Converter={StaticResource InverseBoolToVisibility}}"/>
                                </Border>
                            </StackPanel>

                            <!-- v2.17.17: no MaxHeight — the * grid row bounds this
                                 list, so the built-in ItemsStackPanel virtualizes
                                 against a real viewport and the wheel scrolls it
                                 directly. A MaxHeight here (with the old outer
                                 ScrollViewer) is what defeated virtualization and
                                 forced the manual wheel handler. -->
                            <ListView x:Name="TimelineInboxList"
                                      Grid.Row="3"
                                      ItemsSource="{x:Bind ViewModel.VisibleReviewMoments, Mode=OneWay}"
                                      SelectionMode="None"
                                      IsItemClickEnabled="False"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      Padding="0,0,8,0"
                                      Visibility="{x:Bind ViewModel.ShowReviewMomentsList, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                      ScrollViewer.IsHorizontalScrollChainingEnabled="False">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="Padding" Value="0,0,0,7"/>
                                        <Setter Property="Margin" Value="0"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="vm:EvidenceInboxItem">
                                            <Border Background="{StaticResource SurfaceInsetBrush}"
                                                    BorderBrush="{x:Bind StatusAccentBrush, Mode=OneWay}"
                                                    BorderThickness="1" CornerRadius="2" Padding="10,9">
                                                <StackPanel Spacing="7">
                                                    <!-- Header row: badges + title + action buttons -->
                                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                                        <StackPanel Grid.Column="0" Spacing="4">
                                                            <StackPanel Orientation="Horizontal" Spacing="5">
                                                                <Border Background="{x:Bind SourceSurfaceBrush, Mode=OneWay}"
                                                                        BorderBrush="{x:Bind SourceAccentBrush, Mode=OneWay}"
                                                                        BorderThickness="1" CornerRadius="2" Padding="6,2">
                                                                    <TextBlock Text="{x:Bind SourceLabel}"
                                                                               FontFamily="{StaticResource MonoFont}"
                                                                               FontSize="{Binding Caption, Source={StaticResource FontSizes}}"
                                                                               Foreground="{x:Bind SourceAccentBrush, Mode=OneWay}"/>
                                                                </Border>
                                                                <Border Background="{StaticResource CardBackgroundBrush}"
                                                                        BorderBrush="{StaticResource SubtleBorderBrush}"
                                                                        BorderThickness="1" CornerRadius="2" Padding="6,2">
                                                                    <TextBlock Text="{x:Bind TimeRangeText}"
                                                                               FontFamily="{StaticResource MonoFont}"
                                                                               FontSize="{Binding Caption, Source={StaticResource FontSizes}}"
                                                                               Foreground="{StaticResource SecondaryTextBrush}"/>
                                                                </Border>
                                                                <!-- Status badge: hidden for clips (redundant), shown for auto moments -->
                                                                <Border BorderBrush="{x:Bind StatusAccentBrush, Mode=OneWay}"
                                                                        Background="{StaticResource CardBackgroundBrush}"
                                                                        BorderThickness="1" CornerRadius="2" Padding="6,2"
                                                                        Visibility="{x:Bind IsSavedClip, Converter={StaticResource InverseBoolToVisibility}}">
                                                                    <TextBlock Text="{x:Bind StatusLabel, Mode=OneWay}"
                                                                               FontSize="{Binding Caption, Source={StaticResource FontSizes}}"
                                                                               Foreground="{x:Bind StatusAccentBrush, Mode=OneWay}"/>
                                                                </Border>
                                                                <!-- Polarity badge: auto moments only -->
                                                                <Border BorderBrush="{x:Bind PolarityAccentBrush, Mode=OneWay}"
                                                                        Background="{StaticResource CardBackgroundBrush}"
                                                                        BorderThickness="1" CornerRadius="2" Padding="6,2"
                                                                        Visibility="{x:Bind IsSavedClip, Converter={StaticResource InverseBoolToVisibility}}">
                                                                    <TextBlock Text="{x:Bind PolarityLabel, Mode=OneWay}"
                                                                               FontSize="{Binding Caption, Source={StaticResource FontSizes}}"
                                                                               Foreground="{x:Bind PolarityAccentBrush, Mode=OneWay}"/>
                                                                </Border>
                                                            </StackPanel>

                                                            <TextBlock Text="{x:Bind Title}"
                                                                       FontSize="{Binding BodyEmphasis, Source={StaticResource FontSizes}}"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{StaticResource PrimaryTextBrush}"
                                                                       TextWrapping="Wrap"/>
                                                        </StackPanel>

                                                        <!-- Right-side action buttons -->
                                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="2" VerticalAlignment="Top">
                                                            <!-- Share: clips only -->
                                                            <Button DataContext="{x:Bind}"
                                                                    Click="OnShareEvidenceClipClick"
                                                                    Style="{StaticResource GhostIconButtonStyle}"
                                                                    Width="30" Height="30" Padding="0"
                                                                    Visibility="{x:Bind IsSavedClip, Converter={StaticResource BoolToVisibility}}"
                                                                    ToolTipService.ToolTip="Share clip — copy public link">
                                                                <FontIcon Glyph="&#xE72D;"
                                                                          FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                                                          FontSize="{Binding Meta, Source={StaticResource FontSizes}}"/>
                                                            </Button>
                                                            <!-- Delete: clips only — hard red to signal destructive -->
                                                            <Button DataContext="{x:Bind}"
                                                                    Click="OnDeleteEvidenceClipClick"
                                                                    Style="{StaticResource GhostIconButtonStyle}"
                                                                    Width="30" Height="30" Padding="0"
                                                                    BorderBrush="{StaticResource LossRedBrush}"
                                                                    Visibility="{x:Bind IsSavedClip, Converter={StaticResource BoolToVisibility}}"
                                                                    ToolTipService.ToolTip="Delete clip permanently">
                                                                <FontIcon Glyph="&#xE74D;"
                                                                          FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                                                          FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                                                          Foreground="{StaticResource LossRedBrush}"/>
                                                            </Button>
                                                            <!-- Open / Play -->
                                                            <Button Style="{StaticResource GhostIconButtonStyle}"
                                                                    DataContext="{x:Bind}"
                                                                    Click="OnOpenEvidenceClick"
                                                                    Width="62" Height="30" Padding="0"
                                                                    ToolTipService.ToolTip="Open moment">
                                                                <StackPanel Orientation="Horizontal" Spacing="4">
                                                                    <FontIcon Glyph="&#xE768;"
                                                                              FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                                                              FontSize="{Binding Meta, Source={StaticResource FontSizes}}"/>
                                                                    <TextBlock Text="{x:Bind ReviewActionLabel}"
                                                                               FontSize="{Binding Caption, Source={StaticResource FontSizes}}"
                                                                               FontWeight="SemiBold"/>
                                                                </StackPanel>
                                                            </Button>
                                                        </StackPanel>
                                                    </Grid>

                                                    <!-- Objective tag picker — always visible (virtualization bounds cost to visible rows) -->
                                                    <controls:ObjectivePicker Source="{x:Bind TagOptions, Mode=OneWay}"
                                                                              Payload="{x:Bind}"
                                                                              SelectedTitle="{x:Bind ObjectiveTitleDisplay, Mode=OneWay}"
                                                                              PlaceholderText="Tag objective..."
                                                                              TagChosen="OnEvidenceTagChosen"
                                                                              HorizontalAlignment="Stretch"/>

                                                    <!-- Review note — always visible -->
                                                    <TextBox Text="{x:Bind Note, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                             DataContext="{x:Bind}"
                                                             Background="{StaticResource InputBackgroundBrush}"
                                                             BorderBrush="{StaticResource SubtleBorderBrush}"
                                                             BorderThickness="1" CornerRadius="2"
                                                             Foreground="{StaticResource PrimaryTextBrush}"
                                                             FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                                             Padding="8,5"
                                                             PlaceholderText="Review note"
                                                             TextWrapping="Wrap"
                                                             AcceptsReturn="True"
                                                             LostFocus="OnEvidenceNoteLostFocus"/>

                                                    <!-- Bottom action row -->
                                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                                        <!-- Auto-moment review actions: Good/Bad/Evidence/Highlight — shown for non-clip rows only -->
                                                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4"
                                                                    Visibility="{x:Bind IsSavedClip, Converter={StaticResource InverseBoolToVisibility}}">
                                                            <Button Content="Good" Tag="good" DataContext="{x:Bind}"
                                                                    Click="OnEvidencePolarityClick"
                                                                    Style="{StaticResource ListActionButtonStyle}"
                                                                    Height="28" Padding="8,0"/>
                                                            <Button Content="Bad" Tag="bad" DataContext="{x:Bind}"
                                                                    Click="OnEvidencePolarityClick"
                                                                    Style="{StaticResource ListActionButtonStyle}"
                                                                    Height="28" Padding="8,0"/>
                                                            <Button Content="Evidence" Tag="evidence" DataContext="{x:Bind}"
                                                                    Click="OnEvidenceStatusClick"
                                                                    Style="{StaticResource ListActionButtonStyle}"
                                                                    Height="28" Padding="8,0"/>
                                                            <Button Content="Highlight" Tag="highlight" DataContext="{x:Bind}"
                                                                    Click="OnEvidenceStatusClick"
                                                                    Style="{StaticResource ListActionButtonStyle}"
                                                                    Height="28" Padding="8,0"/>
                                                        </StackPanel>

                                                        <!-- Dismiss: quiet ghost button for both clips and auto moments -->
                                                        <Button Grid.Column="1"
                                                                Content="Dismiss" Tag="dismissed" DataContext="{x:Bind}"
                                                                Click="OnEvidenceStatusClick"
                                                                Style="{StaticResource QuietActionButtonStyle}"
                                                                Height="28" Padding="8,0"
                                                                HorizontalAlignment="Right"
                                                                ToolTipService.ToolTip="Hide from review (keeps the clip)"/>
                                                    </Grid>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>

                            <!-- Bookmarks tab: plain jump-only bookmarks (non-clip BookmarkItems) -->
                            <ListView x:Name="BookmarksTabList"
                                      Grid.Row="3"
                                      ItemsSource="{x:Bind ViewModel.VisibleBookmarkItems, Mode=OneWay}"
                                      SelectionMode="None"
                                      IsItemClickEnabled="False"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      Padding="0,0,8,0"
                                      Visibility="{x:Bind ViewModel.IsBookmarkReviewMomentFilterSelected, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                      ScrollViewer.IsHorizontalScrollChainingEnabled="False">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="Padding" Value="0,0,0,5"/>
                                        <Setter Property="Margin" Value="0"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="vm:BookmarkItem">
                                        <Border Background="{StaticResource SurfaceInsetBrush}"
                                                BorderBrush="{StaticResource SubtleBorderBrush}"
                                                BorderThickness="1" CornerRadius="2" Padding="8,7">
                                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                                                <Border Grid.Column="0"
                                                        Width="50"
                                                        Background="{x:Bind SurfaceBrush}"
                                                        BorderBrush="{x:Bind AccentBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="2"
                                                        Padding="5,4"
                                                        VerticalAlignment="Stretch">
                                                    <StackPanel Spacing="3" HorizontalAlignment="Center">
                                                        <TextBlock Text="{x:Bind TimeText}"
                                                                   FontFamily="{StaticResource MonoFont}"
                                                                   FontSize="{Binding Caption, Source={StaticResource FontSizes}}"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{x:Bind AccentBrush}"/>
                                                        <TextBlock Text="{x:Bind KindLabel}"
                                                                   FontSize="{Binding Caption, Source={StaticResource FontSizes}}"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{StaticResource MutedTextBrush}"/>
                                                    </StackPanel>
                                                </Border>

                                                <StackPanel Grid.Column="1" Spacing="3">
                                                    <TextBlock Text="{x:Bind LibraryTitle, Mode=OneWay}"
                                                               FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource PrimaryTextBrush}"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{x:Bind LibraryDetailText}"
                                                               FontFamily="{StaticResource MonoFont}"
                                                               FontSize="{Binding Caption, Source={StaticResource FontSizes}}"
                                                               Foreground="{StaticResource SecondaryTextBrush}"/>
                                                </StackPanel>

                                                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                                    <Button Click="OnBookmarkJumpClick"
                                                            Tag="{x:Bind}"
                                                            Style="{StaticResource GhostIconButtonStyle}"
                                                            Width="32" Height="30" Padding="0"
                                                            ToolTipService.ToolTip="Jump to this bookmark">
                                                        <FontIcon Glyph="&#xE768;"
                                                                  FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                                                  FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"/>
                                                    </Button>
                                                    <Button CommandParameter="{x:Bind Id}"
                                                            Click="OnDeleteBookmark"
                                                            Style="{StaticResource GhostIconButtonStyle}"
                                                            Width="32" Height="30" Padding="0"
                                                            BorderBrush="{StaticResource LossRedBrush}"
                                                            ToolTipService.ToolTip="Delete bookmark permanently">
                                                        <FontIcon Glyph="&#xE74D;"
                                                                  FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                                                  FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                                                  Foreground="{StaticResource LossRedBrush}"/>
                                                    </Button>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>

                        </Grid>
                    </controls:CornerBracketedCard>

                    <!-- v2.17.8: dismissible hint that explains the auto-clipping toggle.
                         Shown only when the inbox has items, auto-clipping is currently on,
                         and the user hasn't permanently hidden it. -->
                    <Border Grid.Row="1"
                            Background="{StaticResource SurfaceInsetBrush}"
                            BorderBrush="{StaticResource AccentBlueBrush}"
                            BorderThickness="1" CornerRadius="2" Padding="12,10"
                            Visibility="{x:Bind ViewModel.ShowAutoClippingHint, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                        <Grid ColumnSpacing="10" ColumnDefinitions="Auto,*,Auto">
                            <FontIcon Grid.Column="0"
                                      Glyph="&#xE946;"
                                      FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                      FontSize="{Binding Subtitle, Source={StaticResource FontSizes}}"
                                      VerticalAlignment="Top"
                                      Margin="0,2,0,0"
                                      Foreground="{StaticResource AccentBlueBrush}"/>

                            <StackPanel Grid.Column="1" Spacing="6">
                                <TextBlock Text="Revu auto-fills the Timeline Inbox from kills, deaths, and objectives. Don't want that? Turn it off in Settings."
                                           FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                           Foreground="{StaticResource PrimaryTextBrush}"
                                           TextWrapping="Wrap"/>
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Button Command="{x:Bind ViewModel.OpenAutoClippingSettingsCommand}"
                                            Style="{StaticResource SecondaryActionButtonStyle}"
                                            Height="28" Padding="10,0"
                                            FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                            Content="Open Settings"/>
                                    <Button Command="{x:Bind ViewModel.DismissAutoClippingHintCommand}"
                                            Style="{StaticResource QuietActionButtonStyle}"
                                            Height="28" Padding="10,0"
                                            FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                            Content="Hide this hint"/>
                                </StackPanel>
                            </StackPanel>

                            <Button Grid.Column="2"
                                    Command="{x:Bind ViewModel.DismissAutoClippingHintCommand}"
                                    Style="{StaticResource GhostIconButtonStyle}"
                                    Width="28" Height="28" Padding="0"
                                    VerticalAlignment="Top"
                                    ToolTipService.ToolTip="Hide this hint">
                                <FontIcon Glyph="&#xE711;"
                                          FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                          FontSize="{Binding Meta, Source={StaticResource FontSizes}}"/>
                            </Button>
                        </Grid>
                    </Border>

                </Grid>
            </Grid>
        </Grid>

    </Grid>
</Page>
