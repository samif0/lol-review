п»ї<Page
    x:Name="RootReviewPage"
    x:Class="Revu.App.Views.ReviewPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:svc="using:Revu.App.Services"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:Revu.App.ViewModels"
    xmlns:converters="using:Revu.App.Converters"
    xmlns:controls="using:Revu.App.Controls"
    mc:Ignorable="d"
    Background="Transparent">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <converters:InverseBoolConverter x:Key="InverseBoolConverter"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis"/>
    </Page.Resources>

    <Grid x:Name="RootGrid">
        <!-- Loading overlay -->
        <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                      HorizontalAlignment="Center" VerticalAlignment="Center"
                      Width="48" Height="48"
                      Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVis}}"/>

        <Grid RowDefinitions="Auto,*">

            <!-- Header: Back + Hero + Watch VOD -->
            <Grid Grid.Row="0" Padding="40,28,40,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Command="{x:Bind ViewModel.CancelCommand}"
                        Style="{StaticResource GhostIconButtonStyle}"
                        VerticalAlignment="Top"
                        Margin="0,16,12,0"
                        ToolTipService.ToolTip="Back">
                    <FontIcon Glyph="&#xE72B;" FontSize="{Binding BodyEmphasis, Source={StaticResource FontSizes}}"/>
                </Button>

                <controls:HeroHeader Grid.Column="1"
                                     EyebrowText="GAME ANALYSIS"
                                     Title="{x:Bind ViewModel.HeaderText, Mode=OneWay}"/>

                <StackPanel Grid.Column="2"
                            VerticalAlignment="Top"
                            HorizontalAlignment="Right"
                            Margin="16,14,0,0"
                            Spacing="4">
                    <Button Content="Export"
                            Command="{x:Bind ViewModel.ExportReviewCommand}"
                            IsEnabled="{x:Bind Not(ViewModel.IsExportingReview), Mode=OneWay}"
                            Style="{StaticResource SecondaryActionButtonStyle}"
                            Height="32"
                            Padding="14,0"
                            ToolTipService.ToolTip="Export this game's review"/>
                    <TextBlock Text="{x:Bind ViewModel.ExportStatusText, Mode=OneWay}"
                               FontFamily="{StaticResource MonoFont}"
                               FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               TextAlignment="Right"
                               MaxWidth="240"
                               TextWrapping="Wrap"
                               Visibility="{x:Bind HasText(ViewModel.ExportStatusText), Mode=OneWay}"/>
                </StackPanel>

            </Grid>

            <!-- Scrollable Content -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="24,8,24,24">
                <StackPanel Spacing="16" HorizontalAlignment="Stretch">

                    <!-- вЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђ
                         HERO CARD: Champion + Result + KDA + VOD
                         вЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђ -->
                    <Border Style="{StaticResource ElevatedCardStyle}"
                            BorderBrush="{StaticResource AccentGoldBrush}"
                            BorderThickness="1,1,1,2">
                        <StackPanel Spacing="14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Left: Champion + Result -->
                                <StackPanel Grid.Column="0" Spacing="2">
                                    <TextBlock Text="{x:Bind ViewModel.ChampionName, Mode=OneWay}"
                                               FontSize="{Binding HeroLarge, Source={StaticResource FontSizes}}" FontWeight="Bold"
                                               FontFamily="{StaticResource DisplayFont}"
                                               Foreground="{StaticResource AccentGoldBrush}"/>
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <TextBlock Text="{x:Bind ViewModel.ResultText, Mode=OneWay}"
                                                   FontSize="{Binding Title, Source={StaticResource FontSizes}}" FontWeight="Bold"/>
                                        <TextBlock FontSize="{Binding BodyEmphasis, Source={StaticResource FontSizes}}"
                                                   Foreground="{StaticResource SecondaryTextBrush}"
                                                   VerticalAlignment="Center">
                                            <Run Text="{x:Bind ViewModel.GameModeText, Mode=OneWay}"/>
                                        </TextBlock>
                                        <TextBlock Text="{x:Bind ViewModel.DurationText, Mode=OneWay}"
                                                   FontSize="{Binding BodyEmphasis, Source={StaticResource FontSizes}}"
                                                   Foreground="{StaticResource MutedTextBrush}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Right: KDA -->
                                <StackPanel Grid.Column="1" HorizontalAlignment="Right"
                                            VerticalAlignment="Center" Spacing="2">
                                    <TextBlock Text="{x:Bind ViewModel.KdaText, Mode=OneWay}"
                                               FontSize="{Binding Hero, Source={StaticResource FontSizes}}" FontWeight="Bold"
                                               FontFamily="{StaticResource DisplayFont}"
                                               Foreground="{StaticResource PrimaryTextBrush}"
                                               HorizontalAlignment="Right"/>
                                    <TextBlock Text="{x:Bind ViewModel.KdaRatioText, Mode=OneWay}"
                                               FontSize="{Binding BodyEmphasis, Source={StaticResource FontSizes}}"
                                               Foreground="{StaticResource SecondaryTextBrush}"
                                               HorizontalAlignment="Right"/>
                                </StackPanel>
                            </Grid>

                            <!-- VOD button (inside hero card) -->
                            <StackPanel Orientation="Horizontal" Spacing="12"
                                        Visibility="{x:Bind ViewModel.HasVod, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                                <Button Command="{x:Bind ViewModel.WatchVodCommand}"
                                        Style="{StaticResource GoldActionButtonStyle}"
                                        FontSize="{Binding BodyEmphasis, Source={StaticResource FontSizes}}" FontWeight="SemiBold"
                                        Height="36" Padding="16,0" CornerRadius="2"
                                        BorderThickness="1">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon Glyph="&#xE714;" FontSize="{Binding Subtitle, Source={StaticResource FontSizes}}"/>
                                        <TextBlock Text="Review VOD" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <TextBlock FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           VerticalAlignment="Center">
                                    <Run Text="{x:Bind ViewModel.BookmarkCount, Mode=OneWay}"/>
                                    <Run Text=" bookmarks"/>
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- вЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђ
                         GAME STATS
                         вЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђ -->
                    <!-- Zone divider marks the stats as read-only reference so
                         the eye separates them from the input sections below. -->
                    <Grid ColumnSpacing="10" Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="GAME STATS // AUTO-CAPTURED"
                                   FontFamily="{StaticResource MonoFont}"
                                   FontSize="{Binding Caption, Source={StaticResource FontSizes}}"
                                   CharacterSpacing="300"
                                   Foreground="{StaticResource MutedTextBrush}"/>
                        <Rectangle Grid.Column="1" Height="1"
                                   Fill="{StaticResource SubtleBorderBrush}"
                                   VerticalAlignment="Center"/>
                    </Grid>

                    <Grid ColumnSpacing="8" RowSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <controls:StatCard Grid.Row="0" Grid.Column="0"
                                           Label="DAMAGE" Value="{x:Bind ViewModel.DamageText, Mode=OneWay}"/>
                        <controls:StatCard Grid.Row="0" Grid.Column="1"
                                           Label="CS" Value="{x:Bind ViewModel.CsText, Mode=OneWay}"/>
                        <controls:StatCard Grid.Row="0" Grid.Column="2"
                                           Label="CS/MIN" Value="{x:Bind ViewModel.CsPerMinText, Mode=OneWay}"/>
                        <controls:StatCard Grid.Row="0" Grid.Column="3"
                                           Label="VISION" Value="{x:Bind ViewModel.VisionText, Mode=OneWay}"/>

                        <controls:StatCard Grid.Row="1" Grid.Column="0"
                                           Label="GOLD" Value="{x:Bind ViewModel.GoldText, Mode=OneWay}"/>
                        <controls:StatCard Grid.Row="1" Grid.Column="1"
                                           Label="KILL PART." Value="{x:Bind ViewModel.KillParticipationText, Mode=OneWay}"/>
                        <controls:StatCard Grid.Row="1" Grid.Column="2"
                                           Label="DMG TAKEN" Value="{x:Bind ViewModel.DamageTakenText, Mode=OneWay}"/>
                        <controls:StatCard Grid.Row="1" Grid.Column="3"
                                           Label="WARDS" Value="{x:Bind ViewModel.WardsPlacedText, Mode=OneWay}"/>
                    </Grid>

                    <!-- v2.18: laning-at-10 + rank benchmark context вЂ” the stat
                         cards above read against ground truth, not a vacuum. -->
                    <StackPanel Spacing="3">
                        <TextBlock Text="{x:Bind ViewModel.LaningAt10Line, Mode=OneWay}"
                                   FontFamily="{StaticResource MonoFont}"
                                   FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                   CharacterSpacing="150"
                                   Foreground="{StaticResource AccentBlueBrush}"
                                   Visibility="{x:Bind ViewModel.HasLaningAt10, Mode=OneWay, Converter={StaticResource BoolToVis}}"/>
                        <TextBlock Text="{x:Bind ViewModel.BenchmarkRankLine, Mode=OneWay}"
                                   FontFamily="{StaticResource MonoFont}"
                                   FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                   CharacterSpacing="150"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   Visibility="{x:Bind ViewModel.HasBenchmarks, Mode=OneWay, Converter={StaticResource BoolToVis}}"/>
                        <TextBlock Text="{x:Bind ViewModel.BenchmarkNextLine, Mode=OneWay}"
                                   FontFamily="{StaticResource MonoFont}"
                                   FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                   CharacterSpacing="150"
                                   Foreground="{StaticResource AccentGoldBrush}"
                                   Visibility="{x:Bind ViewModel.HasBenchmarks, Mode=OneWay, Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>

                    <!-- вЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђ
                         OBJECTIVE PRACTICE (moved up, after stats)
                         вЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђ -->
                    <!-- "YOUR REVIEW" divider is the page's visual entry point вЂ”
                         everything below it asks for input. -->
                    <Grid ColumnSpacing="10" Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="YOUR REVIEW // START HERE"
                                   FontFamily="{StaticResource MonoFont}"
                                   FontSize="{Binding Caption, Source={StaticResource FontSizes}}"
                                   CharacterSpacing="300"
                                   Foreground="{StaticResource AccentGoldBrush}"/>
                        <Rectangle Grid.Column="1" Height="1"
                                   Fill="{StaticResource SubtleBorderBrush}"
                                   VerticalAlignment="Center"/>
                    </Grid>

                    <!-- v2.18 (schema v5): one-tap focus check. The first input on
                         the page вЂ” fast enough to answer while tilted. Asked
                         against the Start Block intent for the day. -->
                    <controls:CornerBracketedCard
                            CardBorderBrush="{StaticResource AccentGoldBrush}"
                            Visibility="{x:Bind ViewModel.HasSessionIntentionForGame, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                        <Grid ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Spacing="4">
                                <controls:SectionTitle Text="FOCUS CHECK"/>
                                <TextBlock FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           TextWrapping="Wrap"
                                           Text="{x:Bind ViewModel.SessionIntentionForGame, Mode=OneWay}"/>
                                <TextBlock Text="Did you actually play to it this game?"
                                           FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                           Foreground="{StaticResource MutedTextBrush}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                <ToggleButton Content="Yes"
                                              IsChecked="{x:Bind ViewModel.FocusAdherenceYes, Mode=OneWay}"
                                              Command="{x:Bind ViewModel.SetFocusAdherenceCommand}"
                                              CommandParameter="2"
                                              Style="{StaticResource HudPracticedToggleStyle}"/>
                                <ToggleButton Content="Partly"
                                              IsChecked="{x:Bind ViewModel.FocusAdherencePartly, Mode=OneWay}"
                                              Command="{x:Bind ViewModel.SetFocusAdherenceCommand}"
                                              CommandParameter="1"
                                              Style="{StaticResource HudPracticedToggleStyle}"/>
                                <ToggleButton Content="No"
                                              IsChecked="{x:Bind ViewModel.FocusAdherenceNo, Mode=OneWay}"
                                              Command="{x:Bind ViewModel.SetFocusAdherenceCommand}"
                                              CommandParameter="0"
                                              Style="{StaticResource HudPracticedToggleStyle}"/>
                            </StackPanel>
                        </Grid>
                    </controls:CornerBracketedCard>

                    <!-- v2.18 (schema v5): death audit. One tap per death вЂ” the
                         classified mix across games becomes the diagnosis. -->
                    <controls:CornerBracketedCard
                            Visibility="{x:Bind ViewModel.HasDeathAudit, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                        <StackPanel Spacing="10">
                            <controls:SectionTitle Text="DEATH AUDIT"/>
                            <TextBlock Text="Tag the cause of each death. One tap each вЂ” the pattern across games is the diagnosis, not any single death."
                                       FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       TextWrapping="Wrap"/>
                            <ItemsRepeater ItemsSource="{x:Bind ViewModel.DeathAudit, Mode=OneWay}">
                                <ItemsRepeater.Layout>
                                    <StackLayout Spacing="6"/>
                                </ItemsRepeater.Layout>
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate x:DataType="vm:DeathAuditItem">
                                        <Border Background="{StaticResource InputBackgroundBrush}"
                                                BorderBrush="{StaticResource SubtleBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="2"
                                                Padding="10,6">
                                            <Grid ColumnSpacing="12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <!-- v2.18 (P-006): the timestamp jumps the VOD to
                                                     this death (10s lead-in) so the cause is tagged
                                                     from footage, not memory. Plain text when the
                                                     game has no VOD. -->
                                                <Button Grid.Column="0"
                                                        Content="{x:Bind TimeText}"
                                                        Command="{Binding ElementName=RootReviewPage, Path=ViewModel.OpenDeathInVodCommand}"
                                                        CommandParameter="{x:Bind}"
                                                        ToolTipService.ToolTip="Watch this death in the VOD"
                                                        FontFamily="{StaticResource MonoFont}"
                                                        FontSize="{Binding BodyEmphasis, Source={StaticResource FontSizes}}"
                                                        Foreground="{StaticResource LossRedBrush}"
                                                        Background="Transparent"
                                                        BorderBrush="{StaticResource SubtleBorderBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="2"
                                                        Padding="8,3"
                                                        MinWidth="56"
                                                        VerticalAlignment="Center"
                                                        Visibility="{Binding ElementName=RootReviewPage, Path=ViewModel.HasVod, Converter={StaticResource BoolToVis}}"/>
                                                <TextBlock Grid.Column="0"
                                                           Text="{x:Bind TimeText}"
                                                           FontFamily="{StaticResource MonoFont}"
                                                           FontSize="{Binding BodyEmphasis, Source={StaticResource FontSizes}}"
                                                           Foreground="{StaticResource LossRedBrush}"
                                                           VerticalAlignment="Center"
                                                           MinWidth="44"
                                                           Visibility="{Binding ElementName=RootReviewPage, Path=ViewModel.HasVod, Converter={StaticResource InverseBoolToVis}}"/>
                                                <ItemsRepeater Grid.Column="1" ItemsSource="{x:Bind Chips}">
                                                    <ItemsRepeater.Layout>
                                                        <UniformGridLayout MinItemWidth="92"
                                                                           MinRowSpacing="4"
                                                                           MinColumnSpacing="4"
                                                                           ItemsStretch="Fill"/>
                                                    </ItemsRepeater.Layout>
                                                    <ItemsRepeater.ItemTemplate>
                                                        <DataTemplate x:DataType="vm:DeathChipOption">
                                                            <Button Background="Transparent"
                                                                    BorderThickness="1"
                                                                    BorderBrush="{x:Bind ChipBorderBrush, Mode=OneWay}"
                                                                    Padding="8,3"
                                                                    HorizontalAlignment="Stretch"
                                                                    HorizontalContentAlignment="Center"
                                                                    CornerRadius="2"
                                                                    DataContext="{x:Bind}"
                                                                    Click="OnDeathChipClick"
                                                                    ToolTipService.ToolTip="{x:Bind Hint}">
                                                                <TextBlock Text="{x:Bind Label}"
                                                                           FontFamily="{StaticResource MonoFont}"
                                                                           FontSize="{Binding Caption, Source={StaticResource FontSizes}}"
                                                                           CharacterSpacing="150"
                                                                           Foreground="{x:Bind ChipForegroundBrush, Mode=OneWay}"/>
                                                            </Button>
                                                        </DataTemplate>
                                                    </ItemsRepeater.ItemTemplate>
                                                </ItemsRepeater>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>
                        </StackPanel>
                    </controls:CornerBracketedCard>

                    <controls:CornerBracketedCard
                            Visibility="{x:Bind ViewModel.HasObjectives, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                        <StackPanel Spacing="10">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                <StackPanel Grid.Column="0" Spacing="4">
                                    <controls:SectionTitle Text="OBJECTIVES + EVIDENCE"/>
                                    <TextBlock Text="Use saved clips and timeline evidence to decide what you practiced, then add any notes that matter."
                                               FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                               Foreground="{StaticResource SecondaryTextBrush}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Command="{x:Bind ViewModel.WatchVodCommand}"
                                        Style="{StaticResource GoldListActionButtonStyle}"
                                        VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon Glyph="&#xE714;" FontSize="{Binding BodyEmphasis, Source={StaticResource FontSizes}}"/>
                                        <TextBlock Text="Review VOD"/>
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <Border Background="{StaticResource InputBackgroundBrush}"
                                    BorderBrush="{StaticResource SubtleBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="2"
                                    Padding="12,8"
                                    Visibility="{x:Bind ViewModel.IsEvidenceLoading, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <ProgressRing IsActive="True" Width="18" Height="18"/>
                                    <TextBlock Text="Building evidence..."
                                               FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                               Foreground="{StaticResource SecondaryTextBrush}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <StackPanel Spacing="8"
                                        Visibility="{x:Bind ViewModel.HasUnassignedEvidenceItems, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="EVIDENCE TO SORT"
                                           FontFamily="{StaticResource MonoFont}"
                                           FontSize="{Binding Caption, Source={StaticResource FontSizes}}"
                                           CharacterSpacing="200"
                                           Foreground="{StaticResource AccentPurpleBrush}"/>
                                <ItemsRepeater ItemsSource="{x:Bind ViewModel.UnassignedEvidenceItems, Mode=OneWay}">
                                    <ItemsRepeater.Layout>
                                        <StackLayout Spacing="6"/>
                                    </ItemsRepeater.Layout>
                                    <ItemsRepeater.ItemTemplate>
                                        <DataTemplate x:DataType="vm:EvidenceInboxItem">
                                            <!-- 3px left edge in polarity color (green/red/neutral)
                                                 so the good/bad call is readable at a glance. -->
                                            <Border Background="{StaticResource InputBackgroundBrush}"
                                                    BorderBrush="{x:Bind PolarityAccentBrush, Mode=OneWay}"
                                                    BorderThickness="3,1,1,1"
                                                    CornerRadius="2"
                                                    Padding="10,8">
                                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                                    <StackPanel Grid.Column="0" Spacing="6">
                                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                                            <TextBlock Text="{x:Bind TimeRangeText}"
                                                                       FontFamily="{StaticResource MonoFont}"
                                                                       FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                                                       Foreground="{StaticResource AccentGoldBrush}"/>
                                                            <TextBlock Text="{x:Bind Title}"
                                                                       FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{StaticResource PrimaryTextBrush}"
                                                                       TextWrapping="Wrap"/>
                                                        </StackPanel>
                                                        <controls:ObjectivePicker Source="{x:Bind TagOptions, Mode=OneWay}"
                                                                                  Payload="{x:Bind}"
                                                                                  SelectedTitle="{x:Bind ObjectiveTitleDisplay, Mode=OneWay}"
                                                                                  PlaceholderText="Attach to objective..."
                                                                                  TagChosen="OnEvidenceTagChosen"
                                                                                  HorizontalAlignment="Stretch"/>
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                                                        <Button Content="Good" Tag="good" DataContext="{x:Bind}"
                                                                Click="OnEvidencePolarityClick"
                                                                Style="{StaticResource ListActionButtonStyle}"
                                                                Height="28" Padding="8,0"/>
                                                        <Button Content="Bad" Tag="bad" DataContext="{x:Bind}"
                                                                Click="OnEvidencePolarityClick"
                                                                Style="{StaticResource ListActionButtonStyle}"
                                                                Height="28" Padding="8,0"/>
                                                        <Button Style="{StaticResource GhostIconButtonStyle}"
                                                                DataContext="{x:Bind}"
                                                                Click="OnOpenEvidenceClick"
                                                                ToolTipService.ToolTip="Open in VOD">
                                                            <FontIcon Glyph="&#xE768;"
                                                                      FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                                                      FontSize="{Binding BodyEmphasis, Source={StaticResource FontSizes}}"/>
                                                        </Button>
                                                        <Button Style="{StaticResource GhostIconButtonStyle}"
                                                                Tag="dismissed"
                                                                DataContext="{x:Bind}"
                                                                Click="OnEvidenceStatusClick"
                                                                ToolTipService.ToolTip="Dismiss">
                                                            <FontIcon Glyph="&#xE74D;"
                                                                      FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                                                      FontSize="{Binding BodyEmphasis, Source={StaticResource FontSizes}}"
                                                                      Foreground="{StaticResource LossRedBrush}"/>
                                                        </Button>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsRepeater.ItemTemplate>
                                </ItemsRepeater>
                            </StackPanel>

                            <TextBlock Text="Each objective below includes its attached evidence, practice toggle, and notes."
                                       FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       TextWrapping="Wrap"/>

                            <ItemsRepeater ItemsSource="{x:Bind ViewModel.ObjectiveAssessments, Mode=OneWay}">
                                <ItemsRepeater.Layout>
                                    <StackLayout Spacing="8"/>
                                </ItemsRepeater.Layout>
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ObjectiveAssessment">
                                        <Border Background="{StaticResource InputBackgroundBrush}"
                                                CornerRadius="2"
                                                BorderThickness="1,1,1,2"
                                                BorderBrush="{x:Bind AccentBrush}"
                                                Padding="14">
                                            <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="10">
                                                <!-- Row 0: Title + practiced toggle -->
                                                <Grid ColumnDefinitions="*,Auto">
                                                    <StackPanel Spacing="2">
                                                        <TextBlock Text="{x:Bind Title}"
                                                                   FontSize="{Binding Subtitle, Source={StaticResource FontSizes}}"
                                                                   FontWeight="Bold"
                                                                   Foreground="{StaticResource PrimaryTextBrush}"/>
                                                        <TextBlock Text="{x:Bind PhaseLabel}"
                                                                   FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                                                   Foreground="{StaticResource AccentBlueBrush}"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="1" Spacing="3">
                                                        <ToggleButton Content="PRACTICED"
                                                                      IsChecked="{x:Bind Practiced, Mode=TwoWay}"
                                                                      Style="{StaticResource HudPracticedToggleStyle}"
                                                                      HorizontalAlignment="Right"/>
                                                        <!-- P-008: explains the pre-check when evidence
                                                             on this game links to this objective. -->
                                                        <TextBlock Text="AUTO &#x2014; EVIDENCE ATTACHED"
                                                                   FontFamily="{StaticResource MonoFont}"
                                                                   FontSize="{Binding Caption, Source={StaticResource FontSizes}}"
                                                                   CharacterSpacing="120"
                                                                   Foreground="{StaticResource AccentTealBrush}"
                                                                   HorizontalAlignment="Right"
                                                                   Visibility="{x:Bind PracticedFromEvidence, Converter={StaticResource BoolToVis}}"/>
                                                    </StackPanel>
                                                </Grid>

                                                <!-- Row 1: Criteria + measured verdict (v2.18, schema v5) -->
                                                <StackPanel Grid.Row="1" Spacing="4">
                                                    <TextBlock Text="{x:Bind Criteria}"
                                                               FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                                               Foreground="{StaticResource SecondaryTextBrush}"
                                                               TextWrapping="Wrap"/>
                                                    <TextBlock Text="{x:Bind CriteriaVerdict}"
                                                               FontFamily="{StaticResource MonoFont}"
                                                               FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                                               CharacterSpacing="150"
                                                               Foreground="{x:Bind CriteriaVerdictBrush}"
                                                               TextWrapping="Wrap"
                                                               Visibility="{x:Bind HasCriteriaVerdict, Converter={StaticResource BoolToVis}}"/>
                                                </StackPanel>

                                                <!-- Row 2: General notes for this objective on this game -->
                                                <StackPanel Grid.Row="2" Spacing="4">
                                                    <TextBlock Text="GENERAL NOTES"
                                                               FontFamily="{StaticResource MonoFont}"
                                                               FontSize="{Binding Caption, Source={StaticResource FontSizes}}"
                                                               CharacterSpacing="200"
                                                               Foreground="{StaticResource MutedTextBrush}"/>
                                                    <TextBox Text="{x:Bind ExecutionNote, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                             PlaceholderText="How did this objective go in the game?"
                                                             TextWrapping="Wrap" AcceptsReturn="True"
                                                             MinHeight="52" FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                                             Background="{StaticResource CardBackgroundBrush}"
                                                             BorderBrush="{StaticResource SubtleBorderBrush}"
                                                             Foreground="{StaticResource PrimaryTextBrush}"
                                                             CornerRadius="2"/>
                                                </StackPanel>

                                                <StackPanel Grid.Row="3" Spacing="8"
                                                            Visibility="{x:Bind HasEvidenceItems, Converter={StaticResource BoolToVis}}">
                                                    <TextBlock Text="ATTACHED EVIDENCE"
                                                               FontFamily="{StaticResource MonoFont}"
                                                               FontSize="{Binding Caption, Source={StaticResource FontSizes}}"
                                                               CharacterSpacing="200"
                                                               Foreground="{StaticResource AccentTealBrush}"/>
                                                    <ItemsRepeater ItemsSource="{x:Bind EvidenceItems, Mode=OneWay}">
                                                        <ItemsRepeater.Layout>
                                                            <StackLayout Spacing="6"/>
                                                        </ItemsRepeater.Layout>
                                                        <ItemsRepeater.ItemTemplate>
                                                            <DataTemplate x:DataType="vm:EvidenceInboxItem">
                                                                <!-- Polarity edge: good/bad of each attached
                                                                     clip readable without opening it. -->
                                                                <Border Background="{StaticResource CardBackgroundBrush}"
                                                                        BorderBrush="{x:Bind PolarityAccentBrush, Mode=OneWay}"
                                                                        BorderThickness="3,1,1,1"
                                                                        CornerRadius="2"
                                                                        Padding="9,7">
                                                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                                                        <StackPanel Grid.Column="0" Spacing="3">
                                                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                                                <TextBlock Text="{x:Bind TimeRangeText}"
                                                                                           FontFamily="{StaticResource MonoFont}"
                                                                                           FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                                                                           Foreground="{StaticResource AccentGoldBrush}"/>
                                                                                <TextBlock Text="{x:Bind Title}"
                                                                                           FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                                                                           FontWeight="SemiBold"
                                                                                           Foreground="{StaticResource PrimaryTextBrush}"
                                                                                           TextWrapping="Wrap"/>
                                                                            </StackPanel>
                                                                            <TextBlock Text="{x:Bind Note}"
                                                                                       FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                                                                       Foreground="{StaticResource SecondaryTextBrush}"
                                                                                       TextWrapping="Wrap"
                                                                                       Visibility="{x:Bind HasNote, Converter={StaticResource BoolToVis}}"/>
                                                                        </StackPanel>
                                                                        <Button Grid.Column="1"
                                                                                Style="{StaticResource GhostIconButtonStyle}"
                                                                                DataContext="{x:Bind}"
                                                                                Click="OnOpenEvidenceClick"
                                                                                ToolTipService.ToolTip="Open moment">
                                                                            <FontIcon Glyph="&#xE768;"
                                                                                      FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                                                                      FontSize="{Binding BodyEmphasis, Source={StaticResource FontSizes}}"/>
                                                                        </Button>
                                                                    </Grid>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsRepeater.ItemTemplate>
                                                    </ItemsRepeater>
                                                </StackPanel>

                                                <!-- Row 4: v2.15.0 custom prompts for this objective (in-game + post-game phases) -->
                                                <StackPanel Grid.Row="4" Spacing="8"
                                                            Visibility="{x:Bind HasPrompts, Converter={StaticResource BoolToVis}}">
                                                    <TextBlock Text="CUSTOM PROMPTS"
                                                               FontFamily="{StaticResource MonoFont}"
                                                               FontSize="{Binding Caption, Source={StaticResource FontSizes}}"
                                                               CharacterSpacing="200"
                                                               Foreground="{StaticResource AccentPurpleBrush}"/>
                                                    <ItemsRepeater ItemsSource="{x:Bind Prompts, Mode=OneWay}">
                                                        <ItemsRepeater.Layout>
                                                            <StackLayout Spacing="8"/>
                                                        </ItemsRepeater.Layout>
                                                        <ItemsRepeater.ItemTemplate>
                                                            <DataTemplate x:DataType="vm:PromptAnswerField">
                                                                <StackPanel Spacing="6">
                                                                    <!-- v2.16.2: pre-game answers carry a small caps eyebrow
                                                                         so the user can tell carried-over answers from the
                                                                         in-game/post-game prompts below. v2.17.26: these are
                                                                         now editable here so they can be finished post-game. -->
                                                                    <TextBlock Text="YOUR PRE-GAME ANSWER"
                                                                               FontFamily="{StaticResource MonoFont}"
                                                                               FontSize="{Binding Caption, Source={StaticResource FontSizes}}"
                                                                               CharacterSpacing="200"
                                                                               Foreground="{StaticResource AccentGoldBrush}"
                                                                               Visibility="{x:Bind IsPreGame, Converter={StaticResource BoolToVis}}"/>
                                                                    <!-- v2.15.0: body-size + primary text so prompt reads clearly. -->
                                                                    <TextBlock Text="{x:Bind Label}"
                                                                               FontFamily="{StaticResource BodyFont}"
                                                                               FontSize="{Binding BodyEmphasis, Source={StaticResource FontSizes}}"
                                                                               FontWeight="SemiBold"
                                                                               Foreground="{StaticResource PrimaryTextBrush}"
                                                                               TextWrapping="Wrap"/>
                                                                    <TextBox Text="{x:Bind AnswerText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                             PlaceholderText="Write your answer..."
                                                                             TextWrapping="Wrap" AcceptsReturn="True"
                                                                             MinHeight="44"
                                                                             FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                                                             Background="{StaticResource CardBackgroundBrush}"
                                                                             BorderBrush="{StaticResource SubtleBorderBrush}"
                                                                             Foreground="{StaticResource PrimaryTextBrush}"
                                                                             CornerRadius="2"/>
                                                                </StackPanel>
                                                            </DataTemplate>
                                                        </ItemsRepeater.ItemTemplate>
                                                    </ItemsRepeater>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>
                        </StackPanel>
                    </controls:CornerBracketedCard>

                    <!-- вЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђ
                         SELF ASSESSMENT: Mental Rating + Performance
                         вЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђ -->
                    <controls:CornerBracketedCard>
                        <StackPanel Spacing="10">

                            <!-- Mental Rating -->
                            <controls:SectionTitle Text="MENTAL RATING"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Slider Grid.Column="0"
                                        Value="{x:Bind ViewModel.MentalRating, Mode=TwoWay}"
                                        Minimum="1" Maximum="10"
                                        StepFrequency="1"
                                        TickFrequency="1"
                                        TickPlacement="Outside"
                                        VerticalAlignment="Center"/>

                                <TextBlock Grid.Column="1"
                                           Text="{x:Bind ViewModel.MentalRating, Mode=OneWay}"
                                           FontSize="{Binding HeroLarge, Source={StaticResource FontSizes}}" FontWeight="Bold"
                                           FontFamily="{StaticResource DisplayFont}"
                                           Margin="16,0,0,0"
                                           VerticalAlignment="Center"
                                           MinWidth="50"
                                           TextAlignment="Center"/>
                            </Grid>

                            <!-- v2.15.0: Performance Review block moved out of this card.
                                 See the "PERFORMANCE REVIEW (LEGACY)" card at the bottom of the page. -->
                        </StackPanel>
                    </controls:CornerBracketedCard>

                    <!-- вЂўВђвЂўВђвЂўВђ Mental Reflection (shown when mental <= 3) вЂўВђвЂўВђвЂўВђ -->
                    <Border Visibility="{x:Bind ViewModel.ShowMentalReflection, Mode=OneWay, Converter={StaticResource BoolToVis}}"
                            Background="{StaticResource WarningSurfaceBrush}"
                            BorderBrush="{StaticResource AccentGoldBrush}"
                            BorderThickness="2"
                            CornerRadius="2" Padding="16">
                        <StackPanel Spacing="8">
                            <controls:SectionTitle Text="MENTAL REFLECTION"/>

                            <TextBlock Text="What triggered the tilt?"
                                       FontSize="{Binding BodyEmphasis, Source={StaticResource FontSizes}}"
                                       Foreground="{StaticResource PrimaryTextBrush}"/>

                            <TextBox Text="{x:Bind ViewModel.MentalHandled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     PlaceholderText="What happened and how did you handle it?"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     MinHeight="60"
                                     FontSize="{Binding BodyEmphasis, Source={StaticResource FontSizes}}"
                                     Background="{StaticResource InputBackgroundBrush}"
                                     BorderBrush="{StaticResource SubtleBorderBrush}"
                                     Foreground="{StaticResource PrimaryTextBrush}"
                                     CornerRadius="2"/>
                        </StackPanel>
                    </Border>

                    <!-- вЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђ
                         MATCHUP NOTES
                         вЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђ -->
                    <Grid ColumnSpacing="10" Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="OPTIONAL CONTEXT"
                                   FontFamily="{StaticResource MonoFont}"
                                   FontSize="{Binding Caption, Source={StaticResource FontSizes}}"
                                   CharacterSpacing="300"
                                   Foreground="{StaticResource MutedTextBrush}"/>
                        <Rectangle Grid.Column="1" Height="1"
                                   Fill="{StaticResource SubtleBorderBrush}"
                                   VerticalAlignment="Center"/>
                    </Grid>

                    <!-- v2.18 (digest 2026-06-11-2 P3a): REAPPRAISAL вЂ” the
                         outside/within-control pair. ViewModel, drafts, and
                         repository have round-tripped these since 2026-03-22;
                         the form never rendered the inputs (write-path audit,
                         brief 2026-06-11-03). Collapsed by default so the cost
                         stays opt-in; auto-expands when saved text exists. -->
                    <controls:CornerBracketedCard>
                        <StackPanel Spacing="10">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                <controls:SectionTitle Grid.Column="0"
                                                       Text="REAPPRAISAL"
                                                       VerticalAlignment="Center"/>
                                <ToggleButton Grid.Column="1"
                                              Content="WRITE"
                                              Style="{StaticResource HudPracticedToggleStyle}"
                                              IsChecked="{x:Bind ViewModel.IsReappraisalExpanded, Mode=TwoWay}"/>
                            </Grid>
                            <TextBlock Text="Optional вЂ” split the game into what was outside your control and what was yours to change."
                                       FontFamily="{StaticResource MonoFont}"
                                       FontSize="{Binding Caption, Source={StaticResource FontSizes}}"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       TextWrapping="Wrap"/>
                            <StackPanel Spacing="10"
                                        Visibility="{x:Bind ViewModel.IsReappraisalExpanded, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="Outside your control"
                                               FontSize="{Binding BodyEmphasis, Source={StaticResource FontSizes}}"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource PrimaryTextBrush}"/>
                                    <TextBox Text="{x:Bind ViewModel.OutsideControl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             PlaceholderText="Jungle diff, autofill, disconnects..."
                                             TextWrapping="Wrap"
                                             AcceptsReturn="True"
                                             MinHeight="56"
                                             FontSize="{Binding BodyEmphasis, Source={StaticResource FontSizes}}"
                                             Background="{StaticResource InputBackgroundBrush}"
                                             BorderBrush="{StaticResource SubtleBorderBrush}"
                                             Foreground="{StaticResource PrimaryTextBrush}"
                                             CornerRadius="2"/>
                                </StackPanel>
                                <StackPanel Spacing="6">
                                    <TextBlock Text="Within your control"
                                               FontSize="{Binding BodyEmphasis, Source={StaticResource FontSizes}}"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource PrimaryTextBrush}"/>
                                    <TextBox Text="{x:Bind ViewModel.WithinControl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             PlaceholderText="What you could have done differently..."
                                             TextWrapping="Wrap"
                                             AcceptsReturn="True"
                                             MinHeight="56"
                                             FontSize="{Binding BodyEmphasis, Source={StaticResource FontSizes}}"
                                             Background="{StaticResource InputBackgroundBrush}"
                                             BorderBrush="{StaticResource SubtleBorderBrush}"
                                             Foreground="{StaticResource PrimaryTextBrush}"
                                             CornerRadius="2"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </controls:CornerBracketedCard>

                    <controls:CornerBracketedCard>
                        <StackPanel Spacing="10">
                            <controls:SectionTitle Text="MATCHUP NOTES"/>
                            <TextBlock Text="{x:Bind ViewModel.MatchupHeading, Mode=OneWay}"
                                       FontSize="{Binding Subtitle, Source={StaticResource FontSizes}}"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource AccentBlueBrush}"/>

                            <TextBlock Text="Enemy champion"
                                       FontSize="{Binding BodyEmphasis, Source={StaticResource FontSizes}}"
                                       Foreground="{StaticResource PrimaryTextBrush}"/>
                            <TextBox Text="{x:Bind ViewModel.EnemyLaner, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     PlaceholderText="Enemy laner or main matchup champion"
                                     FontSize="{Binding BodyEmphasis, Source={StaticResource FontSizes}}"
                                     Background="{StaticResource InputBackgroundBrush}"
                                     BorderBrush="{StaticResource SubtleBorderBrush}"
                                     Foreground="{StaticResource PrimaryTextBrush}"
                                     CornerRadius="2"
                                     Height="36"/>

                            <TextBlock Text="What should you remember for this matchup?"
                                       FontSize="{Binding BodyEmphasis, Source={StaticResource FontSizes}}"
                                       Foreground="{StaticResource PrimaryTextBrush}"/>
                            <TextBox Text="{x:Bind ViewModel.MatchupNote, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     PlaceholderText="Lane-specific or matchup-specific reminders..."
                                     TextWrapping="Wrap" AcceptsReturn="True"
                                     MinHeight="70" FontSize="{Binding BodyEmphasis, Source={StaticResource FontSizes}}"
                                     Background="{StaticResource InputBackgroundBrush}"
                                     BorderBrush="{StaticResource SubtleBorderBrush}"
                                     Foreground="{StaticResource PrimaryTextBrush}"
                                     CornerRadius="2"/>

                            <ItemsRepeater ItemsSource="{x:Bind ViewModel.MatchupHistory, Mode=OneWay}"
                                           Visibility="{x:Bind ViewModel.HasMatchupHistory, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                                <ItemsRepeater.Layout>
                                    <StackLayout Spacing="6"/>
                                </ItemsRepeater.Layout>
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate x:DataType="vm:MatchupHistoryItem">
                                        <Border Background="{StaticResource InputBackgroundBrush}"
                                                CornerRadius="2"
                                                BorderThickness="1"
                                                BorderBrush="{StaticResource SubtleBorderBrush}"
                                                Padding="12">
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="{x:Bind MetaText}"
                                                           FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                                           Foreground="{StaticResource SecondaryTextBrush}"/>
                                                <TextBlock Text="{x:Bind Note}"
                                                           FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                                           Foreground="{StaticResource PrimaryTextBrush}"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>
                        </StackPanel>
                    </controls:CornerBracketedCard>

                    <!-- вЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђ
                         NOTES + CONCEPT TAGS (merged)
                         вЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђ -->
                    <controls:CornerBracketedCard>
                        <StackPanel Spacing="10">
                            <controls:SectionTitle Text="REVIEW NOTES"/>

                            <TextBlock Text="Additional review notes"
                                       FontSize="{Binding BodyEmphasis, Source={StaticResource FontSizes}}"
                                       Foreground="{StaticResource PrimaryTextBrush}"/>
                            <TextBox Text="{x:Bind ViewModel.ReviewNotes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     PlaceholderText="Anything else you want to remember from this game..."
                                     TextWrapping="Wrap" AcceptsReturn="True"
                                     MinHeight="70" FontSize="{Binding BodyEmphasis, Source={StaticResource FontSizes}}"
                                     Background="{StaticResource InputBackgroundBrush}"
                                     BorderBrush="{StaticResource SubtleBorderBrush}"
                                     Foreground="{StaticResource PrimaryTextBrush}"
                                     CornerRadius="2"/>

                            <TextBlock Text="Anything else you noticed (outside your objectives)"
                                       FontSize="{Binding BodyEmphasis, Source={StaticResource FontSizes}}"
                                       Foreground="{StaticResource PrimaryTextBrush}"/>
                            <TextBox Text="{x:Bind ViewModel.SpottedProblems, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     PlaceholderText="Patterns or issues that aren't one of your active objectives вЂ” seeds for future ones."
                                     TextWrapping="Wrap" AcceptsReturn="True"
                                     MinHeight="70" FontSize="{Binding BodyEmphasis, Source={StaticResource FontSizes}}"
                                     Background="{StaticResource InputBackgroundBrush}"
                                     BorderBrush="{StaticResource SubtleBorderBrush}"
                                     Foreground="{StaticResource PrimaryTextBrush}"
                                     CornerRadius="2"/>

                            <!-- Separator -->
                            <Border Height="1"
                                    Background="{StaticResource SubtleBorderBrush}"
                                    Margin="0,4"/>

                            <!-- Concept Tags -->
                            <controls:SectionTitle Text="CONCEPT TAGS"/>

                            <ItemsRepeater ItemsSource="{x:Bind ViewModel.AllTags, Mode=OneWay}">
                                <ItemsRepeater.Layout>
                                    <UniformGridLayout Orientation="Horizontal"
                                                       MinItemWidth="150"
                                                       MinItemHeight="36"
                                                       MinColumnSpacing="6"
                                                       MinRowSpacing="6"
                                                       ItemsStretch="Fill"/>
                                </ItemsRepeater.Layout>
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ConceptTagItem">
                                        <ToggleButton IsChecked="{x:Bind IsSelected, Mode=TwoWay}"
                                                      FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                                      Height="34"
                                                      CornerRadius="2"
                                                      Padding="12,0"
                                                      HorizontalAlignment="Stretch"
                                                      Background="{x:Bind TagBackgroundBrush}"
                                                      Foreground="{StaticResource PrimaryTextBrush}"
                                                      BorderBrush="{x:Bind TagBorderBrush}"
                                                      BorderThickness="1">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <Border Width="10" Height="10" CornerRadius="5"
                                                        Background="{x:Bind TagAccentBrush}"/>
                                                <TextBlock Text="{x:Bind Name}"
                                                           VerticalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </ToggleButton>
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>
                        </StackPanel>
                    </controls:CornerBracketedCard>

                    <!-- вЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђ
                         ATTRIBUTION + SESSION NOTE (v2.15.0 legacy-only)
                         вЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђ -->
                    <!-- v2.15.0: Performance Review pushed to bottom so Objectives lead the page.
                         Legacy-only вЂ” new reviews skip this entirely. -->
                    <controls:CornerBracketedCard
                        Visibility="{x:Bind ViewModel.ShowLegacyFields, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                        <StackPanel Spacing="10">
                            <controls:SectionTitle Text="PERFORMANCE REVIEW (LEGACY)"/>
                            <TextBlock Text="Read-only carryover from an earlier version of Revu. New reviews use Objectives + Custom Prompts instead."
                                       FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       TextWrapping="Wrap"/>

                            <TextBlock Text="What went well?"
                                       FontSize="{Binding BodyEmphasis, Source={StaticResource FontSizes}}" Foreground="{StaticResource PrimaryTextBrush}"/>
                            <TextBox Text="{x:Bind ViewModel.WentWell, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     PlaceholderText="Good plays, decisions, mechanics..."
                                     TextWrapping="Wrap" AcceptsReturn="True"
                                     MinHeight="70" FontSize="{Binding BodyEmphasis, Source={StaticResource FontSizes}}"
                                     Background="{StaticResource InputBackgroundBrush}"
                                     BorderBrush="{StaticResource SubtleBorderBrush}"
                                     Foreground="{StaticResource PrimaryTextBrush}"
                                     CornerRadius="2"/>

                            <TextBlock Text="What could improve?"
                                       FontSize="{Binding BodyEmphasis, Source={StaticResource FontSizes}}" Foreground="{StaticResource PrimaryTextBrush}"/>
                            <TextBox Text="{x:Bind ViewModel.Mistakes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     PlaceholderText="Deaths, missed plays, bad decisions..."
                                     TextWrapping="Wrap" AcceptsReturn="True"
                                     MinHeight="70" FontSize="{Binding BodyEmphasis, Source={StaticResource FontSizes}}"
                                     Background="{StaticResource InputBackgroundBrush}"
                                     BorderBrush="{StaticResource SubtleBorderBrush}"
                                     Foreground="{StaticResource PrimaryTextBrush}"
                                     CornerRadius="2"/>

                            <TextBlock Text="Focus for next game"
                                       FontSize="{Binding BodyEmphasis, Source={StaticResource FontSizes}}" Foreground="{StaticResource PrimaryTextBrush}"/>
                            <TextBox Text="{x:Bind ViewModel.FocusNext, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     PlaceholderText="What will you focus on improving?"
                                     FontSize="{Binding BodyEmphasis, Source={StaticResource FontSizes}}"
                                     Background="{StaticResource InputBackgroundBrush}"
                                     BorderBrush="{StaticResource SubtleBorderBrush}"
                                     Foreground="{StaticResource PrimaryTextBrush}"
                                     CornerRadius="2"
                                     Height="36"/>
                        </StackPanel>
                    </controls:CornerBracketedCard>

                    <controls:CornerBracketedCard
                        Visibility="{x:Bind ViewModel.ShowLegacyFields, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                        <StackPanel Spacing="10">
                            <controls:SectionTitle Text="ATTRIBUTION (LEGACY)"/>
                            <TextBlock Text="Carryover from an earlier review shape. Read-only reference вЂ” new reviews don't collect this."
                                       FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       TextWrapping="Wrap"/>

                            <TextBlock Text="What most influenced the outcome?"
                                       FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                       Foreground="{StaticResource SecondaryTextBrush}"/>

                            <Grid ColumnSpacing="8" RowSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <RadioButton Grid.Row="0" Grid.Column="0"
                                             Content="My play" GroupName="Attribution"
                                             IsChecked="{x:Bind IsMyPlaySelected, Mode=OneWay}"
                                             Checked="OnAttributionChanged"
                                             Tag="My play"
                                             Foreground="{StaticResource PrimaryTextBrush}"/>
                                <RadioButton Grid.Row="0" Grid.Column="1"
                                             Content="Team effort" GroupName="Attribution"
                                             IsChecked="{x:Bind IsTeamEffortSelected, Mode=OneWay}"
                                             Checked="OnAttributionChanged"
                                             Tag="Team effort"
                                             Foreground="{StaticResource PrimaryTextBrush}"/>
                                <RadioButton Grid.Row="1" Grid.Column="0"
                                             Content="Teammates" GroupName="Attribution"
                                             IsChecked="{x:Bind IsTeammatesSelected, Mode=OneWay}"
                                             Checked="OnAttributionChanged"
                                             Tag="Teammates"
                                             Foreground="{StaticResource PrimaryTextBrush}"/>
                                <RadioButton Grid.Row="1" Grid.Column="1"
                                             Content="External" GroupName="Attribution"
                                             IsChecked="{x:Bind IsExternalSelected, Mode=OneWay}"
                                             Checked="OnAttributionChanged"
                                             Tag="External"
                                             Foreground="{StaticResource PrimaryTextBrush}"/>
                            </Grid>

                            <!-- Separator -->
                            <Border Height="1"
                                    Background="{StaticResource SubtleBorderBrush}"
                                    Margin="0,4"/>

                            <!-- Session Note -->
                            <controls:SectionTitle Text="SESSION NOTE"/>

                            <TextBox Text="{x:Bind ViewModel.ImprovementNote, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     PlaceholderText="Quick note for your session log..."
                                     FontSize="{Binding BodyEmphasis, Source={StaticResource FontSizes}}"
                                     Background="{StaticResource InputBackgroundBrush}"
                                     BorderBrush="{StaticResource SubtleBorderBrush}"
                                     Foreground="{StaticResource PrimaryTextBrush}"
                                     CornerRadius="2"
                                     Height="36"/>
                        </StackPanel>
                    </controls:CornerBracketedCard>

                    <!-- вЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђ
                         ACTION BAR
                         вЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђвЂўВђ -->

                    <!-- Validation + save behavior info -->
                    <StackPanel Spacing="4"
                                Visibility="{x:Bind ViewModel.HasValidationMessage, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{x:Bind ViewModel.ValidationMessage, Mode=OneWay}"
                                   FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                   Foreground="{StaticResource LossRedBrush}"
                                   TextWrapping="Wrap"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>

                    <TextBlock Text="{x:Bind ViewModel.SaveBehaviorText, Mode=OneWay}"
                               FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                               Foreground="{StaticResource MutedTextBrush}"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"/>

                    <!-- Equal-width action buttons -->
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Content="Cancel"
                                Command="{x:Bind ViewModel.CancelCommand}"
                                Style="{StaticResource SecondaryActionButtonStyle}"
                                FontSize="{Binding Subtitle, Source={StaticResource FontSizes}}"
                                Height="44"
                                CornerRadius="2"
                                HorizontalAlignment="Stretch"/>

                        <Button Grid.Column="1"
                                Content="Save Review"
                                Command="{x:Bind ViewModel.SaveReviewCommand}"
                                Style="{StaticResource PrimaryActionButtonStyle}"
                                FontSize="{Binding Subtitle, Source={StaticResource FontSizes}}" FontWeight="Bold"
                                Height="44"
                                CornerRadius="2"
                                HorizontalAlignment="Stretch"/>
                    </Grid>

                    <!-- Bottom spacer -->
                    <Border Height="24"/>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
