я╗┐<Page
    x:Class="Revu.App.Views.ReviewPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:svc="using:Revu.App.Services"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:Revu.App.ViewModels"
    xmlns:converters="using:Revu.App.Converters"
    xmlns:controls="using:Revu.App.Controls"
    mc:Ignorable="d"
    Background="Transparent">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <converters:InverseBoolConverter x:Key="InverseBoolConverter"/>
    </Page.Resources>

    <Grid x:Name="RootGrid">
        <!-- Loading overlay -->
        <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                      HorizontalAlignment="Center" VerticalAlignment="Center"
                      Width="48" Height="48"
                      Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVis}}"/>

        <Grid RowDefinitions="Auto,*">

            <!-- Header: Back + Hero + Watch VOD -->
            <Grid Grid.Row="0" Padding="40,28,40,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Command="{x:Bind ViewModel.CancelCommand}"
                        Style="{StaticResource GhostIconButtonStyle}"
                        VerticalAlignment="Top"
                        Margin="0,16,12,0"
                        ToolTipService.ToolTip="Back">
                    <FontIcon Glyph="&#xE72B;" FontSize="{Binding BodyEmphasis, Source={StaticResource FontSizes}}"/>
                </Button>

                <controls:HeroHeader Grid.Column="1"
                                     EyebrowText="GAME ANALYSIS"
                                     Title="{x:Bind ViewModel.HeaderText, Mode=OneWay}"/>

            </Grid>

            <!-- Scrollable Content -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="24,8,24,24">
                <StackPanel Spacing="16" HorizontalAlignment="Stretch">

                    <!-- тАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬Р
                         HERO CARD: Champion + Result + KDA + VOD
                         тАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬Р -->
                    <Border Style="{StaticResource ElevatedCardStyle}"
                            BorderBrush="{StaticResource AccentGoldBrush}"
                            BorderThickness="1,1,1,2">
                        <StackPanel Spacing="14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Left: Champion + Result -->
                                <StackPanel Grid.Column="0" Spacing="2">
                                    <TextBlock Text="{x:Bind ViewModel.ChampionName, Mode=OneWay}"
                                               FontSize="{Binding HeroLarge, Source={StaticResource FontSizes}}" FontWeight="Bold"
                                               FontFamily="{StaticResource DisplayFont}"
                                               Foreground="{StaticResource AccentGoldBrush}"/>
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <TextBlock Text="{x:Bind ViewModel.ResultText, Mode=OneWay}"
                                                   FontSize="{Binding Title, Source={StaticResource FontSizes}}" FontWeight="Bold"/>
                                        <TextBlock FontSize="{Binding BodyEmphasis, Source={StaticResource FontSizes}}"
                                                   Foreground="{StaticResource SecondaryTextBrush}"
                                                   VerticalAlignment="Center">
                                            <Run Text="{x:Bind ViewModel.GameModeText, Mode=OneWay}"/>
                                        </TextBlock>
                                        <TextBlock Text="{x:Bind ViewModel.DurationText, Mode=OneWay}"
                                                   FontSize="{Binding BodyEmphasis, Source={StaticResource FontSizes}}"
                                                   Foreground="{StaticResource MutedTextBrush}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Right: KDA -->
                                <StackPanel Grid.Column="1" HorizontalAlignment="Right"
                                            VerticalAlignment="Center" Spacing="2">
                                    <TextBlock Text="{x:Bind ViewModel.KdaText, Mode=OneWay}"
                                               FontSize="{Binding Hero, Source={StaticResource FontSizes}}" FontWeight="Bold"
                                               FontFamily="{StaticResource DisplayFont}"
                                               Foreground="{StaticResource PrimaryTextBrush}"
                                               HorizontalAlignment="Right"/>
                                    <TextBlock Text="{x:Bind ViewModel.KdaRatioText, Mode=OneWay}"
                                               FontSize="{Binding BodyEmphasis, Source={StaticResource FontSizes}}"
                                               Foreground="{StaticResource SecondaryTextBrush}"
                                               HorizontalAlignment="Right"/>
                                </StackPanel>
                            </Grid>

                            <!-- VOD button (inside hero card) -->
                            <StackPanel Orientation="Horizontal" Spacing="12"
                                        Visibility="{x:Bind ViewModel.HasVod, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                                <Button Command="{x:Bind ViewModel.WatchVodCommand}"
                                        Style="{StaticResource GoldActionButtonStyle}"
                                        FontSize="{Binding BodyEmphasis, Source={StaticResource FontSizes}}" FontWeight="SemiBold"
                                        Height="36" Padding="16,0" CornerRadius="2"
                                        BorderThickness="1">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon Glyph="&#xE714;" FontSize="{Binding Subtitle, Source={StaticResource FontSizes}}"/>
                                        <TextBlock Text="Review VOD" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <TextBlock FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           VerticalAlignment="Center">
                                    <Run Text="{x:Bind ViewModel.BookmarkCount, Mode=OneWay}"/>
                                    <Run Text=" bookmarks"/>
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- тАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬Р
                         GAME STATS
                         тАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬Р -->
                    <controls:SectionTitle Text="GAME STATS" Margin="0,4,0,0"/>

                    <Grid ColumnSpacing="8" RowSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <controls:StatCard Grid.Row="0" Grid.Column="0"
                                           Label="DAMAGE" Value="{x:Bind ViewModel.DamageText, Mode=OneWay}"/>
                        <controls:StatCard Grid.Row="0" Grid.Column="1"
                                           Label="CS" Value="{x:Bind ViewModel.CsText, Mode=OneWay}"/>
                        <controls:StatCard Grid.Row="0" Grid.Column="2"
                                           Label="CS/MIN" Value="{x:Bind ViewModel.CsPerMinText, Mode=OneWay}"/>
                        <controls:StatCard Grid.Row="0" Grid.Column="3"
                                           Label="VISION" Value="{x:Bind ViewModel.VisionText, Mode=OneWay}"/>

                        <controls:StatCard Grid.Row="1" Grid.Column="0"
                                           Label="GOLD" Value="{x:Bind ViewModel.GoldText, Mode=OneWay}"/>
                        <controls:StatCard Grid.Row="1" Grid.Column="1"
                                           Label="KILL PART." Value="{x:Bind ViewModel.KillParticipationText, Mode=OneWay}"/>
                        <controls:StatCard Grid.Row="1" Grid.Column="2"
                                           Label="DMG TAKEN" Value="{x:Bind ViewModel.DamageTakenText, Mode=OneWay}"/>
                        <controls:StatCard Grid.Row="1" Grid.Column="3"
                                           Label="WARDS" Value="{x:Bind ViewModel.WardsPlacedText, Mode=OneWay}"/>
                    </Grid>

                    <!-- тАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬Р
                         OBJECTIVE PRACTICE (moved up, after stats)
                         тАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬Р -->
                    <controls:CornerBracketedCard
                            Visibility="{x:Bind ViewModel.HasObjectives, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                        <StackPanel Spacing="10">
                            <controls:SectionTitle Text="OBJECTIVE PRACTICE"/>
                            <TextBlock Text="Mark whether you actually practiced your active objectives in this game."
                                       FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       TextWrapping="Wrap"/>

                            <ItemsRepeater ItemsSource="{x:Bind ViewModel.ObjectiveAssessments, Mode=OneWay}">
                                <ItemsRepeater.Layout>
                                    <StackLayout Spacing="8"/>
                                </ItemsRepeater.Layout>
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ObjectiveAssessment">
                                        <Border Background="{StaticResource InputBackgroundBrush}"
                                                CornerRadius="2"
                                                BorderThickness="1,1,1,2"
                                                BorderBrush="{x:Bind AccentBrush}"
                                                Padding="14">
                                            <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="10">
                                                <!-- Row 0: Title + practiced toggle -->
                                                <Grid ColumnDefinitions="*,Auto">
                                                    <StackPanel Spacing="2">
                                                        <TextBlock Text="{x:Bind Title}"
                                                                   FontSize="{Binding Subtitle, Source={StaticResource FontSizes}}"
                                                                   FontWeight="Bold"
                                                                   Foreground="{StaticResource PrimaryTextBrush}"/>
                                                        <TextBlock Text="{x:Bind PhaseLabel}"
                                                                   FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                                                   Foreground="{StaticResource AccentBlueBrush}"/>
                                                    </StackPanel>
                                                    <ToggleButton Grid.Column="1"
                                                                  IsChecked="{x:Bind Practiced, Mode=TwoWay}"
                                                                  Style="{StaticResource HudPracticedToggleStyle}"/>
                                                </Grid>

                                                <!-- Row 1: Criteria -->
                                                <TextBlock Grid.Row="1"
                                                           Text="{x:Bind Criteria}"
                                                           FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                                           Foreground="{StaticResource SecondaryTextBrush}"
                                                           TextWrapping="Wrap"/>

                                                <!-- Row 2: General notes for this objective on this game -->
                                                <StackPanel Grid.Row="2" Spacing="4">
                                                    <TextBlock Text="GENERAL NOTES"
                                                               FontFamily="{StaticResource MonoFont}"
                                                               FontSize="{Binding Caption, Source={StaticResource FontSizes}}"
                                                               CharacterSpacing="200"
                                                               Foreground="{StaticResource MutedTextBrush}"/>
                                                    <TextBox Text="{x:Bind ExecutionNote, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                             PlaceholderText="How did this objective go in the game?"
                                                             TextWrapping="Wrap" AcceptsReturn="True"
                                                             MinHeight="52" FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                                             Background="{StaticResource CardBackgroundBrush}"
                                                             BorderBrush="{StaticResource SubtleBorderBrush}"
                                                             Foreground="{StaticResource PrimaryTextBrush}"
                                                             CornerRadius="2"/>
                                                </StackPanel>

                                                <!-- Row 3: v2.15.0 custom prompts for this objective (in-game + post-game phases) -->
                                                <StackPanel Grid.Row="3" Spacing="8"
                                                            Visibility="{x:Bind HasPrompts, Converter={StaticResource BoolToVis}}">
                                                    <TextBlock Text="CUSTOM PROMPTS"
                                                               FontFamily="{StaticResource MonoFont}"
                                                               FontSize="{Binding Caption, Source={StaticResource FontSizes}}"
                                                               CharacterSpacing="200"
                                                               Foreground="{StaticResource AccentPurpleBrush}"/>
                                                    <ItemsRepeater ItemsSource="{x:Bind Prompts, Mode=OneWay}">
                                                        <ItemsRepeater.Layout>
                                                            <StackLayout Spacing="8"/>
                                                        </ItemsRepeater.Layout>
                                                        <ItemsRepeater.ItemTemplate>
                                                            <DataTemplate x:DataType="vm:PromptAnswerField">
                                                                <StackPanel Spacing="6">
                                                                    <!-- v2.16.2: pre-game answers carry a small caps eyebrow
                                                                         so the user can tell read-only carryover from the
                                                                         editable in-game/post-game prompts below. -->
                                                                    <TextBlock Text="YOUR PRE-GAME ANSWER"
                                                                               FontFamily="{StaticResource MonoFont}"
                                                                               FontSize="{Binding Caption, Source={StaticResource FontSizes}}"
                                                                               CharacterSpacing="200"
                                                                               Foreground="{StaticResource AccentGoldBrush}"
                                                                               Visibility="{x:Bind IsPreGame, Converter={StaticResource BoolToVis}}"/>
                                                                    <!-- v2.15.0: body-size + primary text so prompt reads clearly. -->
                                                                    <TextBlock Text="{x:Bind Label}"
                                                                               FontFamily="{StaticResource BodyFont}"
                                                                               FontSize="{Binding BodyEmphasis, Source={StaticResource FontSizes}}"
                                                                               FontWeight="SemiBold"
                                                                               Foreground="{StaticResource PrimaryTextBrush}"
                                                                               TextWrapping="Wrap"/>
                                                                    <TextBox Text="{x:Bind AnswerText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                             PlaceholderText="Write your answer..."
                                                                             TextWrapping="Wrap" AcceptsReturn="True"
                                                                             MinHeight="44"
                                                                             IsReadOnly="{x:Bind IsPreGame}"
                                                                             FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                                                             Background="{StaticResource CardBackgroundBrush}"
                                                                             BorderBrush="{StaticResource SubtleBorderBrush}"
                                                                             Foreground="{StaticResource PrimaryTextBrush}"
                                                                             CornerRadius="2"/>
                                                                </StackPanel>
                                                            </DataTemplate>
                                                        </ItemsRepeater.ItemTemplate>
                                                    </ItemsRepeater>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>
                        </StackPanel>
                    </controls:CornerBracketedCard>

                    <!-- тАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬Р
                         SELF ASSESSMENT: Mental Rating + Performance
                         тАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬Р -->
                    <controls:CornerBracketedCard>
                        <StackPanel Spacing="10">

                            <!-- Mental Rating -->
                            <controls:SectionTitle Text="MENTAL RATING"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Slider Grid.Column="0"
                                        Value="{x:Bind ViewModel.MentalRating, Mode=TwoWay}"
                                        Minimum="1" Maximum="10"
                                        StepFrequency="1"
                                        TickFrequency="1"
                                        TickPlacement="Outside"
                                        VerticalAlignment="Center"/>

                                <TextBlock Grid.Column="1"
                                           Text="{x:Bind ViewModel.MentalRating, Mode=OneWay}"
                                           FontSize="{Binding HeroLarge, Source={StaticResource FontSizes}}" FontWeight="Bold"
                                           FontFamily="{StaticResource DisplayFont}"
                                           Margin="16,0,0,0"
                                           VerticalAlignment="Center"
                                           MinWidth="50"
                                           TextAlignment="Center"/>
                            </Grid>

                            <!-- v2.15.0: Performance Review block moved out of this card.
                                 See the "PERFORMANCE REVIEW (LEGACY)" card at the bottom of the page. -->
                        </StackPanel>
                    </controls:CornerBracketedCard>

                    <!-- тАв┬РтАв┬РтАв┬Р Mental Reflection (shown when mental <= 3) тАв┬РтАв┬РтАв┬Р -->
                    <Border Visibility="{x:Bind ViewModel.ShowMentalReflection, Mode=OneWay, Converter={StaticResource BoolToVis}}"
                            Background="{StaticResource WarningSurfaceBrush}"
                            BorderBrush="{StaticResource AccentGoldBrush}"
                            BorderThickness="2"
                            CornerRadius="2" Padding="16">
                        <StackPanel Spacing="8">
                            <controls:SectionTitle Text="MENTAL REFLECTION"/>

                            <TextBlock Text="What triggered the tilt?"
                                       FontSize="{Binding BodyEmphasis, Source={StaticResource FontSizes}}"
                                       Foreground="{StaticResource PrimaryTextBrush}"/>

                            <TextBox Text="{x:Bind ViewModel.MentalHandled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     PlaceholderText="What happened and how did you handle it?"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     MinHeight="60"
                                     FontSize="{Binding BodyEmphasis, Source={StaticResource FontSizes}}"
                                     Background="{StaticResource InputBackgroundBrush}"
                                     BorderBrush="{StaticResource SubtleBorderBrush}"
                                     Foreground="{StaticResource PrimaryTextBrush}"
                                     CornerRadius="2"/>
                        </StackPanel>
                    </Border>

                    <!-- тАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬Р
                         MATCHUP NOTES
                         тАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬Р -->
                    <controls:CornerBracketedCard>
                        <StackPanel Spacing="10">
                            <controls:SectionTitle Text="MATCHUP NOTES"/>
                            <TextBlock Text="{x:Bind ViewModel.MatchupHeading, Mode=OneWay}"
                                       FontSize="{Binding Subtitle, Source={StaticResource FontSizes}}"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource AccentBlueBrush}"/>

                            <TextBlock Text="Enemy champion"
                                       FontSize="{Binding BodyEmphasis, Source={StaticResource FontSizes}}"
                                       Foreground="{StaticResource PrimaryTextBrush}"/>
                            <TextBox Text="{x:Bind ViewModel.EnemyLaner, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     PlaceholderText="Enemy laner or main matchup champion"
                                     FontSize="{Binding BodyEmphasis, Source={StaticResource FontSizes}}"
                                     Background="{StaticResource InputBackgroundBrush}"
                                     BorderBrush="{StaticResource SubtleBorderBrush}"
                                     Foreground="{StaticResource PrimaryTextBrush}"
                                     CornerRadius="2"
                                     Height="36"/>

                            <TextBlock Text="What should you remember for this matchup?"
                                       FontSize="{Binding BodyEmphasis, Source={StaticResource FontSizes}}"
                                       Foreground="{StaticResource PrimaryTextBrush}"/>
                            <TextBox Text="{x:Bind ViewModel.MatchupNote, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     PlaceholderText="Lane-specific or matchup-specific reminders..."
                                     TextWrapping="Wrap" AcceptsReturn="True"
                                     MinHeight="70" FontSize="{Binding BodyEmphasis, Source={StaticResource FontSizes}}"
                                     Background="{StaticResource InputBackgroundBrush}"
                                     BorderBrush="{StaticResource SubtleBorderBrush}"
                                     Foreground="{StaticResource PrimaryTextBrush}"
                                     CornerRadius="2"/>

                            <ItemsRepeater ItemsSource="{x:Bind ViewModel.MatchupHistory, Mode=OneWay}"
                                           Visibility="{x:Bind ViewModel.HasMatchupHistory, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                                <ItemsRepeater.Layout>
                                    <StackLayout Spacing="6"/>
                                </ItemsRepeater.Layout>
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate x:DataType="vm:MatchupHistoryItem">
                                        <Border Background="{StaticResource InputBackgroundBrush}"
                                                CornerRadius="2"
                                                BorderThickness="1"
                                                BorderBrush="{StaticResource SubtleBorderBrush}"
                                                Padding="12">
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="{x:Bind MetaText}"
                                                           FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                                           Foreground="{StaticResource SecondaryTextBrush}"/>
                                                <TextBlock Text="{x:Bind Note}"
                                                           FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                                           Foreground="{StaticResource PrimaryTextBrush}"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>
                        </StackPanel>
                    </controls:CornerBracketedCard>

                    <!-- тАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬Р
                         NOTES + CONCEPT TAGS (merged)
                         тАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬Р -->
                    <controls:CornerBracketedCard>
                        <StackPanel Spacing="10">
                            <controls:SectionTitle Text="REVIEW NOTES"/>

                            <TextBlock Text="Additional review notes"
                                       FontSize="{Binding BodyEmphasis, Source={StaticResource FontSizes}}"
                                       Foreground="{StaticResource PrimaryTextBrush}"/>
                            <TextBox Text="{x:Bind ViewModel.ReviewNotes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     PlaceholderText="Anything else you want to remember from this game..."
                                     TextWrapping="Wrap" AcceptsReturn="True"
                                     MinHeight="70" FontSize="{Binding BodyEmphasis, Source={StaticResource FontSizes}}"
                                     Background="{StaticResource InputBackgroundBrush}"
                                     BorderBrush="{StaticResource SubtleBorderBrush}"
                                     Foreground="{StaticResource PrimaryTextBrush}"
                                     CornerRadius="2"/>

                            <TextBlock Text="Anything else you noticed (outside your objectives)"
                                       FontSize="{Binding BodyEmphasis, Source={StaticResource FontSizes}}"
                                       Foreground="{StaticResource PrimaryTextBrush}"/>
                            <TextBox Text="{x:Bind ViewModel.SpottedProblems, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     PlaceholderText="Patterns or issues that aren't one of your active objectives тАФ seeds for future ones."
                                     TextWrapping="Wrap" AcceptsReturn="True"
                                     MinHeight="70" FontSize="{Binding BodyEmphasis, Source={StaticResource FontSizes}}"
                                     Background="{StaticResource InputBackgroundBrush}"
                                     BorderBrush="{StaticResource SubtleBorderBrush}"
                                     Foreground="{StaticResource PrimaryTextBrush}"
                                     CornerRadius="2"/>

                            <!-- Separator -->
                            <Border Height="1"
                                    Background="{StaticResource SubtleBorderBrush}"
                                    Margin="0,4"/>

                            <!-- Concept Tags -->
                            <controls:SectionTitle Text="CONCEPT TAGS"/>

                            <ItemsRepeater ItemsSource="{x:Bind ViewModel.AllTags, Mode=OneWay}">
                                <ItemsRepeater.Layout>
                                    <UniformGridLayout Orientation="Horizontal"
                                                       MinItemWidth="150"
                                                       MinItemHeight="36"
                                                       MinColumnSpacing="6"
                                                       MinRowSpacing="6"
                                                       ItemsStretch="Fill"/>
                                </ItemsRepeater.Layout>
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ConceptTagItem">
                                        <ToggleButton IsChecked="{x:Bind IsSelected, Mode=TwoWay}"
                                                      FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                                      Height="34"
                                                      CornerRadius="2"
                                                      Padding="12,0"
                                                      HorizontalAlignment="Stretch"
                                                      Background="{x:Bind TagBackgroundBrush}"
                                                      Foreground="{StaticResource PrimaryTextBrush}"
                                                      BorderBrush="{x:Bind TagBorderBrush}"
                                                      BorderThickness="1">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <Border Width="10" Height="10" CornerRadius="5"
                                                        Background="{x:Bind TagAccentBrush}"/>
                                                <TextBlock Text="{x:Bind Name}"
                                                           VerticalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </ToggleButton>
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>
                        </StackPanel>
                    </controls:CornerBracketedCard>

                    <!-- тАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬Р
                         ATTRIBUTION + SESSION NOTE (v2.15.0 legacy-only)
                         тАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬Р -->
                    <!-- v2.15.0: Performance Review pushed to bottom so Objectives lead the page.
                         Legacy-only тАФ new reviews skip this entirely. -->
                    <controls:CornerBracketedCard
                        Visibility="{x:Bind ViewModel.ShowLegacyFields, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                        <StackPanel Spacing="10">
                            <controls:SectionTitle Text="PERFORMANCE REVIEW (LEGACY)"/>
                            <TextBlock Text="Read-only carryover from an earlier version of Revu. New reviews use Objectives + Custom Prompts instead."
                                       FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       TextWrapping="Wrap"/>

                            <!-- Ask coach about this game (deep-link to Coach page, hidden when flag off) -->
                            <Border x:Name="AskCoachBanner"
                                    Background="{StaticResource InputBackgroundBrush}"
                                    BorderBrush="{StaticResource SubtleBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="2"
                                    Padding="10,8"
                                    Visibility="Collapsed">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <FontIcon Grid.Column="0"
                                                  Glyph="&#xE8BD;"
                                                  FontSize="{Binding BodyEmphasis, Source={StaticResource FontSizes}}"
                                                  Foreground="{StaticResource AccentPurpleBrush}"
                                                  FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                                  Margin="0,0,8,0"
                                                  VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="Write your review first, then ask the coach about this game. The coach sees your review, the compacted stats, and your history."
                                                   FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                                   Foreground="{StaticResource SecondaryTextBrush}"
                                                   TextWrapping="Wrap"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                    <Button Grid.Column="1"
                                            Content="Ask coach about this game"
                                            Click="OnAskCoachAboutGameClick"
                                            Style="{StaticResource QuietActionButtonStyle}"
                                            FontSize="{Binding Meta, Source={StaticResource FontSizes}}" Height="28"
                                            Padding="12,0" CornerRadius="2"/>
                                </Grid>
                            </Border>

                            <TextBlock Text="What went well?"
                                       FontSize="{Binding BodyEmphasis, Source={StaticResource FontSizes}}" Foreground="{StaticResource PrimaryTextBrush}"/>
                            <TextBox Text="{x:Bind ViewModel.WentWell, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     PlaceholderText="Good plays, decisions, mechanics..."
                                     TextWrapping="Wrap" AcceptsReturn="True"
                                     MinHeight="70" FontSize="{Binding BodyEmphasis, Source={StaticResource FontSizes}}"
                                     Background="{StaticResource InputBackgroundBrush}"
                                     BorderBrush="{StaticResource SubtleBorderBrush}"
                                     Foreground="{StaticResource PrimaryTextBrush}"
                                     CornerRadius="2"/>

                            <TextBlock Text="What could improve?"
                                       FontSize="{Binding BodyEmphasis, Source={StaticResource FontSizes}}" Foreground="{StaticResource PrimaryTextBrush}"/>
                            <TextBox Text="{x:Bind ViewModel.Mistakes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     PlaceholderText="Deaths, missed plays, bad decisions..."
                                     TextWrapping="Wrap" AcceptsReturn="True"
                                     MinHeight="70" FontSize="{Binding BodyEmphasis, Source={StaticResource FontSizes}}"
                                     Background="{StaticResource InputBackgroundBrush}"
                                     BorderBrush="{StaticResource SubtleBorderBrush}"
                                     Foreground="{StaticResource PrimaryTextBrush}"
                                     CornerRadius="2"/>

                            <TextBlock Text="Focus for next game"
                                       FontSize="{Binding BodyEmphasis, Source={StaticResource FontSizes}}" Foreground="{StaticResource PrimaryTextBrush}"/>
                            <TextBox Text="{x:Bind ViewModel.FocusNext, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     PlaceholderText="What will you focus on improving?"
                                     FontSize="{Binding BodyEmphasis, Source={StaticResource FontSizes}}"
                                     Background="{StaticResource InputBackgroundBrush}"
                                     BorderBrush="{StaticResource SubtleBorderBrush}"
                                     Foreground="{StaticResource PrimaryTextBrush}"
                                     CornerRadius="2"
                                     Height="36"/>
                        </StackPanel>
                    </controls:CornerBracketedCard>

                    <controls:CornerBracketedCard
                        Visibility="{x:Bind ViewModel.ShowLegacyFields, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                        <StackPanel Spacing="10">
                            <controls:SectionTitle Text="ATTRIBUTION (LEGACY)"/>
                            <TextBlock Text="Carryover from an earlier review shape. Read-only reference тАФ new reviews don't collect this."
                                       FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       TextWrapping="Wrap"/>

                            <TextBlock Text="What most influenced the outcome?"
                                       FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                       Foreground="{StaticResource SecondaryTextBrush}"/>

                            <Grid ColumnSpacing="8" RowSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <RadioButton Grid.Row="0" Grid.Column="0"
                                             Content="My play" GroupName="Attribution"
                                             IsChecked="{x:Bind IsMyPlaySelected, Mode=OneWay}"
                                             Checked="OnAttributionChanged"
                                             Tag="My play"
                                             Foreground="{StaticResource PrimaryTextBrush}"/>
                                <RadioButton Grid.Row="0" Grid.Column="1"
                                             Content="Team effort" GroupName="Attribution"
                                             IsChecked="{x:Bind IsTeamEffortSelected, Mode=OneWay}"
                                             Checked="OnAttributionChanged"
                                             Tag="Team effort"
                                             Foreground="{StaticResource PrimaryTextBrush}"/>
                                <RadioButton Grid.Row="1" Grid.Column="0"
                                             Content="Teammates" GroupName="Attribution"
                                             IsChecked="{x:Bind IsTeammatesSelected, Mode=OneWay}"
                                             Checked="OnAttributionChanged"
                                             Tag="Teammates"
                                             Foreground="{StaticResource PrimaryTextBrush}"/>
                                <RadioButton Grid.Row="1" Grid.Column="1"
                                             Content="External" GroupName="Attribution"
                                             IsChecked="{x:Bind IsExternalSelected, Mode=OneWay}"
                                             Checked="OnAttributionChanged"
                                             Tag="External"
                                             Foreground="{StaticResource PrimaryTextBrush}"/>
                            </Grid>

                            <!-- Separator -->
                            <Border Height="1"
                                    Background="{StaticResource SubtleBorderBrush}"
                                    Margin="0,4"/>

                            <!-- Session Note -->
                            <controls:SectionTitle Text="SESSION NOTE"/>

                            <TextBox Text="{x:Bind ViewModel.ImprovementNote, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     PlaceholderText="Quick note for your session log..."
                                     FontSize="{Binding BodyEmphasis, Source={StaticResource FontSizes}}"
                                     Background="{StaticResource InputBackgroundBrush}"
                                     BorderBrush="{StaticResource SubtleBorderBrush}"
                                     Foreground="{StaticResource PrimaryTextBrush}"
                                     CornerRadius="2"
                                     Height="36"/>
                        </StackPanel>
                    </controls:CornerBracketedCard>

                    <!-- тАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬Р
                         ACTION BAR
                         тАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬РтАв┬Р -->

                    <!-- Validation + save behavior info -->
                    <StackPanel Spacing="4"
                                Visibility="{x:Bind ViewModel.HasValidationMessage, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{x:Bind ViewModel.ValidationMessage, Mode=OneWay}"
                                   FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                   Foreground="{StaticResource LossRedBrush}"
                                   TextWrapping="Wrap"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>

                    <TextBlock Text="{x:Bind ViewModel.SaveBehaviorText, Mode=OneWay}"
                               FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                               Foreground="{StaticResource MutedTextBrush}"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"/>

                    <!-- Equal-width action buttons -->
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Content="Cancel"
                                Command="{x:Bind ViewModel.CancelCommand}"
                                Style="{StaticResource SecondaryActionButtonStyle}"
                                FontSize="{Binding Subtitle, Source={StaticResource FontSizes}}"
                                Height="44"
                                CornerRadius="2"
                                HorizontalAlignment="Stretch"/>

                        <Button Grid.Column="1"
                                Content="Save Review"
                                Command="{x:Bind ViewModel.SaveReviewCommand}"
                                Style="{StaticResource PrimaryActionButtonStyle}"
                                FontSize="{Binding Subtitle, Source={StaticResource FontSizes}}" FontWeight="Bold"
                                Height="44"
                                CornerRadius="2"
                                HorizontalAlignment="Stretch"/>
                    </Grid>

                    <!-- Bottom spacer -->
                    <Border Height="24"/>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
