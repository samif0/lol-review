<Page
    x:Class="Revu.App.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:svc="using:Revu.App.Services"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:converters="using:Revu.App.Converters"
    xmlns:controls="using:Revu.App.Controls"
    mc:Ignorable="d"
    Background="Transparent">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </Page.Resources>

    <Grid x:Name="RootGrid">
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="40,30,40,40">
            <StackPanel Spacing="14" HorizontalAlignment="Stretch">

                <!-- ••• Hero ••• -->
                <controls:HeroHeader EyebrowText="CONFIGURATION"
                                     Title="Settings"
                                     Subtitle="VOD FOLDERS // BACKUPS // INTEGRATIONS"/>

                <!-- ••• Ascent VOD Recordings Section ••• -->
                <controls:CornerBracketedCard>
                    <StackPanel Spacing="8">
                        <controls:SectionTitle Text="ASCENT VOD RECORDINGS"/>

                        <TextBlock Text="Point this to your Ascent recordings folder to enable VOD playback and timestamped bookmarks in your reviews."
                                   FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   TextWrapping="Wrap"/>

                        <!-- Folder path row -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBox Grid.Column="0"
                                     Text="{x:Bind ViewModel.AscentFolder, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     PlaceholderText="e.g. C:\Users\you\Videos\Ascent"
                                     FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                     Background="{StaticResource InputBackgroundBrush}"
                                     BorderBrush="{StaticResource SubtleBorderBrush}"
                                     Foreground="{StaticResource PrimaryTextBrush}"
                                     CornerRadius="2"
                                     Height="36"
                                     Margin="0,0,8,0"/>

                            <Button Grid.Column="1"
                                    Content="Browse"
                                    Command="{x:Bind ViewModel.BrowseAscentFolderCommand}"
                                    Style="{StaticResource QuietActionButtonStyle}"
                                    FontSize="{Binding Body, Source={StaticResource FontSizes}}" Height="36"
                                    Padding="16,0" CornerRadius="2"/>
                        </Grid>

                        <!-- Status text -->
                        <TextBlock Text="{x:Bind ViewModel.AscentStatus, Mode=OneWay}"
                                   FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                   Foreground="{StaticResource SecondaryTextBrush}"/>

                        <!-- Action buttons -->
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Content="Scan for VODs"
                                    Click="OnScanVodsClick"
                                    Style="{StaticResource PrimaryActionButtonStyle}"
                                    FontSize="{Binding Meta, Source={StaticResource FontSizes}}" Height="30"
                                    Padding="12,0" CornerRadius="2"
                                    HorizontalAlignment="Left"/>
                            <Button Content="Clear Ascent Folder"
                                    Command="{x:Bind ViewModel.ClearAscentFolderCommand}"
                                    Style="{StaticResource SecondaryActionButtonStyle}"
                                    FontSize="{Binding Meta, Source={StaticResource FontSizes}}" Height="30"
                                    Padding="12,0" CornerRadius="2"
                                    HorizontalAlignment="Left"/>
                        </StackPanel>

                        <TextBlock x:Name="ScanResultText"
                                   FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                   Foreground="{StaticResource WinGreenBrush}"
                                   Visibility="Collapsed"/>
                    </StackPanel>
                </controls:CornerBracketedCard>

                <!-- ••• Clip Settings Section ••• -->
                <controls:CornerBracketedCard>
                    <StackPanel Spacing="8">
                        <controls:SectionTitle Text="CLIP SETTINGS"/>

                        <!-- ffmpeg status -->
                        <TextBlock Text="{x:Bind ViewModel.FfmpegStatusText, Mode=OneWay}"
                                   FontSize="{Binding Meta, Source={StaticResource FontSizes}}"/>

                        <TextBlock Text="Save short video clips from your VOD recordings. Clips are stored separately from Ascent recordings."
                                   FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   TextWrapping="Wrap"/>

                        <!-- Clips folder path row -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="Folder:"
                                       FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                       Foreground="{StaticResource PrimaryTextBrush}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"/>

                            <TextBox Grid.Column="1"
                                     Text="{x:Bind ViewModel.ClipsFolder, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                     Background="{StaticResource InputBackgroundBrush}"
                                     BorderBrush="{StaticResource SubtleBorderBrush}"
                                     Foreground="{StaticResource PrimaryTextBrush}"
                                     CornerRadius="2"
                                     Height="36"
                                     Margin="0,0,8,0"/>

                            <Button Grid.Column="2"
                                    Content="Browse"
                                    Command="{x:Bind ViewModel.BrowseClipsFolderCommand}"
                                    Style="{StaticResource QuietActionButtonStyle}"
                                    FontSize="{Binding Body, Source={StaticResource FontSizes}}" Height="36"
                                    Padding="16,0" CornerRadius="2"/>
                        </Grid>

                        <!-- Max size row -->
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="Max folder size (MB):"
                                       FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                       Foreground="{StaticResource PrimaryTextBrush}"
                                       VerticalAlignment="Center"/>

                            <TextBox Text="{x:Bind ViewModel.ClipsMaxSizeMbText, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                     Width="120" Height="36"
                                     FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                     CornerRadius="2"
                                     Background="#1a1a24"
                                     Foreground="#e8e8f0"
                                     BorderBrush="#1e1e2e"/>

                            <TextBlock Text="{x:Bind ViewModel.CurrentClipUsage, Mode=OneWay}"
                                       FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <TextBlock Text="Oldest clips are automatically deleted when the folder exceeds this size."
                                   FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                   Foreground="{StaticResource SecondaryTextBrush}"/>
                    </StackPanel>
                </controls:CornerBracketedCard>

                <!-- ••• Database Backup Section ••• -->
                <controls:CornerBracketedCard>
                    <StackPanel Spacing="8">
                        <controls:SectionTitle Text="DATABASE BACKUP"/>

                        <TextBlock Text="Back up your database automatically when the app starts. Keeps last 5 backups."
                                   FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   TextWrapping="Wrap"/>

                        <CheckBox Content="Enable automatic backups"
                                  IsChecked="{x:Bind ViewModel.BackupEnabled, Mode=TwoWay}"
                                  FontSize="{Binding BodyEmphasis, Source={StaticResource FontSizes}}"
                                  Foreground="{StaticResource PrimaryTextBrush}"/>

                        <TextBlock Text="Backup folder:"
                                   FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                   Foreground="{StaticResource PrimaryTextBrush}"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBox Grid.Column="0"
                                     Text="{x:Bind ViewModel.BackupFolder, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                     Background="{StaticResource InputBackgroundBrush}"
                                     BorderBrush="{StaticResource SubtleBorderBrush}"
                                     Foreground="{StaticResource PrimaryTextBrush}"
                                     CornerRadius="2"
                                     Height="36"
                                     Margin="0,0,8,0"/>

                            <Button Grid.Column="1"
                                    Content="Browse"
                                    Command="{x:Bind ViewModel.BrowseBackupFolderCommand}"
                                    Style="{StaticResource QuietActionButtonStyle}"
                                    FontSize="{Binding Body, Source={StaticResource FontSizes}}" Height="36"
                                    Padding="16,0" CornerRadius="2"/>
                        </Grid>
                    </StackPanel>
                </controls:CornerBracketedCard>

                <!-- ••• Tilt Fix Mode Section ••• -->
                <controls:CornerBracketedCard>
                    <StackPanel Spacing="8">
                        <controls:SectionTitle Text="TILT FIX MODE"/>

                        <TextBlock Text="Enable mood check-ins before games, session intention setting, and mental reflection prompts when mental rating is low."
                                   FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   TextWrapping="Wrap"/>

                        <ToggleSwitch IsOn="{x:Bind ViewModel.TiltFixEnabled, Mode=TwoWay}"
                                      Header="Enable Tilt Fix features"
                                      OnContent="On" OffContent="Off"/>
                    </StackPanel>
                </controls:CornerBracketedCard>

                <!-- ••• Review Save Behavior ••• -->
                <controls:CornerBracketedCard>
                    <StackPanel Spacing="8">
                        <controls:SectionTitle Text="REVIEW SAVE BEHAVIOR"/>

                        <TextBlock Text="Control whether the review screen requires written review content before save. When this is off, you can intentionally save a game as reviewed even if you leave the main review notes blank."
                                   FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   TextWrapping="Wrap"/>

                        <ToggleSwitch IsOn="{x:Bind ViewModel.RequireReviewNotes, Mode=TwoWay}"
                                      Header="Require review notes before save"
                                      OnContent="Required"
                                      OffContent="Optional"/>
                    </StackPanel>
                </controls:CornerBracketedCard>

                <!-- ••• App Version & Updates Section ••• -->
                <controls:CornerBracketedCard>
                    <StackPanel Spacing="8">
                        <controls:SectionTitle Text="APP VERSION"/>

                        <TextBlock Text="{x:Bind ViewModel.AppVersion, Mode=OneWay}"
                                   FontSize="{Binding Subtitle, Source={StaticResource FontSizes}}" FontWeight="SemiBold"
                                   Foreground="{StaticResource PrimaryTextBrush}"/>

                        <TextBlock Text="Installed clients check for updates automatically when the app launches."
                                   FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   TextWrapping="Wrap"/>

                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Content="Check for Updates"
                                    Command="{x:Bind ViewModel.CheckForUpdateCommand}"
                                    Style="{StaticResource QuietActionButtonStyle}"
                                    FontSize="{Binding Body, Source={StaticResource FontSizes}}" Height="32"
                                    Padding="14,0" CornerRadius="2"/>

                            <Button Content="Download &amp; Restart"
                                    Command="{x:Bind ViewModel.DownloadAndApplyUpdateCommand}"
                                    Visibility="{x:Bind ViewModel.IsUpdateAvailable, Mode=OneWay, Converter={StaticResource BoolToVis}}"
                                    Style="{StaticResource GoldActionButtonStyle}"
                                    FontSize="{Binding Body, Source={StaticResource FontSizes}}" Height="32"
                                    Padding="14,0" CornerRadius="2"/>
                        </StackPanel>

                        <TextBlock Text="{x:Bind ViewModel.UpdateStatusText, Mode=OneWay}"
                                   FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                   Foreground="{x:Bind ViewModel.UpdateStatusBrush, Mode=OneWay}"/>
                    </StackPanel>
                </controls:CornerBracketedCard>

                <!-- ••• AI Coach Section ••• -->
                <controls:CornerBracketedCard>
                    <StackPanel Spacing="10">
                        <Grid>
                            <controls:SectionTitle Text="AI COACH"/>
                            <Border Background="{StaticResource AccentPurpleBrush}"
                                    CornerRadius="3"
                                    Padding="5,1"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Margin="80,2,0,0">
                                <TextBlock Text="ALPHA"
                                           FontSize="{Binding Caption, Source={StaticResource FontSizes}}"
                                           FontWeight="Bold"
                                           Foreground="#07060B"/>
                            </Border>
                        </Grid>

                        <!-- Master enable toggle -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Spacing="2">
                                <TextBlock Text="Enable Coach (alpha)"
                                           FontSize="{Binding BodyEmphasis, Source={StaticResource FontSizes}}"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource PrimaryTextBrush}"/>
                                <TextBlock Text="Still experimental. Answers may be wrong. You can turn this on or off at any time; it only affects your UI."
                                           FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                            <ToggleSwitch x:Name="CoachEnableToggle"
                                          Grid.Column="1"
                                          VerticalAlignment="Center"
                                          Toggled="OnCoachEnableToggled"/>
                        </Grid>

                        <Border x:Name="CoachSettingsBody"
                                Visibility="Collapsed">
                            <StackPanel Spacing="10">

                        <TextBlock Text="{x:Bind CoachViewModel.ProviderHint, Mode=OneWay}"
                                   FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   TextWrapping="Wrap"/>

                        <TextBlock Text="Get a free Google AI Studio API key at https://aistudio.google.com/apikey"
                                   FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,4"
                                   IsTextSelectionEnabled="True"/>

                        <!-- Core coach runtime (~30 MB). Required for every provider. -->
                        <StackPanel Spacing="2" Margin="0,4,0,4">
                            <TextBlock Text="Coach runtime (~30 MB)"
                                       FontSize="{Binding Body, Source={StaticResource FontSizes}}" FontWeight="SemiBold"/>
                            <TextBlock Text="Embedded Python sidecar. Required to use any coach feature."
                                       FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="2">
                                <TextBlock FontSize="{Binding Body, Source={StaticResource FontSizes}}" FontWeight="SemiBold">
                                    <Run Text="Status:"/>
                                    <Run Text="{x:Bind CoachViewModel.InstallStatus, Mode=OneWay}"/>
                                </TextBlock>
                                <ProgressBar Value="{x:Bind CoachViewModel.InstallProgress, Mode=OneWay}"
                                             Minimum="0" Maximum="100"
                                             Height="4"
                                             Visibility="{x:Bind CoachViewModel.IsInstalling, Mode=OneWay, Converter={StaticResource BoolToVis}}"/>
                            </StackPanel>

                            <Button Grid.Column="1"
                                    Content="Install"
                                    Command="{x:Bind CoachViewModel.InstallCoreCommand}"
                                    Style="{StaticResource QuietActionButtonStyle}"
                                    FontSize="{Binding Body, Source={StaticResource FontSizes}}" Height="32"
                                    Padding="16,0" CornerRadius="2"
                                    Margin="0,0,6,0"/>

                            <Button Grid.Column="2"
                                    Content="Uninstall"
                                    Command="{x:Bind CoachViewModel.UninstallCoreCommand}"
                                    Style="{StaticResource QuietActionButtonStyle}"
                                    FontSize="{Binding Body, Source={StaticResource FontSizes}}" Height="32"
                                    Padding="16,0" CornerRadius="2"/>
                        </Grid>

                        <!-- ML extras pack (~230 MB). Optional; enables /concepts/* endpoints. -->
                        <StackPanel Spacing="2" Margin="0,10,0,4">
                            <TextBlock Text="ML extras (~230 MB)"
                                       FontSize="{Binding Body, Source={StaticResource FontSizes}}" FontWeight="SemiBold"/>
                            <TextBlock Text="Adds sentence embeddings and clustering for concept analysis. Optional — install later if you want coach to index concepts across your games."
                                       FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="2">
                                <TextBlock FontSize="{Binding Body, Source={StaticResource FontSizes}}" FontWeight="SemiBold">
                                    <Run Text="Status:"/>
                                    <Run Text="{x:Bind CoachViewModel.MlInstallStatus, Mode=OneWay}"/>
                                </TextBlock>
                                <ProgressBar Value="{x:Bind CoachViewModel.MlInstallProgress, Mode=OneWay}"
                                             Minimum="0" Maximum="100"
                                             Height="4"
                                             Visibility="{x:Bind CoachViewModel.IsInstallingMl, Mode=OneWay, Converter={StaticResource BoolToVis}}"/>
                            </StackPanel>

                            <Button Grid.Column="1"
                                    Content="Install"
                                    Command="{x:Bind CoachViewModel.InstallMlCommand}"
                                    Style="{StaticResource QuietActionButtonStyle}"
                                    FontSize="{Binding Body, Source={StaticResource FontSizes}}" Height="32"
                                    Padding="16,0" CornerRadius="2"
                                    Margin="0,0,6,0"/>

                            <Button Grid.Column="2"
                                    Content="Uninstall"
                                    Command="{x:Bind CoachViewModel.UninstallMlCommand}"
                                    Style="{StaticResource QuietActionButtonStyle}"
                                    FontSize="{Binding Body, Source={StaticResource FontSizes}}" Height="32"
                                    Padding="16,0" CornerRadius="2"/>
                        </Grid>

                        <!-- Provider selection -->
                        <Grid Margin="0,6,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="Provider"
                                       FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       VerticalAlignment="Center"/>

                            <ComboBox Grid.Column="1"
                                      ItemsSource="{x:Bind CoachViewModel.ProviderOptions}"
                                      SelectedItem="{x:Bind CoachViewModel.SelectedProvider, Mode=TwoWay}"
                                      Height="32"
                                      MinWidth="200"
                                      FontSize="{Binding Body, Source={StaticResource FontSizes}}"/>
                        </Grid>

                        <!-- Ollama settings -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="Ollama URL"
                                       FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       VerticalAlignment="Center"/>

                            <TextBox Grid.Column="1"
                                     Text="{x:Bind CoachViewModel.OllamaBaseUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     PlaceholderText="http://localhost:11434"
                                     FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                     Background="{StaticResource InputBackgroundBrush}"
                                     BorderBrush="{StaticResource SubtleBorderBrush}"
                                     Foreground="{StaticResource PrimaryTextBrush}"
                                     CornerRadius="2"
                                     Height="32"/>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="Ollama model"
                                       FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       VerticalAlignment="Center"/>

                            <TextBox Grid.Column="1"
                                     Text="{x:Bind CoachViewModel.OllamaModel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     PlaceholderText="gemma4:e4b"
                                     FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                     Background="{StaticResource InputBackgroundBrush}"
                                     BorderBrush="{StaticResource SubtleBorderBrush}"
                                     Foreground="{StaticResource PrimaryTextBrush}"
                                     CornerRadius="2"
                                     Height="32"/>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="Vision model"
                                       FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       VerticalAlignment="Center"/>

                            <TextBox Grid.Column="1"
                                     Text="{x:Bind CoachViewModel.OllamaVisionModel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     PlaceholderText="gemma4:e4b"
                                     FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                     Background="{StaticResource InputBackgroundBrush}"
                                     BorderBrush="{StaticResource SubtleBorderBrush}"
                                     Foreground="{StaticResource PrimaryTextBrush}"
                                     CornerRadius="2"
                                     Height="32"/>
                        </Grid>

                        <!-- Google AI -->
                        <Grid Margin="0,6,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="Google AI model"
                                       FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       VerticalAlignment="Center"/>

                            <TextBox Grid.Column="1"
                                     Text="{x:Bind CoachViewModel.GoogleAiModel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     PlaceholderText="gemini-2.5-flash"
                                     FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                     Background="{StaticResource InputBackgroundBrush}"
                                     BorderBrush="{StaticResource SubtleBorderBrush}"
                                     Foreground="{StaticResource PrimaryTextBrush}"
                                     CornerRadius="2"
                                     Height="32"/>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="Google AI key"
                                       FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       VerticalAlignment="Center"/>

                            <Grid Grid.Column="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <PasswordBox Grid.Column="0"
                                             x:Name="GoogleAiApiKeyBox"
                                             PasswordChanged="OnGoogleAiApiKeyChanged"
                                             PlaceholderText="(leave blank to keep existing)"
                                             FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                             Background="{StaticResource InputBackgroundBrush}"
                                             BorderBrush="{StaticResource SubtleBorderBrush}"
                                             Foreground="{StaticResource PrimaryTextBrush}"
                                             CornerRadius="2"
                                             Height="32"/>
                                <Button Grid.Column="1"
                                        Content="Clear"
                                        Command="{x:Bind CoachViewModel.ClearGoogleAiKeyCommand}"
                                        Visibility="{x:Bind CoachViewModel.GoogleAiKeyStored, Mode=OneWay, Converter={StaticResource BoolToVis}}"
                                        Style="{StaticResource QuietActionButtonStyle}"
                                        FontSize="{Binding Meta, Source={StaticResource FontSizes}}" Height="32"
                                        Padding="10,0" CornerRadius="2"
                                        Margin="6,0,0,0"/>
                            </Grid>
                        </Grid>

                        <Grid Visibility="{x:Bind CoachViewModel.GoogleAiKeyStored, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="1"
                                       Text="âœ“ Key saved to Windows Credential Manager. Leave blank above to keep it."
                                       FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                       Foreground="{StaticResource SecondaryTextBrush}"/>
                        </Grid>

                        <!-- OpenRouter -->
                        <Grid Margin="0,6,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="OpenRouter model"
                                       FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       VerticalAlignment="Center"/>

                            <TextBox Grid.Column="1"
                                     Text="{x:Bind CoachViewModel.OpenRouterModel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     PlaceholderText="google/gemma-3-27b-it"
                                     FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                     Background="{StaticResource InputBackgroundBrush}"
                                     BorderBrush="{StaticResource SubtleBorderBrush}"
                                     Foreground="{StaticResource PrimaryTextBrush}"
                                     CornerRadius="2"
                                     Height="32"/>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="OpenRouter key"
                                       FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       VerticalAlignment="Center"/>

                            <Grid Grid.Column="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <PasswordBox Grid.Column="0"
                                             x:Name="OpenRouterApiKeyBox"
                                             PasswordChanged="OnOpenRouterApiKeyChanged"
                                             PlaceholderText="(leave blank to keep existing)"
                                             FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                             Background="{StaticResource InputBackgroundBrush}"
                                             BorderBrush="{StaticResource SubtleBorderBrush}"
                                             Foreground="{StaticResource PrimaryTextBrush}"
                                             CornerRadius="2"
                                             Height="32"/>
                                <Button Grid.Column="1"
                                        Content="Clear"
                                        Command="{x:Bind CoachViewModel.ClearOpenRouterKeyCommand}"
                                        Visibility="{x:Bind CoachViewModel.OpenRouterKeyStored, Mode=OneWay, Converter={StaticResource BoolToVis}}"
                                        Style="{StaticResource QuietActionButtonStyle}"
                                        FontSize="{Binding Meta, Source={StaticResource FontSizes}}" Height="32"
                                        Padding="10,0" CornerRadius="2"
                                        Margin="6,0,0,0"/>
                            </Grid>
                        </Grid>

                        <Grid Visibility="{x:Bind CoachViewModel.OpenRouterKeyStored, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="1"
                                       Text="âœ“ Key saved to Windows Credential Manager. Leave blank above to keep it."
                                       FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                       Foreground="{StaticResource SecondaryTextBrush}"/>
                        </Grid>

                        <!-- Save config -->
                        <Button Content="Save coach config"
                                Command="{x:Bind CoachViewModel.SaveConfigCommand}"
                                Style="{StaticResource QuietActionButtonStyle}"
                                FontSize="{Binding Body, Source={StaticResource FontSizes}}" Height="32"
                                Padding="16,0" CornerRadius="2"
                                HorizontalAlignment="Left"
                                Margin="0,6,0,0"/>

                        <!-- Test prompt -->
                        <Border Background="{StaticResource InputBackgroundBrush}"
                                BorderBrush="{StaticResource SubtleBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="2"
                                Padding="10"
                                Margin="0,12,0,0">
                            <StackPanel Spacing="6">
                                <TextBlock Text="TEST CONNECTION"
                                           FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource SecondaryTextBrush}"/>

                                <TextBox Text="{x:Bind CoachViewModel.TestPromptText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         PlaceholderText="Prompt for smoke test"
                                         FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         MinHeight="32"
                                         Height="32"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Foreground="{StaticResource PrimaryTextBrush}"/>

                                <Button Content="Send test prompt"
                                        Command="{x:Bind CoachViewModel.TestConnectionCommand}"
                                        Style="{StaticResource QuietActionButtonStyle}"
                                        FontSize="{Binding Body, Source={StaticResource FontSizes}}" Height="30"
                                        Padding="14,0" CornerRadius="2"
                                        HorizontalAlignment="Left"/>

                                <TextBlock Text="{x:Bind CoachViewModel.TestResult, Mode=OneWay}"
                                           FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <!-- How to use -->
                        <TextBlock FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,8,0,0">
                            <Run Text="Once the test prompt works, open the Coach tab in the sidebar to chat with your data."/>
                        </TextBlock>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </controls:CornerBracketedCard>

                <!-- ••• Save Button Row ••• -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="{x:Bind ViewModel.SaveStatusText, Mode=OneWay}"
                               FontSize="{Binding BodyEmphasis, Source={StaticResource FontSizes}}" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>

                    <Button Grid.Column="1"
                            Content="Save Settings"
                            Command="{x:Bind ViewModel.SaveCommand}"
                            Style="{StaticResource PrimaryActionButtonStyle}"
                            FontSize="{Binding Subtitle, Source={StaticResource FontSizes}}" FontWeight="Bold"
                            Height="40" Padding="24,0"
                            CornerRadius="2"/>
                </Grid>

                <!-- Revu account (compact status; full flow lives in onboarding) -->
                <controls:CornerBracketedCard CardBorderBrush="{StaticResource AccentBlueBrush}">
                    <StackPanel Spacing="12">
                        <controls:SectionTitle Text="REVU ACCOUNT"/>

                        <!-- Logged-in: show profile + Riot ID/Region -->
                        <StackPanel Spacing="10"
                                    Visibility="{x:Bind IsState(ViewModel.RiotAuthState, 'loggedIn'), Mode=OneWay}">
                            <TextBlock FontFamily="{StaticResource BodyFont}"
                                       FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                       Foreground="{StaticResource PrimaryTextBrush}"
                                       TextWrapping="Wrap">
                                <Run Text="Logged in as "/>
                                <Run Text="{x:Bind ViewModel.RiotAuthLoggedInEmail, Mode=OneWay}"
                                     FontWeight="SemiBold"/>
                                <Run Text="."/>
                            </TextBlock>

                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="1*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Spacing="4">
                                    <TextBlock Text="RIOT ID"
                                               FontFamily="{StaticResource MonoFont}"
                                               FontSize="{Binding Caption, Source={StaticResource FontSizes}}"
                                               CharacterSpacing="250"
                                               Foreground="{StaticResource SecondaryTextBrush}"/>
                                    <TextBox Text="{x:Bind ViewModel.RiotId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             PlaceholderText="gameName#tagLine"
                                             FontFamily="{StaticResource MonoFont}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="4">
                                    <TextBlock Text="REGION"
                                               FontFamily="{StaticResource MonoFont}"
                                               FontSize="{Binding Caption, Source={StaticResource FontSizes}}"
                                               CharacterSpacing="250"
                                               Foreground="{StaticResource SecondaryTextBrush}"/>
                                    <ComboBox SelectedValue="{x:Bind ViewModel.RiotRegion, Mode=TwoWay}"
                                              HorizontalAlignment="Stretch"
                                              PlaceholderText="Pick region">
                                        <x:String>na1</x:String>
                                        <x:String>br1</x:String>
                                        <x:String>la1</x:String>
                                        <x:String>la2</x:String>
                                        <x:String>euw1</x:String>
                                        <x:String>eun1</x:String>
                                        <x:String>tr1</x:String>
                                        <x:String>ru</x:String>
                                        <x:String>kr</x:String>
                                        <x:String>jp1</x:String>
                                        <x:String>oc1</x:String>
                                        <x:String>ph2</x:String>
                                        <x:String>sg2</x:String>
                                        <x:String>th2</x:String>
                                        <x:String>tw2</x:String>
                                        <x:String>vn2</x:String>
                                    </ComboBox>
                                </StackPanel>
                            </Grid>

                            <Button Content="LOG OUT"
                                    Command="{x:Bind ViewModel.RiotAuthLogoutCommand}"
                                    Style="{StaticResource PrimaryActionButtonStyle}"
                                    HorizontalAlignment="Stretch"
                                    Height="40"
                                    IsEnabled="{x:Bind Not(ViewModel.RiotAuthBusy), Mode=OneWay}"/>
                        </StackPanel>

                        <!-- Logged-out: inline login/signup form (parallel to onboarding auth) -->
                        <StackPanel Spacing="12"
                                    Visibility="{x:Bind IsState(ViewModel.RiotAuthState, 'loggedOut'), Mode=OneWay}">
                            <TextBlock Text="Log in with your email, or enter an invite code if you're signing up for the first time."
                                       FontFamily="{StaticResource BodyFont}"
                                       FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       TextWrapping="Wrap"/>

                            <StackPanel Spacing="4">
                                <TextBlock Text="EMAIL"
                                           FontFamily="{StaticResource MonoFont}"
                                           FontSize="{Binding Caption, Source={StaticResource FontSizes}}"
                                           CharacterSpacing="250"
                                           Foreground="{StaticResource SecondaryTextBrush}"/>
                                <TextBox Text="{x:Bind ViewModel.RiotAuthEmail, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         PlaceholderText="you@example.com"
                                         FontFamily="{StaticResource MonoFont}"
                                         InputScope="EmailSmtpAddress"/>
                            </StackPanel>

                            <StackPanel Spacing="4">
                                <TextBlock Text="INVITE CODE (SIGNUP ONLY — OPTIONAL)"
                                           FontFamily="{StaticResource MonoFont}"
                                           FontSize="{Binding Caption, Source={StaticResource FontSizes}}"
                                           CharacterSpacing="250"
                                           Foreground="{StaticResource SecondaryTextBrush}"/>
                                <TextBox Text="{x:Bind ViewModel.RiotAuthInviteCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         PlaceholderText="Leave blank if you already have an account"
                                         FontFamily="{StaticResource MonoFont}"
                                         CharacterCasing="Upper"/>
                            </StackPanel>

                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0"
                                        Content="LOG IN"
                                        Command="{x:Bind ViewModel.RiotAuthLoginCommand}"
                                        Style="{StaticResource PrimaryActionButtonStyle}"
                                        IsEnabled="{x:Bind Not(ViewModel.RiotAuthBusy), Mode=OneWay}"
                                        HorizontalAlignment="Stretch"
                                        Height="40"/>
                                <Button Grid.Column="1"
                                        Content="SIGN UP"
                                        Command="{x:Bind ViewModel.RiotAuthSignupCommand}"
                                        IsEnabled="{x:Bind Not(ViewModel.RiotAuthBusy), Mode=OneWay}"
                                        HorizontalAlignment="Stretch"
                                        Height="40"/>
                            </Grid>
                        </StackPanel>

                        <!-- Code-sent: OTP entry after Send Code / Signup fires -->
                        <StackPanel Spacing="12"
                                    Visibility="{x:Bind IsState(ViewModel.RiotAuthState, 'codeSent'), Mode=OneWay}">
                            <TextBlock Text="{x:Bind ViewModel.RiotAuthInfo, Mode=OneWay}"
                                       FontFamily="{StaticResource BodyFont}"
                                       FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                       Foreground="{StaticResource PrimaryTextBrush}"
                                       TextWrapping="Wrap"/>

                            <StackPanel Spacing="4">
                                <TextBlock Text="CODE"
                                           FontFamily="{StaticResource MonoFont}"
                                           FontSize="{Binding Caption, Source={StaticResource FontSizes}}"
                                           CharacterSpacing="250"
                                           Foreground="{StaticResource SecondaryTextBrush}"/>
                                <TextBox Text="{x:Bind ViewModel.RiotAuthOtpCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         PlaceholderText="8-character code from email"
                                         FontFamily="{StaticResource MonoFont}"
                                         CharacterCasing="Upper"/>
                            </StackPanel>

                            <Button Content="VERIFY"
                                    Command="{x:Bind ViewModel.RiotAuthVerifyCommand}"
                                    Style="{StaticResource PrimaryActionButtonStyle}"
                                    IsEnabled="{x:Bind Not(ViewModel.RiotAuthBusy), Mode=OneWay}"
                                    HorizontalAlignment="Stretch"
                                    Height="40"/>

                            <HyperlinkButton Command="{x:Bind ViewModel.RiotAuthBackToEmailCommand}"
                                             Content="Wrong email? Go back"
                                             Padding="0"
                                             HorizontalAlignment="Center"
                                             IsEnabled="{x:Bind Not(ViewModel.RiotAuthBusy), Mode=OneWay}"/>
                        </StackPanel>

                        <TextBlock Text="{x:Bind ViewModel.RiotAuthError, Mode=OneWay}"
                                   FontFamily="{StaticResource BodyFont}"
                                   FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                   Foreground="{StaticResource LossRedBrush}"
                                   TextWrapping="Wrap"
                                   Visibility="{x:Bind HasText(ViewModel.RiotAuthError), Mode=OneWay}"/>
                    </StackPanel>
                </controls:CornerBracketedCard>

                <!-- Bottom spacer -->
                <Border Height="24"/>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
