<Page
    x:Class="Revu.App.Views.GamesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:Revu.App.ViewModels"
    xmlns:controls="using:Revu.App.Controls"
    xmlns:converters="using:Revu.App.Converters"
    mc:Ignorable="d"
    Background="Transparent">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <Style x:Key="GamesSegmentButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryActionButtonStyle}">
            <Setter Property="Height" Value="32"/>
            <Setter Property="MinWidth" Value="86"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="FontFamily" Value="{StaticResource MonoFont}"/>
            <Setter Property="FontSize" Value="{Binding Meta, Source={StaticResource FontSizes}}"/>
            <Setter Property="CornerRadius" Value="2"/>
        </Style>
    </Page.Resources>

    <Grid x:Name="RootGrid" Padding="40,30,40,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <controls:HeroHeader Grid.Row="0"
                             EyebrowText="OBJECTIVE LOOP"
                             Title="Games"
                             Subtitle="QUEUE // TODAY // HISTORY // VOD"
                             Margin="0,0,0,16"/>

        <Border Grid.Row="1"
                Background="{StaticResource CardBackgroundBrush}"
                BorderBrush="{StaticResource SubtleBorderBrush}"
                BorderThickness="1"
                CornerRadius="2"
                Padding="10"
                Margin="0,0,0,12">
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="16">
                <Border Grid.Column="0"
                        Background="{StaticResource InputBackgroundBrush}"
                        BorderBrush="{StaticResource SubtleBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="2"
                        Padding="3">
                    <StackPanel Orientation="Horizontal" Spacing="3">
                        <Button x:Name="QueueSegment"
                                Content="Queue"
                                Tag="0"
                                Style="{StaticResource GamesSegmentButtonStyle}"
                                Click="SegmentButton_Click"/>
                        <Button x:Name="TodaySegment"
                                Content="Today"
                                Tag="1"
                                Style="{StaticResource GamesSegmentButtonStyle}"
                                Click="SegmentButton_Click"/>
                        <Button x:Name="HistorySegment"
                                Content="History"
                                Tag="2"
                                Style="{StaticResource GamesSegmentButtonStyle}"
                                Click="SegmentButton_Click"/>
                        <Button x:Name="VodSegment"
                                Content="VOD"
                                Tag="3"
                                Style="{StaticResource GamesSegmentButtonStyle}"
                                Click="SegmentButton_Click"/>
                    </StackPanel>
                </Border>
                <TextBlock Grid.Column="1"
                           Text="{x:Bind ViewModel.Heading, Mode=OneWay}"
                           FontFamily="{StaticResource HeadingFont}"
                           FontSize="{Binding Title, Source={StaticResource FontSizes}}"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource PrimaryTextBrush}"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <ProgressRing Grid.Row="2"
                      IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      Width="48"
                      Height="48"
                      Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVis}}"/>

        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Spacing="6" Padding="0,0,0,36">
                <TextBlock Text="{x:Bind ViewModel.EmptyMessage, Mode=OneWay}"
                           FontSize="{Binding Subtitle, Source={StaticResource FontSizes}}"
                           Foreground="{StaticResource SecondaryTextBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,40,0,0"
                           Visibility="{x:Bind ViewModel.HasGames, Mode=OneWay, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}"/>

                <ItemsRepeater ItemsSource="{x:Bind ViewModel.Games, Mode=OneWay}">
                    <ItemsRepeater.Layout>
                        <StackLayout Spacing="6"/>
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="vm:GameDisplayItem">
                            <!-- v2.17.8: Tag carries GameId so RowActivated can route to Review,
                                 and the action StackPanel swallows its own Tapped so a click on
                                 a button doesn't ALSO trigger the row navigate. -->
                            <controls:GameRowCard Champion="{x:Bind ChampionDisplay}"
                                                  Win="{x:Bind Win}"
                                                  Meta="{x:Bind MetaLine}"
                                                  Kda="{x:Bind KdaText}"
                                                  Stats="{x:Bind StatsLine}"
                                                  Tag="{x:Bind GameId}"
                                                  RowActivated="GameRow_RowActivated">
                                <controls:GameRowCard.Actions>
                                    <StackPanel Orientation="Horizontal" Spacing="6"
                                                Tapped="ActionsStack_Tapped">
                                        <Button Content="{x:Bind PrimaryActionText}"
                                                Style="{StaticResource ListActionButtonStyle}"
                                                Tag="{x:Bind GameId}"
                                                Click="PrimaryActionButton_Click"/>
                                        <Button Content="Skip"
                                                Style="{StaticResource ListActionButtonStyle}"
                                                Tag="{x:Bind GameId}"
                                                Visibility="{x:Bind HasReview, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}"
                                                ToolTipService.ToolTip="Mark reviewed without opening"
                                                Click="SkipReviewButton_Click"/>
                                        <Button Style="{StaticResource GhostIconButtonStyle}"
                                                Tag="{x:Bind GameId}"
                                                ToolTipService.ToolTip="Delete this game permanently"
                                                Click="DeleteGameButton_Click">
                                            <FontIcon Glyph="&#xE74D;"
                                                      FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                                      FontSize="{Binding BodyEmphasis, Source={StaticResource FontSizes}}"
                                                      Foreground="{StaticResource LossRedBrush}"/>
                                        </Button>
                                    </StackPanel>
                                </controls:GameRowCard.Actions>
                            </controls:GameRowCard>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>

                <Button Content="Load More"
                        Style="{StaticResource PrimaryActionButtonStyle}"
                        Visibility="{x:Bind ViewModel.HasMoreHistory, Mode=OneWay, Converter={StaticResource BoolToVis}}"
                        Command="{x:Bind ViewModel.LoadMoreHistoryCommand}"
                        HorizontalAlignment="Center"
                        Margin="0,12,0,0"
                        Height="32"
                        Width="160"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
