<Page
    x:Name="RootPage"
    x:Class="Revu.App.Views.PreGamePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:svc="using:Revu.App.Services"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:Revu.App.ViewModels"
    xmlns:converters="using:Revu.App.Converters"
    xmlns:controls="using:Revu.App.Controls"
    mc:Ignorable="d"
    Background="Transparent">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Big section header — separates the 4 groups visually. -->
        <Style x:Key="GroupHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource MonoFont}"/>
            <Setter Property="FontSize" Value="{Binding Caption, Source={StaticResource FontSizes}}"/>
            <Setter Property="CharacterSpacing" Value="300"/>
            <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}"/>
            <Setter Property="Margin" Value="0,16,0,4"/>
        </Style>
    </Page.Resources>

    <ScrollViewer x:Name="RootScroll"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Spacing="10" Padding="40,20,40,40"
                    MaxWidth="620" HorizontalAlignment="Center">

            <!-- Hero -->
            <controls:HeroHeader EyebrowText="CHAMP SELECT"
                                 Title="Lock In"/>

            <!-- ════════════════════════════════════════════════════════════
                 GROUP 1: INTEL — What am I playing, and what do I remember?
                 ════════════════════════════════════════════════════════════ -->
            <TextBlock Style="{StaticResource GroupHeaderStyle}"
                       Text="— INTEL —"/>

            <!-- v2.16.1: rotating intel deck — passive learning during champ-select
                 dead time. Cycles priority objective → last game → matchup notes →
                 prior pre-game answers → enemy ability cooldowns. -->
            <controls:IntelRotatorControl
                ItemsSource="{x:Bind ViewModel.IntelDeck, Mode=OneWay}"
                Visibility="{x:Bind ViewModel.HasIntelDeck, Mode=OneWay, Converter={StaticResource BoolToVis}}"/>

            <!-- Waiting-state placeholder: shown while champ select data is still
                 arriving and none of the other intel cards have anything yet. -->
            <controls:CornerBracketedCard
                CardBorderBrush="{StaticResource SubtleBorderBrush}"
                Visibility="{x:Bind ViewModel.ShowIntelWaiting, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                <StackPanel Spacing="8" HorizontalAlignment="Center" Padding="0,8">
                    <TextBlock Text="WAITING FOR CHAMP SELECT"
                               FontFamily="{StaticResource MonoFont}"
                               FontSize="{Binding Caption, Source={StaticResource FontSizes}}"
                               Foreground="{StaticResource AccentBlueBrush}"
                               CharacterSpacing="250"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Lock in your champion — matchup intel + notes appear here."
                               FontFamily="{StaticResource BodyFont}"
                               FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </controls:CornerBracketedCard>

            <!-- Matchup card: visible when MY champ is locked (enemy may still be loading) -->
            <controls:CornerBracketedCard
                CardBorderBrush="{StaticResource AccentBlueBrush}"
                Visibility="{x:Bind ViewModel.HasMatchupDetected, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                <StackPanel Spacing="6">
                    <controls:SectionTitle Text="MATCHUP"/>
                    <StackPanel Orientation="Horizontal"
                                Spacing="12"
                                HorizontalAlignment="Center">
                        <TextBlock Text="{x:Bind ViewModel.MyChampionName, Mode=OneWay}"
                                   FontFamily="{StaticResource DisplayFont}"
                                   FontSize="{Binding Title, Source={StaticResource FontSizes}}"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource AccentBlueBrush}"/>
                        <TextBlock Text="vs"
                                   FontFamily="{StaticResource HeadingFont}"
                                   FontSize="{Binding Title, Source={StaticResource FontSizes}}"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="{x:Bind EnemyOrPlaceholder(ViewModel.EnemyChampionName), Mode=OneWay}"
                                   FontFamily="{StaticResource DisplayFont}"
                                   FontSize="{Binding Title, Source={StaticResource FontSizes}}"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource LossRedBrush}"/>
                    </StackPanel>
                </StackPanel>
            </controls:CornerBracketedCard>

            <!-- Matchup history notes (keyed on my champ vs enemy) -->
            <controls:CornerBracketedCard
                CardBorderBrush="{StaticResource AccentBlueBrush}"
                Visibility="{x:Bind ViewModel.HasMatchupHistory, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                <StackPanel Spacing="8">
                    <controls:SectionTitle Text="{x:Bind ViewModel.MatchupHeaderText, Mode=OneWay}"/>
                    <ItemsRepeater ItemsSource="{x:Bind ViewModel.MatchupHistory, Mode=OneWay}">
                        <ItemsRepeater.Layout>
                            <StackLayout Spacing="6"/>
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="vm:PreGameMatchupItem">
                                <Border Background="{StaticResource SurfaceInsetBrush}"
                                        BorderBrush="{StaticResource SubtleBorderBrush}"
                                        BorderThickness="1" Padding="10,8">
                                    <StackPanel Spacing="3">
                                        <TextBlock Text="{x:Bind Note}"
                                                   FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                                   Foreground="{StaticResource PrimaryTextBrush}"
                                                   TextWrapping="Wrap"/>
                                        <TextBlock Text="{x:Bind DateText}"
                                                   FontFamily="{StaticResource MonoFont}"
                                                   FontSize="{Binding Caption, Source={StaticResource FontSizes}}"
                                                   Foreground="{StaticResource MutedTextBrush}"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </StackPanel>
            </controls:CornerBracketedCard>

            <!-- Last game intel — carry-over from most recent review -->
            <controls:CornerBracketedCard
                CardBorderBrush="{StaticResource AccentBlueBrush}"
                Visibility="{x:Bind ViewModel.HasLastFocus, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                <StackPanel Spacing="8">
                    <controls:SectionTitle Text="LAST GAME INTEL"/>
                    <TextBlock Text="{x:Bind ViewModel.LastFocus, Mode=OneWay}"
                               FontFamily="{StaticResource BodyFont}"
                               FontSize="{Binding BodyEmphasis, Source={StaticResource FontSizes}}"
                               Foreground="{StaticResource PrimaryTextBrush}"
                               TextWrapping="Wrap"/>
                    <TextBlock Text="{x:Bind ViewModel.LastMistakes, Mode=OneWay}"
                               FontFamily="{StaticResource MonoFont}"
                               FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                               Foreground="{StaticResource MutedTextBrush}"
                               TextWrapping="Wrap"
                               Visibility="{x:Bind ViewModel.HasLastMistakes, Mode=OneWay, Converter={StaticResource BoolToVis}}"/>
                </StackPanel>
            </controls:CornerBracketedCard>

            <!-- ════════════════════════════════════════════════════════════
                 GROUP 2: MENTAL — How am I feeling coming in?
                 (Only shown when TiltFix mode is enabled)
                 ════════════════════════════════════════════════════════════ -->
            <TextBlock Style="{StaticResource GroupHeaderStyle}"
                       Text="— MENTAL —"
                       Visibility="{x:Bind ViewModel.ShowMoodSelector, Mode=OneWay, Converter={StaticResource BoolToVis}}"/>

            <controls:CornerBracketedCard
                CardBorderBrush="{StaticResource AccentPurpleBrush}"
                Visibility="{x:Bind ViewModel.ShowMoodSelector, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                <StackPanel Spacing="8">
                    <controls:SectionTitle Text="HOW ARE YOU FEELING?"/>
                    <controls:MoodSelector SelectedMood="{x:Bind ViewModel.SelectedMood, Mode=TwoWay}"/>
                </StackPanel>
            </controls:CornerBracketedCard>

            <!-- ════════════════════════════════════════════════════════════
                 GROUP 3: OBJECTIVES — What am I practicing?
                 One merged card: priority at top, list below, pick inline.
                 ════════════════════════════════════════════════════════════ -->
            <TextBlock Style="{StaticResource GroupHeaderStyle}"
                       Text="— OBJECTIVES —"
                       Visibility="{x:Bind ViewModel.HasActiveObjective, Mode=OneWay, Converter={StaticResource BoolToVis}}"/>

            <!-- Objectives mega-card: priority headline + practiced-toggle list + pick shortcuts -->
            <controls:CornerBracketedCard
                CardBorderBrush="{StaticResource AccentGoldBrush}"
                Visibility="{x:Bind ViewModel.HasActiveObjective, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                <StackPanel Spacing="14">

                    <!-- Priority objective header -->
                    <StackPanel Spacing="4">
                        <controls:SectionTitle Text="PRIORITY"/>
                        <TextBlock Text="{x:Bind ViewModel.ActiveObjectiveTitle, Mode=OneWay}"
                                   FontFamily="{StaticResource HeadingFont}"
                                   FontSize="{Binding Title, Source={StaticResource FontSizes}}"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource PrimaryTextBrush}"
                                   TextWrapping="Wrap"/>
                        <TextBlock Text="{x:Bind ViewModel.ActiveObjectiveCriteria, Mode=OneWay}"
                                   FontFamily="{StaticResource MonoFont}"
                                   FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <!-- Practiced-toggle list — mark what you worked on this game -->
                    <StackPanel Spacing="6"
                                Visibility="{x:Bind ViewModel.HasPreGameObjectives, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="PRACTICED THIS GAME?"
                                   FontFamily="{StaticResource MonoFont}"
                                   FontSize="{Binding Caption, Source={StaticResource FontSizes}}"
                                   CharacterSpacing="200"
                                   Foreground="{StaticResource SecondaryTextBrush}"/>
                        <ItemsRepeater ItemsSource="{x:Bind ViewModel.PreGameObjectives, Mode=OneWay}">
                            <ItemsRepeater.Layout>
                                <StackLayout Spacing="6"/>
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="vm:ObjectiveAssessment">
                                    <Border Background="{StaticResource InputBackgroundBrush}"
                                            CornerRadius="2"
                                            BorderThickness="1"
                                            BorderBrush="{StaticResource SubtleBorderBrush}"
                                            Padding="12,10">
                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                            <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                                                <TextBlock Text="{x:Bind Title}"
                                                           FontFamily="{StaticResource HeadingFont}"
                                                           FontSize="{Binding Subtitle, Source={StaticResource FontSizes}}"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource PrimaryTextBrush}"
                                                           TextWrapping="Wrap"/>
                                                <TextBlock Text="{x:Bind Criteria}"
                                                           FontFamily="{StaticResource MonoFont}"
                                                           FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                                           Foreground="{StaticResource SecondaryTextBrush}"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>
                                            <ToggleButton Grid.Column="1"
                                                          VerticalAlignment="Center"
                                                          IsChecked="{x:Bind Practiced, Mode=TwoWay}"
                                                          Style="{StaticResource HudPracticedToggleStyle}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </StackPanel>

                    <!-- v2.15.0: CUSTOM PRE-GAME PROMPTS per active objective. -->
                    <StackPanel Spacing="10"
                                Visibility="{x:Bind ViewModel.HasPreGamePromptBlocks, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="YOUR PRE-GAME PROMPTS"
                                   FontFamily="{StaticResource MonoFont}"
                                   FontSize="{Binding Caption, Source={StaticResource FontSizes}}"
                                   CharacterSpacing="200"
                                   Foreground="{StaticResource SecondaryTextBrush}"/>

                        <ItemsRepeater ItemsSource="{x:Bind ViewModel.PreGamePromptBlocks, Mode=OneWay}">
                            <ItemsRepeater.Layout>
                                <StackLayout Spacing="10"/>
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="vm:PreGameObjectivePromptBlock">
                                    <Border Background="{StaticResource CardAltBackgroundBrush}"
                                            BorderBrush="{x:Bind AccentBrush}"
                                            BorderThickness="1"
                                            CornerRadius="2"
                                            Padding="12,10">
                                        <StackPanel Spacing="10">
                                            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                                <Rectangle Width="14" Height="1"
                                                           Fill="{x:Bind AccentBrush}"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Text="{x:Bind EyebrowText}"
                                                           FontFamily="{StaticResource MonoFont}"
                                                           FontSize="{Binding Caption, Source={StaticResource FontSizes}}"
                                                           CharacterSpacing="300"
                                                           Foreground="{x:Bind AccentBrush}"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <TextBlock Text="{x:Bind ObjectiveTitle}"
                                                       FontFamily="{StaticResource HeadingFont}"
                                                       FontSize="{Binding Subtitle, Source={StaticResource FontSizes}}"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource PrimaryTextBrush}"
                                                       TextWrapping="Wrap"/>

                                            <ItemsRepeater ItemsSource="{x:Bind Prompts, Mode=OneWay}">
                                                <ItemsRepeater.Layout>
                                                    <StackLayout Spacing="8"/>
                                                </ItemsRepeater.Layout>
                                                <ItemsRepeater.ItemTemplate>
                                                    <DataTemplate x:DataType="vm:PreGamePromptAnswer">
                                                        <StackPanel Spacing="6">
                                                            <!-- v2.15.0: body-size + primary text so the question reads clearly.
                                                                 Was Caption + SecondaryTextBrush and barely legible against dark bg. -->
                                                            <TextBlock Text="{x:Bind Label}"
                                                                       FontFamily="{StaticResource BodyFont}"
                                                                       FontSize="{Binding BodyEmphasis, Source={StaticResource FontSizes}}"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{StaticResource PrimaryTextBrush}"
                                                                       TextWrapping="Wrap"/>
                                                            <TextBox Text="{x:Bind AnswerText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                     PlaceholderText="Write your answer..."
                                                                     TextWrapping="Wrap"
                                                                     AcceptsReturn="True"
                                                                     MinHeight="48"
                                                                     Background="{StaticResource InputBackgroundBrush}"
                                                                     BorderBrush="{StaticResource SubtleBorderBrush}"
                                                                     Foreground="{StaticResource PrimaryTextBrush}"
                                                                     FontFamily="{StaticResource BodyFont}"
                                                                     FontSize="{Binding Body, Source={StaticResource FontSizes}}"/>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ItemsRepeater.ItemTemplate>
                                            </ItemsRepeater>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </StackPanel>

                </StackPanel>
            </controls:CornerBracketedCard>

            <!-- v2.15.0: INTENT section (FOCUS + SESSION MINDSET) removed.
                 Objectives + their custom prompts above now carry the user's
                 pre-game intention. VM properties left intact so save/load
                 paths don't blow up; they'll just stay blank on new games. -->

            <!-- Auto-close note -->
            <TextBlock Text="This page closes automatically when your game loads."
                       FontFamily="{StaticResource MonoFont}"
                       FontSize="{Binding Caption, Source={StaticResource FontSizes}}"
                       Foreground="{StaticResource MutedTextBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,12,0,0"/>

        </StackPanel>
    </ScrollViewer>
</Page>
