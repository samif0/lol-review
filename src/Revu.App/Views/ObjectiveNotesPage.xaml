<Page
    x:Class="Revu.App.Views.ObjectiveNotesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:converters="using:Revu.App.Converters"
    xmlns:vm="using:Revu.App.ViewModels"
    mc:Ignorable="d"
    Background="{StaticResource AppBackgroundBrush}">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Padding="24,20,24,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Command="{x:Bind ViewModel.GoBackCommand}"
                    Background="Transparent"
                    BorderThickness="0"
                    VerticalAlignment="Center"
                    Margin="0,0,12,0"
                    Padding="6">
                <FontIcon Glyph="&#xE76B;" FontSize="{Binding Title, Source={StaticResource FontSizes}}"
                          Foreground="{StaticResource SecondaryTextBrush}"/>
            </Button>

            <StackPanel Grid.Column="1" Spacing="2">
                <TextBlock Text="{x:Bind ViewModel.ObjectiveTitle, Mode=OneWay}"
                           FontSize="{Binding TitleLarge, Source={StaticResource FontSizes}}" FontWeight="Bold"
                           Foreground="{StaticResource PrimaryTextBrush}"/>
                <TextBlock Text="{x:Bind ViewModel.ObjectiveStatus, Mode=OneWay}"
                           FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                           Foreground="{StaticResource SecondaryTextBrush}"/>
            </StackPanel>
        </Grid>

        <!-- Loading -->
        <ProgressRing Grid.Row="1"
                      IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                      HorizontalAlignment="Center" VerticalAlignment="Center"
                      Width="48" Height="48"
                      Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVis}}"/>

        <!-- Empty state -->
        <Border Grid.Row="1"
                Style="{StaticResource CardStyle}"
                Margin="24,0"
                Visibility="{x:Bind ViewModel.HasAnything, Mode=OneWay, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}">
            <TextBlock Text="No notes, execution notes, or clips linked to this objective yet."
                       FontSize="{Binding Subtitle, Source={StaticResource FontSizes}}"
                       Foreground="{StaticResource SecondaryTextBrush}"
                       HorizontalAlignment="Center"
                       TextWrapping="Wrap"
                       Margin="0,30"/>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      Visibility="{x:Bind ViewModel.HasAnything, Mode=OneWay, Converter={StaticResource BoolToVis}}">
            <StackPanel Margin="24,0,24,24" Spacing="16">

                <!-- Review Notes -->
                <StackPanel Spacing="8"
                            Visibility="{x:Bind ViewModel.HasReviewNotes, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="REVIEW NOTES"
                               FontSize="{Binding Meta, Source={StaticResource FontSizes}}" FontWeight="Bold"
                               Foreground="{StaticResource AccentGoldBrush}"
                               Margin="0,0,0,2"/>
                    <ItemsRepeater ItemsSource="{x:Bind ViewModel.ReviewNotes, Mode=OneWay}">
                        <ItemsRepeater.Layout>
                            <StackLayout Spacing="8"/>
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="vm:ObjectiveReviewNoteRow">
                                <Border Background="{StaticResource CardBackgroundBrush}"
                                        CornerRadius="2"
                                        Padding="14,12"
                                        BorderThickness="1"
                                        BorderBrush="{StaticResource SubtleBorderBrush}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Spacing="6">
                                            <TextBlock Text="{x:Bind Header}"
                                                       FontSize="{Binding Body, Source={StaticResource FontSizes}}" FontWeight="SemiBold"
                                                       Foreground="{StaticResource SecondaryTextBrush}"/>
                                            <TextBlock Text="{x:Bind Notes}"
                                                       FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                                       Foreground="{StaticResource PrimaryTextBrush}"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <Button Grid.Column="1"
                                                Content="Open"
                                                Background="{StaticResource TagBackgroundBrush}"
                                                Foreground="{StaticResource SecondaryTextBrush}"
                                                BorderBrush="{StaticResource SubtleBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="2" Height="28"
                                                FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                                VerticalAlignment="Top"
                                                Margin="12,0,0,0"
                                                Tag="{x:Bind GameId}"
                                                Click="OpenReview_Click"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </StackPanel>

                <!-- Execution Notes -->
                <StackPanel Spacing="8"
                            Visibility="{x:Bind ViewModel.HasExecutionNotes, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="EXECUTION NOTES"
                               FontSize="{Binding Meta, Source={StaticResource FontSizes}}" FontWeight="Bold"
                               Foreground="{StaticResource AccentBlueBrush}"
                               Margin="0,0,0,2"/>
                    <ItemsRepeater ItemsSource="{x:Bind ViewModel.ExecutionNotes, Mode=OneWay}">
                        <ItemsRepeater.Layout>
                            <StackLayout Spacing="8"/>
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="vm:ObjectiveExecutionNoteRow">
                                <Border Background="{StaticResource CardBackgroundBrush}"
                                        CornerRadius="2"
                                        Padding="14,12"
                                        BorderThickness="1"
                                        BorderBrush="{StaticResource SubtleBorderBrush}">
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="{x:Bind Header}"
                                                   FontSize="{Binding Body, Source={StaticResource FontSizes}}" FontWeight="SemiBold"
                                                   Foreground="{StaticResource SecondaryTextBrush}"/>
                                        <TextBlock Text="{x:Bind Note}"
                                                   FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                                   Foreground="{StaticResource PrimaryTextBrush}"
                                                   FontStyle="Italic"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </StackPanel>

                <!-- Clips / Bookmarks -->
                <StackPanel Spacing="8"
                            Visibility="{x:Bind ViewModel.HasBookmarks, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="CLIPS &amp; BOOKMARKS"
                               FontSize="{Binding Meta, Source={StaticResource FontSizes}}" FontWeight="Bold"
                               Foreground="{StaticResource AccentPurpleBrush}"
                               Margin="0,0,0,2"/>
                    <ItemsRepeater ItemsSource="{x:Bind ViewModel.Bookmarks, Mode=OneWay}">
                        <ItemsRepeater.Layout>
                            <StackLayout Spacing="8"/>
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="vm:ObjectiveBookmarkRow">
                                <Border Background="{StaticResource CardBackgroundBrush}"
                                        CornerRadius="2"
                                        Padding="14,12"
                                        BorderThickness="1"
                                        BorderBrush="{StaticResource SubtleBorderBrush}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Spacing="4">
                                            <StackPanel Orientation="Horizontal" Spacing="10">
                                                <Border Background="{StaticResource TagBackgroundBrush}"
                                                        CornerRadius="2" Padding="6,2">
                                                    <TextBlock Text="{x:Bind TimeLabel}"
                                                               FontSize="{Binding Meta, Source={StaticResource FontSizes}}" FontWeight="Bold"
                                                               Foreground="{StaticResource AccentPurpleBrush}"/>
                                                </Border>
                                                <TextBlock Text="{x:Bind GameLabel}"
                                                           FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                                           Foreground="{StaticResource SecondaryTextBrush}"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <TextBlock Text="{x:Bind Note}"
                                                       FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                                       Foreground="{StaticResource PrimaryTextBrush}"
                                                       TextWrapping="Wrap"
                                                       Visibility="{x:Bind HasNote, Converter={StaticResource BoolToVis}}"/>
                                            <TextBlock Text="{x:Bind Tags}"
                                                       FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       Visibility="{x:Bind HasTags, Converter={StaticResource BoolToVis}}"/>
                                        </StackPanel>
                                        <Button Grid.Column="1"
                                                Content="Play"
                                                Background="{StaticResource TagBackgroundBrush}"
                                                Foreground="{StaticResource AccentPurpleBrush}"
                                                BorderBrush="{StaticResource AccentPurpleBrush}"
                                                BorderThickness="1"
                                                CornerRadius="2" Height="28"
                                                FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                                VerticalAlignment="Top"
                                                Margin="12,0,0,0"
                                                Tag="{x:Bind BookmarkId}"
                                                Click="PlayBookmark_Click"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
