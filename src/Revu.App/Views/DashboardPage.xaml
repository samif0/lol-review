<Page
    x:Class="Revu.App.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:svc="using:Revu.App.Services"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:Revu.App.Controls"
    xmlns:vm="using:Revu.App.ViewModels"
    xmlns:converters="using:Revu.App.Converters"
    mc:Ignorable="d"
    Background="Transparent">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </Page.Resources>

    <Grid x:Name="RootGrid" Background="Transparent">

        <!-- Loading spinner -->
        <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      Width="48"
                      Height="48"
                      Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVis}}"/>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ••• HERO ••• -->
            <controls:HeroHeader Grid.Row="0"
                                 EyebrowText="DASHBOARD"
                                 Title="{x:Bind ViewModel.Greeting, Mode=OneWay}"
                                 Margin="40,16,40,8"/>

            <!-- ••• CONTENT ••• -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="40,0,40,40">
                <StackPanel MaxWidth="1600"
                            HorizontalAlignment="Stretch"
                            Spacing="14">

                    <!-- v2.16: Start Block — manual pre-queue ritual.
                         Auto-trigger from LCU home-state still TBD.
                         Intent-first dashboard: until a goal is locked for
                         today, Start Block leads as the hero CTA; once locked
                         it collapses to a compact chip echoing the goal.
                         Top margin keeps hover lift/glow from clipping against
                         the 0-top-padding ScrollViewer edge. -->
                    <controls:CornerBracketedCard
                        CardBorderBrush="{StaticResource AccentGoldBrush}"
                        Margin="0,8,0,0"
                        Visibility="{x:Bind ViewModel.ShowIntentHero, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Spacing="8">
                                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                    <Rectangle Width="18" Height="1"
                                               Fill="{StaticResource AccentGoldBrush}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="START BLOCK"
                                               FontFamily="{StaticResource MonoFont}"
                                               FontSize="{Binding Caption, Source={StaticResource FontSizes}}"
                                               CharacterSpacing="300"
                                               Foreground="{StaticResource AccentGoldBrush}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Text="Set your intent before you queue."
                                           FontFamily="{StaticResource HeadingFont}"
                                           FontSize="{Binding Title, Source={StaticResource FontSizes}}"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource PrimaryTextBrush}"
                                           TextWrapping="Wrap"/>
                                <TextBlock Text="A 30-second ritual: name one focus for this block of games, check your priority objective, lock in. Deliberate practice starts before the queue pops."
                                           FontFamily="{StaticResource BodyFont}"
                                           FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Content="START BLOCK"
                                    Click="StartBlockButton_Click"
                                    Style="{StaticResource GoldActionButtonStyle}"
                                    FontWeight="SemiBold"
                                    VerticalAlignment="Center"
                                    Height="44"
                                    Padding="24,0"
                                    CornerRadius="2"/>
                        </Grid>
                    </controls:CornerBracketedCard>

                    <Border Background="{StaticResource SurfaceInsetBrush}"
                            BorderBrush="{StaticResource AccentGoldBrush}"
                            BorderThickness="1"
                            CornerRadius="2"
                            Padding="14,10"
                            Margin="0,8,0,0"
                            Visibility="{x:Bind ViewModel.HasSessionIntention, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="INTENT LOCKED //"
                                       FontFamily="{StaticResource MonoFont}"
                                       FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                       CharacterSpacing="200"
                                       Foreground="{StaticResource AccentGoldBrush}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1"
                                       Text="{x:Bind ViewModel.SessionIntention, Mode=OneWay}"
                                       FontFamily="{StaticResource BodyFont}"
                                       FontSize="{Binding BodyEmphasis, Source={StaticResource FontSizes}}"
                                       Foreground="{StaticResource PrimaryTextBrush}"
                                       TextTrimming="CharacterEllipsis"
                                       VerticalAlignment="Center"/>
                            <Button Grid.Column="2"
                                    Content="New Block"
                                    Click="StartBlockButton_Click"
                                    Style="{StaticResource ListActionButtonStyle}"
                                    VerticalAlignment="Center"/>
                            <Button Grid.Column="3"
                                    Content="End Block"
                                    Click="EndBlockButton_Click"
                                    Style="{StaticResource ListActionButtonStyle}"
                                    VerticalAlignment="Center"
                                    Visibility="{x:Bind ViewModel.ShowEndBlockButton, Mode=OneWay, Converter={StaticResource BoolToVis}}"/>
                            <TextBlock Grid.Column="3"
                                       Text="{x:Bind ViewModel.BlockClosedText, Mode=OneWay}"
                                       FontFamily="{StaticResource MonoFont}"
                                       FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                       CharacterSpacing="200"
                                       Foreground="{StaticResource AccentGoldBrush}"
                                       VerticalAlignment="Center"
                                       Visibility="{x:Bind ViewModel.HasDebrief, Mode=OneWay, Converter={StaticResource BoolToVis}}"/>
                        </Grid>
                    </Border>

                    <!-- ••• NEXT STEP (empty-state prompt — hides at Normal stage) ••• -->
                    <controls:CornerBracketedCard
                        CardBorderBrush="{StaticResource AccentTealBrush}"
                        Visibility="{x:Bind ViewModel.ShowNextStepCard, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                        <StackPanel Spacing="12">
                            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                <Rectangle Width="18" Height="1"
                                           Fill="{StaticResource AccentTealBrush}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="{x:Bind ViewModel.NextStepEyebrow, Mode=OneWay}"
                                           FontFamily="{StaticResource MonoFont}"
                                           FontSize="{Binding Caption, Source={StaticResource FontSizes}}"
                                           CharacterSpacing="300"
                                           Foreground="{StaticResource AccentTealBrush}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="{x:Bind ViewModel.NextStepTitle, Mode=OneWay}"
                                       FontFamily="{StaticResource HeadingFont}"
                                       FontSize="{Binding Title, Source={StaticResource FontSizes}}"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource PrimaryTextBrush}"
                                       TextWrapping="Wrap"/>
                            <TextBlock Text="{x:Bind ViewModel.NextStepBody, Mode=OneWay}"
                                       FontFamily="{StaticResource BodyFont}"
                                       FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       TextWrapping="Wrap"/>

                            <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Left">
                                <Button Content="{x:Bind ViewModel.NextStepCta, Mode=OneWay}"
                                        Command="{x:Bind ViewModel.TakeNextStepCommand}"
                                        Style="{StaticResource PrimaryActionButtonStyle}"
                                        Visibility="{x:Bind ViewModel.ShowNextStepCta, Mode=OneWay, Converter={StaticResource BoolToVis}}"
                                        Height="44"
                                        Padding="20,0"/>

                                <HyperlinkButton Command="{x:Bind ViewModel.DismissNextStepCommand}"
                                                 Content="Dismiss"
                                                 Padding="0"
                                                 VerticalAlignment="Center"
                                                 Visibility="{x:Bind ViewModel.ShowNextStepDismiss, Mode=OneWay, Converter={StaticResource BoolToVis}}"/>
                            </StackPanel>
                        </StackPanel>
                    </controls:CornerBracketedCard>

                    <!-- ••• ASCENT REMINDER (shown until a folder is chosen or the user dismisses) ••• -->
                    <controls:CornerBracketedCard
                        CardBorderBrush="{StaticResource AccentGoldBrush}"
                        Visibility="{x:Bind ViewModel.ShowAscentReminder, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                        <StackPanel Spacing="10">
                            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                <Rectangle Width="18" Height="1"
                                           Fill="{StaticResource AccentGoldBrush}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="OPTIONAL"
                                           FontFamily="{StaticResource MonoFont}"
                                           FontSize="{Binding Caption, Source={StaticResource FontSizes}}"
                                           CharacterSpacing="300"
                                           Foreground="{StaticResource AccentGoldBrush}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="Connect your Ascent recordings folder"
                                       FontFamily="{StaticResource HeadingFont}"
                                       FontSize="{Binding Subtitle, Source={StaticResource FontSizes}}"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource PrimaryTextBrush}"
                                       TextWrapping="Wrap"/>
                            <TextBlock Text="Revu pairs each game with its Ascent VOD so you can rewatch moments from inside the app. Default folder: C:\Users\&lt;you&gt;\Videos\Ascent"
                                       FontFamily="{StaticResource BodyFont}"
                                       FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       TextWrapping="Wrap"/>

                            <!-- v2.17.8: surface the Ascent download link inline so users
                                 who don't have Ascent installed yet don't hit a dead end
                                 on this prompt. -->
                            <TextBlock FontFamily="{StaticResource BodyFont}"
                                       FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       TextWrapping="Wrap">
                                <Run Text="Don't have Ascent yet? Download it at "/><Hyperlink NavigateUri="https://tryascent.gg"
                                                                                                 Foreground="{StaticResource AccentBlueBrush}"><Run Text="tryascent.gg"/></Hyperlink><Run Text="."/>
                            </TextBlock>

                            <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Left">
                                <Button Content="CHOOSE FOLDER"
                                        Command="{x:Bind ViewModel.PickAscentFolderCommand}"
                                        Style="{StaticResource PrimaryActionButtonStyle}"
                                        Height="44"
                                        Padding="20,0"/>
                                <HyperlinkButton Command="{x:Bind ViewModel.DismissAscentReminderCommand}"
                                                 Content="Not now"
                                                 Padding="0"
                                                 VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </controls:CornerBracketedCard>

                    <!-- Session banner -->
                    <controls:BannerControl Tone="Positive"
                                            Message="{x:Bind ViewModel.SessionBannerText, Mode=OneWay}"
                                            Icon="&#xE946;"
                                            Visibility="{x:Bind ViewModel.ShowSessionBanner, Mode=OneWay, Converter={StaticResource BoolToVis}}"/>

                    <!-- Run reset (voluntary tilt ritual) -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Spacing="10">
                        <Button Click="EndBlockButton_Click"
                                Background="Transparent"
                                BorderBrush="{StaticResource AccentGoldBrush}"
                                BorderThickness="1"
                                Padding="14,6"
                                Visibility="{x:Bind ViewModel.ShowEndBlockStandalone, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                            <TextBlock FontFamily="{StaticResource MonoFont}"
                                       FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                       Foreground="{StaticResource AccentGoldBrush}"
                                       Text="END BLOCK — DEBRIEF"/>
                        </Button>
                        <Button Command="{x:Bind ViewModel.RunResetCommand}"
                                Background="Transparent"
                                BorderBrush="{StaticResource LossRedBrush}"
                                BorderThickness="1"
                                Padding="14,6"
                                Visibility="{x:Bind ViewModel.ShowMainDashboardSections, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                            <TextBlock FontFamily="{StaticResource MonoFont}"
                                       FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                       Foreground="{StaticResource LossRedBrush}"
                                       Text="I'M TILTED — RUN RESET"/>
                        </Button>
                    </StackPanel>

                    <!-- v2.18 (schema v5): dominant classified death cause, last 14 days -->
                    <Border Background="{StaticResource SurfaceInsetBrush}"
                            BorderBrush="{StaticResource LossRedBrush}"
                            BorderThickness="1"
                            CornerRadius="2"
                            Padding="14,10"
                            Visibility="{x:Bind ViewModel.HasDeathMix, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{x:Bind ViewModel.DeathMixText, Mode=OneWay}"
                                   FontFamily="{StaticResource MonoFont}"
                                   FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                   CharacterSpacing="200"
                                   Foreground="{StaticResource LossRedBrush}"/>
                    </Border>

                    <!-- ••• STAT STRIP ••• -->
                    <controls:StatStrip Visibility="{x:Bind ViewModel.ShowMainDashboardSections, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                        <!-- Today's session framed against the user's own
                             30-day baseline so a one-game day doesn't read as
                             an alarm. Win-rate color stays neutral below
                             3 games — sample too small to celebrate or panic. -->
                        <controls:StatCell Label="Games"
                                           Value="{x:Bind ViewModel.TotalGames, Mode=OneWay}"
                                           Sub="TODAY"/>
                        <controls:StatCell Label="Win Rate"
                                           Value="{x:Bind ViewModel.WinratePercent, Mode=OneWay}"
                                           ValueBrush="{x:Bind ViewModel.WinrateBrush, Mode=OneWay}"
                                           Sub="{x:Bind ViewModel.WinRateSub, Mode=OneWay}"
                                           ToolTipService.ToolTip="Today's session record. 30-DAY = your win rate across the last 30 days."/>
                        <controls:StatCell Label="Avg Mental"
                                           Value="{x:Bind ViewModel.AvgMental, Mode=OneWay}"
                                           Sub="{x:Bind ViewModel.AvgMentalSub, Mode=OneWay}"
                                           ToolTipService.ToolTip="Average post-game mental rating (1–10) across today's reviews. 30-DAY AVG = your own 30-day baseline."/>
                        <controls:StatCell Label="Adherence"
                                           Value="{x:Bind ViewModel.AdherenceStreak, Mode=OneWay}"
                                           ValueBrush="{StaticResource AccentGoldBrush}"
                                           Sub="{x:Bind ViewModel.AdherenceSub, Mode=OneWay}"
                                           ToolTipService.ToolTip="Consecutive play-days with zero rule breaks. Skipped games are neutral and don't end the streak. Define your rules on the Rules page."/>
                        <controls:StatCell Label="Patterns"
                                           Value="{x:Bind ViewModel.ReviewedPatternCount, Mode=OneWay}"
                                           ValueBrush="{StaticResource AccentBlueBrush}"
                                           Sub="{x:Bind ViewModel.PatternsReviewedSub, Mode=OneWay}"
                                           ToolTipService.ToolTip="Cross-game patterns you've worked through in Pattern Review. Open one from 'Patterns To Review' below, walk its moments across games, then mark it reviewed."/>
                    </controls:StatStrip>

                    <controls:CornerBracketedCard CardBorderBrush="{StaticResource AccentGoldBrush}"
                                                  Visibility="{x:Bind ViewModel.ShowVodEvidencePending, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12" Padding="4">
                            <StackPanel Grid.Column="0" Spacing="4">
                                <controls:SectionTitle Text="VOD EVIDENCE PENDING"/>
                                <TextBlock Text="{x:Bind ViewModel.VodEvidencePendingText, Mode=OneWay}"
                                           FontSize="{Binding BodyEmphasis, Source={StaticResource FontSizes}}"
                                           Foreground="{StaticResource PrimaryTextBrush}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Content="Review VOD"
                                    Command="{x:Bind ViewModel.NavigateToVodEvidenceCommand}"
                                    Style="{StaticResource GoldListActionButtonStyle}"
                                    VerticalAlignment="Center"/>
                        </Grid>
                    </controls:CornerBracketedCard>

                    <controls:CornerBracketedCard CardBorderBrush="{StaticResource LossRedBrush}"
                                                  Visibility="{x:Bind ViewModel.HasObjectivePatterns, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                        <StackPanel Spacing="10" Padding="4">
                            <controls:SectionTitle Text="PATTERNS TO REVIEW"/>
                            <ItemsRepeater ItemsSource="{x:Bind ViewModel.ObjectivePatterns, Mode=OneWay}">
                                <ItemsRepeater.Layout>
                                    <StackLayout Spacing="6"/>
                                </ItemsRepeater.Layout>
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ObjectivePatternItem">
                                        <Border Background="{StaticResource SurfaceInsetBrush}"
                                                BorderBrush="{x:Bind AccentBrush}"
                                                BorderThickness="1" CornerRadius="2" Padding="10">
                                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                                <StackPanel Grid.Column="0" Spacing="3">
                                                    <TextBlock Text="{x:Bind Title}"
                                                               FontSize="{Binding BodyEmphasis, Source={StaticResource FontSizes}}"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource PrimaryTextBrush}"
                                                               TextWrapping="Wrap"/>
                                                    <TextBlock Text="{x:Bind Detail}"
                                                               FontSize="{Binding Body, Source={StaticResource FontSizes}}"
                                                               Foreground="{StaticResource SecondaryTextBrush}"
                                                               TextWrapping="Wrap"/>
                                                </StackPanel>
                                                <Button Grid.Column="1"
                                                        Content="Open"
                                                        DataContext="{x:Bind}"
                                                        Click="ObjectivePatternOpen_Click"
                                                        Style="{StaticResource ListActionButtonStyle}"
                                                        VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>
                        </StackPanel>
                    </controls:CornerBracketedCard>

                    <!-- ••• MAIN BODY: Unreviewed + Objectives ••• -->
                    <Grid ColumnSpacing="14"
                          Visibility="{x:Bind ViewModel.ShowMainDashboardSections, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="5*"/>
                            <ColumnDefinition Width="3*"/>
                        </Grid.ColumnDefinitions>

                        <!-- â”€â”€ LEFT: Unreviewed â”€â”€ -->
                        <controls:CornerBracketedCard Grid.Column="0">
                            <StackPanel Spacing="12" Padding="4">
                                <controls:SectionTitle Text="UNREVIEWED"/>

                                <TextBlock Text="Queue is clear — everything from the last 3 days has been reviewed."
                                           FontFamily="{StaticResource MonoFont}"
                                           FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                           Foreground="{StaticResource WinGreenBrush}"
                                           TextWrapping="Wrap"
                                           Visibility="{x:Bind ViewModel.AllReviewed, Mode=OneWay, Converter={StaticResource BoolToVis}}"/>

                                <ItemsRepeater ItemsSource="{x:Bind ViewModel.UnreviewedGames, Mode=OneWay}">
                                    <ItemsRepeater.Layout>
                                        <StackLayout Spacing="6"/>
                                    </ItemsRepeater.Layout>
                                    <ItemsRepeater.ItemTemplate>
                                        <DataTemplate x:DataType="vm:GameDisplayItem">
                                            <controls:GameRowCard Champion="{x:Bind ChampionDisplay}"
                                                                  Win="{x:Bind Win}"
                                                                  Meta="{x:Bind MetaLine}"
                                                                  Kda="{x:Bind KdaText}"
                                                                  Stats="{x:Bind StatsLine}">
                                                <controls:GameRowCard.Actions>
                                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                                        <Button Content="Review"
                                                                Style="{StaticResource ListActionButtonStyle}"
                                                                Tag="{x:Bind GameId}"
                                                                Click="ReviewButton_Click"/>
                                                        <Button Content="Skip"
                                                                Style="{StaticResource ListActionButtonStyle}"
                                                                Tag="{x:Bind GameId}"
                                                                ToolTipService.ToolTip="Mark reviewed without opening — clears it from the queue"
                                                                Click="SkipReviewButton_Click"/>
                                                        <Button Style="{StaticResource GhostIconButtonStyle}"
                                                                Tag="{x:Bind GameId}"
                                                                ToolTipService.ToolTip="Delete this game permanently"
                                                                Click="DeleteGameButton_Click">
                                                            <FontIcon Glyph="&#xE74D;"
                                                                      FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                                                      FontSize="{Binding BodyEmphasis, Source={StaticResource FontSizes}}"
                                                                      Foreground="{StaticResource LossRedBrush}"/>
                                                        </Button>
                                                    </StackPanel>
                                                </controls:GameRowCard.Actions>
                                            </controls:GameRowCard>
                                        </DataTemplate>
                                    </ItemsRepeater.ItemTemplate>
                                </ItemsRepeater>
                            </StackPanel>
                        </controls:CornerBracketedCard>

                        <!-- â”€â”€ RIGHT: Objectives + Last Focus â”€â”€ -->
                        <StackPanel Grid.Column="1" Spacing="14">
                            <controls:CornerBracketedCard>
                                <StackPanel Spacing="14">
                                    <controls:SectionTitle Text="ACTIVE OBJECTIVES"/>

                                    <TextBlock Text="No active objectives. Add one when you want a clear practice lane."
                                               FontFamily="{StaticResource MonoFont}"
                                               FontSize="{Binding Meta, Source={StaticResource FontSizes}}"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               TextWrapping="Wrap"
                                               Visibility="{x:Bind HasObjectives, Mode=OneWay, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}"/>

                                    <ItemsRepeater ItemsSource="{x:Bind ViewModel.ActiveObjectives, Mode=OneWay}"
                                                   Visibility="{x:Bind HasObjectives, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                                        <ItemsRepeater.Layout>
                                            <StackLayout Spacing="14"/>
                                        </ItemsRepeater.Layout>
                                        <ItemsRepeater.ItemTemplate>
                                            <DataTemplate x:DataType="vm:DashboardObjectiveItem">
                                                <Grid ColumnSpacing="14"
                                                      ToolTipService.ToolTip="Objective score: +2 per win and −1 per loss in games where you practice it, +2 each time you attach clip evidence. Ladder: Exploring → Drilling (15 pts) → Ingraining (30) → Ready (50). The ring fills toward Ready.">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>

                                                    <controls:HudProgressRing Grid.Column="0"
                                                                              Progress="{x:Bind Progress}"
                                                                              Label="{x:Bind ProgressLabel}"
                                                                              AccentBrush="{x:Bind LevelColorBrush}"
                                                                              TrackBrush="{x:Bind LevelDimColorBrush}"
                                                                              VerticalAlignment="Center"/>

                                                    <StackPanel Grid.Column="1" Spacing="3" VerticalAlignment="Center">
                                                        <Border Background="{x:Bind PriorityBadgeBackgroundBrush}"
                                                                CornerRadius="2" Padding="6,2"
                                                                HorizontalAlignment="Left"
                                                                Visibility="{x:Bind IsPriority, Converter={StaticResource BoolToVis}}">
                                                            <TextBlock Text="PRIORITY"
                                                                       FontFamily="{StaticResource MonoFont}"
                                                                       FontSize="{Binding Caption, Source={StaticResource FontSizes}}"
                                                                       FontWeight="Bold"
                                                                       Foreground="{x:Bind PriorityBadgeForegroundBrush}"/>
                                                        </Border>
                                                        <TextBlock Text="{x:Bind Title}"
                                                                   FontFamily="{StaticResource HeadingFont}"
                                                                   FontSize="{Binding Subtitle, Source={StaticResource FontSizes}}"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{StaticResource PrimaryTextBrush}"
                                                                   TextWrapping="Wrap"/>
                                                        <TextBlock Text="{x:Bind MetaText}"
                                                                   FontFamily="{StaticResource MonoFont}"
                                                                   FontSize="{Binding Caption, Source={StaticResource FontSizes}}"
                                                                   Foreground="{StaticResource MutedTextBrush}"
                                                                   TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsRepeater.ItemTemplate>
                                    </ItemsRepeater>
                                </StackPanel>
                            </controls:CornerBracketedCard>

                            <!-- v2.15.0: LAST FOCUS card removed. See DashboardViewModel.cs for rationale. -->
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
