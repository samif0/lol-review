{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Revu",
  "version": "3.1.7",
  "identifier": "gg.revu.desktop",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Revu",
        "width": 1600,
        "height": 1000,
        "minWidth": 980,
        "minHeight": 640,
        "resizable": true,
        "center": true,
        "backgroundColor": "#0a0818",
        "decorations": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: asset: http://asset.localhost; style-src 'self' 'unsafe-inline'; font-src 'self'; script-src 'self'; connect-src 'self' ipc: http://ipc.localhost asset: http://asset.localhost; media-src 'self' asset: http://asset.localhost blob:",
      "assetProtocol": {
        "enable": true,
        "scope": ["$HOME/**", "$VIDEO/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico"
    ]
  }
}
